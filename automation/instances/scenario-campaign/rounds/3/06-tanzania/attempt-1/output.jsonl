shared router.\n925\t        // Model-initiated yields ARE subject to the agent's canDelegateTo gate.\n926\t        if (!this.space) throw new Error('Space not loaded');\n927\t        const routed = await routeCommonYield(req, this.buildYieldContext(this.space, { enforceDelegatePolicy: true }));\n928\t        return routed.handled ? routed.value : undefined;\n929\t      }\n930\t    }\n931\t  }\n932\t\n933\t  /**\n934\t   * Build the shared-yield-router context for the session VM. The session has no\n935\t   * tasklist auto-capture (that's delegate-only), and resolves delegate() by\n936\t   * constructing a fresh registry from its own + dependent + dynamic spaces.\n937\t   */\n938\t  private mintRunScope(): TraceScope {\n939\t    this.runCount++;\n940\t    // Label stays 'session' so the `context` field on all turn-loop trace events\n941\t    // remains backward-compatible (existing jq recipes + tests filter by it). The\n942\t    // unique nodeId distinguishes runs in the execution tree.\n943\t    const scope = this.tracer.child(this.rootScope ?? undefined, 'run', 'session');\n944\t    this.currentScope = scope;\n945\t    return scope;\n946\t  }\n947\t\n948\t  private buildYieldContext(\n949\t    space: Space,\n950\t    { enforceDelegatePolicy = false }: { enforceDelegatePolicy?: boolean } = {},\n951\t  ): YieldRouterContext {\n952\t    return {\n953\t      space,\n954\t      clock: this.opts.clock,\n955\t      tracer: this.tracer,\n956\t      scope: this.currentScope ?? undefined,\n957\t      apiCallResolver: this.opts.appGlobals?.apiCall,\n958\t      apiCallAllow: this.appCapabilities['api:call']?.allow,\n959\t      connectionResolver: this.opts.appGlobals?.callConnection,\n960\t      documentResolver: this.opts.documentResolver,\n961\t      integrationStatusResolver: this.opts.integrationStatusResolver,\n962\t      // Store + manual-emit resolvers (plan S10) ride appGlobals like callConnection.\n963\t      storeResolver: this.opts.appGlobals?.store,\n964\t      emitEventResolver: this.opts.appGlobals?.emitEvent,\n965\t      // Consent gate (plan S10): set ONLY for interactive sessions (cli wires it\n966\t      // from renderHost.ask); absent ⇒ consent-marked yields fail closed.\n967\t      requestConsent: this.opts.consentPrompter,\n968\t      // installSpace live-registers the installed space here — the SAME shared\n969\t      // map registerSpace writes, so delegate() reaches it immediately. (The\n970\t      // router's registerSpace case stays fork-only: it is gated on\n971\t      // resolveRegisterSpace, which the session never sets.)\n972\t      dynamicSpaces: this.dynamicSpaces,\n973\t      // Code-node runner for `tasklist()` yields whose SPACE tasklist has code\n974\t      // nodes (plan S9). Host-built (libs/cli) — core never executes node modules.\n975\t      codeNodeCtxFactory: this.opts.codeNodeCtxFactory,\n976\t      getForkEngine: () => this.getForkEngine(),\n977\t      // Runs host-side with the space dir as cwd, so a checker (tests / tsc) sees\n978\t      // files written by attempt forks.\n979\t      execCommand: (cmd: string) => {\n980\t        try {\n981\t          const out = execSync(cmd, { cwd: this.opts.spaceDir, maxBuffer: 8 * 1024 * 1024, timeout: 60000 });\n982\t          return { ok: true, output: out.toString() };\n983\t        } catch (e: unknown) {\n984\t          const err = e as { stdout?: Buffer; stderr?: Buffer; message?: string };\n985\t          const output = (err.stdout?.toString() ?? '') + (err.stderr?.toString() ?? '') || (err.message ?? String(e));\n986\t          return { ok: false, output };\n987\t        }\n988\t      },\n989\t      runDelegate: async (packageName, agentName, action, delegateOpts) => {\n990\t        // Yield-time canDelegateTo gate (unified semantics). Applied only to\n991\t        // MODEL-initiated delegate yields (enforceDelegatePolicy) — the\n992\t        // defaultAction fast path is host policy and stays exempt. The gate\n993\t        // decides WHETHER the t