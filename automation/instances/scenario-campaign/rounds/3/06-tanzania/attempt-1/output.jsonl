{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_U64OthWUrkRz52vr1ev9dIhz","type":"tool_result","content":"150\t  /**\n151\t   * Table names known to the resolving project's `database/`. When provided,\n152\t   * a `db:*` cap whose `tables` names an unknown table fails loud. When\n153\t   * **undefined** (a bare cap on a system / project-agnostic space) the table\n154\t   * existence check is DEFERRED to the project the space resolves into.\n155\t   */\n156\t  knownTables?: string[];\n157\t}\n158\t\n159\tfunction isRecord(v: unknown): v is Record<string, unknown> {\n160\t  return typeof v === 'object' && v !== null && !Array.isArray(v);\n161\t}\n162\t\n163\t/** Parse + validate a `db:*` config payload into `{ tables?: string[] }`. */\n164\tfunction parseDbConfig(\n165\t  id: CapabilityId,\n166\t  config: unknown,\n167\t  ctx: ParseCapabilitiesCtx,\n168\t): { tables?: string[] } {\n169\t  if (!isRecord(config)) {\n170\t    throw new Error(\n171\t      `Agent \"${ctx.agentId}\" capability \"${id}\" has an invalid config: expected a map like { tables: [...] }`,\n172\t    );\n173\t  }\n174\t  const unknownKeys = Object.keys(config).filter((k) => k !== 'tables');\n175\t  if (unknownKeys.length > 0) {\n176\t    throw new Error(\n177\t      `Agent \"${ctx.agentId}\" capability \"${id}\" has disallowed config key(s): ${unknownKeys.join(', ')}. Allowed key: tables`,\n178\t    );\n179\t  }\n180\t  if (!('tables' in config)) return {};\n181\t\n182\t  const rawTables = config['tables'];\n183\t  if (!Array.isArray(rawTables) || rawTables.some((t) => typeof t !== 'string')) {\n184\t    throw new Error(\n185\t      `Agent \"${ctx.agentId}\" capability \"${id}\" config \"tables\" must be a list of table names`,\n186\t    );\n187\t  }\n188\t  const tables = rawTables as string[];\n189\t\n190\t  // Table-existence check only where a project context exists; a bare cap on a\n191\t  // project-agnostic system space (knownTables undefined) DEFERS this check.\n192\t  if (ctx.knownTables !== undefined) {\n193\t    const known = new Set(ctx.knownTables);\n194\t    const missing = tables.filter((t) => !known.has(t));\n195\t    if (missing.length > 0) {\n196\t      throw new Error(\n197\t        `Agent \"${ctx.agentId}\" capability \"${id}\" names table(s) not in the project's database/: ${missing.join(', ')}. Known tables: ${ctx.knownTables.length ? ctx.knownTables.join(', ') : '(none)'}`,\n198\t      );\n199\t    }\n200\t  }\n201\t\n202\t  return { tables };\n203\t}\n204\t\n205\t/** Parse + validate an `api:call` config payload into `{ allow: string[] }`. */\n206\tfunction parseApiCallConfig(config: unknown, ctx: ParseCapabilitiesCtx): { allow: string[] } {\n207\t  if (!isRecord(config)) {\n208\t    throw new Error(\n209\t      `Agent \"${ctx.agentId}\" capability \"api:call\" has an invalid config: expected a map like { allow: [...] }`,\n210\t    );\n211\t  }\n212\t  const unknownKeys = Object.keys(config).filter((k) => k !== 'allow');\n213\t  if (unknownKeys.length > 0) {\n214\t    throw new Error(\n215\t      `Agent \"${ctx.agentId}\" capability \"api:call\" has disallowed config key(s): ${unknownKeys.join(', ')}. Allowed key: allow`,\n216\t    );\n217\t  }\n218\t  const rawAllow = config['allow'];\n219\t  if (!Array.isArray(rawAllow) || rawAllow.length === 0 || rawAllow.some((a) => typeof a !== 'string')) {\n220\t    throw new Error(\n221\t      `Agent \"${ctx.agentId}\" capability \"api:call\" requires a non-empty \"allow\" list of endpoint names, ` +\n222\t        `or [\"*\"] for any endpoint the project declares`,\n223\t    );\n224\t  }\n225\t  // `'*'` is the ONE wildcard: \"any endpoint THIS project declares\". It exists for agents that\n226\t  // cannot know the endpoint names up front because they are authored per project at runtime —\n227\t  // the user's own orchestrator (THING) inside the user's own project. It stays an explicit,\n228\t  // opt-in declaration: the list is still required, and a named list still means ONLY those.\n229\t  // The list is enforced where `apiCall` is resolved (eval/yield-router.ts).\n230\t  return { allow: rawAllow as string[] };\n231\t}\n232\t\n233\t/** Parse + validate a `connections:use` config payload into `{ providers: string[] }`. */\n234\tfunction parseConnectionsConfig(config: unknown, ctx: ParseCapabilitiesCtx): { providers: string[] } {\n235\t  if (!isRecord(config)) {\n236\t    throw new Error(\n237\t      `Agent \"${ctx.agentId}\" capability \"connections:use\" has an invalid config: expected a map like { providers: [...] }`,\n238\t    );\n239\t  }\n240\t  const unknownKeys = Object.keys(config).filter((k) => k !== 'providers');\n241\t  if (unknownKeys.length > 0) {\n242\t    throw new Error(\n243\t      `Agent \"${ctx.agentId}\" capability \"connections:use\" has disallowed config key(s): ${unknownKeys.join(', ')}. Allowed key: providers`,\n244\t    );\n245\t  }\n246\t  const rawProviders = config['providers'];\n247\t  if (!Array.isArray(rawProviders) || rawProviders.length === 0 || rawProviders.some((p) => typeof p !== 'string')) {\n248\t    throw new Error(\n249\t      `Agent \"${ctx.agentId}\" capability \"connections:use\" requires a non-empty \"providers\" list of service ids (there is no \"connect to anything\")`,\n250\t    );\n251\t  }\n252\t  return { providers: rawProviders as string[] };\n253\t}\n254\t\n255\t/**\n256\t * Parse the frontmatter `capabilities:` list into an {@link AppCapabilities}\n257\t * model. `raw` is the raw frontmatter value (expected: a list); `undefined`/\n258\t * absent yields an empty model. Throws (fail-loud) on any malformed entry.\n259\t */\n260\texport function parseCapabilities(raw: unknown, ctx: ParseCapabilitiesCtx): AppCapabilities {\n261\t  const result: AppCapabilities = {};\n262\t  if (raw === undefined || raw === null) return result;\n263\t\n264\t  if (!Array.isArray(raw)) {\n265\t    throw new Error(\n266\t      `Agent \"${ctx.agentId}\" \"capabilities\" must be a list of capability ids (b