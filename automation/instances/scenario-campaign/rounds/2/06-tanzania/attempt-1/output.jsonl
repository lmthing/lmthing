{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_2H50lnpScpFhF5XQTfveyESm","type":"tool_result","content":"1\texport const name = 'costs-by-leg';\n2\texport const description = 'Return all costs for a single itinerary leg, with subtotal, grouped by category. Used when drilling into a leg from the itinerary detail or cost tracker.';\n3\t\n4\texport interface Input {\n5\t  // legId is extracted from the route path; the page passes no explicit input for this GET.\n6\t}\n7\t\n8\texport interface CostItem {\n9\t  id: string;\n10\t  leg_id: string;\n11\t  leg_title: string;\n12\t  category: string;\n13\t  description: string;\n14\t  amount_usd: number | null;\n15\t  amount_tzs: number | null;\n16\t  is_unbudgeted: boolean;\n17\t  notes: string;\n18\t}\n19\t\n20\texport interface CategoryGroup {\n21\t  category: string;\n22\t  items: CostItem[];\n23\t  subtotal_usd: number;\n24\t  subtotal_tzs: number;\n25\t}\n26\t\n27\texport interface Output {\n28\t  items: CostItem[];\n29\t  groups: CategoryGroup[];\n30\t  subtotal_usd: number;\n31\t  subtotal_tzs: number;\n32\t}\n33\t\n34\texport default async function handler(input: Input, ctx: { db: any; params: { legId: string } }): Promise<Output> {\n35\t  const legId = ctx.params.legId;\n36\t  const allCosts = await ctx.db.query('trip_costs');\n37\t  const items: CostItem[] = (allCosts.items || allCosts || []).filter((c: any) => c.leg_id === legId);\n38\t\n39\t  // Group by category and compute subtotals\n40\t  const categoryMap = new Map<string, CostItem[]>();\n41\t  let subtotal_usd = 0;\n42\t  let subtotal_tzs = 0;\n43\t\n44\t  for (const item of items) {\n45\t    if (!categoryMap.has(item.category)) {\n46\t      categoryMap.set(item.category, []);\n47\t    }\n48\t    categoryMap.get(item.category)!.push(item);\n49\t    if (item.amount_usd != null) subtotal_usd += item.amount_usd;\n50\t    if (item.amount_tzs != null) subtotal_tzs += item.amount_tzs;\n51\t  }\n52\t\n53\t  const groups: CategoryGroup[] = [];\n54\t  for (const [category, catItems] of categoryMap) {\n55\t    let catSubtotalUsd = 0;\n56\t    let catSubtotalTzs = 0;\n57\t    for (const ci of catItems) {\n58\t      if (ci.amount_usd != null) catSubtotalUsd += ci.amount_usd;\n59\t      if (ci.amount_tzs != null) catSubtotalTzs += ci.amount_tzs;\n60\t    }\n61\t    groups.push({\n62\t      category,\n63\t      items: catItems,\n64\t      subtotal_usd: catSubtotalUsd,\n65\t      subtotal_tzs: catSubtotalTzs,\n66\t    });\n67\t  }\n68\t\n69\t  return { items, groups, subtotal_usd, subtotal_tzs };\n70\t}"}]},"parent_tool_use_id":"call_tPb0UsB1toyLruNLs583FlmL","session_id":"9c7a9dc1-bb8c-4315-b194-e357aac0f2c7","uuid":"bbec1b5a-ec9d-4874-be5e-a21c4faba875","timestamp":"2026-07-16T18:28:30.977Z","subagent_type":"Explore","task_description":"Trace endpoint build failure"}
