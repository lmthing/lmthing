 'Y' });\n122\t\n123\t    // And the emitted VARIABLES block reflects the distinct values.\n124\t    const varsMsg = history.messages.find((m) => m.blockType === 'variables');\n125\t    expect(varsMsg?.content).toContain('\"from\": \"X\"');\n126\t    expect(varsMsg?.content).toContain('\"from\": \"Y\"');\n127\t    vm.dispose();\n128\t  });\n129\t\n130\t  it('resolves parallel yields concurrently, not sequentially', async () => {\n131\t    const vm = await createVM();\n132\t    const startTimes: Record<string, number> = {};\n133\t    const endTimes: Record<string, number> = {};\n134\t    const y = (tag: string) =>\n135\t      new Promise((resolve, reject) => {\n136\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n137\t      });\n138\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n139\t\n140\t    const history = new MessageHistory();\n141\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n142\t\n143\t    await runTurnLoop({\n144\t      vm,\n145\t      history,\n146\t      systemBlock: 'test',\n147\t      ambientDts: 'declare function y(tag: string): Promise<any>;',\n148\t      renderHost: silentHost,\n149\t      streamFn: scriptedStream('const [a, b] = await Promise.all([y(\"X\"), y(\"Y\")]);'),\n150\t      processYield: async (req) => {\n151\t        const tag = req.args[0] as string;\n152\t        startTimes[tag] = Date.now();\n153\t        await new Promise((r) => setTimeout(r, 80));\n154\t        endTimes[tag] = Date.now();\n155\t        return { tag };\n156\t      },\n157\t      maxRetries: 2,\n158\t    });\n159\t\n160\t    // Both must have started (both yields were dispatched)\n161\t    expect(startTimes['X']).toBeDefined();\n162\t    expect(startTimes['Y']).toBeDefined();\n163\t    // Y must have started before X finished — proving concurrent execution.\n164\t    expect(startTimes['Y']).toBeLessThan(endTimes['X']!);\n165\t    expect(readGlobal(vm, 'a')).toEqual({ tag: 'X' });\n166\t    expect(readGlobal(vm, 'b')).toEqual({ tag: 'Y' });\n167\t    vm.dispose();\n168\t  });\n169\t\n170\t  it('binds a destructured single-yield object result to each name', async () => {\n171\t    const vm = await createVM();\n172\t    const ask2 = () =>\n173\t      new Promise((resolve, reject) => {\n174\t        vm.pendingYields.push({ kind: 'ask', args: [], deferred: { resolve, reject }, vmPromiseHandle: undefined } as YieldRequest);\n175\t      });\n176\t    injectGlobal(vm.ctx, 'ask2', ask2 as (...a: unknown[]) => unknown);\n177\t\n178\t    const history = new MessageHistory();\n179\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n180\t\n181\t    await runTurnLoop({\n182\t      vm,\n183\t      history,\n184\t      systemBlock: 'test',\n185\t      ambientDts: 'declare function ask2(): Promise<any>;',\n186\t      renderHost: silentHost,\n187\t      streamFn: scriptedStream('const { name, age } = await ask2();'),\n188\t      processYield: async () => ({ name: 'Ada', age: 36 }),\n189\t      maxRetries: 2,\n190\t    });\n191\t\n192\t    expect(readGlobal(vm, 'name')).toBe('Ada');\n193\t    expect(readGlobal(vm, 'age')).toBe(36);\n194\t    vm.dispose();\n195\t  });\n196\t});\n197\t\n198\tdescribe('turn loop — setSessionMeta() runs end-to-end in a real VM', () => {\n199\t  it('injects the real global, typechecks against LIBRARY_DTS, and binds {ok:true}', async () => {"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"c735520a-4010-4ebd-aaf9-18dedc77cc56","timestamp":"2026-07-16T02:08:09.466Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
