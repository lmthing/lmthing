# Copy to .env.local and fill in your values.
# .env.local is git-ignored.

# ── K8s via kubectl proxy ────────────────────────────────────────────────────
# Run `kubectl proxy --port=8001` in a separate terminal (or via make local-up).
# No TLS or service account token needed — kubectl proxy authenticates as you.
K8S_LOCAL_PROXY=true
K8S_API_URL=http://localhost:8001

# ── Local compute ────────────────────────────────────────────────────────────
LOCAL_DEV=true
COMPUTE_IMAGE=compute:local
# Run `minikube ip` and paste the result here (make local-k8s-setup prints it)
MINIKUBE_IP=192.168.49.2

# ── Postgres (Docker Compose) ────────────────────────────────────────────────
DATABASE_URL=postgresql://lmthing:lmthing_local@localhost:5432/lmthing

# ── LiteLLM (Docker Compose) ─────────────────────────────────────────────────
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-lmt-local-dev

# ── Gateway JWT ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
GATEWAY_JWT_SECRET=REPLACE_ME_openssl_rand_base64_32

# ── Stripe (dummy — billing routes will return errors but won't crash) ────────
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
STRIPE_PRICE_STARTER=price_dummy
STRIPE_PRICE_BASIC=price_dummy
STRIPE_PRICE_PRO=price_dummy
STRIPE_PRICE_MAX=price_dummy

# ── Zitadel (dummy — use VITE_DEMO_USER=true in the frontend to skip auth) ──
ZITADEL_URL=http://localhost:8080
ZITADEL_CLIENT_ID=local
ZITADEL_CLIENT_SECRET=local

# ── ACR (not used — LOCAL_DEV=true skips ACR pull secret creation) ────────────
ACR_REGISTRY=localhost
ACR_USERNAME=local
ACR_PASSWORD=local

# ── Base URL ──────────────────────────────────────────────────────────────────
BASE_URL=https://cloud.test
