ate.\n812\t      delegateRunner: (p, a, act, o, allowed) => this.runDelegateForFork(p, a, act, o, allowed),\n813\t      // Forks may read attachments too — thread the same host resolver.\n814\t      documentResolver: this.opts.documentResolver,\n815\t    }));\n816\t    return this.forkEngine;\n817\t  }\n818\t\n819\t  /**\n820\t   * Soft per-turn reminder of OPEN todos (status pending/in_progress) from the\n821\t   * model-maintained `.lmthing/todos.json` (written by the todoWrite system function).\n822\t   * Re-surfaced every turn so the agent never loses track — but never blocks termination\n823\t   * (soft). Top-level session only; forks/delegates do not get this. Returns undefined\n824\t   * when there is no list or nothing open.\n825\t   */\n826\t  private readTodoReminder(): string | undefined {\n827\t    try {\n828\t      const raw = readFileSync(this.opts.spaceDir + '/.lmthing/todos.json', 'utf8');\n829\t      const items = JSON.parse(raw) as Array<{ content?: unknown; status?: unknown }>;\n830\t      const open = (Array.isArray(items) ? items : []).filter(\n831\t        (i) => i && typeof i.content === 'string' && i.status !== 'completed',\n832\t      );\n833\t      if (open.length === 0) return undefined;\n834\t      const lines = open.map((i) => `- [${i.status === 'in_progress' ? '~' : ' '}] ${String(i.content)}`);\n835\t      return [\n836\t        '## Open todos (you added these — keep working through them; mark each done with todoWrite when complete)',\n837\t        ...lines,\n838\t      ].join('\\n');\n839\t    } catch {\n840\t      return undefined; // no file / unreadable / bad JSON → nothing to remind\n841\t    }\n842\t  }\n843\t\n844\t  /**\n845\t   * The `beforeTurn` hook wired into every session turn loop: compose all\n846\t   * registered soft reminders (see `ReminderRegistry`). Fires once per model\n847\t   * episode. Top-level session only — forks/delegates do not set this hook.\n848\t   */\n849\t  private beforeTurn(): string | undefined {\n850\t    return this.reminders.collect();\n851\t  }\n852\t\n853\t  /**\n854\t   * Naming nudge (a reminder provider): because `setSessionMeta` ends the turn, the\n855\t   * agent frequently answers first and never names the conversation — especially on\n856\t   * quick one-statement turns. If it still hasn't named the session after 2 turns,\n857\t   * re-surface a short prompt to do it. Returns undefined (nothing to add) once\n858\t   * named or before the threshold.\n859\t   */\n860\t  private namingNudge(): string | undefined {\n861\t    if (this.sessionNamed || this.turnNo <= 2) return undefined;\n862\t    return (\n863\t      '## Name this conversation\\n' +\n864\t      'You have not named this session yet. Call `setSessionMeta({ title, slug })` now with a short, ' +\n865\t      'human-readable title so it is easy to find later — a status set via `setActivity` is NOT a title.'\n866\t    );\n867\t  }\n868\t\n869\t  /**\n870\t   * Record the agent's setSessionMeta() call (the fire-and-forget host hook). Core\n871\t   * stays persistence-free: we trim the title, slugify the slug, mark the session\n872\t   * named (silencing the nudge), and emit a session_meta trace event the server's\n873\t   * wireTracer ingests to update + persist the SessionEntry (mirrors how\n874\t   * totalCostUsd rides llm_response events). Returns whether anything was set.\n875\t   */\n876\t  private recordSessionMeta(meta: { title?: unknown; slug?: unknown }): boolean {\n877\t    const title = typeof meta.title === 'string' ? meta.title.trim().slice(0, 120) : undefined;\n878\t    // slugify: lowercase, non-alphanumerics → '-', collapse/trim dashes, cap length.\n879\t    const rawSlug = typeof meta.slug === 'string'\n880\t      ? meta.slug.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60)\n881\t      : undefined;\n882\t    const slug = rawSlug || undefined;\n883\t    if (title || slug) {\n884\t      this.sessionNamed = true; // silence the naming nudge (beforeTurn