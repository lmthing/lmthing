{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_sfJQvblhEfpwSUxUMzAekFeg","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, existsSync, readFileSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join, dirname } from 'node:path';\n5\timport { fileURLToPath } from 'node:url';\n6\timport { createVM, type VM } from '../sandbox/quickjs.js';\n7\timport { injectHostTools } from '../globals/host-tools.js';\n8\timport { transpileStatement } from '../typecheck/transpile.js';\n9\timport { loadSpace } from './load.js';\n10\timport { loadTasklistFromSpace } from './tasklist-load.js';\n11\timport { validateDag, resolveGoalTask } from '../tasklist/dag.js';\n12\timport type { RenderHost } from '../session/types.js';\n13\t\n14\tconst __dirname = dirname(fileURLToPath(import.meta.url));\n15\tconst ARCHITECT_DIR = join(__dirname, '..', '..', 'system-spaces', 'system-architect');\n16\tconst FNS = join(ARCHITECT_DIR, 'functions');\n17\tconst host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n18\t\n19\tfunction injectFn(vm: VM, name: string): void {\n20\t  const src = readFileSync(join(FNS, `${name}.ts`), 'utf8');\n21\t  const js = transpileStatement(src)\n22\t    .replace(/^export\\s+default\\s+function\\s+/gm, `function ${name} `)\n23\t    .replace(/^export\\s+default\\s+/gm, `const ${name} = `)\n24\t    .replace(/^export\\s+/gm, '');\n25\t  const r = vm.evalScript(`${js}\\nglobalThis['${name}'] = ${name};`);\n26\t  if (!r.ok) throw new Error(`inject ${name} failed: ${r.error}`);\n27\t}\n28\tfunction evalDump(vm: VM, code: string): any {\n29\t  const res = vm.ctx.evalCode(code);\n30\t  if (res.error) { const e = vm.ctx.dump(res.error); res.error.dispose(); throw new Error(JSON.stringify(e)); }\n31\t  const v = vm.ctx.dump(res.value); res.value.dispose(); return v;\n32\t}\n33\t\n34\tdescribe('per-file builders smoke', () => {\n35\t  let vm: VM; let baseDir: string;\n36\t  beforeEach(async () => {\n37\t    baseDir = mkdtempSync(join(tmpdir(), 'builders-'));\n38\t    vm = await createVM();\n39\t    injectHostTools(vm, { renderHost: host, spaceDir: baseDir });\n40\t    for (const f of ['writeAgentFile', 'writeFunctionFile', 'writeTaskFile', 'writeKnowledgeIndex', 'writeKnowledgeOption', 'writeComponentFile', 'validateSpace']) injectFn(vm, f);\n41\t  });\n42\t  afterEach(() => { vm.dispose(); rmSync(baseDir, { recursive: true, force: true }); });\n43\t\n44\t  it('builds a valid, registerable space file-by-file', () => {\n45\t    const dir = join(baseDir, 'dog-expert');\n46\t    const D = JSON.stringify(dir);\n47\t    const agent = evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({\n48\t      agentSlug: 'dog-expert', agentTitle: 'Dog Expert',\n49\t      systemPrompt: 'You are a dog breed expert. Answer using pre-researched knowledge where available.',\n50\t      knowledge: ['dogs/breeds'], functions: ['scoreBreed'],\n51\t      actions: [{ id: 'answer', label: 'Answer', description: 'Answer a dog question', tasklist: 'answer' }],\n52\t    })})`);\n53\t    expect(agent.ok).toBe(true);\n54\t\n55\t    // New knowledge contract: index.md body is the OVERVIEW (covers all options); the\n56\t    // field has >=2 aspect option files (never a single \"overview\" option).\n57\t    const ki = evalDump(vm, `writeKnowledgeIndex(${D}, \"dogs\", \"breeds\", ${JSON.stringify({ variable: 'breeds', default: 'retrievers', description: 'Dog breeds grouped by purpose: retrievers (work/family), toy breeds (companions), and herding dogs each have distinct temperaments and care needs.' })})`);\n58\t    expect(ki.ok).toBe(true);\n59\t    const ko1 = evalDump(vm, `writeKnowledgeOption(${D}, \"dogs\", \"breeds\", \"retrievers\", ${JSON.stringify('# Retrievers\\\\nLabrador and Golden Retrievers: friendly, energetic family dogs.')})`);\n60\t    expect(ko1.ok).toBe(true);\n61\t    const ko2 = evalDump(vm, `writeKnowledgeOption(${D}, \"dogs\", \"breeds\", \"toy_breeds\", ${JSON.stringify('# Toy Breeds\\\\nPoodle and Chihuahua: small companion dogs for apartments.')})`);\n62\t    expect(ko2.ok).toBe(true);\n63\t\n64\t    const fn = evalDump(vm, `writeFunctionFile(${D}, \"scoreBreed\", ${JSON.stringify('export function scoreBreed(name: string): number { return name.length; }')})`);\n65\t    expect(fn.ok).toBe(true);\n66\t\n67\t    const t1 = evalDump(vm, `writeTaskFile(${D}, \"answer\", ${JSON.stringify({ id: 'reply', instruction: 'Load knowledge then answer. Resolve: currentTask.resolve({ answer })', output: { answer: 'string' }, goal: true })})`);\n68\t    expect(t1.ok).toBe(true);\n69\t    expect(t1.path).toMatch(/01-reply\\.md$/);\n70\t\n71\t    const v = evalDump(vm, `validateSpace(${D})`);\n72\t    expect(v.ok).toBe(true);\n73\t    expect(v.errors).toEqual([]);\n74\t    expect(existsSync(join(dir, 'agents', 'dog-expert', 'instruct.md'))).toBe(true);\n75\t  });\n76\t\n77\t  it('rejects placeholder loadKnowledge in agent prompt and task instruction', () => {\n78\t    const dir = join(baseDir, 'sP'); const D = JSON.stringify(dir);\n79\t    const a = evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({\n80\t      agentSlug: 'p', agentTitle: 'P',\n81\t      systemPrompt: \"Load it: await loadKnowledge('<domain>', '<field>', '<aspect>.md')\",\n82\t      actions: [{ id: 'go', label: 'Go', description: 'd', tasklist: 'go' }],\n83\t    })})`);\n84\t    expect(a.ok).toBe(false);\n85\t    expect(a.error).toMatch(/placeholder/i);\n86\t    const t = evalDump(vm, `writeTaskFile(${D}, \"go\", ${JSON.stringify({ id: 'x', instruction: \"await loadKnowledge('<domain>', '<field>', '<aspect>.md')\", output: { r: 'string' }, goal: true })})`);\n87\t    expect(t.ok).toBe(false);\n88\t    expect(t.error).toMatch(/placeholder/i);\n89\t  });\n90\t\n91\t  // A knowledge-grounded task that is told only to \"answer, grounded in the knowledge\" has no rule\n92\t  // for the case that matters: the knowledge is SILENT on the question. Live, a generated insurance\n93\t  // agent then answered a market-check question from its (unrelated) car-policy note and told the\n94\t  // user there was a cheaper option — naming their own current insurer. Every task that loads\n95\t  // knowledge must carry the grounding rule, whatever prose the architect's model wrote.\n96\t  it('appends the grounding rule to every task that loads knowledge (never answer past the knowledge)', () => {\n97\t    const dir = join(baseDir, 'sG'); const D = JSON.stringify(dir);\n98\t    evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({ agentSlug: 'g', agentTitle: 'G', systemPrompt: 'x', actions: [{ id: 'answer', label: 'A', description: 'd', tasklist: 'answer' }] })})`);\n99\t\n100\t    const grounded = evalDump(vm, `writeTaskFile(${D}, \"answer\", ${JSON.stringify({\n101\t      id: 'reply',\n102\t      instruction: \"Answer `query`. Code:\\nconst k = await loadKnowledge('insurance','car','policy.md');\\ncurrentTask.resolve({ answer: 'md' });\",\n103\t      output: { answer: 'string' }, goal: true,\n104\t    })})`);\n105\t    expect(grounded.ok).toBe(true);\n106\t    const body = readFileSync(grounded.path, 'utf8');\n107\t    expect(body).toMatch(/does not answer/i);\n108\t    expect(body).toMatch(/never infer, guess, or present a conclusion the knowledge does not state/i);\n109\t\n110\t    // Already stated in the model's own words → not duplicated.\n111\t    const already = evalDump(vm, `writeTaskFile(${D}, \"answer\", ${JSON.stringify({\n112\t      id: 'own',\n113\t      instruction: \"await loadKnowledge('insurance','car','policy.md'); If the notes don't cover it, say so — never invent.\",\n114\t      output: { answer: 'string' },\n115\t    })})`);\n116\t    expect(readFileSync(already.path, 'utf8')).not.toMatch(/never infer, guess, or present/i);\n117\t\n118\t    // A task that loads NO knowledge is left exactly as authored.\n119\t    const plain = evalDump(vm, `writeTaskFile(${D}, \"answer\", ${JSON.stringify({\n120\t      id: 'plain', instruction: 'Compute the total. currentTask.resolve({ answer: \"42\" });', output: { answer: 'string' },\n121\t    })})`);\n122\t    expect(readFileSync(plain.path, 'utf8')).not.toMatch(/never infer/i);\n123\t  });\n124\t\n125\t  it('bakes knowledge:write onto the agent and a per-node capability into a task', () => {\n126\t    const dir = join(baseDir, 'sK'); const D = JSON.stringify(dir);\n127\t    const a = evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({\n128\t      agentSlug: 'zx', agentTitle: 'ZX', systemPrompt: 'Answer about zanzibar.',\n129\t      capabilities: ['knowledge:write', 'not-a-cap'], // unknown id filtered out\n130\t      actions: [{ id: 'answer', label: 'A', description: 'd', tasklist: 'answer' }],\n131\t    })})`);\n132\t    expect(a.ok).toBe(true);\n133\t    const agentBody = readFileSync(join(dir, 'agents', 'zx', 'instruct.md'), 'utf8');\n134\t    expect(agentBody).toMatch(/capabilities:\\n\\s+- knowledge:write/);\n135\t    expect(agentBody).not.toMatch(/not-a-cap/);\n136\t\n137\t    const store = evalDump(vm, `writeTaskFile(${D}, \"research_and_store\", ${JSON.stringify({\n138\t      id: 'store',\n139\t      instruction: \"const w = writeKnowledge('a','b','c','x', { source: 'researched' }); currentTask.resolve({ stored: w.ok });\",\n140\t      output: { stored: 'boolean' }, role: 'general', capabilities: ['knowledge:write'], goal: true,\n141\t    })})`);\n142\t    expect(store.ok).toBe(true);\n143\t    expect(readFileSync(store.path, 'utf8')).toMatch(/capabilities:\\n\\s+- knowledge:write/);\n144\t  });\n145\t\n146\t  it('rejects a function with a syntax error (typecheck on write)', () => {\n147\t    const dir = join(baseDir, 's2'); const D = JSON.stringify(dir);\n148\t    const fn = evalDump(vm, `writeFunctionFile(${D}, \"broken\", ${JSON.stringify('export function broken( { return 1 }')})`);\n149\t    expect(fn.ok).toBe(false);\n150\t    expect(fn.errors.length).toBeGreaterThan(0);\n151\t    expect(existsSync(join(dir, 'functions', 'broken.ts'))).toBe(false);\n152\t  });\n153\t\n154\t  it('re-writes a task in place (idempotent ordinal)', () => {\n155\t    const dir = join(baseDir, 's3'); const D = JSON.stringify(dir);\n156\t    evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({ agentSlug: 'a', agentTitle: 'A', systemPrompt: 'x', actions: [{ id: 'go', label: 'Go', description: 'd', tasklist: 'go' }] })})`);\n157\t    evalDump(vm, `writeTaskFile(${D}, \"go\", ${JSON.stringify({ id: 'one', instruction: 'first', output: { r: 'string' } })})`);\n158\t    const t2 = evalDump(vm, `writeTaskFile(${D}, \"go\", ${JSON.stringify({ id: 'two', instruction: 'second', output: { r: 'string' }, goal: true })})`);\n159\t    expect(t2.path).toMatch(/02-two\\.md$/);\n160\t    const t1b = evalDump(vm, `writeTaskFile(${D}, \"go\", ${JSON.stringify({ id: 'one', instruction: 'first-rev', output: { r: 'string' } })})`);\n161\t    expect(t1b.path).toMatch(/01-one\\.md$/);\n162\t    expect(readFileSync(join(dir, 'tasklists', 'go', '01-one.md'), 'utf8')).toContain('first-rev');\n163\t  });\n164\t\n165\t  it('writeAgentFile emits defaultAction and canDelegateTo (not the legacy dependencies)', () => {\n166\t    const dir = join(baseDir, 's4'); const D = JSON.stringify(dir);\n167\t    evalDump(vm, `writeAgentFile(${D}, ${JSON.stringify({ agentSlug: 'a', agentTitle: 'A', systemPrompt: 'x', defaultAction: 'go', canDelegateTo: ['other-space/helper#run'], actions: [{ id: 'go', label: 'Go', description: 'd', tasklist: 'go' }, { id: 'other', label: 'O', description: 'd', tasklist: 'other' }] })})`);\n168\t    const fm = readFileSync(join(dir, 'agents', 'a', 'instruct.md'), 'utf8');\n169\t    expect(fm).toContain('defaultAction: go');\n170\t    expect(fm).toContain('canDelegateTo:');\n171\t    expect(fm).toContain('- other-space/helper#run');\n172\t    expect(fm).not.toContain('dependencies:'); // org/format/space/agents/frontmatter.md: canDelegateTo replaces dependencies\n173\t  });\n174\t});\n175\t\n176\tdescribe('system-architect space loads with the restructured tasklists', () => {\n177\t  it('loads the architect space and resolves the per-file builder functions', async () => {\n178\t    const space = await loadSpace(ARCHITECT_DIR);\n179\t    const architect = space.agents['architect']!;\n180\t    expect(architect).toBeTruthy();\n181\t    // The agent declares the per-file builders (not the removed scaffoldSpace/parseSkill).\n182\t    const declared = new Set(architect.config.functions);\n183\t    for (const fn of ['writeAgentFile', 'writeTaskFile', 'writeFunctionFile', 'writeKnowledgeIndex', 'writeKnowledgeOption', 'writeComponentFile', 'validateSpace']) {\n184\t      expect(declared.has(fn)).toBe(true);\n185\t    }\n186\t    // The removed import agent is gone.\n187\t    expect(space.agents['skill-to-space-transformer']).toBeUndefined();\n188\t  });\n189\t\n190\t  it('synthesize_and_run is a valid DAG: design→(build_field/build_function fan-out)→write_agent→write_tasks→validate→register→finalize', async () => {\n191\t    const space = await loadSpace(ARCHITECT_DIR);\n192\t    const tasks = await loadTasklistFromSpace(space, 'synthesize_and_run');\n193\t    expect(() => validateDag(tasks)).not.toThrow();\n194\t    expect(Object.keys(tasks).sort()).toEqual(\n195\t      ['build_field', 'build_function', 'design', 'finalize', 'register', 'validate', 'write_agent', 'write_tasks'],\n196\t    );\n197\t    expect(resolveGoalTask(tasks)?.id).toBe('finalize');\n198\t    // Per-file builds fan out over the design step's arrays (host-driven map nodes).\n199\t    expect(tasks['build_field']!.forEach).toBe('design.fields');\n200\t    expect(tasks['build_function']!.forEach).toBe('design.functions');\n201\t    // Read-only steps are explore; file-writing steps are general (least privilege).\n202\t    expect(tasks['design']!.role).toBe('explore');\n203\t    expect(tasks['write_agent']!.role).toBe('general');\n204\t    expect(tasks['validate']!.role).toBe('explore');\n205\t    // write_agent waits for both fan-outs; register waits for validate.\n206\t    expect(tasks['write_agent']!.dependsOn).toEqual(['design', 'build_field', 'build_function']);\n207\t    expect(tasks['register']!.dependsOn).toEqual(['design', 'validate']);\n208\t  });\n209\t\n210\t  it('iterate_space is a valid DAG: load→diagnose→edit→reregister→redelegate, redelegate is the goal', async () => {\n211\t    const space = await loadSpace(ARCHITECT_DIR);\n212\t    const tasks = await loadTasklistFromSpace(space, 'iterate_space');\n213\t    expect(() => validateDag(tasks)).not.toThrow();\n214\t    expect(Object.keys(tasks).sort()).toEqual(['diagnose', 'edit', 'load', 'redelegate', 'reregister']);\n215\t    expect(resolveGoalTask(tasks)?.id).toBe('redelegate');\n216\t    // A4: redelegate threads load's actionId, so it depends on load (not just reregister).\n217\t    expect(tasks['redelegate']!.dependsOn).toEqual(['reregister', 'load']);\n218\t  });\n219\t});\n220\t"}]},"parent_tool_use_id":"call_cwYgt85iKLtg0vqZsWTtUM66","session_id":"b8a0991b-bce4-420b-844a-664f990ff54b","uuid":"882873cd-ac56-463e-824d-3e2a7aaac805","timestamp":"2026-07-15T22:46:23.752Z","subagent_type":"Explore","task_description":"Trace specialist creation route"}
