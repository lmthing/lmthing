{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_dT4GdcKa4hmxGvTNgALwN3LS","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport type { CodeNodeCtxFactory } from './orchestrator.js';\n7\timport { ForkEngine } from '../fork/fork.js';\n8\timport { loadSpace } from '../spaces/load.js';\n9\timport { createMockStreamFn } from '../testing/mock-provider.js';\n10\timport type { RenderHost } from '../session/types.js';\n11\timport type { StreamOpts } from '../eval/stream-types.js';\n12\t\n13\t/**\n14\t * Code-node execution in the orchestrator (plan step S2). Core never imports a\n15\t * code node's module — the orchestrator calls an injected `codeNodeCtxFactory`.\n16\t * These tests supply an in-memory factory (standing in for the CLI/pod's worker\n17\t * runner) and assert code-node output feeds the DAG identically to an agent\n18\t * node: dependsOn wiring, forEach fan-out (as a body AND as the array source),\n19\t * required-task-failure propagation, and the no-factory error.\n20\t */\n21\t\n22\tconst tmpDirs: string[] = [];\n23\tafterAll(async () => {\n24\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n25\t});\n26\t\n27\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n28\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-codeorch-'));\n29\t  tmpDirs.push(dir);\n30\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n31\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n32\t  const tl = join(dir, 'tasklists', 'flow');\n33\t  await mkdir(tl, { recursive: true });\n34\t  for (const [name, contents] of Object.entries(files)) {\n35\t    await writeFile(join(tl, name), contents, 'utf8');\n36\t  }\n37\t  return dir;\n38\t}\n39\t\n40\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n41\t\n42\t/** ForkEngine wired to a mock streamFn answering agent nodes by output-schema token. */\n43\tfunction engineFor(dir: string, answers: Array<{ token: string; code: string }>): ForkEngine {\n44\t  const streamFn = createMockStreamFn((o: StreamOpts) => {\n45\t    const user = o.messages.map((m) => m.content).join('\\n');\n46\t    for (const a of answers) {\n47\t      if (user.includes('Output schema:') && user.includes(a.token)) return a.code;\n48\t    }\n49\t    return '';\n50\t  });\n51\t  return new ForkEngine({\n52\t    maxConcurrentForks: 4,\n53\t    parentHistory: [],\n54\t    parentSpaceDir: dir,\n55\t    parentAgentSlug: 'main',\n56\t    renderHost: silentHost,\n57\t    streamFn,\n58\t  });\n59\t}\n60\t\n61\t/** A code-node factory backed by an in-memory { taskId -> run } map. Records the\n62\t *  inputs each code node received so tests can assert seed/upstream threading. */\n63\tfunction factoryFrom(\n64\t  runners: Record<string, (inputs: Record<string, unknown>) => unknown>,\n65\t  seenInputs?: Record<string, Record<string, unknown>>,\n66\t): CodeNodeCtxFactory {\n67\t  return (node) => ({\n68\t    runCodeNode: async (inputs) => {\n69\t      if (seenInputs) seenInputs[node.id] = inputs;\n70\t      const fn = runners[node.id];\n71\t      if (!fn) throw new Error(`test: no runner for code node \"${node.id}\"`);\n72\t      return (await fn(inputs)) as Record<string, unknown>;\n73\t    },\n74\t  });\n75\t}\n76\t\n77\tdescribe('runTasklist code nodes', () => {\n78\t  it('runs a code node fed by an upstream AGENT node, with output feeding the envelope', async () => {\n79\t    const dir = await makeTasklistSpace({\n80\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n81\t      '02-sum.ts': `export const node = { dependsOn: ['list'], output: { total: 'number' } };\\nexport async function run() { return {}; }`,\n82\t    });\n83\t    const space = await loadSpace(dir);\n84\t    const seen: Record<string, Record<string, unknown>> = {};\n85\t    const engine = engineFor(dir, [{ token: 'LIST_T', code: `currentTask.resolve({ items: [1, 2, 3, 4] });` }]);\n86\t    const factory = factoryFrom(\n87\t      { sum: (inputs) => ({ total: (inputs['list'] as { items: number[] }).items.reduce((a, b) => a + b, 0) }) },\n88\t      seen,\n89\t    );\n90\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine, seed: { base: 100 }, codeNodeCtxFactory: factory });\n91\t    expect(result.data).toEqual({ total: 10 });\n92\t    expect(result.ok).toBe(true);\n93\t    expect(result.degraded).toBe(false);\n94\t    // Inputs mirror what an agent fork would see: seed vars + upstream output keyed by dep id.\n95\t    expect(seen['sum']).toEqual({ base: 100, list: { items: [1, 2, 3, 4] } });\n96\t  });\n97\t\n98\t  it('fans a code node out over an upstream array (code node AS a forEach body)', async () => {\n99\t    const dir = await makeTasklistSpace({\n100\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n101\t      '02-each.ts': `export const node = { dependsOn: ['list'], forEach: 'list.items', goal: true, output: { n: 'number' } };\\nexport async function run() { return {}; }`,\n102\t    });\n103\t    const space = await loadSpace(dir);\n104\t    const engine = engineFor(dir, [{ token: 'LIST_T', code: `currentTask.resolve({ items: [10, 20, 30] });` }]);\n105\t    const factory = factoryFrom({ each: (inputs) => ({ n: (inputs['item'] as number) * 2 }) });\n106\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine, codeNodeCtxFactory: factory });\n107\t    // forEach collects each element's output into an array, in order.\n108\t    expect(result.data).toEqual([{ n: 20 }, { n: 40 }, { n: 60 }]);\n109\t    expect(result.ok).toBe(true);\n110\t  });\n111\t\n112\t  it('lets a code node PRODUCE the array that a downstream forEach code node fans over', async () => {\n113\t    // Covers \"a code node's array output can drive forEach\" with no agent nodes at all.\n114\t    const dir = await makeTasklistSpace({\n115\t      '01-gen.ts': `export const node = { output: { items: 'array' } };\\nexport async function run() { return {}; }`,\n116\t      '02-each.ts': `export const node = { dependsOn: ['gen'], forEach: 'gen.items', goal: true, output: { v: 'number' } };\\nexport async function run() { return {}; }`,\n117\t    });\n118\t    const space = await loadSpace(dir);\n119\t    const engine = engineFor(dir, []); // no agent nodes\n120\t    const factory = factoryFrom({\n121\t      gen: () => ({ items: [5, 6] }),\n122\t      each: (inputs) => ({ v: inputs['item'] as number }),\n123\t    });\n124\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine, codeNodeCtxFactory: factory });\n125\t    expect(result.data).toEqual([{ v: 5 }, { v: 6 }]);\n126\t  });\n127\t\n128\t  it('propagates a required code node failure as a required-task failure', async () => {\n129\t    const dir = await makeTasklistSpace({\n130\t      '01-boom.ts': `export const node = { goal: true, output: { v: 'number' } };\\nexport async function run() { return {}; }`,\n131\t    });\n132\t    const space = await loadSpace(dir);\n133\t    const engine = engineFor(dir, []);\n134\t    const factory = factoryFrom({ boom: () => { throw new Error('kaboom'); } });\n135\t    await expect(\n136\t      runTasklist({ name: 'flow', space, forkEngine: engine, codeNodeCtxFactory: factory }),\n137\t    ).rejects.toThrow(/Required task \"boom\" failed: kaboom/);\n138\t  });\n139\t\n140\t  it('skips an OPTIONAL code node whose run throws, and still completes the goal', async () => {\n141\t    const dir = await makeTasklistSpace({\n142\t      '01-flaky.ts': `export const node = { optional: true, output: { v: 'number' } };\\nexport async function run() { return {}; }`,\n143\t      '02-main.md': `---\\nid: main\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nMAIN_T: the real work.`,\n144\t    });\n145\t    const space = await loadSpace(dir);\n146\t    const engine = engineFor(dir, [{ token: 'MAIN_T', code: `currentTask.resolve({ v: 7 });` }]);\n147\t    const factory = factoryFrom({ flaky: () => { throw new Error('nope'); } });\n148\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine, codeNodeCtxFactory: factory });\n149\t    expect(result.data).toEqual({ v: 7 });\n150\t    expect(result.ok).toBe(true);\n151\t  });\n152\t\n153\t  it('fails a required code node with a clear error when no codeNodeCtxFactory is provided', async () => {\n154\t    const dir = await makeTasklistSpace({\n155\t      '01-code.ts': `export const node = { goal: true, output: { v: 'number' } };\\nexport async function run() { return {}; }`,\n156\t    });\n157\t    const space = await loadSpace(dir);\n158\t    const engine = engineFor(dir, []);\n159\t    await expect(\n160\t      runTasklist({ name: 'flow', space, forkEngine: engine }),\n161\t    ).rejects.toThrow(/Required task \"code\" failed:.*codeNodeCtxFactory/s);\n162\t  });\n163\t});\n164\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"35f8a827-7309-4b68-a77e-17b30f91d3ca","timestamp":"2026-07-16T06:19:31.648Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
