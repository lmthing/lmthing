  \"}\",\n  \"\",\n  // Color dots per category for grouping headers\n  \"const CATEGORY_COLORS: Record<string, string> = {\",\n  \"  lodging: '#3b82f6',\",\n  \"  safari: '#f59e0b',\",\n  \"  transport: '#8b5cf6',\",\n  \"  visa: '#10b981',\",\n  \"  souvenir: '#ec4899',\",\n  \"  tips: '#ef4444',\",\n  \"};\",\n  \"\",\n  // Sort priority for category groups\n  \"const CATEGORY_ORDER = ['safari', 'lodging', 'transport', 'visa', 'tips', 'souvenir'];\",\n  \"\",\n  \"function formatCurrency(amount: number, currency: string): string {\",\n  \"  if (currency === 'TZS') return `TZS ${amount.toLocaleString()}`;\",\n  \"  return `$${amount.toLocaleString()}`;\",\n  \"}\",\n  \"\",\n  \"export default function Page() {\",\n  \"  const { data: costs, isLoading, error } = useApi<{ items: CostItem[] }>('costs-list');\",\n  \"  const { data: summaryData } = useApi<CostSummary>('costs-summary');\",\n  \"\",\n  \"  if (isLoading) return <p className=\\\"p-4 text-muted\\\">Loading costs…</p>;\",\n  \"  if (error) return <p className=\\\"p-4 text-destructive\\\">Could not load cost data.</p>;\",\n  \"\",\n  \"  const items = costs?.items ?? [];\",\n  \"\",\n  \"  if (items.length === 0) {\",\n  \"    return (\",\n  \"      <main className=\\\"p-4\\\">\",\n  \"        <EmptyState title=\\\"No costs yet\\\" subtitle=\\\"Cost line-items will appear here once you add them.\\\" />\",\n  \"      </main>\",\n  \"    );\",\n  \"  }\",\n  \"\",\n  \"  // Group items by category, sorted by CATEGORY_ORDER\",\n  \"  const grouped: Record<string, CostItem[]> = {};\",\n  \"  const catOrderSet = new Set(CATEGORY_ORDER);\",\n  \"  for (const it of items) {\",\n  \"    if (!grouped[it.category]) grouped[it.category] = [];\",\n  \"    grouped[it.category].push(it);\",\n  \"  }\",\n  \"  const orderedCats = CATEGORY_ORDER.filter((c) => grouped[c]);\",\n  \"  // Append any categories not in the predefined order\",\n  \"  for (const cat of Object.keys(grouped)) {\",\n  \"    if (!catOrderSet.has(cat)