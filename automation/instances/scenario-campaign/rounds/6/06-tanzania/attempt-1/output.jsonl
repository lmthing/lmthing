{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_dkkEjcxugttLbY0v6Wf415zc","type":"tool_result","content":"35\t  evaluateDelegatePolicy,\n36\t  isDelegateAllowed,\n37\t  formatDelegateDenial,\n38\t  type DelegatePolicy,\n39\t} from '../exec/target-match.js';\n40\t\n41\t/** One image/file attachment on a user turn. Audio is transcribed to text\n42\t *  upstream, so it never appears here. An IMAGE carries a model-facing `part`\n43\t *  (sent to a vision model). A FILE carries neither `part` nor `text` — the\n44\t *  delegated files agent fetches its content itself via `readDocument(id)`, so\n45\t *  the session hands it only an id-anchored note (keyed by `id`). */\n46\texport interface UserAttachment {\n47\t  id: string;\n48\t  kind: 'image' | 'file';\n49\t  mediaType: string;\n50\t  filename?: string;\n51\t  /** Image part (sent to a vision model). Absent for files. */\n52\t  part?: MediaPart;\n53\t  /** Legacy: decoded text of a text file. No longer populated — files are read\n54\t   *  on demand via `readDocument(id)`. Retained for backward-compatible shape. */\n55\t  text?: string;\n56\t}\n57\t\n58\t/** A user turn's input: plain text, or text plus image/file attachments. A text\n59\t *  orchestrator (THING) can't read the parts directly — it delegates them to a\n60\t *  vision/file agent by their id (see the attachment note added to its message). */\n61\texport type UserInput = string | { text: string; attachments?: UserAttachment[] };\n62\t\n63\t/** Normalize a user turn to its text + attachments. */\n64\tfunction normalizeInput(message: UserInput): { text: string; attachments?: UserAttachment[] } {\n65\t  return typeof message === 'string' ? { text: message } : message;\n66\t}\n67\t\n68\t/** A short text note listing the turn's image/file attachments (by id), appended\n69\t *  to a text agent's message so it knows what's attached and can delegate each to\n70\t *  the right specialist. The bytes are NOT in the text — only ids + metadata. */\n71\tfunction attachmentNote(attachments: UserAttachment[]): string {\n72\t  if (!attachments.length) return '';\n73\t  const lines = attachments\n74\t    .map((a) => `  - ${a.kind}: ${a.filename ?? a.mediaType} — attachmentId \"${a.id}\"`)\n75\t    .join('\\n');\n76\t  return (\n77\t    `\\n\\n[The user attached the following. You cannot read them yourself — delegate each ` +\n78\t    `by its id: an image to \\`system-vision/vision\\`, a file to \\`system-files/dispatch\\`, ` +\n79\t    `passing \\`{ query, attachmentIds: [\"<id>\"] }\\`.\\n${lines}]`\n80\t  );\n81\t}\n82\t\n83\t/** Extract the plain-text portion of a user turn (drops framing/attachments) —\n84\t *  used for the defaultAction fast-path `query`. */"}]},"parent_tool_use_id":"call_DTWyob8TJtBDOIwxjDDTvEGN","session_id":"c2f33b80-852a-433e-8510-ac2647f435a2","uuid":"a4246c8f-8771-4680-b7a8-fdc453df92f3","timestamp":"2026-07-15T19:34:15.071Z","subagent_type":"Explore","task_description":"Trace voice attachment routing"}
