{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_c6kqYhCkRADvIcsroNa7x4XE","type":"tool_result","content":"1\timport { roleProfile } from '../fork/roles.js';\n2\timport type { AppCapabilities } from '../spaces/capabilities.js';\n3\t\n4\t/**\n5\t * Read-only fork roles (`explore`/`plan`) can never receive a write/authoring\n6\t * capability — the app grants are intersected with `allowWrite`, exactly as the\n7\t * host-tools write gate withholds `writeFileRaw`. Only the read/outbound grants\n8\t * (`db:read`, `api:call`, `connections:use`, `store:read`) survive; every\n9\t * mutating/authoring grant (`db:write`/`db:schema`/`pages:write`/`api:write`/\n10\t * `hooks:write`/`knowledge:write`/`store:install`/`events:emit`) is dropped. NOTE: `connections:use`\n11\t * can have a side-effect (POST to an external service), but is treated as\n12\t * outbound like `api:call` — the caller's own read-only intent governs, not the\n13\t * transport. Drop it here if read-only forks must never mutate external state.\n14\t */\n15\texport function intersectAppCaps(app: AppCapabilities, allowWrite: boolean): AppCapabilities {\n16\t  if (allowWrite) return app;\n17\t  const out: AppCapabilities = {};\n18\t  if (app['db:read']) out['db:read'] = app['db:read'];\n19\t  if (app['api:call']) out['api:call'] = app['api:call'];\n20\t  if (app['connections:use']) out['connections:use'] = app['connections:use'];\n21\t  // store:read is pure catalog discovery — safe for read-only roles. The\n22\t  // mutating store:install (writes into the project) and events:emit (triggers\n23\t  // hooks) are withheld, like every other write grant.\n24\t  if (app['store:read']) out['store:read'] = app['store:read'];\n25\t  return out;\n26\t}\n27\t\n28\t/**\n29\t * NARROW a capability set to a per-task-node subset — SELECT ∩ DECLARED, never widen.\n30\t *\n31\t * A tasklist task node may carry `capabilities: [<id>, ...]` to run with only a subset of\n32\t * its owning agent's grants (least privilege per step: e.g. only the migrate write-node of\n33\t * user-memory's tasklist carries `db:write`, its sibling collect-node runs without it). When\n34\t * `allow` is undefined the node inherits the agent's full set unchanged. When present, we copy\n35\t * ONLY the entries already granted to the agent, preserving each cap's scope object by\n36\t * reference — so a node can never conjure a capability (or a wider table scope) the agent\n37\t * itself lacks. Because `forkCapabilities` runs this before `intersectAppCaps`, the read-only\n38\t * role gate still applies on top.\n39\t */\n40\texport function narrowAppCaps(app: AppCapabilities, allow: import('../spaces/capabilities.js').CapabilityId[] | undefined): AppCapabilities {\n41\t  if (!allow) return app;\n42\t  const out: AppCapabilities = {};\n43\t  for (const id of allow) {\n44\t    if (app[id] !== undefined) (out as Record<string, unknown>)[id] = app[id];\n45\t  }\n46\t  return out;\n47\t}\n48\t\n49\t/**\n50\t * CapabilityProfile — the single description of what a child VM context may do.\n51\t *\n52\t * The three execution contexts (top-level session, fork leaf, delegate) used to\n53\t * hand-maintain three near-identical wiring blocks that silently drifted apart\n54\t * (the A1 delegate-nesting bug). The profile now drives BOTH sides of the wiring\n55\t * from one value:\n56\t *   - which value-yielding globals `createChildVM` injects (exec/bootstrap.ts)\n57\t *   - which ambient declarations `buildAmbientDts` emits, so a call to a global\n58\t *     that is not injected fails typecheck (a clean retryable error) instead of\n59\t *     passing typecheck and throwing at runtime.\n60\t *\n61\t * Phase 5: the `delegate` flag is now driven at EVERY level by the unified\n62\t * `canDelegateTo` policy (`exec/target-match.ts evaluateDelegatePolicy`) —\n63\t * callers pass `policy.mode !== 'none'` so injection and the ambient DTS stay\n64\t * in lockstep with the yield-time gate.\n65\t */\n66\texport interface CapabilityProfile {\n67\t  /** Which context this VM runs: informational + future gating. */\n68\t  kind: 'session' | 'fork' | 'delegate';\n69\t  /** `ask()` — top-level session only (forks/delegates are headless/autonomous). */\n70\t  ask: boolean;\n71\t  /** `fork()` + `tasklist()` — orchestrating contexts only, never fork leaves\n72\t   *  (a leaf spawning its own subtree would bypass the concurrency semaphore\n73\t   *  and the depth accounting). */\n74\t  orchestrate: boolean;\n75\t  /** `delegate()` global. Gated at every level by the unified `canDelegateTo`\n76\t   *  policy: sessions/delegates lose it when their AGENT declares\n77\t   *  `canDelegateTo: []`; fork leaves only get it when the TASK opts in via\n78\t   *  `canDelegateTo` AND the engine has a delegateRunner wired. */\n79\t  delegate: boolean;\n80\t  /** `registerSpace()` — a session-state mutation (writes the shared\n81\t   *  dynamicSpaces map), so it is withheld from read-only fork roles exactly\n82\t   *  like writeFileRaw. NOTE: its DTS declaration is unconditional (matching\n83\t   *  the pre-unification DTS, which only stripped ask/tasklist/fork/delegate). */\n84\t  registerSpace: boolean;\n85\t  /** `setSessionMeta()` — sets the session title/slug. Top-level session only\n86\t   *  (forks/delegates are headless sub-runs with no session identity to name),\n87\t   *  so it is gated exactly like `ask`. */\n88\t  setSessionMeta: boolean;\n89\t  /** Host write access: writeFileRaw + mutating shell commands (host-tools profile). */\n90\t  allowWrite: boolean;\n91\t  /** `createScratch()` + a sandboxed generic fs/shell surface (the engineer's code\n92\t   *  sandbox). Derived from the `fs:scratch` app grant. When true, `createChildVM`\n93\t   *  injects the scratch primitives and overrides `execShell` with the scratch-rooted\n94\t   *  one, and `buildAmbientDts` emits `SCRATCH_DTS` + `EXEC_SHELL_DTS`. When false —\n95\t   *  every non-engineer agent — the generic fs surface is neither injected as a\n96\t   *  callable model global nor declared, so a stray call fails typecheck. */\n97\t  scratchFs: boolean;\n98\t  /** Project-app capability grants (`capabilities:` frontmatter → parsed `AppCapabilities`).\n99\t   *  Drives BOTH which app globals `createChildVM` injects (`db.*`/`apiCall`/`writePage`/…)\n100\t   *  AND which capability fragments `buildAmbientDts` emits — kept in lockstep exactly like\n101\t   *  the boolean flags above. Empty (`{}`) for any agent that declares no `capabilities:`\n102\t   *  (the default), so a session/fork/delegate with no app grants injects no app globals and\n103\t   *  declares none in its DTS. Read-only fork roles receive the `allowWrite`-intersected set. */\n104\t  app: AppCapabilities;\n105\t}\n106\t\n107\t/** Top-level session VM: the full toolkit, including the interactive `ask()`.\n108\t *  `canDelegate` comes from the session agent's `canDelegateTo` policy\n109\t *  (`evaluateDelegatePolicy(...).mode !== 'none'`); defaults to true. */\n110\texport function sessionCapabilities(canDelegate = true, app: AppCapabilities = {}): CapabilityProfile {\n111\t  return { kind: 'session', ask: true, orchestrate: true, delegate: canDelegate, registerSpace: true, setSessionMeta: true, allowWrite: true, scratchFs: !!app['fs:scratch'], app };\n112\t}\n113\t\n114\t/**\n115\t * Fork leaf VM. Headless (no ask), non-orchestrating (no fork/tasklist);\n116\t * `delegate` only when the task's `canDelegateTo` gate is satisfied by the\n117\t * caller; write capability (and registerSpace, which mutates session state)\n118\t * follows the role's host-tools profile — explore/plan are read-only.\n119\t */\n120\texport function forkCapabilities(role: string | undefined, canDelegate: boolean, app: AppCapabilities = {}): CapabilityProfile {\n121\t  const allowWrite = roleProfile(role).allowWrite !== false;\n122\t  const forkApp = intersectAppCaps(app, allowWrite);\n123\t  return { kind: 'fork', ask: false, orchestrate: false, delegate: canDelegate, registerSpace: allowWrite, setSessionMeta: false, allowWrite, scratchFs: !!forkApp['fs:scratch'], app: forkApp };\n124\t}\n125\t\n126\t/**\n127\t * Delegate VM. A programmatic sub-agent: autonomous (no ask), but a full\n128\t * orchestrator over its own actions/tasklists (fork/tasklist). `delegate`\n129\t * follows the DELEGATED AGENT's own `canDelegateTo` policy (defaults to true).\n130\t * registerSpace is not injected (matching the pre-unification wiring — spaces\n131\t * are registered by the session or by write-capable forks).\n132\t */\n133\texport function delegateCapabilities(canDelegate = true, app: AppCapabilities = {}): CapabilityProfile {\n134\t  return { kind: 'delegate', ask: false, orchestrate: true, delegate: canDelegate, registerSpace: false, setSessionMeta: false, allowWrite: true, scratchFs: !!app['fs:scratch'], app };\n135\t}\n136\t"}]},"parent_tool_use_id":null,"session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"228f9f4f-e18b-4f12-be57-09df37cf7ca8","timestamp":"2026-07-16T19:27:09.738Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/exec/capability.ts","content":"import { roleProfile } from '../fork/roles.js';\nimport type { AppCapabilities } from '../spaces/capabilities.js';\n\n/**\n * Read-only fork roles (`explore`/`plan`) can never receive a write/authoring\n * capability — the app grants are intersected with `allowWrite`, exactly as the\n * host-tools write gate withholds `writeFileRaw`. Only the read/outbound grants\n * (`db:read`, `api:call`, `connections:use`, `store:read`) survive; every\n * mutating/authoring grant (`db:write`/`db:schema`/`pages:write`/`api:write`/\n * `hooks:write`/`knowledge:write`/`store:install`/`events:emit`) is dropped. NOTE: `connections:use`\n * can have a side-effect (POST to an external service), but is treated as\n * outbound like `api:call` — the caller's own read-only intent governs, not the\n * transport. Drop it here if read-only forks must 