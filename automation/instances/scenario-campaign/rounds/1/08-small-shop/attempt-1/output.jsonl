{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_5UgtR1Ha2ZJpAOkWHaGNZY8U","type":"tool_result","content":"1\t/**\n2\t * lmthing.cloud gateway client — everything a scenario needs to stand up a disposable prod\n3\t * test user: register, provision the compute pod, load API keys into pod env, wake it.\n4\t *\n5\t * Budget note: scenarios burn real tokens. We deliberately load the **direct Azure** keys from\n6\t * `sdk/org/.env` into the pod env (AZURE_API_KEY + AZURE_RESOURCE_NAME + the LM_MODEL_* aliases),\n7\t * so agent traffic goes straight to Azure AI Foundry and never touches the per-user LiteLLM key\n8\t * that carries the tier budget. A user therefore does not \"run out\" mid-scenario. `budget()` is\n9\t * still exposed so a scenario can assert on spend, and `provisionUser()` is cheap enough to call\n10\t * again if a pod ever does get budget-capped.\n11\t */\n12\timport { readFileSync } from 'node:fs';\n13\timport { SDK_ORG } from './paths.mjs';\n14\timport { mintSession } from './jwt.mjs';\n15\timport { fetchResilient } from './pod.mjs';\n16\timport { LOCAL, LOCAL_BASE, ensureLocalServer } from './local.mjs';\n17\t\n18\texport const GATEWAY = process.env.LM_GATEWAY ?? 'https://lmthing.cloud';\n19\t\n20\tclass HttpError extends Error {\n21\t  constructor(method, url, status, body) {\n22\t    super(`${method} ${url} → ${status}: ${typeof body === 'string' ? body : JSON.stringify(body)}`);\n23\t    this.status = status;\n24\t    this.body = body;\n25\t  }\n26\t}\n27\t\n28\tasync function req(method, path, { token, body, base = GATEWAY } = {}) {\n29\t  const res = await fetchResilient(`${base}${path}`, {\n30\t    method,\n31\t    headers: {\n32\t      ...(body ? { 'content-type': 'application/json' } : {}),\n33\t      ...(token ? { authorization: `Bearer ${token}` } : {}),\n34\t    },\n35\t    ...(body ? { body: JSON.stringify(body) } : {}),\n36\t  });\n37\t  const text = await res.text();\n38\t  let parsed = text;\n39\t  try {\n40\t    parsed = JSON.parse(text);\n41\t  } catch {\n42\t    /* keep raw text */\n43\t  }\n44\t  if (!res.ok) throw new HttpError(method, path, res.status, parsed);\n45\t  return parsed;\n46\t}\n47\t\n48\t/** Parse `sdk/org/.env` into a plain object (no dotenv dep; ignores comments + blanks). */\n49\texport function readSdkEnv() {\n50\t  const raw = readFileSync(`${SDK_ORG}/.env`, 'utf8');\n51\t  const out = {};\n52\t  for (const line of raw.split('\\n')) {\n53\t    const m = /^\\s*([A-Z0-9_]+)\\s*=\\s*(.*)\\s*$/.exec(line);\n54\t    if (!m) continue; // comment or blank\n55\t    out[m[1]] = m[2].replace(/^[\"']|[\"']$/g, '');\n56\t  }\n57\t  return out;\n58\t}\n59\t\n60\t/**\n61\t * The env vars a pod needs to run agents against Azure directly (budget-free), plus web search.\n62\t * Anything absent from sdk/org/.env is simply omitted.\n63\t */\n64\texport function agentEnvFromSdk() {\n65\t  const env = readSdkEnv();\n66\t  const keys = [\n67\t    'AZURE_API_KEY',\n68\t    'AZURE_RESOURCE_NAME',\n69\t    'TAVILY_API_KEY',\n70\t    'LM_MODEL_XS',\n71\t    'LM_MODEL_S',\n72\t    'LM_MODEL_M',\n73\t    'LM_MODEL_L',\n74\t    'LM_MODEL_M_R',\n75\t    'LM_MODEL_L_R',\n76\t    'LM_MODEL_VISION',\n77\t    'LM_TRANSCRIBE_MODEL',\n78\t  ];\n79\t  const out = {};\n80\t  for (const k of keys) if (env[k]) out[k] = env[k];\n81\t  return out;\n82\t}\n83\t\n84\t/** `POST /api/auth/register` → { user_id, api_key }. Login is broken in prod; we mint instead. */\n85\texport async function register(email, password) {\n86\t  return req('POST', '/api/auth/register', { body: { email, password } });\n87\t}\n88\t\n89\texport const ensurePod = (token) => req('POST', '/api/compute/ensure', { token });\n90\texport const podStatus = (token) => req('GET', '/api/compute/status', { token });\n91\texport const wakePod = (token) => req('POST', '/api/compute/wake', { token });\n92\t\n93\t/**\n94\t * Remaining LiteLLM budget. NOTE this lives on the POD (`routes/budget.ts` relays the caller's\n95\t * Authorization to the gateway and computes the line with the master key) — there is no\n96\t * `/api/budget` on the gateway itself. Scenarios run on direct Azure keys, so this is\n97\t * informational: it tells you whether the tier key is exhausted, not whether the run can proceed.\n98\t */\n99\texport const budget = (token) => req('GET', '/api/budget', { token, base: podBase() });\n100\t\n101\t/**\n102\t * `PUT /api/compute/env` REPLACES the whole var set, so always GET-merge-PUT — clobbering the\n103\t * gateway-injected lmthingcloud creds would break the pod.\n104\t *\n105\t * A PUT rolls the deployment, and pod sessions are IN-MEMORY: any session created against the\n106\t * old pod dies with it (`GET /api/sessions/:id/events` → 404 unknown session). So we skip the\n107\t * write entirely when nothing would change — which is the common case on a reused test user.\n108\t *\n109\t * @returns {{merged: object, changed: boolean}}\n110\t */\n111\texport async function mergePodEnv(token, vars) {\n112\t  const current = await req('GET', '/api/compute/env', { token }).catch(() => ({ vars: {} }));\n113\t  const existing = current.vars ?? {};\n114\t  const merged = { ...existing, ...vars };\n115\t  const changed = Object.entries(merged).some(([k, v]) => existing[k] !== v);\n116\t  if (!changed) return { merged, changed: false };\n117\t  await req('PUT', '/api/compute/env', { token, body: { vars: merged } });\n118\t  return { merged, changed: true };\n119\t}\n120\t\n121\t/**\n122\t * Wait until a session created NOW would survive — i.e. the env-triggered rollout is finished.\n123\t *\n124\t * There is no reliable \"which pod process am I talking to\" signal from outside, and the gateway's\n125\t * `pod.ready` (readyReplicas > 0) stays true across a rolling update because the OLD replica is\n126\t * still ready. So we test the property we actually need, directly: create a probe session, wait,\n127\t * and confirm it still exists. If the pod rolled under us, the probe vanishes and we retry.\n128\t */\n129\texport async function waitPodSettled(token, base = podBase(), { attempts = 6, settleMs = 9_000 } = {}) {\n130\t  const headers = { authorization: `Bearer ${token}`, 'content-type': 'application/json' };\n131\t  for (let i = 0; i < attempts; i++) {\n132\t    try {\n133\t      const res = await fetch(`${base}/api/sessions`, {\n134\t        method: 'POST',\n135\t        headers,\n136\t        body: JSON.stringify({ projectId: 'user' }),\n137\t      });\n138\t      if (res.ok) {\n139\t        const { sessionId } = await res.json();\n140\t        await new Promise((r) => setTimeout(r, settleMs));\n141\t        const list = await fetch(`${base}/api/sessions`, { headers }).then((r) => r.json());\n142\t        const alive = (list.sessions ?? []).some((s) => s.sessionId === sessionId);\n143\t        if (alive) {\n144\t          // Clean up the probe so it doesn't pollute the scenario's session list.\n145\t          await fetch(`${base}/api/sessions/${sessionId}`, { method: 'DELETE', headers }).catch(() => {});\n146\t          return true;\n147\t        }\n148\t      }\n149\t    } catch {\n150\t      /* pod mid-roll — retry */\n151\t    }\n152\t    await new Promise((r) => setTimeout(r, 5_000));\n153\t  }\n154\t  throw new Error('pod never settled: a freshly created session keeps disappearing');\n155\t}\n156\t\n157\t/**\n158\t * Poll until the gateway reports the pod ready (or throw).\n159\t *\n160\t * Readiness lives at `status.pod.ready` / `status.pod.stage === 'ready'` — NOT at the top level.\n161\t * Note \"ready\" here means readyReplicas>0, which precedes Envoy actually wiring the woken\n162\t * endpoint (see the pod-readiness-edge race); callers that immediately hit the pod should\n163\t * tolerate one early 503, which `Pod.req` surfaces as a normal HttpError.\n164\t */\n165\texport async function waitPodReady(token, { timeoutMs = 180_000, intervalMs = 3_000 } = {}) {\n166\t  const deadline = Date.now() + timeoutMs;\n167\t  let last;\n168\t  while (Date.now() < deadline) {\n169\t    try {\n170\t      last = await podStatus(token);\n171\t      if (last?.pod?.ready || last?.pod?.stage === 'ready') return last;\n172\t    } catch (err) {\n173\t      last = { error: String(err) };\n174\t    }\n175\t    await new Promise((r) => setTimeout(r, intervalMs));\n176\t  }\n177\t  throw new Error(`pod not ready after ${timeoutMs}ms: ${JSON.stringify(last)}`);\n178\t}\n179\t\n180\t/**\n181\t * Full disposable-test-user provision: register → mint session → ensure pod → load agent keys →\n182\t * wait ready. Returns everything a scenario needs, including a `pod` base URL.\n183\t *\n184\t * Pods are reached through the chat origin: Envoy validates the JWT and routes on the `sub` claim\n185\t * to `lmthing.user-<id>.svc`, waking a scaled-to-zero pod on the way.\n186\t */\n187\texport async function provisionUser({ label = 'scn', password = 'Test-Passw0rd!' } = {}) {\n188\t  // Local target: no register, no JWT, no pod env PUT. Bring up (or attach to) the one shared\n189\t  // `lmthing serve`, which reads sdk/org/.env for the Azure keys itself. The pod does no auth, so\n190\t  // token is null; lanes are isolated by projectId, not by user, on this single server.\n191\t  if (LOCAL) {\n192\t    await ensureLocalServer();\n193\t    return { email: `${label}@local`, password, userId: `local-${label}`, session: null, token: null, pod: LOCAL_BASE };\n194\t  }\n195\t  const email = `${label}-${Date.now().toString(36)}@lmthing.test`;\n196\t  const { user_id: userId } = await register(email, password);\n197\t  const session = mintSession(userId, email);\n198\t  await ensurePod(session.accessToken);\n199\t  // Pod env must be loaded BEFORE the first agent turn: the PUT rolls the pod, and a restart\n200\t  // mid-scenario destroys in-memory sessions (it would look like a spurious failure).\n201\t  const { changed } = await mergePodEnv(session.accessToken, agentEnvFromSdk());\n202\t  await waitPodReady(session.accessToken);\n203\t  if (changed) await waitPodSettled(session.accessToken);\n204\t  return { email, password, userId, session, token: session.accessToken, pod: podBase() };\n205\t}\n206\t\n207\t/** The origin that fronts a user's pod (Envoy routes by JWT `sub`; local → the shared serve). */\n208\texport const podBase = () => process.env.LM_POD_BASE ?? (LOCAL ? LOCAL_BASE : 'https://lmthing.chat');\n209\t"}]},"parent_tool_use_id":null,"session_id":"e527c9e4-a091-4065-bd58-17ce2dd60e21","uuid":"c015cc60-2c56-428b-a166-59150b86efa8","timestamp":"2026-07-14T16:41:57.163Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/gateway.mjs","content":"/**\n * lmthing.cloud gateway client — everything a scenario needs to stand up a disposable prod\n * test user: register, provision the compute pod, load API keys into pod env, wake it.\n *\n * Budget note: scenarios burn real tokens. We deliberately load the **direct Azure** keys from\n * `sdk/org/.env` into the pod env (AZURE_API_KEY + AZURE_RESOURCE_NAME + the LM_MODEL_* aliases),\n * so agent traffic goes straight to Azure AI Foundry and never touches the per-user LiteLLM key\n * that carries the tier budget. A user therefore does not \"run out\" mid-scenario. `budget()` is\n * still exposed so a scenario can assert on spend, and `provisionUser()` is cheap enough to call\n * again if a pod ever does get budget-capped.\n */\nimport { readFileSync } from 'node:fs';\nimport { SDK_ORG } from './paths.mjs';\nimport { mintSession } from './jwt.mjs';\nimport { fetchResilient } from './pod.mjs';\nimport { LOCAL, LOCAL_BASE, ensureLocalServer } from './local.mjs';\n\nexport const GATEWAY = process.env.LM_GATEWAY ?? 'https://lmthing.cloud';\n\nclass HttpError extends Error {\n  constructor(method, url, status, body) {\n    super(`${method} ${url} → ${status}: ${typeof body === 'string' ? body : JSON.stringify(body)}`);\n    this.status = status;\n    this.body = body;\n  }\n}\n\nasync function req(method, path, { token, body, base = GATEWAY } = {}) {\n  const res = await fetchResilient(`${base}${path}`, {\n    method,\n    headers: {\n      ...(body ? { 'content-type': 'application/json' } : {}),\n      ...(token ? { authorization: `Bearer ${token}` } : {}),\n    },\n    ...(body ? { body: JSON.stringify(body) } : {}),\n  });\n  const text = await res.text();\n  let parsed = text;\n  try {\n    parsed = JSON.parse(text);\n  } catch {\n    /* keep raw text */\n  }\n  if (!res.ok) throw new HttpError(method, path, res.status, parsed);\n  return parsed;\n}\n\n/** Parse `sdk/org/.env` into a plain object (no dotenv dep; ignores comments + blanks). */\nexport function readSdkEnv() {\n  const raw = readFileSync(`${SDK_ORG}/.env`, 'utf8');\n  const out = {};\n  for (const line of raw.split('\\n')) {\n    const m = /^\\s*([A-Z0-9_]+)\\s*=\\s*(.*)\\s*$/.exec(line);\n    if (!m) continue; // comment or blank\n    out[m[1]] = m[2].replace(/^[\"']|[\"']$/g, '');\n  }\n  return out;\n}\n\n/**\n * The env vars a pod needs to run agents against Azure directly (budget-free), plus web search.\n * Anything absent from sdk/org/.env is simply omitted.\n */\nexport function agentEnvFromSdk() {\n  const env = readSdkEnv();\n  const keys = [\n    'AZURE_API_KEY',\n    'AZURE_RESOURCE_NAME',\n    'TAVILY_API_KEY',\n    'LM_MODEL_XS',\n    'LM_MODEL_S',\n    'LM_MODEL_M',\n    'LM_MODEL_L',\n    'LM_MODEL_M_R',\n    'LM_MODEL_L_R',\n    'LM_MODEL_VISION',\n    'LM_TRANSCRIBE_MODEL',\n  ];\n  const out = {};\n  for (const k of keys) if (env[k]) out[k] = env[k];\n  return out;\n}\n\n/** `POST /api/auth/register` → { user_id, api_key }. Login is broken in prod; we mint instead. */\nexport async function register(email, password) {\n  return req('POST', '/api/auth/register', { body: { email, password } });\n}\n\nexport const ensurePod = (token) => req('POST', '/api/compute/ensure', { token });\nexport const podStatus = (token) => req('GET', '/api/compute/status', { token });\nexport const wakePod = (token) => req('POST', '/api/compute/wake', { token });\n\n/**\n * Remaining LiteLLM budget. NOTE this lives on the POD (`routes/budget.ts` relays the caller's\n * Authorization to the gateway and computes the line with the master key) — there is no\n * `/api/budget` on the gateway itself. Scenarios run on direct Azure keys, so this is\n * informational: it tells you whether the tier key is exhausted, not whether the run can proceed.\n */\nexport const budget = (token) => req('GET', '/api/budget', { token, base: podBase() });\n\n/**\n * `PUT /api/compute/env` REPLACES the whole var set, so always GET-merge-PUT — clobbering the\n * gateway-injected lmthingcloud creds would break the pod.\n *\n * A PUT rolls the deployment, and pod sessions are IN-MEMORY: any session created against the\n * old pod dies with it (`GET /api/sessions/:id/events` → 404 unknown session). So we skip the\n * write entirely when nothing would change — which is the common case on a reused test user.\n *\n * @returns {{merged: object, changed: boolean}}\n */\nexport async function mergePodEnv(token, vars) {\n  const current = await req('GET', '/api/compute/env', { token }).catch(() => ({ vars: {} }));\n  const existing = current.vars ?? {};\n  const merged = { ...existing, ...vars };\n  const changed = Object.entries(merged).some(([k, v]) => existing[k] !== v);\n  if (!changed) return { merged, changed: false };\n  await req('PUT', '/api/compute/env', { token, body: { vars: merged } });\n  return { merged, changed: true };\n}\n\n/**\n * Wait until a session created NOW would survive — i.e. the env-triggered rollout is finished.\n *\n * There is no reliable \"which pod process am I talking to\" signal from outside, and the gateway's\n * `pod.ready` (readyReplicas > 0) stays true across a rolling update because the OLD replica is\n * still ready. So we test the property we actually need, directly: create a probe session, wait,\n * and confirm it still exists. If the pod rolled under us, the probe vanishes and we retry.\n */\nexport async function waitPodSettled(token, base = podBase(), { attempts = 6, settleMs = 9_000 } = {}) {\n  const headers = { authorization: `Bearer ${token}`, 'content-type': 'application/json' };\n  for (let i = 0; i < attempts; i++) {\n    try {\n      const res = await fetch(`${base}/api/sessions`, {\n        method: 'POST',\n        headers,\n        body: JSON.stringify({ projectId: 'user' }),\n      });\n      if (res.ok) {\n        const { sessionId } = await res.json();\n        await new Promise((r) => setTimeout(r, settleMs));\n        const list = await fetch(`${base}/api/sessions`, { headers }).then((r) => r.json());\n        const alive = (list.sessions ?? []).some((s) => s.sessionId === sessionId);\n        if (alive) {\n          // Clean up the probe so it doesn't pollute the scenario's session list.\n          await fetch(`${base}/api/sessions/${sessionId}`, { method: 'DELETE', headers }).catch(() => {});\n          return true;\n        }\n      }\n    } catch {\n      /* pod mid-roll — retry */\n    }\n    await new Promise((r) => setTimeout(r, 5_000));\n  }\n  throw new Error('pod never settled: a freshly created session keeps disappearing');\n}\n\n/**\n * Poll until the gateway reports the pod ready (or throw).\n *\n * Readiness lives at `status.pod.ready` / `status.pod.stage === 'ready'` — NOT at the top level.\n * Note \"ready\" here means readyReplicas>0, which precedes Envoy actually wiring the woken\n * endpoint (see the pod-readiness-edge race); callers that immediately hit the pod should\n * tolerate one early 503, which `Pod.req` surfaces as a normal HttpError.\n */\nexport async function waitPodReady(token, { timeoutMs = 180_000, intervalMs = 3_000 } = {}) {\n  const deadline = Date.now() + timeoutMs;\n  let last;\n  while (Date.now() < deadline) {\n    try {\n      last = await podStatus(token);\n      if (last?.pod?.ready || last?.pod?.stage === 'ready') return last;\n    } catch (err) {\n      last = { error: String(err) };\n    }\n    await new Promise((r) => setTimeout(r, intervalMs));\n  }\n  throw new Error(`pod not ready after ${timeoutMs}ms: ${JSON.stringify(last)}`);\n}\n\n/**\n * Full disposable-test-user provision: register → mint session → ensure pod → load agent keys →\n * wait ready. Returns everything a scenario needs, including a `pod` base URL.\n *\n * Pods are reached through the chat origin: Envoy validates the JWT and routes on the `sub` claim\n * to `lmthing.user-<id>.svc`, waking a scaled-to-zero pod on the way.\n */\nexport async function provisionUser({ label = 'scn', password = 'Test-Passw0rd!' } = {}) {\n  // Local target: no register, no JWT, no pod env PUT. Bring up (or attach to) the one shared\n  // `lmthing serve`, which reads sdk/org/.env for the Azure keys itself. The pod does no auth, so\n  // token is null; lanes are isolated by projectId, not by user, on this single server.\n  if (LOCAL) {\n    await ensureLocalServer();\n    return { email: `${label}@local`, password, userId: `local-${label}`, session: null, token: null, pod: LOCAL_BASE };\n  }\n  const email = `${label}-${Date.now().toString(36)}@lmthing.test`;\n  const { user_id: userId } = await register(email, password);\n  const session = mintSession(userId, email);\n  await ensurePod(session.accessToken);\n  // Pod env must be loaded BEFORE the first agent turn: the PUT rolls the pod, and a restart\n  // mid-scenario destroys in-memory sessions (it would look like a spurious failure).\n  const { changed } = await mergePodEnv(session.accessToken, agentEnvFromSdk());\n  await waitPodReady(session.accessToken);\n  if (changed) await waitPodSettled(session.accessToken);\n  return { email, password, userId, session, token: session.accessToken, pod: podBase() };\n}\n\n/** The origin that fronts a user's pod (Envoy routes by JWT `sub`; local → the shared serve). */\nexport const podBase = () => process.env.LM_POD_BASE ?? (LOCAL ? LOCAL_BASE : 'https://lmthing.chat');\n","numLines":209,"startLine":1,"totalLines":209}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_TS00wwnyif2iQA2OOVGJmC6i","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Harness smoke test — proves the whole chain works before any scenario burns an hour on it:\n4\t * register → pod → env → THING session → a real LLM turn → trace assertions.\n5\t *\n6\t *   node smoke.mjs [label]\n7\t *\n8\t * If this fails, no scenario can pass; fix the harness first.\n9\t */\n10\timport { Pod } from './lib/pod.mjs';\n11\timport { ThingSession, approveAllConsent } from './lib/thing.mjs';\n12\timport { Report } from './lib/report.mjs';\n13\timport { getUser } from './provision.mjs';\n14\timport { budget } from './lib/gateway.mjs';\n15\t\n16\tconst label = process.argv[2] ?? 'smoke';\n17\tconst r = new Report('smoke', 'Harness smoke test');\n18\t\n19\tr.step('provision', 'a fresh prod user with a ready pod and Azure keys loaded');\n20\tconst user = await getUser(label);\n21\tr.check('user registered', !!user.userId, user.userId);\n22\tr.check('pod reachable', !!user.pod, user.pod);\n23\t\n24\tconst pod = new Pod({ base: user.pod, token: user.token });\n25\t\n26\tr.step('pod API', 'projects + store catalog answer over the Envoy-routed origin');\n27\tconst projects = await pod.listProjects();\n28\tr.check('GET /api/projects', Array.isArray(projects.projects ?? projects), JSON.stringify(projects).slice(0, 200));\n29\tconst store = await pod.storeSpaces();\n30\tconst spaces = store.spaces ?? [];\n31\tr.check('store catalog non-empty', spaces.length > 0, `${spaces.length} spaces`);\n32\tr.note(`catalog: ${spaces.map((s) => s.id).join(', ')}`);\n33\t\n34\tr.step('THING turn', 'a real LLM turn completes and the trace shows llm calls + a display');\n35\tconst thing = new ThingSession(pod, { verbose: true, onAsk: approveAllConsent });\n36\tawait thing.start();\n37\tconst turn = await thing.send('In one sentence: what can you help me build?', { timeoutMs: 240_000 });\n38\tr.check('turn completed', true, `${(turn.durationMs / 1000).toFixed(1)}s`);\n39\tr.check('LLM was called', turn.llmCalls > 0, `${turn.llmCalls} calls`);\n40\tr.check('THING replied', turn.text.length > 0, turn.text.slice(0, 200));\n41\tr.check('no eval errors', turn.errors.length === 0, JSON.stringify(turn.errors).slice(0, 300));\n42\tr.metric('first turn', (turn.durationMs / 1000).toFixed(1), 's');\n43\tr.metric('tokens', `${turn.tokens.in} in / ${turn.tokens.out} out`);\n44\t\n45\tconst b = await budget(user.token).catch((e) => ({ error: String(e) }));\n46\tr.note(`budget: ${JSON.stringify(b)}`);\n47\t\n48\tr.save(`${new URL('.', import.meta.url).pathname}.state/smoke-report.md`);\n49\tprocess.exit(r.passed ? 0 : 1);\n50\t"}]},"parent_tool_use_id":null,"session_id":"e527c9e4-a091-4065-bd58-17ce2dd60e21","uuid":"31d021eb-4f5b-4da2-af3d-0985e36f2bb3","timestamp":"2026-07-14T16:41:57.164Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/smoke.mjs","content":"#!/usr/bin/env node\n/**\n * Harness smoke test — proves the whole chain works before any scenario burns an hour on it:\n * register → pod → env → THING session → a real LLM turn → trace assertions.\n *\n *   node smoke.mjs [label]\n *\n * If this fails, no scenario can pass; fix the harness first.\n */\nimport { Pod } from './lib/pod.mjs';\nimport { ThingSession, approveAllConsent } from './lib/thing.mjs';\nimport { Report } from './lib/report.mjs';\nimport { getUser } from './provision.mjs';\nimport { budget } from './lib/gateway.mjs';\n\nconst label = process.argv[2] ?? 'smoke';\nconst r = new Report('smoke', 'Harness smoke test');\n\nr.step('provision', 'a fresh prod user with a ready pod and Azure keys loaded');\nconst user = await getUser(label);\nr.check('user registered', !!user.userId, user.userId);\nr.check('pod reachable', !!user.pod, user.pod);\n\nconst pod = new Pod({ base: user.pod, token: user.token });\n\nr.step('pod API', 'projects + store catalog answer over the Envoy-routed origin');\nconst projects = await pod.listProjects();\nr.check('GET /api/projects', Array.isArray(projects.projects ?? projects), JSON.stringify(projects).slice(0, 200));\nconst store = await pod.storeSpaces();\nconst spaces = store.spaces ?? [];\nr.check('store catalog non-empty', spaces.length > 0, `${spaces.length} spaces`);\nr.note(`catalog: ${spaces.map((s) => s.id).join(', ')}`);\n\nr.step('THING turn', 'a real LLM turn completes and the trace shows llm calls + a display');\nconst thing = new ThingSession(pod, { verbose: true, onAsk: approveAllConsent });\nawait thing.start();\nconst turn = await thing.send('In one sentence: what can you help me build?', { timeoutMs: 240_000 });\nr.check('turn completed', true, `${(turn.durationMs / 1000).toFixed(1)}s`);\nr.check('LLM was called', turn.llmCalls > 0, `${turn.llmCalls} calls`);\nr.check('THING replied', turn.text.length > 0, turn.text.slice(0, 200));\nr.check('no eval errors', turn.errors.length === 0, JSON.stringify(turn.errors).slice(0, 300));\nr.metric('first turn', (turn.durationMs / 1000).toFixed(1), 's');\nr.metric('tokens', `${turn.tokens.in} in / ${turn.tokens.out} out`);\n\nconst b = await budget(user.token).catch((e) => ({ error: String(e) }));\nr.note(`budget: ${JSON.stringify(b)}`);\n\nr.save(`${new URL('.', import.meta.url).pathname}.state/smoke-report.md`);\nprocess.exit(r.passed ? 0 : 1);\n","numLines":50,"startLine":1,"totalLines":50}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_t1MMleI1P1ee4Mzkq4x3CWN9","type":"tool_result","content":"1\t/**\n2\t * Gateway JWT minting.\n3\t *\n4\t * Production `POST /api/auth/login` is broken (Zitadel password grant is disabled — see\n5\t * .issues/zitadel-password-login-disabled.md), so a test harness cannot obtain a session the\n6\t * normal way. Instead we mint the same HS256 token the gateway itself issues, using the\n7\t * `GATEWAY_JWT_SECRET` from the `lmthing-secrets` k8s secret. Token shape must match\n8\t * cloud/gateway/src/lib/tokens.ts, because Envoy validates it at the edge and routes on `sub`.\n9\t *\n10\t * The secret is read from `.etc/.gateway-jwt-secret.b64` (gitignored). Mind the DOUBLE base64:\n11\t * k8s `.data.<key>` is base64 of the env *value*, and that value is itself base64 of the signing\n12\t * key (the gateway does `Buffer.from(process.env.GATEWAY_JWT_SECRET, 'base64')`). So the file must\n13\t * hold the env value — i.e. pipe the k8s blob through `base64 -d` ONCE when fetching, and let this\n14\t * module do the second decode:\n15\t *\n16\t *   ssh …@4.223.83.5 'kubectl get secret lmthing-secrets -n lmthing \\\n17\t *     -o jsonpath=\"{.data.GATEWAY_JWT_SECRET}\" | base64 -d' > .etc/.gateway-jwt-secret.b64\n18\t *\n19\t * (A file that is 44 chars long is right; 60 means you skipped the `base64 -d` and every token\n20\t * will 401.)\n21\t */\n22\timport { createHmac } from 'node:crypto';\n23\timport { readFileSync } from 'node:fs';\n24\timport { REPO_ROOT } from './paths.mjs';\n25\t\n26\tconst SECRET_FILE = `${REPO_ROOT}/.etc/.gateway-jwt-secret.b64`;\n27\t\n28\tlet cachedSecret = null;\n29\t\n30\t/** Raw HMAC key (the base64 blob in k8s decodes to the signing key the gateway uses). */\n31\tfunction secret() {\n32\t  if (cachedSecret) return cachedSecret;\n33\t  let b64;\n34\t  try {\n35\t    b64 = readFileSync(SECRET_FILE, 'utf8').trim();\n36\t  } catch {\n37\t    throw new Error(\n38\t      `missing ${SECRET_FILE} — fetch it from the cluster:\\n` +\n39\t        `  ssh -i ~/GEANT/lmthing/devops/terraform/generated/lmthing-test-key.pem azureuser@4.223.83.5 \\\\\\n` +\n40\t        `    'kubectl get secret lmthing-secrets -n lmthing -o jsonpath=\"{.data.GATEWAY_JWT_SECRET}\"' \\\\\\n` +\n41\t        `    > ${SECRET_FILE}`,\n42\t    );\n43\t  }\n44\t  cachedSecret = Buffer.from(b64, 'base64');\n45\t  return cachedSecret;\n46\t}\n47\t\n48\tconst b64url = (obj) =>\n49\t  Buffer.from(JSON.stringify(obj)).toString('base64url').replace(/=+$/, '');\n50\t\n51\tfunction sign(payload) {\n52\t  const head = `${b64url({ alg: 'HS256', typ: 'JWT' })}.${b64url(payload)}`;\n53\t  const sig = createHmac('sha256', secret()).update(head).digest('base64url').replace(/=+$/, '');\n54\t  return `${head}.${sig}`;\n55\t}\n56\t\n57\t/**\n58\t * Mint an access+refresh pair for a user id. `ttlSec` defaults to 12h — long enough for a full\n59\t * scenario run, short enough to be harmless if it leaks into a log.\n60\t */\n61\texport function mintSession(userId, email, ttlSec = 43_200) {\n62\t  const now = Math.floor(Date.now() / 1000);\n63\t  return {\n64\t    accessToken: sign({ email, sub: userId, iat: now, exp: now + ttlSec }),\n65\t    refreshToken: sign({ type: 'refresh', sub: userId, iat: now, exp: now + 2_592_000 }),\n66\t    expiresAt: (now + ttlSec) * 1000,\n67\t    userId,\n68\t    email,\n69\t    githubRepo: null,\n70\t    githubUsername: null,\n71\t  };\n72\t}\n73\t"}]},"parent_tool_use_id":null,"session_id":"e527c9e4-a091-4065-bd58-17ce2dd60e21","uuid":"1cd04562-44dc-4c54-bda8-334c5f67e8e3","timestamp":"2026-07-14T16:41:57.165Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/jwt.mjs","content":"/**\n * Gateway JWT minting.\n *\n * Production `POST /api/auth/login` is broken (Zitadel password grant is disabled — see\n * .issues/zitadel-password-login-disabled.md), so a test harness cannot obtain a session the\n * normal way. Instead we mint the same HS256 token the gateway itself issues, using the\n * `GATEWAY_JWT_SECRET` from the `lmthing-secrets` k8s secret. Token shape must match\n * cloud/gateway/src/lib/tokens.ts, because Envoy validates it at the edge and routes on `sub`.\n *\n * The secret is read from `.etc/.gateway-jwt-secret.b64` (gitignored). Mind the DOUBLE base64:\n * k8s `.data.<key>` is base64 of the env *value*, and that value is itself base64 of the signing\n * key (the gateway does `Buffer.from(process.env.GATEWAY_JWT_SECRET, 'base64')`). So the file must\n * hold the env value — i.e. pipe the k8s blob through `base64 -d` ONCE when fetching, and let this\n * module do the second decode:\n *\n *   ssh …@4.223.83.5 'kubectl get secret lmthing-secrets -n lmthing \\\n *     -o jsonpath=\"{.data.GATEWAY_JWT_SECRET}\" | base64 -d' > .etc/.gateway-jwt-secret.b64\n *\n * (A file that is 44 chars long is right; 60 means you skipped the `base64 -d` and every token\n * will 401.)\n */\nimport { createHmac } from 'node:crypto';\nimport { readFileSync } from 'node:fs';\nimport { REPO_ROOT } from './paths.mjs';\n\nconst SECRET_FILE = `${REPO_ROOT}/.etc/.gateway-jwt-secret.b64`;\n\nlet cachedSecret = null;\n\n/** Raw HMAC key (the base64 blob in k8s decodes to the signing key the gateway uses). */\nfunction secret() {\n  if (cachedSecret) return cachedSecret;\n  let b64;\n  try {\n    b64 = readFileSync(SECRET_FILE, 'utf8').trim();\n  } catch {\n    throw new Error(\n      `missing ${SECRET_FILE} — fetch it from the cluster:\\n` +\n        `  ssh -i ~/GEANT/lmthing/devops/terraform/generated/lmthing-test-key.pem azureuser@4.223.83.5 \\\\\\n` +\n        `    'kubectl get secret lmthing-secrets -n lmthing -o jsonpath=\"{.data.GATEWAY_JWT_SECRET}\"' \\\\\\n` +\n        `    > ${SECRET_FILE}`,\n    );\n  }\n  cachedSecret = Buffer.from(b64, 'base64');\n  return cachedSecret;\n}\n\nconst b64url = (obj) =>\n  Buffer.from(JSON.stringify(obj)).toString('base64url').replace(/=+$/, '');\n\nfunction sign(payload) {\n  const head = `${b64url({ alg: 'HS256', typ: 'JWT' })}.${b64url(payload)}`;\n  const sig = createHmac('sha256', secret()).update(head).digest('base64url').replace(/=+$/, '');\n  return `${head}.${sig}`;\n}\n\n/**\n * Mint an access+refresh pair for a user id. `ttlSec` defaults to 12h — long enough for a full\n * scenario run, short enough to be harmless if it leaks into a log.\n */\nexport function mintSession(userId, email, ttlSec = 43_200) {\n  const now = Math.floor(Date.now() / 1000);\n  return {\n    accessToken: sign({ email, sub: userId, iat: now, exp: now + ttlSec }),\n    refreshToken: sign({ type: 'refresh', sub: userId, iat: now, exp: now + 2_592_000 }),\n    expiresAt: (now + ttlSec) * 1000,\n    userId,\n    email,\n    githubRepo: null,\n    githubUsername: null,\n  };\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
