ect(organize['build_app']!.instruction).toContain('exactly one self-contained statement');\n128\t    expect(resolveGoalTask(organize)!.id).toBe('build_app');\n129\t  });\n130\t\n131\t  it('user-memory migrate_to_app_db carries db:write on ONLY the migrate node', async () => {\n132\t    const space = await loadSpace(resolve(SYS, 'user-memory'), { requireAgents: false });\n133\t    // The agent declares db:write as the ceiling, exposed via the migrate action.\n134\t    expect(space.agents['memory']!.capabilities?.['db:write']).toBeDefined();\n135\t    expect(space.agents['memory']!.actions.some((a) => a.tasklist === 'migrate_to_app_db')).toBe(true);\n136\t\n137\t    const tasks = await loadTasklistFromSpace(space, 'migrate_to_app_db');\n138\t    expect(tasks['collect']!.capabilities).toEqual([]); // reads memory only — no db\n139\t    expect(tasks['migrate']!.capabilities).toContain('db:write');\n140\t    expect(tasks['forget']!.capabilities).toEqual([]); // tidies memory only — no db\n141\t    expect(resolveGoalTask(tasks)!.id).toBe('forget');\n142\t  });\n143\t\n144\t  it('architect synthesize_and_run uses forEach fan-out with valid roles', async () => {\n145\t    const space = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n146\t    const tasks = await loadTasklistFromSpace(space, 'synthesize_and_run');\n147\t    // build_field / build_function fan out over the design step's arrays.\n148\t    expect(tasks['build_field']!.forEach).toBe('design.fields');\n149\t    expect(tasks['build_function']!.forEach).toBe('design.functions');\n150\t    // Read-only steps are explore; file-writing steps are general.\n151\t    expect(tasks['design']!.role).toBe('explore');\n152\t    expect(tasks['build_field']!.role).toBe('general');\n153\t    expect(tasks['validate']!.role).toBe('explore');\n154\t    // Every role is one of the three profiles.\n155\t    for (const t of Object.values(tasks)) {\n156\t      if (t.role) expect(['explore', 'plan', 'general']).toContain(t.role);\n157\t    }\n158\t  });\n159\t\n160\t  it('appbuilder build_app fans out per-file with valid roles and a finalize goal', async () => {\n161\t    const space = await loadSpace(resolve(SYS, 'system-appbuilder'), { requireAgents: false });\n162\t    const tasks = await loadTasklistFromSpace(space, 'build_app');\n163\t    // design → create_project → per-file forEach builders → finalize (goal).\n164\t    expect(tasks['build_table']!.forEach).toBe('design.tables');\n165\t    expect(tasks['build_api']!.forEach).toBe('design.endpoints');\n166\t    expect(tasks['build_page']!.forEach).toBe('design.pages');\n167\t    expect(tasks['build_hook']!.forEach).toBe('design.hooks');\n168\t    // Every per-file step runs with write access (role general) under the architect's caps.\n169\t    for (const id of ['design', 'create_project', 'build_table', 'build_api', 'build_page', 'build_hook', 'finalize']) {\n170\t      expect(tasks[id]!.role).toBe('general');\n171\t    }\n172\t    // Optional builders don't sink the pipeline; the goal is finalize.\n173\t    expect(tasks['build_table']!.optional).toBe(true);\n174\t    expect(tasks['build_hook']!.optional).toBe(true);\n175\t    expect(resolveGoalTask(tasks)!.id).toBe('finalize');\n176\t    expect(space.tasklists['build_app']!.input).toEqual({ request: 'string' });\n177\t  });\n178\t\n179\t  it('architect tasklists declare input schemas matching what their callers pass', async () => {\n180\t    const space = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n181\t    // THING's build task / the architect instruct seed { topic, goal, research }.\n182\t    expect(space.tasklists['synthesize_and_run']!.input).toEqual({\n183\t      topic: 'string',\n184\t      goal: 'string',\n185\t      research: 'string',\n186\t    });\n187\t    // The architect instruct's Job 2 seeds { spaceKey, feedback }.\n188\t    expect(space.tasklists['iterate_space']!.input).toEqual({\n189\t      spaceKey: 'string',\n190\t      feedback: 'string',\n191\t    });\n192\t  });\n193\t\n194\t  it('research agent exposes shallow research + deep_research (forEach) actions', async () => {\n195\t    const space = await loadSpace(resolve(SYS, 'system-research'), { requireAgents: false });\n196\t    // deep_research: scope (broad search) -> plan -> investigate (forEach) -> synthesize -> summarize.\n197\t    const deep = await loadTasklistFromSpace(space, 'deep_research');\n198\t    expect(deep['scope']!.role).toBe('explore');\n199\t    expect(deep['scope']!.functions).toEqual(['webSearch']);\n200\t    expect(deep['investigate']!.forEach).toBe('plan.questions');\n201\t    expect(deep['investigate_a']).toBeUndefined();\n202\t    // synthesize clusters/dedupes but is no longer the goal — summarize writes the final report.\n203\t    expect(deep['synthesize']!.goal).toBeFalsy();\n204\t    expect(resolveGoalTask(deep)!.id).toBe('summarize');\n205\t    // research: a single shallow quick-answer task.\n206\t    const shallow = await loadTasklistFromSpace(space, 'research');\n207\t    expect(Object.keys(shallow)).toEqual(['answer']);\n208\t    expect(resolveGoalTask(shallow)!.id).toBe('answer');\n209\t  });\n210\t});\n211\t\n212\tdescribe('user-thing build_specialist (structural build pipeline)', () => {\n213\t  async function load(): Promise<{ space: Space; tasks: Record<string, TaskNode> }> {\n214\t    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });\n215\t    const tasks = await loadTasklistFromSpace(space, 'build_specialist');\n216\t    return { space, tasks };\n217\t  }\n218\t\n219\t  it('is a valid 2-task DAG (optional research → build goal) with the declared input schema', async () => {\n220\t    const { space, tasks } = await load();\n221\t    expect(() => validateDag(tasks)).not.toThrow();\n222\t    expect(Object.keys(tasks).sort()).toEqual(['build', 'research']);\n223\t    expect(space.tasklists['build_specialist']!.input).toEqual({ request: 'string' });\n224\t\n225\t    const research = tasks['research']!;\n226\t    expect(research.optional).toBe(true);\n227\t    expect(research.role).toBe('explore');\n228\t    expect(research.functions).toEqual([]);\n229\t    expect(research.output).toEqual({ report: 'object' });\n230\t    expect(research.canDelegateTo).toEqual(['system-research/researcher#deep_research']);\n231\t\n232\t    const build = tasks['build']!;\n233\t    expect(build.goal).toBe(true);\n234\t    expect(resolveGoalTask(tasks)!.id).toBe('build');\n235\t    expect(build.dependsOn).toEqual(['research']);\n236\t    expect(build.role).toBe('general');\n237\t    expect(build.functions).toEqual([]);\n238\t    expect(build.canDelegateTo).toEqual(['system-architect/architect#synthesize_and_run']);\n239\t  });\n240\t\n241\t  it(\"build's output schema mirrors the architect finalize task field-for-field\", async () => {\n242\t    const { tasks } = await load();\n243\t    const architect = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n244\t    const synth = await loadTasklistFromSpace(architect, 'synthesize_and_run');\n245\t    expect(tasks['build']!.output).toEqual(synth['finalize']!.output);\n246\t  });\n247\t\n248\t  it(\"research's prelude performs the delegation itself and typechecks against the fork ambient\", async () => {\n249\t    const { space, tasks } = await load();\n250\t    const research = tasks['research']!;\n251\t    expect(research.prelude).toBeTruthy();\n252\t    const stmts = splitPreludeStatements(research.prelude!);\n253\t    expect(stmts).toHaveLength(1);\n254\t    expect(stmts[0]).toContain(\"await delegate('system-research', 'researcher', 'deep_research'\");\n255\t    typecheckPrelude(research, space.tasklists['build_specialist']!, {});\n256\t  });\n257\t});\n258\t\n259\tdescribe('system-research preludes (deterministic gather moved to the host)', () => {\n260\t  it('every gather task ships a prelude with the expected statements; pure-reasoning tasks do not', a