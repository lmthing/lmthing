t      \"journal_entries\": [\n1151\t        {\n1152\t          \"id\": \"b45e2524-f531-44d0-b11b-23d466160c45\",\n1153\t          \"date\": \"Aug 3-5\",\n1154\t          \"title\": \"Cairo Arrival Stopover\",\n1155\t          \"body\": \"Arrive Cairo Aug 3 (Aegean A3932, 06:55–08:50, ref ZZJQUU). Staying at Eileen Hotel near Tahrir Square/Nile Corniche. Sightseeing plan: Grand Egyptian Museum and Pyramids of Giza. Fly out Aug 4 at 22:40 on EgyptAir to Dar es Salaam (arrive 04:20+1). Late checkout Aug 5 not needed for sleep.\",\n1156\t          \"category\": \"journal\",\n1157\t          \"location\": \"Cairo, Egypt\",\n1158\t          \"contacts\": \"Eileen Hotel: +20 15 56434043, info@eileenhotel.com, 21 Youssef El-Gendy St, Abdeen, Downtown Cairo\",\n1159\t          \"origin\": \"tanzaniamemories.md\"\n1160\t        },\n1161\t        {\n1162\t          \"id\": \"6afcfb6b-5d73-47c8-a223-f6ab335b5e2f\",\n1163\t          \"date\": \"Aug 5\",\n1164\t          \"title\": \"Transit Day — Cairo → Dar → Arusha\",\n1165\t          \"body\": \"EgyptAir CAI→DAR lands 04:20. Connect to Precision Air TC144 DAR→ARK, 10:50–12:00. Arrive Arusha midday. Stay: Serengeti Villa (+255 757 757 928), Aug 5-7.\",\n1166\t          \"category\": \"journal\",\n1167\t          \"location\": \"Dar es Salaam → Arusha, Tanzania\",\n1168\t          \"contacts\": \"Serengeti Villa: +255 757 757 928\",\n1169\t          \"origin\": \"tanzaniamemories.md\"\n1170\t        },\n1171\t        {\n1172\t          \"id\": \"5d05b0e7-fa26-4af1-b213-d10c609762e2\",\n1173\t          \"date\": \"Aug 5-7\",\n1174\t          \"title\": \"Arusha Pre-Safari\",\n1175\t          \"body\": \"Two nights at Serengeti Villa, Arusha. Prep for safari. Tanzania e-visa ($50/person) must be done online at visa.immigration.go.tz — visa-on-arrival no longer available. Zanzibar also requires separate mandatory travel insurance from ZIC.\",\n1176\t          \"category\": \"journal\",\n1177\t          \"location\": \"Arusha, Tanzania\",\n1178\t          \"contacts\": \"\",\n1179\t          \"origin\": \"tanzaniamemories.md\"\n1180\t        },\n1181\t        {\n1182\t          \"id\": \"1bbaac45-ae76-4db7-b85e-966a443ff13f\",\n1183\t          \"date\": \"Aug 7-9\",\n1184\t          \"title\": \"Suricata Safaris — 3-Day Group Camping Safari\",\n1185\t          \"body\": \"Safari with Suricata Safaris Ltd. Day 1: Tarangire National Park (Twiga Camp Site, FB). Day 2: Lake Manyara National Park (Twiga Camp Site, FB). Day 3: Ngorongoro Crater (overnight at Jevas Hotel, HB). Safari package: $1,200 total for 2 pax. $240 deposit (20%) paid. $960 balance due on arrival in cash (post-2009 USD notes) or online via Pesapal (+5% surcharge): payments.pesapal.com/suricatasafaris. Contact: Richard, +255 763 222 293, info@suricatasafaris.com.\",\n1186\t          \"category\": \"journal\",\n1187\t          \"location\": \"Tarangire → Lake Manyara → Ngorongoro Crater, Tanzania\",\n1188\t          \"contacts\": \"Richard (Suricata Safaris): +255 763 222 293, info@suricatasafaris.com\",\n1189\t          \"origin\": \"tanzaniamemories.md\"\n1190\t        },\n1191\t        {\n1192\t          \"id\": \"9790321e-5e85-45ca-b64e-8989cb934013\",\n1193\t          \"date\": \"Aug 9\",\n1194\t          \"title\": \"Ngorongoro Crater Day — One of the Best Days of the Trip\",\n1195\t          \"body\": \"Driver guide: Emmanuel (not Richard) — excellent, pointed out wildlife before it was visible. Bought 2 beaded bracelets from a Maasai lady at the crater rim for Athina Mari — ~$20-25 USD / ~TZS 35,000, exact amount uncertain. Emmanuel mentioned an extra ranger tip at the gate: ~TZS 5,000 cash, separate from park fees — nobody told us beforehand. Described as one of the best days of the trip. Park fees for the day: entry permit $70.80/person, crater service fee $70.80/person, vehicle descent fee $295 (up to 2000kg). Ngorongoro nights are cold — warm layers needed.\",\n1196\t          \"category\": \"journal\",\n1197\t          \"location\": \"Ngorongoro Crater, Tanzania\",\n1198\t          \"contacts\": \"Emmanuel (driver guide)\",\n1199\t          \"origin\": \"voice memo transcription\"\n1200\t        },\n1201\t        {\n1202\t          \"id\": \"c2ab3b17-39b2-496f-9d25-a03f56f0d3e0\",\n1203\t          \"date\": \"Aug 9-11\",\n1204\t          \"title\": \"Arusha Post-Safari — Kutoka Lodge\",\n1205\t          \"body\": \"Two nights at Kutoka Lodge, Arusha. Rest after safari. Next: fly to Zanzibar Aug 11 (Precision Air TC145, 12:40–13:40). Precision Air has luggage restrictions favoring soft bags.\",\n1206\t          \"category\": \"journal\",\n1207\t          \"location\": \"Arusha, Tanzania\",\n1208\t          \"contacts\": \"\",\n1209\t          \"origin\": \"tanzaniamemories.md\"\n1210\t        },\n1211\t        {\n1212\t          \"id\": \"0462bda7-83f8-4502-813b-f240e8cf7f9f\",\n1213\t          \"date\": \"Aug 11-13\",\n1214\t          \"title\": \"Zanzibar — Stone Town\",\n1215\t          \"body\": \"Fly ARK→ZNZ Aug 11 (Precision Air TC145, 12:40–13:40). Stay: Treasures of Zanzibar House, 2 nights. Explore Stone Town.\",\n1216\t          \"category\": \"journal\",\n1217\t          \"location\": \"Stone Town, Zanzibar\",\n1218\t          \"contacts\": \"\",\n1219\t          \"origin\": \"tanzaniamemories.md\"\n1220\t        },\n1221\t        {\n1222\t          \"id\": \"23ce6a6f-7a8d-4e9b-9867-00013f0de3d3\",\n1223\t          \"date\": \"Aug 13-17\",\n1224\t          \"title\": \"Zanzibar — Beach (Kiwengwa)\",\n1225\t          \"body\": \"Stay: Ayla Beach House, Kiwengwa, 4 nights. North coast (Nungwi area) offers more consistent swimming conditions vs. east/south where low tide limits access. Zanzibar local driving permit required (~$15, valid up to 3 months). Vasilis holds an IDP — most rental companies arrange the local permit with license photo 24+ hours before. Police checkpoints are frequent; carry both IDP and local permit (screenshot acceptable).\",\n1226\t          \"category\": \"journal\",\n1227\t          \"location\": \"Kiwengwa, Zanzibar\",\n1228\t          \"contacts\": \"\",\n1229\t          \"origin\": \"tanzaniamemories.md\"\n1230\t        },\n1231\t        {\n1232\t          \"id\": \"4a7a1251-19ee-4224-aa75-0576adebdf1a\",\n1233\t          \"date\": \"Aug 15\",\n1234\t          \"title\": \"The Rock Restaurant Dinner\",\n1235\t          \"body\": \"The Rock Restaurant, Zanzibar. Aug 15, 18:00–20:00 sitting. 2 adults. 2x Tropical Passion Fruit Cheesecake included. Fully paid ($46). Outdoor seating requested for sunset/star views. Contact: +255 776 591 360 / +255 763 070 658, booking@therockrestaurantzanzibar.com.\",\n1236\t          \"category\": \"journal\",\n1237\t          \"location\": \"The Rock Restaurant, Zanzibar\",\n1238\t          \"contacts\": \"+255 776 591 360 / +255 763 070 658, booking@therockrestaurantzanzibar.com\",\n1239\t          \"origin\": \"tanzaniamemories.md\"\n1240\t        },\n1241\t        {\n1242\t          \"id\": \"16e600fd-51f0-4294-903c-ddb1c33b5559\",\n1243\t          \"date\": \"Aug 17-19\",\n1244\t          \"title\": \"Dar es Salaam\",\n1245\t          \"body\": \"Arrive by ferry from Zanzibar. Stay: Sunny Shore B&B, 2 nights. Interest in city exploration: Kivukoni Fish Market, Kariakoo Market, National Museum, Coco Beach, Bongoyo Island.\",\n1246\t          \"category\": \"journal\",\n1247\t          \"location\": \"Dar es Salaam, Tanzania\",\n1248\t          \"contacts\": \"\",\n1249\t          \"origin\": \"tanzaniamemories.md\"\n1250\t        },\n1251\t        {\n1252\t          \"id\": \"a7484914-b616-4112-9580-1ecd9cb65030\",\n1253\t          \"date\": \"Aug 19-20\",\n1254\t          \"title\": \"Cairo Departure Stopover\",\n1255\t          \"body\": \"EgyptAir DAR→CAI, 05:20–11:05. Stay: Ramses Hilton, 1 night. Sightseeing: Islamic Cairo, the Citadel, Khan el-Khalili bazaar, Coptic Cairo. Taxi needed between Citadel and Coptic Cairo. Fly home Aug 20: Aegean A3935 CAI→ATH, 19:55–22:00, ref ZZL22S.\",\n1256\t          \"category\": \"journal\",\n1257\t          \"location\": \"Cairo, Egypt\",\n1258\t          \"contacts\": \"Ramses Hilton, Cairo\",\n1259\t          \"origin\": \"tanzaniamemories.md\"\n1260\t        },\n1261\t        {\n1262\t          \"id\": \"1b9c173f-5cc3-4348-8668-489496c6a2cf\",\n1263\t          \"date\": \"Aug 3-20\",\n1264\t          \"title\": \"Trip Summary & Key Learnings\",\n1265\t          \"body\": \"Full trip: Aug 3-20, 2026. Vasileios Kefallinos + Athina Mari. Cairo → Arusha → Tanzania safari circuit → Zanzibar → Dar es Salaam. Total flights: ~€2,707 (6 legs). Total lodging (excl. safari): ~$951. Safari: $1,200. Key tips: EgyptAir operates Cairo↔Dar — confirmed. Tanzania e-visa mandatory online ($50/person). Egypt e-visa multiple-entry ($65), printed copy mandatory. Ngorongoro nights are cold. Zanzibar: north coast best for swimming. Precision Air: soft bags preferred. August is peak safari season — ideal for Great Wildebeest Migration. Vasilis prefers simple, concise output (bullet lists over tables).\",\n1266\t          \"category\": \"note\",\n1267\t          \"location\": \"Multi-city\",\n1268\t          \"contacts\": \"\",\n1269\t          \"origin\": \"tanzaniamemories.md\"\n1270\t        }\n1271\t      ],\n1272\t      \"park_fees\": [\n1273\t        {\n1274\t          \"id\": \"3692263e-c4a2-41a6-935b-773a30cbc8a6\",\n1275\t          \"fee_name\": \"Entry Permit — Non-EA adult (16+)\",\n1276\t          \"category\": \"entry\",\n1277\t          \"visitor_type\": \"non_ea_adult\",\n1278\t          \"amount\": 70.8,\n1279\t          \"currency\": \"USD\",\n1280\t          \"unit\": \"per person per day\",\n1281\t          \"weight_range\": \"\",\n1282\t          \"notes\": \"Valid for 24h single entry. Ngorongoro Conservation Area.\"\n1283\t        },\n1284\t        {\n1285\t          \"id\": \"fef83a64-e9e1-4f6f-abeb-2718634d6d9d\",\n1286\t          \"fee_name\": \"Entry Permit — Non-EA child (5–16)\",\