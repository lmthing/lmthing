{
  "apps": [
    {
      "id": "blog",
      "title": "Blog",
      "description": "lmthing.blog — personalized AI news, as a project-application (database + pages + api + hooks + newsroom space).",
      "icon": null,
      "tables": [
        "articles",
        "citations",
        "raw_items",
        "research",
        "settings",
        "sources"
      ],
      "pages": [
        "_app.tsx",
        "_layout.tsx",
        "feed/[articleId].tsx",
        "feed/[articleId]/research.tsx",
        "index.tsx",
        "preferences.tsx",
        "tag/[tag].tsx"
      ],
      "endpoints": [
        "articles",
        "feed-list",
        "mark-all-read",
        "mark-read",
        "settings",
        "sources",
        "stats"
      ],
      "hooks": [
        "refresh-sources",
        "synthesize-new"
      ]
    },
    {
      "id": "demo-feed",
      "title": "Personal Feed",
