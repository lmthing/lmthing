: 'Lake Manyara park entry. Source: trip-costs.xlsx / standard tariff' },\\n      // — Tips —\\n      { trip_id: '{{trips[0].id}}', description: 'Ngorongoro ranger tip (cash at gate)', category: 'tips', amount: 5000, currency: 'TZS', payment_status: 'pending_confirmation', date: '2026-08-06', notes: 'Emmanuel mentioned extra ranger tip ~5,000 TZS cash at gate — separate from official park fees. OPEN: ask Richard about this before safari balance payment.' },\\n      { trip_id: '{{trips[0].id}}', description: 'Guide/driver tip (Emmanuel)', category: 'tips', amount: 20, currency: 'USD', payment_status: 'unpaid', date: '2026-08-07', notes: 'Standard guide gratuity for 3-day safari. Source: trip-costs.xlsx' },\\n      // — Souvenirs —\\n      { trip_id: '{{trips[0].id}}', description: '2 beaded bracelets from Maasai lady — Ngorongoro crater day', category: 'souvenirs', amount: 22.5, currency: 'USD', payment_status: 'paid', date: '2026-08-06', notes: 'Athina Mari bought 2 beaded bracelets for ~$20–25 total (~35,000 TZS). Voice note: Ngorongoro crater day, driver Emmanuel.' },\\n      // — Meals —\\n      { trip_id: '{{trips[0].id}}', description: 'Cairo stopover meals', category: 'meals', amount: 30, currency: 'USD', payment_status: 'paid', date: '2026-08-03', notes: 'Meals during Cairo layover. Source: trip-costs.xlsx' },\\n      { trip_id: '{{trips[0].id}}', description: 'Arusha meals (pre- and post-safari)', category: 'meals', amount: 60, currency: 'USD', payment_status: 'paid', date: null, notes: 'Restaurant meals in Arusha outside safari package. Source: trip-costs.xlsx' },\\n      { trip_id: '{{trips[0].id}}', description: 'Stone Town meals and dining', category: 'meals', amount: 200, currency: 'USD', payment_status: 'paid', date: null, notes: 'Dining out in Stone Town over 9 nights. Source: trip-costs.xlsx' },\\n      // — Transport —\\n      { trip_id: '{{trips[0].id}}', description: 'Arusha airport transfers', category: 'transport', amount: 40, currency: 'USD', p