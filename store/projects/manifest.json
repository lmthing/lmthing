      "tables": [
        "feed_items"
      ],
      "pages": [
        "index.tsx"
      ],
      "endpoints": [
        "add-item",
        "feed-list",
        "mark-read"
      ],
      "hooks": [
        "enrich-on-add"
      ]
    },
    {
