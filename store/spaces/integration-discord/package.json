{
  "name": "integration-discord",
  "version": "1.0.0",
  "private": true,
  "lmthing": {
    "kind": "integration",
    "title": "Discord",
    "tags": ["integration", "messaging"],
    "icon": "🎮",
    "description": "Control a Discord bot from THING — post, edit, reply, and react in your server, and answer slash commands.",
    "settings": {
      "type": "object",
      "properties": {
        "INTEGRATION_DISCORD_BOT_TOKEN": { "type": "string", "title": "Bot token", "format": "password" },
        "INTEGRATION_DISCORD_PUBLIC_KEY": { "type": "string", "title": "Public key", "format": "password" },
        "INTEGRATION_DISCORD_APPLICATION_ID": { "type": "string", "title": "Application ID", "format": "password" }
      },
      "required": ["INTEGRATION_DISCORD_BOT_TOKEN", "INTEGRATION_DISCORD_PUBLIC_KEY", "INTEGRATION_DISCORD_APPLICATION_ID"]
    },
    "connection": {
      "provider": "discord",
      "apiBase": "https://discord.com/api/v10",
      "tokenEnv": "INTEGRATION_DISCORD_BOT_TOKEN",
      "auth": { "kind": "bot" }
    }
  }
}
