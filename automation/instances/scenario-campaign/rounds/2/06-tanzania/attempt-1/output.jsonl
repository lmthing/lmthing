 JSON.parse(l) as TraceEvent);\n112\t  } catch {\n113\t    return [];\n114\t  }\n115\t}\n116\t\n117\t/**\n118\t * Spawn the built CLI, stream its output live while buffering, and return the\n119\t * exit code, captured stdout/stderr, and the parsed trace.\n120\t */\n121\texport function runCli(opts: RunCliOpts): Promise<RunCliResult> {\n122\t  if (!hasBin()) {\n123\t    throw new Error(`CLI not built: ${BIN} missing — run \\`pnpm build\\` first`);\n124\t  }\n125\t  mkdirSync(TRACE_DIR, { recursive: true });\n126\t  const tracePath = join(TRACE_DIR, `${opts.scenario}.jsonl`);\n127\t  // Fresh trace per run.\n128\t  rmSync(tracePath, { force: true });\n129\t\n130\t  const argv: string[] = [\n131\t    BIN,\n132\t    '--claude',\n133\t    '--space',\n134\t    opts.space,\n135\t    '--trace',\n136\t    tracePath,\n137\t  ];\n138\t  if (opts.agent) argv.push('--agent', opts.agent);\n139\t  if (opts.model) argv.push('--model', opts.model);\n140\t  if (opts.mock) argv.push('--mock', opts.mock);\n141\t  if (opts.budget?.maxEpisodes !== undefined) argv.push('--max-episodes', String(opts.budget.maxEpisodes));\n142\t  if (opts.budget?.maxToolCalls !== undefined) argv.push('--max-tool-calls', String(opts.budget.maxToolCalls));\n143\t  if (opts.budget?.maxForkDepth !== undefined) argv.push('--max-fork-depth', String(opts.budget.maxForkDepth));\n144\t  if (opts.budget?.maxWallClockMs !== undefined) argv.push('--max-wallclock-ms', String(opts.budget.maxWallClockMs));\n145\t  argv.push(opts.message);\n146\t\n147\t  const timeoutMs = opts.timeoutMs ?? 120_000;\n148\t  const prefix = `    │ `;\n149\t\n150\t  return new Promise<RunCliResult>((resolvePromise) => {\n151\t    process.stdout.write(`\\n  ▶ [${opts.scenario}] ${opts.model ?? opts.mock ?? 'default'} :: ${opts.space}\\n`);\n152\t    const child = spawn(process.execPath, argv, {\n153\t      cwd: opts.cwd ?? REPO_ROOT,\n154\t      env: { ...process.env, ...opts.env },\n155\t    });\n156\t\n157\t    // Feed any ask() the agent makes. The plain-mode ask() reads until a newline\n158\t    // and never resolves on EOF, so append a flood of newlines: the first answer\n159\t    // (if any) goes to the first ask, blank lines satisfy any further asks. Keep\n160\t    // stdin open — ending it would not unblock a pending read.\n161\t    child.stdin.write((opts.stdin ? opts.stdin + '\\n' : '') + '\\n'.repeat(40));\n162\t\n163\t    let stdout = '';\n164\t    let stderr = '';\n165\t    let timedOut = false;\n166\t\n167\t    // Stream + buffer. Indent each line so the model's output is visually nested\n168\t    // under the scenario header.\n169\t    const pipe = (chunk: Buffer, sink: NodeJS.WriteStream, append: (s: string) => void) => {\n170\t      const s = chunk.toString('utf8');\n171\t      append(s);\n172\t      sink.write(s.replace(/\\n/g, `\\n${prefix}`));\n173\t    };\n174\t    child.stdout.on('data', (c: Buffer) => pipe(c, process.stdout, (s) => { stdout += s; }));\n175\t    child.stderr.on('data', (c: Buffer) => pipe(c, process.stderr, (s) => { stderr += s; }));\n176\t\n177\t    const killTimer = setTimeout(() => {\n178\t      timedOut = true;\n179\t      child.kill('SIGKILL');\n180\t    }, timeoutMs);\n181\t\n182\t    // The bundled @types/node doesn't surface EventEmitter methods on\n183\t    // ChildProcessWithoutNullStreams; the child IS an EventEmitter, so cast.\n184\t    (child as unknown as EventEmitter).on('close', (code: number | null): void => {\n185\t      clearTimeout(killTimer);\n186\t      void readTrace(tracePath).then((trace) => {\n187\t        process.stdout.write(`\\n  ◀ [${opts.scenario}] exit=${code}${timedOut ? ' (TIMED OUT)' : ''}  trace=${trace.length} events → ${tracePath}\\n`);\n188\t        resolvePromise({ code, timedOut, stdout, stderr, trace, tracePath });\n189\t      });\n190\t    });\n191\t  });\n192\t}\n193\t\n194\t// ── Trace query helpers (ported from scripts/live-test.sh) ──────────────────\n195\t\n196\texport type LlmReq = Extract<TraceEvent, { type: 'llm_req