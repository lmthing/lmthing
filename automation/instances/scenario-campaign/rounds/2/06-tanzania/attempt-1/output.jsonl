{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_DyP9KOLvpoQhEkWt5mcjtpTF","type":"tool_result","content":"1\t/**\n2\t * Per-project **page-app build** (Phase 5, 5A).\n3\t *\n4\t * Turns a project's `pages/` (client-side React, file-based routing) into a\n5\t * cached, self-contained static bundle under `<projectRoot>/.data/pages-dist/`,\n6\t * served (by 5B) under `…/app/<project>/*`. It runs **on save/boot, never per\n7\t * request**, and short-circuits when nothing under `pages/`/`components/`/`lib/`/\n8\t * `package.json` changed (content-hash cache).\n9\t *\n10\t * Pipeline:\n11\t *   1. **Discover routes** — every non-`_`-prefixed `.tsx`/`.jsx` under `pages/`\n12\t *      is a route (`index` → the dir's path, `[id]` → `:id`); `_app`/`_layout`\n13\t *      are wrappers, not routes.\n14\t *   2. **Endpoint manifest** — `generateAppTypes(projectRoot)` yields the typed\n15\t *      `EndpointContract[]`; we project it to the client `name → { method,\n16\t *      routePath }` manifest injected into the page app.\n17\t *   3. **Generate an entry** (in `.data/pages-build/`, never the repo) that imports\n18\t *      the pages + `_app`/`_layout`, builds the route table + manifest, and mounts\n19\t *      the router (`@app/runtime` `mountApp`).\n20\t *   4. **esbuild bundle** → hashed assets + `index.html` with **relative** URLs.\n21\t *      `@app/runtime` aliases to this package's runtime module, `@app/types` to\n22\t *      the project's generated dts; React is single-instanced from the cli's own\n23\t *      node_modules so page hooks work.\n24\t *\n25\t * Node/build-time only (esbuild, fs). The emitted bundle is browser code.\n26\t */\n27\t\n28\timport { createHash } from 'node:crypto';\n29\timport { existsSync, readFileSync } from 'node:fs';\n30\timport { mkdir, readdir, readFile, rm, stat, writeFile } from 'node:fs/promises';\n31\timport type { Dirent } from 'node:fs';\n32\timport { createRequire } from 'node:module';\n33\timport { dirname, join, relative, sep } from 'node:path';\n34\timport { fileURLToPath } from 'node:url';\n35\t\n36\timport { build, type BuildOptions, type Plugin } from 'esbuild';\n37\timport { isUnderMemoryPressure } from '../../server/mem-watchdog.js';\n38\timport { compile, Features } from '@tailwindcss/node';\n39\timport { Scanner } from '@tailwindcss/oxide';\n40\t\n41\timport { generateAppTypes, type EndpointContract } from './schema.js';\n42\t\n43\t/** A discovered page route. */\n44\texport interface PageRoute {\n45\t  /** Route pattern (`[id]` → `:id`), e.g. `/` or `/items/:id`. */\n46\t  routePath: string;\n47\t  /** Absolute path to the page `.tsx`/`.jsx` file. */\n48\t  file: string;\n49\t}\n50\t\n51\t/** Result of {@link buildProjectPages}. */\n52\texport interface BuiltPages {\n53\t  /** The output dir (`<projectRoot>/.data/pages-dist`). */\n54\t  outDir: string;\n55\t  /** Emitted asset paths relative to {@link outDir} (incl. `index.html`, hashed JS/CSS). */\n56\t  assetManifest: string[];\n57\t  /** `true` when a build ran; `false` on a cache hit or when there is no `pages/`. */\n58\t  built: boolean;\n59\t  /** The discovered route table (`routePath` + source `file`). */\n60\t  routes: PageRoute[];\n61\t}\n62\t\n63\t/** Options for {@link buildProjectPages}. */\n64\texport interface BuildPagesOpts {\n65\t  /** Force a rebuild even on a cache hit. */\n66\t  force?: boolean;\n67\t  /** Minify the bundle (default `true`). */\n68\t  minify?: boolean;\n69\t}\n70\t\n71\tconst PAGE_EXT = /\\.(tsx|jsx)$/;\n72\tconst OUT_SUBDIR = join('.data', 'pages-dist');\n73\tconst BUILD_SUBDIR = join('.data', 'pages-build');\n74\tconst CACHE_FILE = join('.data', 'pages-cache.json');\n75\t\n76\t/**\n77\t * Bumped whenever the **builder itself** — or the bundled `@app/runtime` source it\n78\t * inlines — changes what it emits (independent of project sources), so an existing\n79\t * pod's cached bundle is invalidated and rebuilt. The content hash tracks only the\n80\t * project's own files, so a runtime-only fix needs a bump here to reach cached apps.\n81\t * `2` = Tailwind-compiled design-system CSS is now bundled (previously the theme\n82\t *       tokens/utilities/`@apply` never made it into the output → apps rendered unstyled).\n83\t * `3` = router `Link`/`navigate` re-apply the `…/app/<project>` base and accept the\n84\t *       `href` prop (previously `<Link href>` degraded to a full-page nav that left\n85\t *       the app — e.g. `/discover` instead of `/app/<project>/discover`).\n86\t * `4` = `<Chat>` sends the platform `@lmthing/auth` Bearer token on session create +\n87\t *       WS (previously the pod's JWT-gated `/api/*` proxy 401'd the curator chat).\n88\t * `5` = generated HTML pins the light token theme so project apps don't inherit\n89\t *       dark foreground tokens on light app surfaces.\n90\t */\n91\tconst BUILDER_VERSION = '5';\n92\t\n93\tinterface CacheMeta {\n94\t  hash: string;\n95\t  assetManifest: string[];\n96\t  routes: PageRoute[];\n97\t}\n98\t\n99\t// Process-wide esbuild serialization: each page build peaks ~100 MB, so two\n100\t// concurrent builds double that. Chain them so at most one runs at a time.\n101\tlet esbuildChain: Promise<unknown> = Promise.resolve();\n102\tfunction serializeEsbuild<T>(fn: () => Promise<T>): Promise<T> {\n103\t  const run = esbuildChain.then(fn, fn);\n104\t  esbuildChain = run.then(\n105\t    () => undefined,\n106\t    () => undefined,\n107\t  );\n108\t  return run;\n109\t}\n110\t\n111\t/** Wait (bounded) for hard memory pressure to clear before a heavy build. No-op\n112\t *  off-container (the watchdog never raises pressure there). */\n113\tasync function waitForMemoryHeadroom(maxWaitMs = 30_000): Promise<void> {\n114\t  const start = Date.now();\n115\t  while (isUnderMemoryPressure() && Date.now() - start < maxWaitMs) {\n116\t    await new Promise((r) => setTimeout(r, 1000));\n117\t  }\n118\t}\n119\t\n120\t/**\n121\t * Build (or cache-hit) a project's page app. Returns `{ built:false }` with empty\n122\t * routes/manifest when the project has no `pages/` dir (a db/api-only project).\n123\t */\n124\texport async function buildProjectPages(\n125\t  projectRoot: string,\n126\t  opts: BuildPagesOpts = {},\n127\t): Promise<BuiltPages> {\n128\t  const pagesDir = join(projectRoot, 'pages');\n129\t  const outDir = join(projectRoot, OUT_SUBDIR);\n130\t\n131\t  if (!(await dirExists(pagesDir))) {\n132\t    return { outDir, assetManifest: [], built: false, routes: [] };\n133\t  }\n134\t\n135\t  const routes = await discoverRoutes(pagesDir);\n136\t  const hash = await sourceHash(projectRoot);\n137\t  const cachePath = join(projectRoot, CACHE_FILE);\n138\t\n139\t  if (!opts.force) {\n140\t    const cached = await readCache(cachePath);\n141\t    if (cached && cached.hash === hash && existsSync(join(outDir, 'index.html'))) {\n142\t      return { outDir, assetManifest: cached.assetManifest, built: false, routes: cached.routes };\n143\t    }\n144\t  }\n145\t\n146\t  const assetManifest = await runBuild(projectRoot, pagesDir, outDir, routes, opts);\n147\t  await writeCache(cachePath, { hash, assetManifest, routes });\n148\t  return { outDir, assetManifest, built: true, routes };\n149\t}\n150\t\n151\t// ── Route discovery ───────────────────────────────────────────────────────────\n152\t\n153\t/** The two wrapper basenames that are NOT routes. */\n154\tconst WRAPPERS = new Set(['_app', '_layout']);\n155\t\n156\t/** Walk `pages/` collecting route files (skips `_`-prefixed and `components/`/`lib/`). */\n157\tasync function discoverRoutes(pagesDir: string): Promise<PageRoute[]> {\n158\t  const routes: PageRoute[] = [];\n159\t  await walkPages(pagesDir, pagesDir, routes);\n160\t  routes.sort((a, b) => a.routePath.localeCompare(b.routePath));\n161\t  return routes;\n162\t}\n163\t\n164\tasync function walkPages(root: string, dir: string, out: PageRoute[]): Promise<void> {\n165\t  let entries: Dirent[];\n166\t  try {\n167\t    entries = await readdir(dir, { withFileTypes: true });\n168\t  } catch {\n169\t    return;\n170\t  }\n171\t  for (const entry of entries) {\n172\t    const abs = join(dir, entry.name);\n173\t    if (entry.isDirectory()) {\n174\t      // `components/`/`lib/` under pages/ hold shared code, not routes.\n175\t      if (entry.name === 'components' || entry.name === 'lib' || entry.name.startsWith('_')) continue;\n176\t      await walkPages(root, abs, out);\n177\t      continue;\n178\t    }\n179\t    if (!entry.isFile() || !PAGE_EXT.test(entry.name)) continue;\n180\t    const base = entry.name.replace(PAGE_EXT, '');\n181\t    if (base.startsWith('_')) continue; // _app / _layout / other wrappers\n182\t    out.push({ routePath: routePathFor(root, abs), file: abs });\n183\t  }\n184\t}\n185\t\n186\t/** Map a page file to its route pattern (`index` collapses; `[id]` → `:id`). */\n187\tfunction routePathFor(root: string, file: string): string {\n188\t  const rel = relative(root, file).replace(PAGE_EXT, '');\n189\t  const segs = rel.split(sep).filter((s) => s.length > 0);\n190\t  if (segs.length > 0 && segs[segs.length - 1] === 'index') segs.pop();\n191\t  const parts = segs.map((s) => {\n192\t    const m = /^\\[(.+)\\]$/.exec(s);\n193\t    return m ? `:${m[1]}` : s;\n194\t  });\n195\t  return '/' + parts.join('/');\n196\t}\n197\t\n198\t// ── Endpoint manifest ─────────────────────────────────────────────────────────\n199\t\n200\tinterface ManifestEntry {\n201\t  method: string;\n202\t  routePath: string;\n203\t}\n204\t\n205\t/** Project the typed `EndpointContract[]` down to the client `name → routing` manifest. */\n206\tfunction endpointManifest(endpoints: EndpointContract[]): Record<string, ManifestEntry> {\n207\t  const manifest: Record<string, ManifestEntry> = {};\n208\t  for (const ep of endpoints) manifest[ep.name] = { method: ep.method, routePath: ep.routePath };\n209\t  return manifest;\n210\t}\n211\t\n212\t// ── Build ─────────────────────────────────────────────────────────────────────\n213\t\n214\tasync function runBuild(\n215\t  projectRoot: string,\n216\t  pagesDir: string,\n217\t  outDir: string,\n218\t  routes: PageRoute[],\n219\t  opts: BuildPagesOpts,\n220\t): Promise<string[]> {\n221\t  // Endpoint contracts (also (re)writes types/generated.d.ts).\n222\t  const { endpoints } = await generateAppTypes(projectRoot);\n223\t  const manifest = endpointManifest(endpoints);\n224\t\n225\t  const { aliases, nodePaths, designSystem, uiSrcDir } = resolveEnv(projectRoot);\n226\t\n227\t  // Generate the client entry in a scratch build dir (never the repo tree).\n228\t  const buildDir = join(projectRoot, BUILD_SUBDIR);\n229\t  await rm(buildDir, { recursive: true, force: true });\n230\t  await mkdir(buildDir, { recursive: true });\n231\t  const wrappers = findWrappers(pagesDir);\n232\t\n233\t  // Design-system stylesheet entry: pulls in `@lmthing/css` (theme tokens,\n234\t  // Tailwind base/utilities), scanned against the page + component + design-system\n235\t  // sources so every class the pages/`@lmthing/ui` use is generated. Compiled by\n236\t  // the Tailwind plugin below (esbuild alone can't expand `@theme`/`@apply`).\n237\t  const appCssFile = join(buildDir, 'app.css');\n238\t  await writeFile(appCssFile, renderAppCss(projectRoot, designSystem), 'utf8');\n239\t\n240\t  const entryFile = join(buildDir, 'entry.tsx');\n241\t  await writeFile(\n242\t    entryFile,\n243\t    renderEntry(routes, wrappers, manifest, designSystem.themeCss ? './app.css' : undefined),\n244\t    'utf8',\n245\t  );\n246\t\n247\t  // Fresh output dir (drop stale hashed assets).\n248\t  await rm(outDir, { recursive: true, force: true });\n249\t  await mkdir(outDir, { recursive: true });\n250\t\n251\t  const generatedDts = join(projectRoot, 'types', 'generated.d.ts');\n252\t  if (existsSync(generatedDts)) aliases['@app/types'] = generatedDts;\n253\t\n254\t  const buildOpts: BuildOptions = {\n255\t    entryPoints: { entry: entryFile },\n256\t    bundle: true,\n257\t    format: 'esm',\n258\t    platform: 'browser',\n259\t    target: 'es2020',\n260\t    jsx: 'automatic',\n261\t    jsxImportSource: 'react',\n262\t    minify: opts.minify ?? true,\n263\t    sourcemap: false,\n264\t    metafile: true,\n265\t    write: true,\n266\t    absWorkingDir: outDir,\n267\t    outdir: '.',\n268\t    entryNames: 'assets/[name]-[hash]',\n269\t    assetNames: 'assets/[name]-[hash]',\n270\t    chunkNames: 'assets/[name]-[hash]',\n271\t    loader: { '.css': 'css', '.png': 'file', '.svg': 'file', '.jpg': 'file' },\n272\t    alias: aliases,\n273\t    nodePaths,\n274\t    plugins: [\n275\t      ...(uiSrcDir ? [uiElementsDirResolve(uiSrcDir)] : []),\n276\t      tailwindCssPlugin(),\n277\t    ],\n278\t    logLevel: 'silent',\n279\t  };\n280\t\n281\t  // Serialize esbuild across the process (each build peaks ~100 MB — two at once\n282\t  // can trip the memory watchdog) and defer while the pod is under hard memory\n283\t  // pressure, so a rare cold build never races resident sessions into an OOM.\n284\t  const result = await serializeEsbuild(async () => {\n285\t    await waitForMemoryHeadroom();\n286\t    return build(buildOpts);\n287\t  });\n288\t\n289\t  // Locate the entry's JS output (+ any extracted CSS bundle) from the metafile.\n290\t  let jsRel: string | undefined;\n291\t  let cssRel: string | undefined;\n292\t  for (const [outPath, meta] of Object.entries(result.metafile?.outputs ?? {})) {\n293\t    if (meta.entryPoint) {\n294\t      jsRel = outPath;\n295\t      if (meta.cssBundle) cssRel = meta.cssBundle;\n296\t    }\n297\t  }\n298\t  if (!jsRel) throw new Error('[pages-build] esbuild produced no entry output');\n299\t\n300\t  await writeFile(join(outDir, 'index.html'), renderIndexHtml(jsRel, cssRel), 'utf8');\n301\t\n302\t  // The asset manifest = every emitted file relative to outDir (incl. index.html).\n303\t  const files = await listFiles(outDir);\n304\t  return files.map((f) => relative(outDir, f).split(sep).join('/')).sort();\n305\t}\n306\t\n307\t/** Which optional wrappers exist. */\n308\tfunction findWrappers(pagesDir: string): { app?: string; layout?: string } {\n309\t  const out: { app?: string; layout?: string } = {};\n310\t  for (const ext of ['tsx', 'jsx']) {\n311\t    if (!out.app && existsSync(join(pagesDir, `_app.${ext}`))) out.app = join(pagesDir, `_app.${ext}`);\n312\t    if (!out.layout && existsSync(join(pagesDir, `_layout.${ext}`)))\n313\t      out.layout = join(pagesDir, `_layout.${ext}`);\n314\t  }\n315\t  return out;\n316\t}\n317\t\n318\t/** Emit the generated client entry that mounts the router. */\n319\tfunction renderEntry(\n320\t  routes: PageRoute[],\n321\t  wrappers: { app?: string; layout?: string },\n322\t  manifest: Record<string, ManifestEntry>,\n323\t  cssEntry?: string,\n324\t): string {\n325\t  const lines: string[] = [];\n326\t  // The design-system stylesheet must be first so its tokens/base cascade under\n327\t  // element + page styles. Omitted when `@lmthing/css` can't be resolved.\n328\t  if (cssEntry) lines.push(`import ${JSON.stringify(cssEntry)};`);\n329\t  lines.push(`import { mountApp } from '@app/runtime';`);\n330\t  routes.forEach((r, i) => lines.push(`import Page${i} from ${JSON.stringify(r.file)};`));\n331\t  if (wrappers.app) lines.push(`import App from ${JSON.stringify(wrappers.app)};`);\n332\t  if (wrappers.layout) lines.push(`import Layout from ${JSON.stringify(wrappers.layout)};`);\n333\t  lines.push('');\n334\t  const routeItems = routes\n335\t    .map((r, i) => `  { routePath: ${JSON.stringify(r.routePath)}, Component: Page${i} }`)\n336\t    .join(',\\n');\n337\t  lines.push('mountApp({');\n338\t  lines.push(`  manifest: ${JSON.stringify(manifest)},`);\n339\t  lines.push(`  app: ${wrappers.app ? 'App' : 'null'},`);\n340\t  lines.push(`  layout: ${wrappers.layout ? 'Layout' : 'null'},`);\n341\t  lines.push(`  routes: [\\n${routeItems}\\n  ],`);\n342\t  lines.push('});');\n343\t  lines.push('');\n344\t  return lines.join('\\n');\n345\t}\n346\t\n347\t/**\n348\t * Emit the design-system stylesheet entry (`app.css`). It imports `@lmthing/css`'s\n349\t * theme (Tailwind base + `@theme` tokens) and declares `@source` globs so the\n350\t * Tailwind compiler generates every utility class the pages, shared components and\n351\t * `@lmthing/ui` actually use. A tiny base gives pages the token-driven background /\n352\t * foreground / font by default. Compiled by {@link tailwindCssPlugin}.\n353\t */\n354\tfunction renderAppCss(projectRoot: string, ds: DesignSystem): string {\n355\t  if (!ds.themeCss) return '';\n356\t  const lines = [`@import ${JSON.stringify(ds.themeCss)};`];\n357\t  for (const dir of [\n358\t    join(projectRoot, 'pages'),\n359\t    join(projectRoot, 'components'),\n360\t    join(projectRoot, 'lib'),\n361\t    ...ds.sourceDirs,\n362\t  ]) {\n363\t    if (existsSync(dir)) lines.push(`@source ${JSON.stringify(dir)};`);\n364\t  }\n365\t  lines.push('@layer base {');\n366\t  lines.push('  html, body, #root { height: 100%; }');\n367\t  lines.push('  body { @apply bg-background text-foreground font-sans antialiased; }');\n368\t  lines.push('}');\n369\t  lines.push('');\n370\t  return lines.join('\\n');\n371\t}\n372\t\n373\t/** CSS files carrying any Tailwind v4 directive that esbuild can't expand on its own. */\n374\tconst TAILWIND_DIRECTIVE =\n375\t  /@(tailwind|apply|reference|theme|source|variant|custom-variant|utility|plugin|config)\\b|@import\\s+[\"']tailwindcss/;\n376\t\n377\t/**\n378\t * esbuild plugin that runs the **Tailwind v4 compiler** over every CSS file\n379\t * carrying a Tailwind directive — the design-system theme (`@import \"tailwindcss\"`\n380\t * + `@theme` tokens + utilities) and the `@lmthing/ui` element styles\n381\t * (`@reference` + `@apply`). Without this, esbuild's raw `.css` loader passes\n382\t * those directives through verbatim and the browser drops them, so project apps\n383\t * render **unstyled**. Plain third-party CSS (e.g. xterm) is passed through\n384\t * untouched (and fast).\n385\t */\n386\tfunction tailwindCssPlugin(): Plugin {\n387\t  return {\n388\t    name: 'lmthing-tailwind',\n389\t    setup(pluginBuild) {\n390\t      pluginBuild.onLoad({ filter: /\\.css$/ }, async (args) => {\n391\t        const raw = await readFile(args.path, 'utf8');\n392\t        if (!TAILWIND_DIRECTIVE.test(raw)) return null; // plain CSS → esbuild's own loader\n393\t        const base = dirname(args.path);\n394\t        const compiler = await compile(raw, {\n395\t          base,\n396\t          shouldRewriteUrls: true,\n397\t          onDependency: () => {},\n398\t        });\n399\t        // Scanner sources = the compiler's auto-detected root + any `@source` globs.\n400\t        const sources = (\n401\t          compiler.root === 'none'\n402\t            ? []\n403\t            : compiler.root === null\n404\t              ? [{ base, pattern: '**/*', negated: false }]\n405\t              : [{ ...compiler.root, negated: false }]\n406\t        ).concat(compiler.sources);\n407\t        const candidates: string[] = [];\n408\t        if (compiler.features & Features.Utilities) {\n409\t          const scanner = new Scanner({ sources });\n410\t          for (const c of scanner.scan()) candidates.push(c);\n411\t        }\n412\t        const contents = compiler.build(candidates);\n413\t        return { contents, loader: 'css', resolveDir: base };\n414\t      });\n415\t    },\n416\t  };\n417\t}\n418\t\n419\t/** The static HTML shell — references the hashed bundle with **relative** URLs. */\n420\tfunction renderIndexHtml(jsRel: string, cssRel?: string): string {\n421\t  const css = cssRel ? `\\n    <link rel=\"stylesheet\" href=\"./${cssRel}\">` : '';\n422\t  return `<!doctype html>\n423\t<html lang=\"en\" data-theme=\"light\">\n424\t  <head>\n425\t    <meta charset=\"utf-8\" />\n426\t    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />${css}\n427\t  </head>\n428\t  <body>\n429\t    <div id=\"root\"></div>\n430\t    <script type=\"module\" src=\"./${jsRel}\"></script>\n431\t  </body>\n432\t</html>\n433\t`;\n434\t}\n435\t\n436\t// ── Module/asset resolution ───────────────────────────────────────────────────\n437\t\n438\t/**\n439\t * Resolve the build environment: `@app/runtime` alias to this package's runtime\n440\t * **source**, single-instanced React aliases, and every `node_modules` up from\n441\t * the cli root on the resolution path so page imports (`@lmthing/ui`/`@lmthing/css`,\n442\t * `react/jsx-runtime`, project deps) resolve even though the project lives outside\n443\t * this workspace.\n444\t *\n445\t * Critically, the cli root is found by **walking up to the `@lmthing/cli`\n446\t * `package.json`** — NOT by a `dist/`-relative path — so it works identically when\n447\t * this module runs from `src/` (vitest) and from the **built** cli under `dist/`\n448\t * (where a `dist/`-relative `../runtime` would be absent; the real runtime source\n449\t * lives at `<cliRoot>/src/app/runtime/`, present on disk because the built cli runs\n450\t * from the repo).\n451\t */\n452\tfunction resolveEnv(projectRoot: string): {\n453\t  aliases: Record<string, string>;\n454\t  nodePaths: string[];\n455\t  designSystem: DesignSystem;\n456\t  /** `<@lmthing/ui>/src` — used by {@link uiElementsDirResolve} to fix esbuild's\n457\t   *  exact (no-index) resolution of the package's `./elements/*` directory exports. */\n458\t  uiSrcDir?: string;\n459\t} {\n460\t  const here = dirname(fileURLToPath(import.meta.url)); // src/app/build OR dist/…\n461\t  const cliRoot = findCliRoot(here);\n462\t\n463\t  const runtimeIndex = firstExisting([\n464\t    join(cliRoot, 'src', 'app', 'runtime', 'index.ts'),\n465\t    join(cliRoot, 'src', 'app', 'runtime', 'index.js'),\n466\t    join(cliRoot, 'src', 'app', 'runtime', 'index.tsx'),\n467\t    // Last-ditch: relative to this module (covers an unusual on-disk layout).\n468\t    join(here, '..', 'runtime', 'index.ts'),\n469\t    join(here, '..', 'runtime', 'index.js'),\n470\t  ]);\n471\t\n472\t  const req = createRequire(join(cliRoot, 'package.json'));\n473\t\n474\t  const aliases: Record<string, string> = {};\n475\t  if (runtimeIndex) aliases['@app/runtime'] = runtimeIndex;\n476\t  // Resolve React subpaths to concrete files so single-instancing + `jsx-runtime`\n477\t  // never depend on esbuild's exports-map walk from the scratch entry dir.\n478\t  for (const pkg of [\n479\t    'react',\n480\t    'react-dom',\n481\t    'react/jsx-runtime',\n482\t    'react/jsx-dev-runtime',\n483\t    'react-dom/client',\n484\t  ]) {\n485\t    try {\n486\t      aliases[pkg] = req.resolve(pkg);\n487\t    } catch {\n488\t      /* not present — leave to node_modules resolution below */\n489\t    }\n490\t  }\n491\t\n492\t  // Every node_modules from the cli root up to the fs root (pnpm hoists to the\n493\t  // workspace root), plus the project's own — so bare + subpath imports resolve.\n494\t  const nodePaths = [...nodeModulesUpward(cliRoot), join(projectRoot, 'node_modules')].filter((p) =>\n495\t    existsSync(p),\n496\t  );\n497\t  let uiSrcDir: string | undefined;\n498\t  try {\n499\t    uiSrcDir = dirname(req.resolve('@lmthing/ui')); // `.` export is `src/index.ts` → `<ui>/src`\n500\t  } catch {\n501\t    /* ui not resolvable — the plugin simply never matches */\n502\t  }\n503\t  return { aliases, nodePaths, designSystem: resolveDesignSystem(req), uiSrcDir };\n504\t}\n505\t\n506\t/**\n507\t * esbuild resolves subpaths through a package's `\"exports\"` map EXACTLY — no directory\n508\t * `index` fallback and no extension probing (matching Node's exports semantics). `@lmthing/ui`\n509\t * maps `\"./elements/*\": \"./src/elements/*\"`, and every element is a DIRECTORY with an\n510\t * `index.tsx` (`@lmthing/ui/elements/forms/input` → `src/elements/forms/input/index.tsx`), so\n511\t * the bare directory target fails to resolve (\"Could not resolve @lmthing/ui/elements/forms/input\").\n512\t * Vite (studio/chat) resolves it fine, so it went unnoticed until a project-app page pulled the\n513\t * chat UI in (`@app/runtime` → `Chat` → `@lmthing/ui/chat` → `IntegrationsTab` → `SettingsSchemaForm`)\n514\t * — which broke EVERY project-app page build. This plugin (project-app build ONLY, zero blast\n515\t * radius on the Vite surfaces) rewrites such a directory import to its concrete `index.*` file;\n516\t * a specifier that already resolves is left untouched (the plugin returns nothing and esbuild\n517\t * proceeds normally).\n518\t */\n519\texport function uiElementsDirResolve(uiSrcDir: string): Plugin {\n520\t  const prefix = '@lmthing/ui/elements/';\n521\t  return {\n522\t    name: 'lmthing-ui-elements-dir-resolve',\n523\t    setup(build) {\n524\t      build.onResolve({ filter: /^@lmthing\\/ui\\/elements\\// }, (args) => {\n525\t        const rest = args.path.slice(prefix.length); // e.g. \"forms/input\"\n526\t        for (const ext of ['index.tsx', 'index.ts', 'index.jsx', 'index.js']) {\n527\t          const candidate = join(uiSrcDir, 'elements', rest, ext);\n528\t          if (existsSync(candidate)) return { path: candidate };\n529\t        }\n530\t        return undefined; // not a directory-with-index — let esbuild resolve normally\n531\t      });\n532\t    },\n533\t  };\n534\t}\n535\t\n536\t/** Resolved design-system assets for the Tailwind CSS build. */\n537\tinterface DesignSystem {\n538\t  /** Absolute path to `@lmthing/css`'s theme stylesheet, if resolvable. */\n539\t  themeCss?: string;\n540\t  /** Source dirs to scan for Tailwind class candidates (`@lmthing/ui`/`@lmthing/css`). */\n541\t  sourceDirs: string[];\n542\t}\n543\t\n544\t/**\n545\t * Locate `@lmthing/css` (theme tokens/utilities) and the design-system source\n546\t * trees the Tailwind compiler must scan for used classes. Missing packages leave\n547\t * `themeCss` undefined — the build proceeds without the injected stylesheet rather\n548\t * than failing (mirrors the tiny React-only fixtures in tests).\n549\t */\n550\tfunction resolveDesignSystem(req: NodeRequire): DesignSystem {\n551\t  const sourceDirs: string[] = [];\n552\t  let themeCss: string | undefined;\n553\t  try {\n554\t    // `@lmthing/css` exports `./theme` → `src/theme.css`; scan its whole `src`.\n555\t    themeCss = req.resolve('@lmthing/css/theme');\n556\t    sourceDirs.push(dirname(themeCss));\n557\t  } catch {\n558\t    /* design system not resolvable (e.g. a minimal fixture) — skip */\n559\t  }\n560\t  try {\n561\t    // `@lmthing/ui` components carry raw utility classNames the theme must emit.\n562\t    // Its `.` export is `src/index.ts`, so its dir is the source tree to scan.\n563\t    sourceDirs.push(dirname(req.resolve('@lmthing/ui')));\n564\t  } catch {\n565\t    /* ui not resolvable — pages that avoid it still style correctly */\n566\t  }\n567\t  return { themeCss, sourceDirs };\n568\t}\n569\t\n570\t/** Walk up from `startDir` to the dir whose `package.json` is `@lmthing/cli`. */\n571\tfunction findCliRoot(startDir: string): string {\n572\t  let dir = startDir;\n573\t  for (;;) {\n574\t    const pkg = join(dir, 'package.json');\n575\t    if (existsSync(pkg)) {\n576\t      try {\n577\t        const { name } = JSON.parse(readFileSync(pkg, 'utf8')) as { name?: string };\n578\t        if (name === '@lmthing/cli') return dir;\n579\t      } catch {\n580\t        /* unreadable/!json — keep walking */\n581\t      }\n582\t    }\n583\t    const parent = dirname(dir);\n584\t    if (parent === dir) break; // fs root\n585\t    dir = parent;\n586\t  }\n587\t  // Fallback to the src layout (src/app/build → libs/cli).\n588\t  return join(startDir, '..', '..', '..');\n589\t}\n590\t\n591\t/** Collect every existing `node_modules` from `start` up to the filesystem root. */\n592\tfunction nodeModulesUpward(start: string): string[] {\n593\t  const out: string[] = [];\n594\t  let dir = start;\n595\t  for (;;) {\n596\t    const nm = join(dir, 'node_modules');\n597\t    if (existsSync(nm)) out.push(nm);\n598\t    const parent = dirname(dir);\n599\t    if (parent === dir) break;\n600\t    dir = parent;\n601\t  }\n602\t  return out;\n603\t}\n604\t\n605\tfunction firstExisting(paths: string[]): string | undefined {\n606\t  return paths.find((p) => existsSync(p));\n607\t}\n608\t\n609\t// ── Cache ─────────────────────────────────────────────────────────────────────\n610\t\n611\t/**\n612\t * Content hash of everything that affects the page bundle: `package.json` +\n613\t * every file under `pages/`/`components/`/`lib/` (path + bytes). Content-based\n614\t * (not mtime) so a write-then-immediate-rebuild in the same second still hits.\n615\t */\n616\tasync function sourceHash(projectRoot: string): Promise<string> {\n617\t  const hash = createHash('sha256');\n618\t  hash.update('builder\\0').update(BUILDER_VERSION).update('\\0');\n619\t  const pkg = join(projectRoot, 'package.json');\n620\t  if (existsSync(pkg)) hash.update('package.json\\0').update(await readFile(pkg));\n621\t  for (const sub of ['pages', 'components', 'lib']) {\n622\t    const dir = join(projectRoot, sub);\n623\t    const files = (await listFiles(dir)).sort();\n624\t    for (const f of files) {\n625\t      hash.update(relative(projectRoot, f).split(sep).join('/')).update('\\0').update(await readFile(f));\n626\t    }\n627\t  }\n628\t  return hash.digest('hex');\n629\t}\n630\t\n631\t/** Recursively list all files under `dir` (absolute paths); `[]` if absent. */\n632\tasync function listFiles(dir: string): Promise<string[]> {\n633\t  let entries: Dirent[];\n634\t  try {\n635\t    entries = await readdir(dir, { withFileTypes: true });\n636\t  } catch {\n637\t    return [];\n638\t  }\n639\t  const out: string[] = [];\n640\t  for (const entry of entries) {\n641\t    const abs = join(dir, entry.name);\n642\t    if (entry.isDirectory()) out.push(...(await listFiles(abs)));\n643\t    else if (entry.isFile()) out.push(abs);\n644\t  }\n645\t  return out;\n646\t}\n647\t\n648\tasync function readCache(cachePath: string): Promise<CacheMeta | null> {\n649\t  try {\n650\t    return JSON.parse(await readFile(cachePath, 'utf8')) as CacheMeta;\n651\t  } catch {\n652\t    return null;\n653\t  }\n654\t}\n655\t\n656\tasync function writeCache(cachePath: string, meta: CacheMeta): Promise<void> {\n657\t  await mkdir(dirname(cachePath), { recursive: true });\n658\t  await writeFile(cachePath, JSON.stringify(meta), 'utf8');\n659\t}\n660\t\n661\tasync function dirExists(p: string): Promise<boolean> {\n662\t  try {\n663\t    return (await stat(p)).isDirectory();\n664\t  } catch {\n665\t    return false;\n666\t  }\n667\t}\n668\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"6585018b-15d4-4bae-9d32-7e7dd0976474","timestamp":"2026-07-16T22:24:51.564Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
