ise<unknown>((resolve, reject) => {\n42\t      pushYield({\n43\t        kind: 'delegate',\n44\t        args: [packageName, agentName, resolvedAction, resolvedOpts],\n45\t        deferred: { resolve, reject },\n46\t        vmPromiseHandle: undefined,\n47\t      });\n48\t    });\n49\t  };\n50\t}\n51\t"}]},"parent_tool_use_id":null,"session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"4970e253-e853-4340-9191-df58f897f060","timestamp":"2026-07-16T06:16:57.909Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/globals/delegate.ts","content":"import type { YieldRequest } from '../eval/yield.js';\n\nexport interface DelegateOpts {\n  query?: string;\n  context?: unknown;\n  /** Upload ids of attachments (image/file) to hand to the delegated agent — the\n   *  session resolves these to the actual bytes and attaches them to the delegate's\n   *  message, so a vision/file agent's model receives the image/document. THING\n   *  reads the ids from its message (the server lists attached uploads by id). */\n  attachmentIds?: string[];\n}\n\n/**\n * Create the `delegate` global. Ends the current turn; runs a child agent.\n *\n * `action` is OPTIONAL: with an action id the child runs that action (its tasklist\n * if it has one); without one the child runs model-driven, sees its available\n * actions/tasklists in its system prompt, and may initiate a tasklist itself.\n * For ergonomics, `delegate(pkg, agent, opts)` (opts object in the action slot) is\n * accepted as the no-action form.\n */\nexport function createDelegateGlobal(\n  pushYield: (req: YieldRequest) => void,\n): (packageName: string, agentName: string, action?: string, opts?: DelegateOpts) => Promise<unknown> {\n  return function delegate(\n    packageName: string,\n    agentName: string,\n    action?: string | DelegateOpts,\n    opts?: DelegateOpts,\n  ): Promise<unknown> {\n    // Allow delegate(pkg, agent, opts) — opts passed positionally where action goes