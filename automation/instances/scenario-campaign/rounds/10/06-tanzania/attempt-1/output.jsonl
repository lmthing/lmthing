{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_k4DQBqm3svTCfn3qr6JdaVdf","type":"tool_result","content":"260\t\n261\t          // forEach: host-driven fan-out. Resolve the referenced upstream array and run the\n262\t          // task once per element (parallel, within the engine's concurrency cap), injecting\n263\t          // the element as `item` (+ `index`). Collect the resolved values into an array.\n264\t          if (task.forEach) {\n265\t            const items = resolveForEachItems(task.forEach, allOutputs);\n266\t            const output = await Promise.all(\n267\t              items.map((item, index) => {\n268\t                const elemScope = tracer && taskScope\n269\t                  ? tracer.child(taskScope, 'task', `fork:${task.id}[${index}]`, { tasklist: name, forEachIndex: index })\n270\t                  : undefined;\n271\t                return runFork({ item, index }, elemScope).then((meta) => {\n272\t                  if (meta.degraded) noteDegraded(`${task.id}[${index}]`, meta.reason);\n273\t                  if (tracer && elemScope) tracer.end(elemScope, 'done', { result: meta.value, ...(meta.degraded ? { degraded: true, reason: meta.reason } : {}) });\n274\t                  return meta.value;\n275\t                });\n276\t              }),\n277\t            );\n278\t            return { task, output };\n279\t          }\n280\t\n281\t          const meta = await runFork();\n282\t          if (meta.degraded) noteDegraded(task.id, meta.reason);\n283\t          return { task, output: meta.value };\n284\t        }),\n285\t      );\n286\t\n287\t      for (const result of results) {\n288\t        if (result.status === 'fulfilled') {\n289\t          const { task, output } = result.value;\n290\t          done.add(task.id);\n291\t          allOutputs[task.id] = output;\n292\t          if (tracer) { const ts = taskScopes.get(task.id); if (ts) tracer.end(ts, 'done', { result: output }); }\n293\t          if (goalTask && task.id === goalTask.id) goalOutput = output;\n294\t        } else {\n295\t          // Fork failed\n296\t          const failedTask = ready[results.indexOf(result)]!;\n297\t          const ts = taskScopes.get(failedTask.id);\n298\t          if (failedTask.optional) {\n299\t            skipped.add(failedTask.id);\n300\t            skippedEmitted.add(failedTask.id);\n301\t            if (tracer && ts) tracer.end(ts, 'skipped');\n302\t          } else {\n303\t            const errMsg = result.reason instanceof Error ? result.reason.message : String(result.reason);\n304\t            if (tracer && ts) tracer.end(ts, 'error', { error: errMsg });\n305\t            throw new Error(`Required task \"${failedTask.id}\" failed: ${errMsg}`);\n306\t          }\n307\t        }\n308\t      }\n309\t    }\n310\t\n311\t    // A skipped goal task means the pipeline short-circuited — an upstream\n312\t    // condition was not met — and produced NO result. Returning `undefined`\n313\t    // here would surface to the caller as a silent `null` delegate result with\n314\t    // no explanation (the exact failure that left the architect returning null).\n315\t    // Fail loudly instead, folding in any upstream `errors`/`error` fields so the\n316\t    // model sees WHY (e.g. a validation failure) and can react.\n317\t    if (goalTask && skipped.has(goalTask.id)) {\n318\t      const diagnostics = Object.entries(allOutputs)\n319\t        .map(([id, out]) => {\n320\t          if (out && typeof out === 'object') {\n321\t            const err = (out as Record<string, unknown>).errors ?? (out as Record<string, unknown>).error;\n322\t            if (typeof err === 'string' && err.trim()) return `${id}: ${err.trim()}`;\n323\t          }\n324\t          return null;\n325\t        })\n326\t        .filter((d): d is string => d !== null);\n327\t      const detail = diagnostics.length > 0 ? ` Upstream errors — ${diagnostics.join('; ')}` : '';\n328\t      throw new Error(\n329\t        `Tasklist \"${name}\" produced no result: its goal task \"${goalTask.id}\" was skipped ` +\n330\t          `because an upstream condition was not met.${detail}`,\n331\t      );\n332\t    }\n333\t\n334\t    // Wrap the goal output in a TaskEnvelope at the tasklist BOUNDARY:\n335\t    //   ok        — the goal task itself resolved un-salvaged\n336\t    //   degraded  — any salvage occurred anywhere in the DAG (incl. forEach elements)\n337\t    //   data      — the goal task's RAW schema output (salvaged fields are neutral empties)\n338\t    // Hard failures (stuck DAG, invalid seed, skipped goal, budget/timeout rejects)\n339\t    // still THROW above — they surface as retryable yield errors, unchanged.\n340\t    const envelope: TaskEnvelope = {\n341\t      ok: !goalDegraded,\n342\t      degraded: degradedTasks.length > 0,\n343\t      data: goalOutput,\n344\t      ...(goalDegraded ? { reason: goalReason ?? 'no_resolve' } : {}),\n345\t      ...(degradedTasks.length > 0 ? { degradedTasks } : {}),\n346\t    };\n347\t    if (tracer && tasklistScope) tracer.end(tasklistScope, 'done', { result: envelope });\n348\t    return envelope;\n349\t  } catch (err) {\n350\t    if (tracer && tasklistScope) tracer.end(tasklistScope, 'error', { error: err instanceof Error ? err.message : String(err) });\n351\t    throw err;\n352\t  }\n353\t}\n354\t"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"6af0a91d-8799-4397-9d9a-6f2252ccc8fe","timestamp":"2026-07-15T23:55:17.144Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_WnqPqXS6XCisyuYR8IfTxeb9","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport { ForkEngine, resolveTaskDelegate } from '../fork/fork.js';\n7\timport { loadSpace } from '../spaces/load.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamOpts } from '../eval/stream-types.js';\n11\t\n12\tconst tmpDirs: string[] = [];\n13\tafterAll(async () => { await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true }))); });\n14\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n15\t\n16\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n17\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-deleg-'));\n18\t  tmpDirs.push(dir);\n19\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n20\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'runner\\n', 'utf8');\n21\t  const tl = join(dir, 'tasklists', 'flow');\n22\t  await mkdir(tl, { recursive: true });\n23\t  for (const [n, c] of Object.entries(files)) await writeFile(join(tl, n), c, 'utf8');\n24\t  return dir;\n25\t}\n26\t\n27\tdescribe('resolveTaskDelegate (allowlist)', () => {\n28\t  it('allows a matching target and scopes the action', () => {\n29\t    const r = resolveTaskDelegate(['system-research/researcher#deep_research'], 'system-research', 'researcher');\n30\t    expect(r).toEqual({ allowedActions: ['deep_research'] });\n31\t  });\n32\t  it('allows ANY action when the entry has no #action', () => {\n33\t    expect(resolveTaskDelegate(['sp/ag'], 'sp', 'ag')).toEqual({ allowedActions: undefined });\n34\t  });\n35\t  it('denies a target not in the allowlist', () => {\n36\t    expect(resolveTaskDelegate(['sp/ag#x'], 'other', 'ag')).toBeNull();\n37\t    expect(resolveTaskDelegate(['sp/ag#x'], 'sp', 'nope')).toBeNull();\n38\t  });\n39\t});\n40\t\n41\tdescribe('delegate inside a task (canDelegateTo)', () => {\n42\t  it('routes an allowed delegate through the engine delegateRunner and returns its result', async () => {\n43\t    const dir = await makeTasklistSpace({\n44\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nCALL_T: delegate then resolve.`,\n45\t    });\n46\t    const space = await loadSpace(dir);\n47\t    const calls: Array<{ pkg: string; agent: string; action?: string; allowed?: string[] }> = [];\n48\t    // Turn 1: emit the delegate binding (it yields). Turn 2 (after `r` is bound from the resolved\n49\t    // delegate): emit the resolve. (A single mock that re-emits both each turn would re-delegate.)\n50\t    let turn = 0;\n51\t    const streamFn = createMockStreamFn(() => {\n52\t      turn++;\n53\t      if (turn === 1) return `const r = await delegate('helper', 'agent', 'act', { query: 'hi' });`;\n54\t      return `currentTask.resolve({ v: r.n });`;\n55\t    });\n56\t    const engine = new ForkEngine({\n57\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n58\t      renderHost: silentHost, streamFn,\n59\t      delegateRunner: async (pkg, agent, action, _opts, allowed) => {\n60\t        calls.push({ pkg, agent, action, allowed });\n61\t        return { n: 42 };\n62\t      },\n63\t    });\n64\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { v: number };\n65\t    expect(goal).toEqual({ v: 42 });\n66\t    expect(calls).toEqual([{ pkg: 'helper', agent: 'agent', action: 'act', allowed: ['act'] }]);\n67\t  });\n68\t\n69\t  it('blocks a delegate to a non-allowlisted target (runner never called; fork salvages)', async () => {\n70\t    const dir = await makeTasklistSpace({\n71\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nBAD_T: delegate to a forbidden target.`,\n72\t    });\n73\t    const space = await loadSpace(dir);\n74\t    let runnerCalls = 0;\n75\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n76\t      const u = o.messages.map((m) => m.content).join('\\n');\n77\t      // 'evil/agent' is NOT in canDelegateTo → the delegate yield throws, fork never resolves → salvage.\n78\t      if (u.includes('BAD_T')) return `const r = await delegate('evil', 'agent', 'act', { query: 'x' }) as { n: number };\\ncurrentTask.resolve({ v: r.n });`;\n79\t      return '';\n80\t    });\n81\t    const engine = new ForkEngine({\n82\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n83\t      renderHost: silentHost, streamFn,\n84\t      delegateRunner: async () => { runnerCalls++; return { n: 1 }; },\n85\t    });\n86\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n87\t    expect(runnerCalls).toBe(0);            // forbidden target never reached the runner\n88\t    expect(env.data).toEqual({ v: 0 });     // fork salvaged a NEUTRAL schema-valid placeholder\n89\t    expect(env.ok).toBe(false);             // …and the envelope signals the degradation\n90\t    expect(env.degraded).toBe(true);\n91\t  });\n92\t\n93\t  it('canDelegateTo: [\"*\"] gives the task an UNSCOPED delegate (any target routes to the runner)', async () => {\n94\t    const dir = await makeTasklistSpace({\n95\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"*\"\\noutput:\\n  v: number\\n---\\n\\nSTAR_T: delegate anywhere then resolve.`,\n96\t    });\n97\t    const space = await loadSpace(dir);\n98\t    const calls: Array<{ pkg: string; agent: string; allowed?: string[] }> = [];\n99\t    let turn = 0;\n100\t    const streamFn = createMockStreamFn(() => {\n101\t      turn++;\n102\t      if (turn === 1) return `const r = await delegate('any-space-at-all', 'whoever', 'act', { query: 'hi' });`;\n103\t      return `currentTask.resolve({ v: r.n });`;\n104\t    });\n105\t    const engine = new ForkEngine({\n106\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n107\t      renderHost: silentHost, streamFn,\n108\t      delegateRunner: async (pkg, agent, _action, _opts, allowed) => {\n109\t        calls.push({ pkg, agent, allowed });\n110\t        return { n: 7 };\n111\t      },\n112\t    });\n113\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n114\t    expect(env.ok).toBe(true);\n115\t    expect(env.data).toEqual({ v: 7 });\n116\t    // Unrestricted: no target gate, no action narrowing.\n117\t    expect(calls).toEqual([{ pkg: 'any-space-at-all', agent: 'whoever', allowed: undefined }]);\n118\t  });\n119\t\n120\t  it('canDelegateTo: [\"registered:*\"] admits a dynamicSpaces-registered target and blocks others', async () => {\n121\t    const dir = await makeTasklistSpace({\n122\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"registered:*\"\\noutput:\\n  v: number\\n---\\n\\nREG_T: delegate to the registered space.`,\n123\t    });\n124\t    const space = await loadSpace(dir);\n125\t    const regDir = '/dyn/built-space';\n126\t    const dynamicSpaces = new Map([[regDir, space]]); // any Space value; the gate matches keys/dirs\n127\t    const calls: string[] = [];\n128\t    let turn = 0;\n129\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n130\t      turn++;\n131\t      // Turn 1: an UNREGISTERED target — the gate throws (retryable error).\n132\t      if (turn === 1) return `const r = await delegate('never-registered', 'agent', 'act', { query: 'x' });`;\n133\t      // Turn 2 (retry with the ERROR block): the registered one.\n134\t      if (turn === 2) {\n135\t        const last = o.messages[o.messages.length - 1]?.content ?? '';\n136\t        if (!last.includes('is not permitted')) return `currentTask.resolve({ v: -1 });`;\n137\t        return `const r = await delegate('${regDir}', 'agent', 'act', { query: 'x' });`;\n138\t      }\n139\t      return `currentTask.resolve({ v: r.n });`;\n140\t    });\n141\t    const engine = new ForkEngine({\n142\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n143\t      renderHost: silentHost, streamFn, dynamicSpaces,\n144\t      delegateRunner: async (pkg) => { calls.push(pkg); return { n: 9 }; },\n145\t    });\n146\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n147\t    expect(env.ok).toBe(true);\n148\t    expect(env.data).toEqual({ v: 9 });\n149\t    expect(calls).toEqual([regDir]); // only the registered target reached the runner\n150\t  });\n151\t});\n152\t"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"bc710cb7-0afd-4d29-9304-4c393a3e358a","timestamp":"2026-07-15T23:55:17.145Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Qr78zZXAXX5eWeN94daONg3F","type":"tool_result","content":"1\timport type { YieldRequest } from '../eval/yield.js';\n2\t\n3\t/**\n4\t * Create the `tasklist` global. Ends the current turn; runs a named tasklist.\n5\t * Accepts an optional seed object to pass context variables to all fork tasks.\n6\t */\n7\texport function createTasklistGlobal(\n8\t  pushYield: (req: YieldRequest) => void,\n9\t): (name: string, seed?: Record<string, unknown>) => Promise<unknown> {\n10\t  return function tasklist(name: string, seed?: Record<string, unknown>): Promise<unknown> {\n11\t    return new Promise<unknown>((resolve, reject) => {\n12\t      pushYield({\n13\t        kind: 'tasklist',\n14\t        args: [name, seed],\n15\t        deferred: { resolve, reject },\n16\t        vmPromiseHandle: undefined,\n17\t      });\n18\t    });\n19\t  };\n20\t}\n21\t"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"44431970-23a5-4df0-8160-a46c6988edb8","timestamp":"2026-07-15T23:55:17.146Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_yAoCCSLaSzlGddDuVw3iuuP2","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport { ForkEngine } from '../fork/fork.js';\n7\timport { loadSpace } from '../spaces/load.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamOpts } from '../eval/stream-types.js';\n11\t\n12\t/**\n13\t * Coverage for the host-driven `forEach` map node and per-task `role`/`functions`\n14\t * scoping (the new authoring primitives). Drives the REAL runTasklist + ForkEngine\n15\t * with the scripted mock provider — no API keys.\n16\t */\n17\t\n18\tconst tmpDirs: string[] = [];\n19\tafterAll(async () => {\n20\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n21\t});\n22\t\n23\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n24\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-foreach-'));\n25\t  tmpDirs.push(dir);\n26\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n27\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n28\t  const tl = join(dir, 'tasklists', 'flow');\n29\t  await mkdir(tl, { recursive: true });\n30\t  for (const [name, contents] of Object.entries(files)) {\n31\t    await writeFile(join(tl, name), contents, 'utf8');\n32\t  }\n33\t  return dir;\n34\t}\n35\t\n36\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n37\t\n38\tdescribe('forEach map node', () => {\n39\t  it('fans a task out once per element and collects the results into an array', async () => {\n40\t    const dir = await makeTasklistSpace({\n41\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n42\t      '02-square.md': `---\\nid: square\\ndependsOn: [list]\\nforEach: list.items\\noutput:\\n  n: number\\n---\\n\\nSQUARE_T: square the item.`,\n43\t      '03-done.md': `---\\nid: done\\ndependsOn: [square]\\ngoal: true\\noutput:\\n  total: number\\n---\\n\\nDONE_T: sum the squares.`,\n44\t    });\n45\t    const space = await loadSpace(dir);\n46\t    const seen: string[] = [];\n47\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n48\t      const user = o.messages.map((m) => m.content).join('\\n');\n49\t      if (user.includes('LIST_T')) { seen.push('list'); return `currentTask.resolve({ items: [2, 3, 4] });`; }\n50\t      // Each per-element fork sees its element bound as `item`.\n51\t      if (user.includes('SQUARE_T')) { seen.push('square'); return `currentTask.resolve({ n: item * item });`; }\n52\t      // The dependent task receives `square` as the collected ARRAY of element outputs.\n53\t      if (user.includes('DONE_T')) { seen.push('done'); return `currentTask.resolve({ total: square.reduce((s: number, e: { n: number }) => s + e.n, 0) });`; }\n54\t      return '';\n55\t    });\n56\t    const engine = new ForkEngine({\n57\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n58\t      renderHost: silentHost, streamFn,\n59\t    });\n60\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n61\t    // 2²+3²+4² = 29\n62\t    expect(goal.data).toEqual({ total: 29 });\n63\t    expect(goal.ok).toBe(true);\n64\t    expect(goal.degraded).toBe(false);\n65\t    // square ran three times (one per element).\n66\t    expect(seen.filter((s) => s === 'square')).toHaveLength(3);\n67\t  });\n68\t\n69\t  it('runs zero element forks when the source array is empty', async () => {\n70\t    const dir = await makeTasklistSpace({\n71\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n72\t      '02-each.md': `---\\nid: each\\ndependsOn: [list]\\nforEach: list.items\\ngoal: true\\noutput:\\n  n: number\\n---\\n\\nEACH_T: per item.`,\n73\t    });\n74\t    const space = await loadSpace(dir);\n75\t    const seen: string[] = [];\n76\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n77\t      const user = o.messages.map((m) => m.content).join('\\n');\n78\t      if (user.includes('LIST_T')) return `currentTask.resolve({ items: [] });`;\n79\t      if (user.includes('EACH_T')) { seen.push('each'); return `currentTask.resolve({ n: 1 });`; }\n80\t      return '';\n81\t    });\n82\t    const engine = new ForkEngine({\n83\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n84\t      renderHost: silentHost, streamFn,\n85\t    });\n86\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n87\t    expect(goal.data).toEqual([]); // empty source → empty collected array\n88\t    expect(seen).toHaveLength(0); // no element forks dispatched\n89\t  });\n90\t});\n91\t\n92\tdescribe('charter + tasklist goal injection into task forks', () => {\n93\t  it('injects the parent charter and the tasklist goal, but never raw instruct.md', async () => {\n94\t    const dir = await mkdtemp(join(tmpdir(), 'lmthing-foreach-'));\n95\t    tmpDirs.push(dir);\n96\t    await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n97\t    await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'SECRET_INSTRUCT_BODY: route via delegate and ask the user.\\n', 'utf8');\n98\t    await writeFile(join(dir, 'agents', 'main', 'charter.md'), 'CHARTER_IDENTITY: you are a precise widget expert.\\n', 'utf8');\n99\t    const tl = join(dir, 'tasklists', 'flow');\n100\t    await mkdir(tl, { recursive: true });\n101\t    await writeFile(join(tl, 'index.md'), `---\\n---\\n\\nTASKLIST_GOAL: assemble the widget end to end.`, 'utf8');\n102\t    await writeFile(join(tl, '01-only.md'), `---\\nid: only\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nONLY_T: do the step.`, 'utf8');\n103\t    const space = await loadSpace(dir);\n104\t    let systemSeen = '';\n105\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n106\t      systemSeen = o.system ?? '';\n107\t      const user = o.messages.map((m) => m.content).join('\\n');\n108\t      if (user.includes('ONLY_T')) return `currentTask.resolve({ v: 1 });`;\n109\t      return '';\n110\t    });\n111\t    const engine = new ForkEngine({\n112\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n113\t      parentAgentCharter: space.agents['main']!.charterBody,\n114\t      renderHost: silentHost, streamFn,\n115\t    });\n116\t    await runTasklist({ name: 'flow', space, forkEngine: engine });\n117\t    expect(systemSeen).toContain('CHARTER_IDENTITY'); // charter injected\n118\t    expect(systemSeen).toContain('TASKLIST_GOAL'); // tasklist index.md goal injected\n119\t    expect(systemSeen).not.toContain('SECRET_INSTRUCT_BODY'); // instruct.md NOT injected into forks\n120\t  });\n121\t});\n122\t\n123\tdescribe('per-task role + functions scoping', () => {\n124\t  it('withholds all generic-fs prompt lines from a non-scratch task (fs is off every fork)', async () => {\n125\t    const dir = await makeTasklistSpace({\n126\t      '01-probe.md': `---\\nid: probe\\nrole: explore\\ngoal: true\\noutput:\\n  ok: boolean\\n---\\n\\nPROBE_T: read-only probe.`,\n127\t    });\n128\t    const space = await loadSpace(dir);\n129\t    let systemSeen = '';\n130\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n131\t      systemSeen = o.system ?? '';\n132\t      const user = o.messages.map((m) => m.content).join('\\n');\n133\t      if (user.includes('PROBE_T')) {\n134\t        // A read-only task must NOT reference writeFileRaw — it is now stripped from\n135\t        // the ambient DTS (allowWrite:false), so a stray call would fail typecheck.\n136\t        // The capability/DTS gate itself is pinned by bootstrap.test.ts + roles.test.ts;\n137\t        // this test owns the PROMPT gate below.\n138\t        return `currentTask.resolve({ ok: true });`;\n139\t      }\n140\t      return '';\n141\t    });\n142\t    const engine = new ForkEngine({\n143\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n144\t      renderHost: silentHost, streamFn,\n145\t    });\n146\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { ok: boolean };\n147\t    expect(goal.ok).toBe(true);\n148\t    // Prompt gate: a non-scratch fork's system prompt does NOT advertise the write\n149\t    // primitives (writeFileRaw/readFileRaw are gone entirely) and explicitly tells the\n150\t    // fork there is no filesystem and execShell is unavailable.\n151\t    expect(systemSeen).not.toMatch(/writeFileRaw|readFileRaw/);\n152\t    expect(systemSeen).toMatch(/NO filesystem/i);\n153\t    expect(systemSeen).toMatch(/execShell is unavailable/);\n154\t  });\n155\t\n156\t  it('injects + advertises only the allowlisted functions', async () => {\n157\t    const dir = await mkdtemp(join(tmpdir(), 'lmthing-foreach-'));\n158\t    tmpDirs.push(dir);\n159\t    await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n160\t    await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n161\t    await mkdir(join(dir, 'functions'), { recursive: true });\n162\t    await writeFile(join(dir, 'functions', 'allowedFn.ts'), 'export function allowedFn(): number { return 7; }\\n', 'utf8');\n163\t    await writeFile(join(dir, 'functions', 'deniedFn.ts'), 'export function deniedFn(): number { return 9; }\\n', 'utf8');\n164\t    const tl = join(dir, 'tasklists', 'flow');\n165\t    await mkdir(tl, { recursive: true });\n166\t    await writeFile(\n167\t      join(tl, '01-scoped.md'),\n168\t      `---\\nid: scoped\\nrole: general\\nfunctions: [allowedFn]\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nSCOPED_T: call the allowed fn.`,\n169\t      'utf8',\n170\t    );\n171\t    const space = await loadSpace(dir);\n172\t    let systemSeen = '';\n173\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n174\t      systemSeen = o.system ?? '';\n175\t      const user = o.messages.map((m) => m.content).join('\\n');\n176\t      if (user.includes('SCOPED_T')) return `currentTask.resolve({ v: allowedFn() });`;\n177\t      return '';\n178\t    });\n179\t    const engine = new ForkEngine({\n180\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n181\t      renderHost: silentHost, streamFn,\n182\t      agentFunctions: { allowedFn: 'export function allowedFn(): number { return 7; }', deniedFn: 'export function deniedFn(): number { return 9; }' },\n183\t    });\n184\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { v: number };\n185\t    expect(goal.v).toBe(7); // allowlisted fn injected + callable\n186\t    expect(systemSeen).toContain('allowedFn');\n187\t    expect(systemSeen).not.toContain('deniedFn'); // denied fn neither advertised nor injected\n188\t  });\n189\t});\n190\t"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"d0571a68-1dd8-4ba9-a9e2-811916c97ea8","timestamp":"2026-07-15T23:55:17.147Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Y7LCwEKjugdSItLMuRtx59n8","type":"tool_result","content":"90\t    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });\n91\t\n92\t    const write = await loadTasklistFromSpace(space, 'write_fact');\n93\t    expect(write['classify']!.role).toBe('explore'); // read-only classify\n94\t    expect(write['classify']!.capabilities).toBeUndefined();\n95\t    expect(write['write']!.role).toBe('general');\n96\t    expect(write['write']!.capabilities).toContain('db:write');\n97\t    expect(resolveGoalTask(write)!.id).toBe('write');\n98\t\n99\t    const retract = await loadTasklistFromSpace(space, 'retract_fact');\n100\t    expect(retract['locate']!.role).toBe('explore');\n101\t    expect(retract['remove']!.capabilities).toContain('db:write');\n102\t\n103\t    const answer = await loadTasklistFromSpace(space, 'answer_across_spaces');\n104\t    expect(answer['ask']!.forEach).toBe('split.subquestions');\n105\t    expect(answer['reason']!.capabilities).toContain('db:read');\n106\t    // the fan-out node delegates to registered spaces, not db-writes\n107\t    expect(answer['ask']!.capabilities).toBeUndefined();\n108\t\n109\t    const reconcile = await loadTasklistFromSpace(space, 'reconcile_conflict');\n110\t    expect(resolveGoalTask(reconcile)!.id).toBe('resolve');\n111\t    expect(reconcile['resolve']!.role).toBe('explore'); // pure reasoning, no writes\n112\t\n113\t    const organize = await loadTasklistFromSpace(space, 'organize_material');\n114\t    expect(space.tasklists['organize_material']!.input).toEqual({\n115\t      request: 'string', sourceSummary: 'string', attachmentIds: 'array', specialistFacts: 'string',\n116\t    });\n117\t    expect(organize['build_specialist']!.forEach).toBe('inventory.scopes');\n118\t    expect(organize['build_specialist']!.canDelegateTo).toEqual(['system-architect/architect#synthesize_and_run']);\n119\t    expect(organize['build_app']!.canDelegateTo).toEqual(['system-appbuilder/automator']);\n120\t    expect(resolveGoalTask(organize)!.id).toBe('build_app');\n121\t  });\n122\t\n123\t  it('user-memory migrate_to_app_db carries db:write on ONLY the migrate node', async () => {\n124\t    const space = await loadSpace(resolve(SYS, 'user-memory'), { requireAgents: false });\n125\t    // The agent declares db:write as the ceiling, exposed via the migrate action.\n126\t    expect(space.agents['memory']!.capabilities?.['db:write']).toBeDefined();\n127\t    expect(space.agents['memory']!.actions.some((a) => a.tasklist === 'migrate_to_app_db')).toBe(true);\n128\t\n129\t    const tasks = await loadTasklistFromSpace(space, 'migrate_to_app_db');\n130\t    expect(tasks['collect']!.capabilities).toEqual([]); // reads memory only — no db\n131\t    expect(tasks['migrate']!.capabilities).toContain('db:write');\n132\t    expect(tasks['forget']!.capabilities).toEqual([]); // tidies memory only — no db\n133\t    expect(resolveGoalTask(tasks)!.id).toBe('forget');\n134\t  });\n135\t\n136\t  it('architect synthesize_and_run uses forEach fan-out with valid roles', async () => {\n137\t    const space = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n138\t    const tasks = await loadTasklistFromSpace(space, 'synthesize_and_run');\n139\t    // build_field / build_function fan out over the design step's arrays.\n140\t    expect(tasks['build_field']!.forEach).toBe('design.fields');\n141\t    expect(tasks['build_function']!.forEach).toBe('design.functions');\n142\t    // Read-only steps are explore; file-writing steps are general.\n143\t    expect(tasks['design']!.role).toBe('explore');\n144\t    expect(tasks['build_field']!.role).toBe('general');\n145\t    expect(tasks['validate']!.role).toBe('explore');\n146\t    // Every role is one of the three profiles.\n147\t    for (const t of Object.values(tasks)) {\n148\t      if (t.role) expect(['explore', 'plan', 'general']).toContain(t.role);\n149\t    }\n150\t  });\n151\t\n152\t  it('appbuilder build_app fans out per-file with valid roles and a finalize goal', async () => {\n153\t    const space = await loadSpace(resolve(SYS, 'system-appbuilder'), { requireAgents: false });\n154\t    const tasks = await loadTasklistFromSpace(space, 'build_app');\n155\t    // design → create_project → per-file forEach builders → finalize (goal).\n156\t    expect(tasks['build_table']!.forEach).toBe('design.tables');\n157\t    expect(tasks['build_api']!.forEach).toBe('design.endpoints');\n158\t    expect(tasks['build_page']!.forEach).toBe('design.pages');\n159\t    expect(tasks['build_hook']!.forEach).toBe('design.hooks');\n160\t    // Every per-file step runs with write access (role general) under the architect's caps.\n161\t    for (const id of ['design', 'create_project', 'build_table', 'build_api', 'build_page', 'build_hook', 'finalize']) {\n162\t      expect(tasks[id]!.role).toBe('general');\n163\t    }\n164\t    // Optional builders don't sink the pipeline; the goal is finalize.\n165\t    expect(tasks['build_table']!.optional).toBe(true);\n166\t    expect(tasks['build_hook']!.optional).toBe(true);\n167\t    expect(resolveGoalTask(tasks)!.id).toBe('finalize');\n168\t    expect(space.tasklists['build_app']!.input).toEqual({ request: 'string' });\n169\t  });\n170\t\n171\t  it('architect tasklists declare input schemas matching what their callers pass', async () => {\n172\t    const space = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n173\t    // THING's build task / the architect instruct seed { topic, goal, research }.\n174\t    expect(space.tasklists['synthesize_and_run']!.input).toEqual({\n175\t      topic: 'string',\n176\t      goal: 'string',\n177\t      research: 'string',\n178\t    });\n179\t    // The architect instruct's Job 2 seeds { spaceKey, feedback }.\n180\t    expect(space.tasklists['iterate_space']!.input).toEqual({\n181\t      spaceKey: 'string',\n182\t      feedback: 'string',\n183\t    });\n184\t  });\n185\t\n186\t  it('research agent exposes shallow research + deep_research (forEach) actions', async () => {\n187\t    const space = await loadSpace(resolve(SYS, 'system-research'), { requireAgents: false });\n188\t    // deep_research: scope (broad search) -> plan -> investigate (forEach) -> synthesize -> summarize.\n189\t    const deep = await loadTasklistFromSpace(space, 'deep_research');\n190\t    expect(deep['scope']!.role).toBe('explore');\n191\t    expect(deep['scope']!.functions).toEqual(['webSearch']);\n192\t    expect(deep['investigate']!.forEach).toBe('plan.questions');\n193\t    expect(deep['investigate_a']).toBeUndefined();\n194\t    // synthesize clusters/dedupes but is no longer the goal — summarize writes the final report.\n195\t    expect(deep['synthesize']!.goal).toBeFalsy();\n196\t    expect(resolveGoalTask(deep)!.id).toBe('summarize');\n197\t    // research: a single shallow quick-answer task.\n198\t    const shallow = await loadTasklistFromSpace(space, 'research');\n199\t    expect(Object.keys(shallow)).toEqual(['answer']);\n200\t    expect(resolveGoalTask(shallow)!.id).toBe('answer');\n201\t  });\n202\t});\n203\t\n204\tdescribe('user-thing build_specialist (structural build pipeline)', () => {\n205\t  async function load(): Promise<{ space: Space; tasks: Record<string, TaskNode> }> {\n206\t    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });\n207\t    const tasks = await loadTasklistFromSpace(space, 'build_specialist');\n208\t    return { space, tasks };\n209\t  }\n210\t\n211\t  it('is a valid 2-task DAG (optional research → build goal) with the declared input schema', async () => {\n212\t    const { space, tasks } = await load();\n213\t    expect(() => validateDag(tasks)).not.toThrow();\n214\t    expect(Object.keys(tasks).sort()).toEqual(['build', 'research']);\n215\t    expect(space.tasklists['build_specialist']!.input).toEqual({ request: 'string' });\n216\t\n217\t    const research = tasks['research']!;\n218\t    expect(research.optional).toBe(true);\n219\t    expect(research.role).toBe('explore');\n220\t    expect(research.functions).toEqual([]);\n221\t    expect(research.output).toEqual({ report: 'object' });\n222\t    expect(research.canDelegateTo).toEqual(['system-research/researcher#deep_research']);\n223\t\n224\t    const build = tasks['build']!;\n225\t    expect(build.goal).toBe(true);\n226\t    expect(resolveGoalTask(tasks)!.id).toBe('build');\n227\t    expect(build.dependsOn).toEqual(['research']);\n228\t    expect(build.role).toBe('general');\n229\t    expect(build.functions).toEqual([]);\n230\t    expect(build.canDelegateTo).toEqual(['system-architect/architect#synthesize_and_run']);\n231\t  });\n232\t\n233\t  it(\"build's output schema mirrors the architect finalize task field-for-field\", async () => {\n234\t    const { tasks } = await load();\n235\t    const architect = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n236\t    const synth = await loadTasklistFromSpace(architect, 'synthesize_and_run');\n237\t    expect(tasks['build']!.output).toEqual(synth['finalize']!.output);\n238\t  });\n239\t\n240\t  it(\"research's prelude performs the delegation itself and typechecks against the fork ambient\", async () => {\n241\t    const { space, tasks } = await load();\n242\t    const research = tasks['research']!;\n243\t    expect(research.prelude).toBeTruthy();\n244\t    const stmts = splitPreludeStatements(research.prelude!);\n245\t    expect(stmts).toHaveLength(1);\n246\t    expect(stmts[0]).toContain(\"await delegate('system-research', 'researcher', 'deep_research'\");\n247\t    typecheckPrelude(research, space.tasklists['build_specialist']!, {});\n248\t  });\n249\t});\n250\t\n251\tdescribe('system-research preludes (deterministic gather moved to the host)', () => {\n252\t  it('every gather task ships a prelude with the expected statements; pure-reasoning tasks do not', async () => {\n253\t    const space = aw