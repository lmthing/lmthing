{
  "name": "integration-line",
  "version": "1.0.0",
  "private": true,
  "lmthing": {
    "kind": "integration",
    "title": "LINE",
    "tags": ["integration", "messaging"],
    "icon": "💬",
    "description": "Send LINE messages and reply to inbound LINE chats via THING.",
    "settings": {
      "type": "object",
      "properties": {
        "INTEGRATION_LINE_CHANNEL_ACCESS_TOKEN": { "type": "string", "title": "Channel access token", "format": "password" },
        "INTEGRATION_LINE_CHANNEL_SECRET": { "type": "string", "title": "Channel secret", "format": "password" }
      },
      "required": ["INTEGRATION_LINE_CHANNEL_ACCESS_TOKEN", "INTEGRATION_LINE_CHANNEL_SECRET"]
    },
    "connection": {
      "provider": "line",
      "apiBase": "https://api.line.me",
      "tokenEnv": "INTEGRATION_LINE_CHANNEL_ACCESS_TOKEN",
      "auth": { "kind": "bearer" }
    }
  }
}
