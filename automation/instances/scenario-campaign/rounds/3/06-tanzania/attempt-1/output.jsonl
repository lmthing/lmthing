{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_AM3XINp5jHZAE8wXIN96rI0N","type":"tool_result","content":"75\t   *  project functions. */\n76\t  writeProjectHook?: (slug: string, src: string) => AuthoringResult;\n77\t  writeProjectEvent?: (name: string, src: string) => AuthoringResult;\n78\t  writeProjectFunction?: (name: string, src: string) => AuthoringResult;\n79\t  /** LIVE-project table writer (the `db:schema` twin of the three above): writes\n80\t   *  `<projectRoot>/database/<name>.json` and re-derives the project's db. Without it a\n81\t   *  live project can never gain a data model — `writeTableSchema` only targets a catalog\n82\t   *  template, and a project with no `database/*.json` boots NO db at all. */\n83\t  writeProjectTable?: (name: string, schema: unknown) => AuthoringResult;\n84\t  /** LIVE-project page/API writers (the `pages:write`/`api:write` twins): write\n85\t   *  `<projectRoot>/pages/<route>.tsx` / `<projectRoot>/api/<path>/<METHOD>.ts` and\n86\t   *  rebuild the served app. Without them a live project can gain a data model +\n87\t   *  automation but never a UI — \"turn this into an app I can open\" dead-ends (scenario 05). */\n88\t  writeProjectPage?: (route: string, src: string, opts?: { replace?: boolean }) => AuthoringResult;\n89\t  writeProjectApi?: (route: string, src: string) => AuthoringResult;\n90\t  /** LIVE-project shared-component writer (the `pages:write` twin of `writeProjectPage`):\n91\t   *  writes `<projectRoot>/components/<Name>.tsx` and rebuilds the served app. The typed\n92\t   *  surface for shared UI — there is no space-rooted fs writer for it anymore. */\n93\t  writeProjectComponent?: (name: string, src: string) => AuthoringResult;\n94\t  /** LIVE-project INTROSPECTION reads (the read-side twins of the `writeProject*` writers):\n95\t   *  `listProjectDir(dir)` lists the files under `<projectRoot>/<dir>` (e.g. 'database',\n96\t   *  'hooks', 'events', 'pages', 'api') and `readProjectFile(path)`