{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_nTU1u22ldG1EQekDdbBrjE4Y","type":"tool_result","content":"250\t    history.append({\n251\t      role: 'user',\n252\t      content: userMessage,\n253\t      ...(opts.attachments && opts.attachments.length ? { attachments: opts.attachments } : {}),\n254\t      blockType: 'normal',\n255\t    });\n256\t\n257\t    // Ambient DTS via the shared additive builder: library minus `ask`, this\n258\t    // agent's function/component overlay, the currentTask capture global, and\n259\t    // the query/context seed variables (injected as real VM variables above so\n260\t    // an agent can seed its tasklist with structured data handed down by the\n261\t    // delegator instead of re-serializing it from prose).\n262\t    const overlay = buildOverlay({ ...systemFnSources, ...agentFunctions }, agentComponents);\n263\t    const ambientDts = buildAmbientDts({\n264\t      capabilities,\n265\t      overlay,\n266\t      currentTask: true,\n267\t      projectRoot: !!opts.projectRoot,\n268\t      extraDecls: [`declare const query: string;\\ndeclare const context: Record<string, any>;`],\n269\t    });\n270\t\n271\t    // Runs a child delegate — from this agent's top level OR from one of its tasks' forks —\n272\t    // one level deeper, with the recursion cap enforced by runDelegate's depth/maxDepth.\n273\t    // Spreading opts forwards the inherited parent context (budgetLimits/roleModels/\n274\t    // dynamicSpaces/projectSpacesDir/…) down arbitrary nesting.\n275\t    const runChildDelegate = (\n276\t      packageName: string,\n277\t      agentName: string,\n278\t      action: string | undefined,\n279\t      childOpts: DelegateOpts | undefined,\n280\t      allowedActions: string[] | undefined,\n281\t    ): Promise<unknown> =>\n282\t      runDelegate({\n283\t        ...opts,\n284\t        packageName,\n285\t        agentName,\n286\t        action,\n287\t        allowedActions,\n288\t        delegateOpts: childOpts,\n289\t        scope: delegateScope,\n290\t        depth: opts.depth + 1,\n291\t      });\n292\t\n293\t    const { ForkEngine } = await import('../fork/fork.js');\n294\t    // THE A1 FIX: the delegate-side ForkEngine is built through the same\n295\t    // exhaustively-typed options builder as the session's, so it can no longer\n296\t    // silently drop fields — it now inherits budgetLimits (leaf forks get real\n297\t    // budgets + the near-limit nudge), roleModels (right per-role model),\n298\t    // forkDepth (meaningful nesting accounting) and dynamicSpaces (a fork's\n299\t    // registerSpace() propagates back to the session) from its parent context.\n300\t    const forkEngine = new ForkEngine(forkEngineOptsFrom({\n301\t      maxConcurrentForks: opts.maxConcurrentForks,\n302\t      parentHistory: history.messages,\n303\t      parentSpaceDir: space.dir,\n304\t      parentAgentSlug: agent.slug,\n305\t      parentAgentCharter: agent.charterBody,\n306\t      agentFunctions: functions,\n307\t      agentFunctionsBundled: functionsBundled,\n308\t      renderHost: opts.renderHost,\n309\t      streamFn: opts.streamFn,\n310\t      clock: opts.clock,\n311\t      tracer: opts.tracer,\n312\t      projectSpacesDir: opts.projectSpacesDir,\n313\t      projectRoot: opts.projectRoot,\n314\t      projectId: opts.projectId,\n315\t      // This delegate's forks inherit ITS app grants (role-intersected in forkCapabilities).\n316\t      parentAppCapabilities: capabilities.app,\n317\t      appGlobals: opts.appGlobals,\n318\t      defaultModel: opts.model,\n319\t      budgetLimits: opts.budgetLimits,\n320\t      roleModels: opts.roleModels,\n321\t      // Forks spawned by this delegate nest one level below its delegation depth:\n322\t      // a top-level delegate (depth 0) spawns depth-1 forks (same as session forks);\n323\t      // each nested delegate layer pushes its forks one level deeper.\n324\t      forkDepth: opts.depth + 1,\n325\t      dynamicSpaces: opts.dynamicSpaces,\n326\t      // A task in this agent's tasklist may delegate (gated by its own canDelegateTo); route it\n327\t      // through the same depth-incrementing runner this agent uses for its own delegate() calls.\n328\t      delegateRunner: (packageName, agentName2, action, childOpts, allowedActions) =>\n329\t        runChildDelegate(packageName, agentName2, action, childOpts as DelegateOpts | undefined, allowedActions),\n330\t      // Forks under this delegate may read attachments too — thread the resolver.\n331\t      documentResolver: opts.documentResolver,\n332\t    }));\n333\t\n334\t    try {\n335\t      await runTurnLoop({\n336\t        vm,\n337\t        history,\n338\t        systemBlock,\n339\t        ambientDts,\n340\t        renderHost: opts.renderHost,\n341\t        streamFn: opts.streamFn,\n342\t        processYield: async (req) => {\n343\t          // sleep / fork / tasklist / delegate share the central router. The two\n344\t          // delegate-specific behaviours are passed as hooks: auto-capture of the\n345\t          // action's tasklist result, and depth-incremented recursion.\n346\t          const routed = await routeCommonYield(req, {\n347\t            space,\n348\t            clock: opts.clock,\n349\t            tracer: opts.tracer,\n350\t            scope: delegateScope,\n351\t            apiCallResolver: opts.appGlobals?.apiCall,\n352\t            apiCallAllow: capabilities.app['api:call']?.allow,\n353\t            connectionResolver: opts.appGlobals?.callConnection,\n354\t            documentResolver: opts.documentResolver,\n355\t            // Store search/inspect + manual emits work in delegates (system-store\n356\t            // runs AS a delegate of THING); consent-marked kinds (installSpace)\n357\t            // still FAIL CLOSED here — no requestConsent is wired (delegates are\n358\t            // headless), so the router's consent gate refuses before install.\n359\t            storeResolver: opts.appGlobals?.store,\n360\t            emitEventResolver: opts.appGlobals?.emitEvent,\n361\t            // installSpace live-registers into the session-shared map (visible to\n362\t            // the parent's later delegate()) — same reference forks receive.\n363\t            dynamicSpaces: opts.dynamicSpaces,\n364\t            getForkEngine: () => forkEngine,\n365\t            // `result` is the tasklist's TaskEnvelope ({ ok, degraded, data, … })\n366\t            // since Phase 3 — captured and returned UNTOUCHED, so the delegator\n367\t            // sees the same envelope contract as a direct tasklist() caller.\n368\t            onTasklistResult: (name, result) => {\n369\t              if (capturableTasklists.has(name) && !resultCaptured) {\n370\t                capturedResult = result;\n371\t                resultCaptured = true;\n372\t              }\n373\t            },\n374\t            runDelegate: (packageName, agentName, action, delegateOpts2) => {\n375\t              // Yield-time canDelegateTo gate (unified semantics): this agent's\n376\t              // policy decides whether the target is callable at all — an\n377\t              // out-of-list target throws an actionable, retryable error naming\n378\t              // the allowed targets. `registered:*` consults the session-shared\n379\t              // dynamicSpaces map at call time. On an allowlist match, the\n380\t              // entries' `#action` suffixes narrow the allowed actions (the same\n381\t              // enforcement the old directDeps lookup fed into runDelegate).\n382\t              const allow = isDelegateAllowed(delegatePolicy, packageName, agentName, opts.dynamicSpaces);\n383\t              if (!allow.allowed) {\n384\t                throw new Error(formatDelegateDenial(delegatePolicy, packageName, agentName, 'agent'));\n385\t              }\n386\t              return runChildDelegate(packageName, agentName, action, delegateOpts2, allow.allowedActions);\n387\t            },\n388\t          });\n389\t          return routed.handled ? routed.value : undefined;\n390\t        },\n391\t        maxRetries: 3,\n392\t        tracer: tracer,\n393\t        traceContext: delegateLabel,\n394\t        scope: delegateScope,\n395\t        model: turnModel,\n396\t      });\n397\t      // GUARANTEE (mirrors fork.ts): a delegate whose model finished without calling\n398\t      // currentTask.resolve() — and without running a capturable tasklist — must not\n399\t      // hand `undefined` back to the delegator. The live E4 failure: the engineer did\n400\t      // all the work (wrote files, ran tests) but never resolved, the delegator got\n401\t      // null twice, gave up on the specialist, and improvised the work inline. Force\n402\t      // resolve-only turns with a fresh small budget before returning.\n403\t      for (let nudge = 0; nudge < 2 && !resultCaptured; nudge++) {\n404\t        opts.renderHost.log(`[delegate] no resolve — forcing resolve (attempt ${nudge + 1})`);\n405\t        history.append({\n406\t          role: 'user',\n407\t          content: [\n408\t            'STOP. Do NOT run any more tools, searches, shell commands, or edits.',\n409\t            'You must return your result THIS TURN by calling currentTask.resolve().',\n410\t            'Emit EXACTLY ONE statement: a single currentTask.resolve({...}) call that',\n411\t            'packages the deliverable you already produced above (the code you wrote,',\n412\t            'the answer you found, the files you created — reference bound variables',\n413\t            'where possible). Returning a result is REQUIRED; any other code is rejected.',\n414\t          ].join('\\n'),\n415\t          blockType: 'normal',\n416\t        });\n417\t        try {\n418\t          await runTurnLoop({\n419\t            vm,\n420\t            history,\n421\t            systemBlock,\n422\t            ambientDts,\n423\t            renderHost: opts.renderHost,\n424\t            streamFn: opts.streamFn,\n425\t            processYield: async () => undefined, // resolve-only turns: no yields serviced\n426\t            maxRetries: 3,\n427\t            budget: new Budget({ maxEpisodes: 4 }),\n428\t            tracer: tracer,\n429\t            traceContext: `${delegateLabel}:resolve_nudge`,\n430\t            scope: delegateScope,\n431\t            model: turnModel,\n432\t          });\n433\t        } catch (err) {\n434\t          if (!(err instanceof BudgetExceededError)) throw err;\n435\t        }\n436\t      }\n437\t      tracer.end(delegateScope, 'done', resultCaptured ? { result: capturedResult } : undefined);\n438\t    } catch (err) {\n439\t      tracer.end(delegateScope, 'error', { error: err instanceof Error ? err.message : String(err) });\n440\t      throw err;\n441\t    }\n442\t\n443\t    return resultCaptured ? capturedResult : undefined;\n444\t  } finally {\n445\t    vm.dispose();\n446\t  }\n447\t}\n448\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"647842ac-fb98-4206-b465-a0b5c793ea33","timestamp":"2026-07-16T22:24:33.955Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_7QgsGzl8WKalJ4ikBHt2bEBl","type":"tool_result","content":"620\t    return mergeSystemInto(userSpace, this.systemSpaces);\n621\t  }\n622\t\n623\t  /**\n624\t   * Build the function maps injected into the VM (and, via the same map, the DTS\n625\t   * overlay + forks): system functions are always present (universal capability),\n626\t   * PROJECT functions overlay them, then agent-declared SPACE functions overlay\n627\t   * both. Because a SPACE function of the same name WINS over a project function\n628\t   * (see scopeProjectFunctions — colliding project fns are dropped + warned), the\n629\t   * merged set stays name-disjoint, so the overlay never double-declares.\n630\t   * Project functions are present only for project-rooted sessions (the caller\n631\t   * populates `projectFunctions` from `<projectRoot>/functions/`); a legacy\n632\t   * session's map is byte-identical to before.\n633\t   */\n634\t  private buildInjectedFunctions(space: Space, agent: import('../spaces/load.js').AgentDef): {\n635\t    functions: Record<string, string>;\n636\t    functionsBundled: Record<string, string>;\n637\t  } {\n638\t    const systemFns = systemFunctionSources(this.systemSpaces);\n639\t    const systemBundled = systemFunctionsBundled(this.systemSpaces);\n640\t    const spaceFns = getAgentFunctions(space, agent);\n641\t    const spaceBundled = getAgentFunctionsBundled(space, agent);\n642\t\n643\t    // Third scope: project functions, minus any name already taken by the system\n644\t    // toolkit or the agent's selected space functions (space/system wins).\n645\t    const scoped = this.opts.projectFunctions\n646\t      ? scopeProjectFunctions(\n647\t          {\n648\t            functions: this.opts.projectFunctions,\n649\t            functionsBundled: this.opts.projectFunctionsBundled ?? {},\n650\t          },\n651\t          new Set([...Object.keys(systemFns), ...Object.keys(spaceFns)]),\n652\t          (name) =>\n653\t            this.opts.renderHost.log(\n654\t              `[warn] project function \"${name}\" is shadowed by a space/system function of the same name — the project version is ignored`,\n655\t            ),\n656\t        )\n657\t      : { functions: {}, functionsBundled: {} };\n658\t\n659\t    return {\n660\t      functions: { ...systemFns, ...scoped.functions, ...spaceFns },\n661\t      functionsBundled: { ...systemBundled, ...scoped.functionsBundled, ...spaceBundled },\n662\t    };\n663\t  }\n664\t\n665\t  /**\n666\t   * Create the top-level session VM via the shared exec bootstrap: full\n667\t   * capability profile (interactive ask, fork/tasklist/delegate/registerSpace),\n668\t   * host tools with a live budget-backed progress(), the merged function set,\n669\t   * and the JSX runtime with the agent's component stubs.\n670\t   */\n671\t  private async createSessionVM(\n672\t    functions: Record<string, string>,\n673\t    functionsBundled: Record<string, string>,\n674\t    componentNames: string[],\n675\t    seedVars?: Record<string, unknown>,\n676\t  ): Promise<VM> {\n677\t    return createChildVM({\n678\t      // `delegate` follows the agent's canDelegateTo policy (mode 'none' ⇒ the\n679\t      // global is withheld here AND absent from the ambient DTS built above).\n680\t      capabilities: sessionCapabilities(this.delegatePolicy.mode !== 'none', this.appCapabilities),\n681\t      renderHost: this.opts.renderHost,\n682\t      clock: this.opts.clock,\n683\t      spaceDir: this.opts.spaceDir,\n684\t      projectSpacesDir: this.opts.projectSpacesDir,\n685\t      projectRoot: this.opts.projectRoot,\n686\t      projectId: this.opts.projectId,\n687\t      appGlobals: this.opts.appGlobals,\n688\t      // `progress` reads the live per-run budget (the closure dereferences the\n689\t      // field, so resetting this.budget per task is reflected).\n690\t      progress: () => this.budget.snapshot(),\n691\t      functions,\n692\t      functionsBundled,\n693\t      componentNames,\n694\t      onDisplay: (value) => {\n695\t        const scope = this.currentScope;\n696\t        this.tracer.write({ ts: Date.now(), type: 'display', context: scope?.label ?? 'session', ...(scope ? { nodeId: scope.nodeId } : {}), descriptor: value });\n697\t      },\n698\t      // setActivity from the top-level session VM is always the MAIN \"currently\n699\t      // doing\" line (forks/delegates run in their own VMs with their own hooks).\n700\t      onActivity: (text) => {\n701\t        const scope = this.currentScope;\n702\t        this.tracer.write({ ts: Date.now(), type: 'activity', context: scope?.label ?? 'session', ...(scope ? { nodeId: scope.nodeId } : {}), scope: 'session', text });\n703\t      },\n704\t      // setSessionMeta (fire-and-forget): record + emit the session_meta trace event\n705\t      // inline, without ending the turn.\n706\t      onSessionMeta: (meta) => this.recordSessionMeta(meta),\n707\t      seedVars,\n708\t      onFunctionError: (name, error) => {\n709\t        this.opts.renderHost.log(`[warn] failed to inject function \"${name}\": ${error}`);\n710\t      },\n711\t    });\n712\t  }\n713\t\n714\t  /**\n715\t   * Run a delegate requested by a TASK FORK (gated by that task's `canDelegateTo`). Mirrors the\n716\t   * runtime-context `runDelegate` but sources the space from `this.space` and forwards the task's\n717\t   * `allowedActions`, one recursion level deep (bounded by runDelegate's maxDepth).\n718\t   */\n719\t  private async runDelegateForFork(\n720\t    packageName: string,\n721\t    agentName: string,\n722\t    action: string | undefined,\n723\t    delegateOpts: unknown,\n724\t    allowedActions: string[] | undefined,\n725\t  ): Promise<unknown> {\n726\t    const space = this.space;\n727\t    if (!space) throw new Error('delegate from a task requires a loaded space');\n728\t    const { runDelegate } = await import('../delegate/delegate.js');\n729\t    const { DelegateRegistry } = await import('../delegate/registry.js');\n730\t    const spaceMap = new Map<string, Space>([[this.opts.spaceDir, space]]);\n731\t    for (const [pkgName, depSpace] of Object.entries(space.dependentSpaces)) {\n732\t      spaceMap.set(pkgName, depSpace);\n733\t      spaceMap.set(depSpace.dir, depSpace);\n734\t    }\n735\t    for (const sysSpace of this.systemSpaces) {\n736\t      spaceMap.set(sysSpace.dir, sysSpace);\n737\t      if (sysSpace.packageName) spaceMap.set(sysSpace.packageName, sysSpace);\n738\t    }\n739\t    for (const [key, dynSpace] of this.dynamicSpaces) spaceMap.set(key, dynSpace);\n740\t    return runDelegate({\n741\t      packageName,\n742\t      agentName,\n743\t      action,\n744\t      allowedActions,\n745\t      delegateOpts: delegateOpts as import('../globals/delegate.js').DelegateOpts | undefined,\n746\t      registry: new DelegateRegistry(spaceMap),\n747\t      renderHost: this.opts.renderHost,\n748\t      streamFn: this.deps.streamFn,\n749\t      depth: 1,\n750\t      maxDepth: 5,\n751\t      maxConcurrentForks: this.opts.maxConcurrentForks ?? 4,\n752\t      clock: this.opts.clock,\n753\t      tracer: this.tracer,\n754\t      scope: this.currentScope ?? undefined,\n755\t      systemSpaces: this.systemSpaces,\n756\t      projectSpacesDir: this.opts.projectSpacesDir,\n757\t      projectRoot: this.opts.projectRoot,\n758\t      projectId: this.opts.projectId,\n759\t      appGlobals: this.opts.appGlobals,\n760\t      model: this.opts.modelAlias,\n761\t      // Inherit the session's fork wiring down the delegation chain (A1 fix):\n762\t      // budget caps + role models for the delegate's leaf forks, and the SHARED\n763\t      // dynamicSpaces map so registerSpace() under the delegate propagates back.\n764\t      budgetLimits: this.opts.budget,\n765\t      roleModels: this.opts.roleModels,\n766\t      dynamicSpaces: this.dynamicSpaces,\n767\t      documentResolver: this.opts.documentResolver,\n768\t    });\n769\t  }\n770\t\n771\t  /**\n772\t   * Lazily construct and cache the session's ForkEngine. Shared across fork and\n773\t   * tasklist yields so concurrency is bounded globally rather than per-yield.\n774\t   * Built via forkEngineOptsFrom — the exhaustively-typed options builder shared\n775\t   * with the delegate wiring site — so the two option lists cannot drift (A1).\n776\t   */\n777\t  private async getForkEngine(): Promise<import('../fork/fork.js').ForkEngine> {\n778\t    if (this.forkEngine) return this.forkEngine;\n779\t    const { ForkEngine } = await import('../fork/fork.js');\n780\t    // Resolve the running agent's charter (fork-safe identity) to inject into every fork.\n781\t    const agents = this.space?.agents ?? {};\n782\t    const fkSlug = this.opts.agentSlug === 'default' && !agents['default']\n783\t      ? (Object.keys(agents)[0] ?? this.opts.agentSlug)\n784\t      : this.opts.agentSlug;\n785\t    this.forkEngine = new ForkEngine(forkEngineOptsFrom({\n786\t      maxConcurrentForks: this.opts.maxConcurrentForks ?? 4,\n787\t      parentHistory: this.history.messages,\n788\t      parentSpaceDir: this.opts.spaceDir,\n789\t      parentAgentSlug: this.opts.agentSlug,\n790\t      parentAgentCharter: agents[fkSlug]?.charterBody,\n791\t      renderHost: this.opts.renderHost,\n792\t      streamFn: this.deps.streamFn,\n793\t      clock: this.opts.clock,\n794\t      tracer: this.tracer,\n795\t      agentFunctions: this.agentFunctions,\n796\t      agentFunctionsBundled: this.agentFunctionsBundled,\n797\t      budgetLimits: this.opts.budget,\n798\t      // Session forks are top-level: ForkEngine defaults their depth to 1.\n799\t      forkDepth: undefined,"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"78c3b6e9-273a-4c75-ae97-fe290d452125","timestamp":"2026-07-16T22:24:33.956Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Ns5nGy7510ldaaTaSXW4pyiA","type":"tool_result","content":"1\timport type { RenderHost, Clock } from '../session/types.js';\n2\timport type { StreamOpts, StreamSession } from '../eval/stream-types.js';\n3\timport type { Message } from '../context/history.js';\n4\timport type { VM } from '../sandbox/quickjs.js';\n5\timport { MessageHistory } from '../context/history.js';\n6\timport { runTurnLoop } from '../eval/turn-loop.js';\n7\timport { routeCommonYield, type YieldRouterContext } from '../eval/yield-router.js';\n8\timport { rolePreamble, modelForRole, type RoleModelConfig } from './roles.js';\n9\timport { buildOverlay, extractFunctionSignature } from '../typecheck/overlay.js';\n10\timport { validateOutput } from '../tasklist/schema.js';\n11\timport { NULL_TRACER } from '../sandbox/trace.js';\n12\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n13\timport { Budget, BudgetExceededError, type BudgetLimits } from '../eval/budget.js';\n14\timport { forkCapabilities, narrowAppCaps } from '../exec/capability.js';\n15\timport type { AppCapabilities } from '../spaces/capabilities.js';\n16\timport { createChildVM, buildAmbientDts } from '../exec/bootstrap.js';\n17\timport type { AppGlobalImpls } from '../exec/app-globals.js';\n18\timport type { DocumentResolver } from '../globals/read-document.js';\n19\timport { resolveTaskDelegate, evaluateDelegatePolicy, isDelegateAllowed, formatDelegateDenial } from '../exec/target-match.js';\n20\timport { STATEMENT_PROTOCOL } from '../exec/preamble.js';\n21\timport { salvageData, type DegradeReason } from '../exec/envelope.js';\n22\timport { runPrelude } from '../exec/prelude.js';\n23\t\n24\t// Re-exported for compatibility: the allowlist matcher moved to exec/target-match.ts\n25\t// (Phase 2 exec unification) but was historically imported from fork.ts.\n26\texport { resolveTaskDelegate };\n27\t\n28\t/** Per-fork degradation metadata surfaced by `forkWithMeta` (Phase 3 envelopes). */\n29\texport interface ForkResultMeta<T = unknown> {\n30\t  value: T;\n31\t  /** true when the value was salvaged (the model never produced a schema-valid resolve). */\n32\t  degraded: boolean;\n33\t  reason?: DegradeReason;\n34\t}\n35\t\n36\t/** DTS type for one upstream task value, derived from its declared `output` schema\n37\t *  ({ field -> type }). Array-valued fields become `any[]` so a callback over them\n38\t *  (`.map`/`.find`/`.filter`) gets a contextual element type instead of an implicit-any\n39\t *  (TS7006) that would abort the fork under strict typecheck. An absent schema → `any`. */\n40\texport function taskOutputDts(schema?: Record<string, string>): string {\n41\t  if (!schema || Object.keys(schema).length === 0) return 'any';\n42\t  const fields = Object.entries(schema).map(([name, rawType]) => {\n43\t    const optional = rawType.endsWith('?') ? '?' : '';\n44\t    const type = rawType.replace(/\\?$/, '').trim().toLowerCase();\n45\t    const dts =\n46\t      type === 'string' ? 'string'\n47\t      : type === 'number' ? 'number'\n48\t      : type === 'boolean' ? 'boolean'\n49\t      : type === 'string[]' ? 'string[]'\n50\t      : type === 'number[]' ? 'number[]'\n51\t      : type === 'boolean[]' ? 'boolean[]'\n52\t      : type === 'array' || type.endsWith('[]') ? 'any[]'\n53\t      : type === 'object' ? 'Record<string, unknown>'\n54\t      : 'any';\n55\t    return `${JSON.stringify(name)}${optional}: ${dts}`;\n56\t  });\n57\t  return `{ ${fields.join('; ')} }`;\n58\t}\n59\t\n60\t/** Declared shape of one upstream dependency for typing: its `output` schema plus\n61\t *  whether that dependency is a `forEach` node (whose value is an ARRAY of that shape). */\n62\texport interface UpstreamOutputSchema {\n63\t  fields: Record<string, string>;\n64\t  isArray: boolean;\n65\t}\n66\t\n67\texport interface ForkTask {\n68\t  instruction: string;\n69\t  output: Record<string, string>;\n70\t  seed?: Record<string, unknown>;\n71\t  timeout?: number;\n72\t  taskId?: string;\n73\t  upstreamOutputs?: Record<string, unknown>;\n74\t  /** Declared output schemas for upstream task values, keyed by task id — used to give\n75\t   *  each `declare const <id>` a real type (so callbacks over array outputs don't TS7006).\n76\t   *  A `forEach` dependency is typed `Array<…>` since its collected value is an array. */\n77\t  upstreamOutputSchemas?: Record<string, UpstreamOutputSchema>;\n78\t  /** Subagent role controlling capability profile + system-prompt preamble. */\n79\t  role?: 'explore' | 'plan' | 'general';\n80\t  /** Allowlist of space-function names to inject + advertise (least privilege). When set,\n81\t   *  only these of the engine's agentFunctions are injected and listed; omit for all. */\n82\t  functions?: string[];\n83\t  /** Overall tasklist goal (tasklists/<name>/index.md body), injected as standing context\n84\t   *  so an isolated task knows the pipeline it serves. */\n85\t  tasklistDescription?: string;\n86\t  /** Per-task delegation policy (unified canDelegateTo semantics — see\n87\t   *  exec/target-match.ts `evaluateDelegatePolicy`). Entries `\"space/agent\"`\n88\t   *  (any action) or `\"space/agent#action\"`; `[\"*\"]` = unrestricted;\n89\t   *  `\"registered:*\"` = any runtime-registered space. When the policy is not\n90\t   *  'none' AND the engine has a `delegateRunner`, `delegate()` is injected\n91\t   *  into the fork and gated at yield time. Empty/omitted → no delegation\n92\t   *  (the task-level default). */\n93\t  canDelegateTo?: string[];\n94\t  /** Per-node capability NARROWING (task frontmatter `capabilities:`). When set, the fork runs\n95\t   *  with only the intersection of these ids and the parent agent's declared caps — least\n96\t   *  privilege per step, never widening (see `narrowAppCaps`). Omit to inherit the parent's set. */\n97\t  capabilities?: import('../spaces/capabilities.js').CapabilityId[];\n98\t  /** Host-executed TS statements (task frontmatter `prelude:`) run in the fork VM BEFORE the\n99\t   *  model's first turn, through the same statement pipeline as the turn loop (yields allowed).\n100\t   *  Bound values are surfaced as the fork's first VARIABLES block; per-statement failures bind\n101\t   *  the names `undefined` and are noted there (they never kill the fork). See exec/prelude.ts. */\n102\t  prelude?: string;\n103\t  /** Parent execution scope for hierarchical observability. Set by the yield router\n104\t   *  before each fork() call so each invocation carries the right parentId. */\n105\t  parentScope?: TraceScope;\n106\t}\n107\t\n108\texport interface ForkEngineOpts {\n109\t  maxConcurrentForks: number;\n110\t  parentHistory: Message[];\n111\t  parentSpaceDir: string;\n112\t  parentAgentSlug: string;\n113\t  renderHost: RenderHost;\n114\t  streamFn: (opts: StreamOpts) => Promise<StreamSession>;\n115\t  clock?: Clock;\n116\t  tracer?: Tracer;\n117\t  /** Agent functions (TS source) available in the parent session — injected into fork VMs */\n118\t  agentFunctions?: Record<string, string>;\n119\t  /** Bundled JS versions of agent functions (when space has node_modules) */\n120\t  agentFunctionsBundled?: Record<string, string>;\n121\t  /** Host budget caps applied to each fork's own turn loop (fresh Budget per fork). */\n122\t  budgetLimits?: BudgetLimits;\n123\t  /** Nesting depth of forks spawned by this engine. A session's top-level forks are depth 1. */\n124\t  forkDepth?: number;\n125\t  /** Optional per-role model assignment (e.g. explore/plan → cheap model). */\n126\t  roleModels?: RoleModelConfig;\n127\t  /** Default model alias used for any fork role that has no explicit roleModels entry.\n128\t   *  Propagated from the parent session so llm_request events carry a model field. */\n129\t  defaultModel?: string;\n130\t  /** Body of the parent agent's charter.md — short, fork-safe identity/guardrails injected\n131\t   *  into every fork's system prompt. Unlike instruct.md it carries no ask/delegate/UI prose. */\n132\t  parentAgentCharter?: string;\n133\t  /** Runs a delegate on behalf of a task that declares `canDelegateTo`. Provided by the\n134\t   *  Session / delegate runtime (which own the registry + recursion-depth bound). When absent,\n135\t   *  a task's delegate() yield fails with a clear \"delegation not available\" error. */\n136\t  delegateRunner?: (\n137\t    packageName: string,\n138\t    agentName: string,\n139\t    action: string | undefined,\n140\t    delegateOpts: unknown,\n141\t    allowedActions: string[] | undefined,\n142\t  ) => Promise<unknown>;\n143\t  /** Spaces registered at runtime via registerSpace(). Shared (same Map reference) with\n144\t   *  the parent Session so a fork's registerSpace() is visible to later parent delegate()\n145\t   *  calls — the documented dynamicSpaces invariant. */\n146\t  dynamicSpaces?: Map<string, import('../spaces/load.js').Space>;\n147\t  /** Absolute path to the project's spaces/ dir. Propagated into each fork VM as\n148\t   *  LMTHING_PROJECT_SPACES_DIR so the architect can target it when scaffolding. */\n149\t  projectSpacesDir?: string;\n150\t  /** Absolute project root — propagated into each fork VM as LMTHING_PROJECT_DIR and\n151\t   *  gating app-global injection (a fork inside a project reads/writes that project's app). */\n152\t  projectRoot?: string;\n153\t  /** Project id — propagated as LMTHING_PROJECT_ID. */\n154\t  projectId?: string;\n155\t  /** The parent agent's app-capability grants. A fork task receives the\n156\t   *  `allowWrite`-intersected subset (read-only roles keep only db:read/api:call). */\n157\t  parentAppCapabilities?: AppCapabilities;\n158\t  /** Host-provided app-global engine impls (libs/cli, P2+), passed through to the fork VM. */\n159\t  appGlobals?: AppGlobalImpls;\n160\t  /** Host resolver for the universal `readDocument` global — threaded from the parent\n161\t   *  session/delegate so a fork leaf can read an attached upload's text by id. */\n162\t  documentResolver?: DocumentResolver;\n163\t}\n164\t\n165\texport class ForkEngine {\n166\t  private activeForks = 0;\n167\t  private queue: Array<() => void> = [];\n168\t\n169\t  constructor(private opts: ForkEngineOpts) {}\n170\t\n171\t  /** Model-facing shape (the bare `fork()` global): resolves to just the value. */\n172\t  async fork<T>(task: ForkTask): Promise<T> {\n173\t    return (await this.forkWithMeta<T>(task)).value;\n174\t  }\n175\t\n176\t  /**\n177\t   * Internal variant that also reports whether the value was SALVAGED (and why),\n178\t   * so the tasklist orchestrator can aggregate degradation into a TaskEnvelope\n179\t   * instead of the old prose-placeholder signal. Same execution path as fork().\n180\t   */\n181\t  async forkWithMeta<T>(task: ForkTask): Promise<ForkResultMeta<T>> {\n182\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n183\t    const label = `fork:${task.taskId ?? task.role ?? 'general'}`;\n184\t    // Mint scope as 'queued' before acquiring the slot so wait time is visible\n185\t    const forkScope = tracer.child(task.parentScope, 'fork', label, {\n186\t      role: task.role,\n187\t      taskId: task.taskId,\n188\t      instruction: task.instruction.slice(0, 120),\n189\t      timeout: task.timeout,\n190\t    }, 'queued');\n191\t\n192\t    // Wait for concurrency slot, then activate\n193\t    await this.acquireSlot();\n194\t    tracer.activate(forkScope);\n195\t\n196\t    try {\n197\t      return await this.runFork<T>(task, forkScope);\n198\t    } finally {\n199\t      this.releaseSlot();\n200\t    }\n201\t  }\n202\t\n203\t\n204\t\n205\t  private acquireSlot(): Promise<void> {\n206\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n207\t    if (this.activeForks < this.opts.maxConcurrentForks) {\n208\t      this.activeForks++;\n209\t      tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n210\t      return Promise.resolve();\n211\t    }\n212\t\n213\t    return new Promise((resolve) => {\n214\t      this.queue.push(() => {\n215\t        this.activeForks++;\n216\t        tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n217\t        resolve();\n218\t      });\n219\t    });\n220\t  }\n221\t\n222\t  private releaseSlot(): void {\n223\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n224\t    this.activeForks--;\n225\t    const next = this.queue.shift();\n226\t    if (next) next();\n227\t    else tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n228\t  }\n229\t\n230\t  private async runFork<T>(task: ForkTask, forkScope: TraceScope): Promise<ForkResultMeta<T>> {\n231\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n232\t\n233\t    return new Promise<ForkResultMeta<T>>(async (resolve, reject) => {\n234\t      let settled = false;\n235\t      let didResolve = false;\n236\t      let resolvedValue: unknown;\n237\t      let resolvedError: Error | undefined;\n238\t      let timeoutId: ReturnType<typeof setTimeout> | undefined;\n239\t      // Degradation tracking (Phase 3): set when the value is salvaged rather than\n240\t      // genuinely resolved, so forkWithMeta callers can branch on typed metadata.\n241\t      let salvaged = false;\n242\t      let salvageReason: DegradeReason | undefined;\n243\t\n244\t      const settle = (fn: () => void, endStatus: 'done' | 'error' = 'done', errMsg?: string): void => {\n245\t        if (settled) return;\n246\t        settled = true;\n247\t        if (timeoutId) clearTimeout(timeoutId);\n248\t        tracer.end(forkScope, endStatus, errMsg ? { error: errMsg } : undefined);\n249\t        fn();\n250\t      };\n251\t\n252\t      // Set up timeout\n253\t      if (task.timeout && task.timeout > 0) {\n254\t        const clock = this.opts.clock;\n255\t        if (clock) {\n256\t          clock.setTimeout(() => {\n257\t            const msg = `Fork timed out after ${task.timeout}ms`;\n258\t            settle(() => reject(new Error(msg)), 'error', msg);\n259\t          }, task.timeout);\n260\t        } else {\n261\t          timeoutId = setTimeout(() => {\n262\t            const msg = `Fork timed out after ${task.timeout}ms`;\n263\t            settle(() => reject(new Error(msg)), 'error', msg);\n264\t          }, task.timeout);\n265\t        }\n266\t      }\n267\t\n268\t      // Per-fork budget. Assert nesting depth before spending anything on a VM —\n269\t      // a depth-exceeded fork rejects cleanly with BudgetExceededError.\n270\t      const budget = new Budget(this.opts.budgetLimits ?? {});\n271\t      const depth = this.opts.forkDepth ?? 1;\n272\t\n273\t      let vm: VM | undefined;\n274\t      try {\n275\t        budget.assertForkDepth(depth);\n276\t\n277\t        // Delegation: a task may delegate ONLY per its `canDelegateTo` policy (unified\n278\t        // semantics: omitted/[] = none, [\"*\"] = unrestricted, list = allowlist with\n279\t        // optional \"registered:*\"), and ONLY when the engine was given a delegateRunner\n280\t        // (the Session / delegate runtime owns the registry + recursion bound).\n281\t        // Default: no delegate global — keeps forks isolated and headless as before.\n282\t        const delegatePolicy = evaluateDelegatePolicy(task.canDelegateTo, 'task');\n283\t        const canDelegate = delegatePolicy.mode !== 'none' && typeof this.opts.delegateRunner === 'function';\n284\t        // Per-node capability narrowing FIRST (select a subset of the parent agent's grants,\n285\t        // never widening), THEN the role's read-only intersection on top — so both the injected\n286\t        // globals and the ambient DTS narrow together and a sibling node's stray write fails typecheck.\n287\t        const nodeApp = narrowAppCaps(this.opts.parentAppCapabilities ?? {}, task.capabilities);\n288\t        const capabilities = forkCapabilities(task.role, canDelegate, nodeApp);\n289\t\n290\t        // Space functions from the parent agent. When the task declares a `functions`\n291\t        // allowlist, scope to exactly those (least privilege — fewer tools to misuse,\n292\t        // shorter prompt). An empty array means \"no space functions\".\n293\t        const allFns = this.opts.agentFunctions ?? {};\n294\t        const allFnsBundled = this.opts.agentFunctionsBundled ?? {};\n295\t        const fnAllow = task.functions;\n296\t        const pickAllowed = <T,>(rec: Record<string, T>): Record<string, T> => {\n297\t          if (!fnAllow) return rec;\n298\t          const out: Record<string, T> = {};\n299\t          for (const name of fnAllow) if (name in rec) out[name] = rec[name]!;\n300\t          return out;\n301\t        };\n302\t        const agentFunctions = pickAllowed(allFns);\n303\t        const agentFunctionsBundled = pickAllowed(allFnsBundled);\n304\t\n305\t        // currentTask.resolve records the (schema-validated) result.\n306\t        // IMPORTANT: do NOT call vm.dispose() from inside this callback. We are\n307\t        // executing inside a QuickJS function call frame; disposing the runtime here\n308\t        // causes JS_FreeRuntime to abort because live GC handles are still on the\n309\t        // stack. Instead we record the result and dispose the VM after runTurnLoop exits.\n310\t        const outputSchema = task.output;\n311\t        const currentTaskResolve = (value: unknown): void => {\n312\t          if (didResolve) return;\n313\t          didResolve = true;\n314\t          if (!validateOutput(outputSchema, value)) {\n315\t            resolvedError = new Error(`Fork output does not match schema ${JSON.stringify(outputSchema)}`);\n316\t          } else {\n317\t            resolvedValue = value;\n318\t          }\n319\t        };\n320\t\n321\t        const forkTracer = this.opts.tracer ?? NULL_TRACER;\n322\t        // Shared child-VM bootstrap: seed/upstream vars, currentTask, allowlisted\n323\t        // functions, host tools (role-gated write), yielding globals per the\n324\t        // capability profile (no ask/fork/tasklist; delegate/registerSpace gated),\n325\t        // and the JSX runtime (catalog stubs only — forks get no agent components).\n326\t        vm = await createChildVM({\n327\t          capabilities,\n328\t          renderHost: this.opts.renderHost,\n329\t          clock: this.opts.clock,\n330\t          spaceDir: this.opts.parentSpaceDir,\n331\t          projectSpacesDir: this.opts.projectSpacesDir,\n332\t          projectRoot: this.opts.projectRoot,\n333\t          projectId: this.opts.projectId,\n334\t          appGlobals: this.opts.appGlobals,\n335\t          progress: () => budget.snapshot(),\n336\t          functions: agentFunctions,\n337\t          functionsBundled: agentFunctionsBundled,\n338\t          componentNames: [],\n339\t          onDisplay: (value) => {\n340\t            forkTracer.write({ ts: Date.now(), type: 'display', context: forkScope.label, nodeId: forkScope.nodeId, descriptor: value });\n341\t          },\n342\t          // A fork's setActivity is a SUB-activity keyed by its node — the UI clears\n343\t          // it on this node's node_end (or on an explicit '' clear).\n344\t          onActivity: (text) => {\n345\t            forkTracer.write({ ts: Date.now(), type: 'activity', context: forkScope.label, nodeId: forkScope.nodeId, scope: 'fork', text });\n346\t          },\n347\t          currentTaskResolve,\n348\t          // Seed variables, then upstream outputs as named variables matching the task id.\n349\t          seedVars: { ...(task.seed ?? {}), ...(task.upstreamOutputs ?? {}) },\n350\t          onFunctionError: (name, error) => {\n351\t            this.opts.renderHost.log(`[warn] failed to inject function \"${name}\" into fork: ${error}`);\n352\t          },\n353\t        });\n354\t\n355\t        // Build user message for the child\n356\t        const seedSummary = task.seed && Object.keys(task.seed).length > 0\n357\t          ? `\\nContext variables (available in scope):\\n${Object.entries(task.seed)\n358\t              .map(([k, v]) => `- ${k}: ${JSON.stringify(v)}`)\n359\t              .join('\\n')}`\n360\t          : '';\n361\t        const inputSummary = task.upstreamOutputs\n362\t          ? `\\nInputs from upstream tasks (available as variables):\\n${Object.entries(task.upstreamOutputs)\n363\t              .map(([k, v]) => `- ${k}: ${JSON.stringify(v)}`)\n364\t              .join('\\n')}`\n365\t          : '';\n366\t\n367\t        const outputSchemaStr = JSON.stringify(task.output, null, 2);\n368\t        const userMessage = `${task.instruction}${seedSummary}${inputSummary}\\n\\nOutput schema:\\n${outputSchemaStr}\\n\\nWhen done, call: currentTask.resolve({ ...output })`;\n369\t\n370\t        const history = new MessageHistory();\n371\t        history.append({ role: 'user', content: userMessage, blockType: 'normal' });\n372\t\n373\t        // Ambient DTS, assembled additively by the shared builder. Forks have NO\n374\t        // tasklist/fork/ask declared, so a stray call fails typecheck (a clean\n375\t        // retryable error) instead of passing typecheck then throwing at runtime\n376\t        // and salvaging. `delegate` is declared ONLY when the task may delegate.\n377\t        const functionsOverlay = Object.keys(agentFunctions).length > 0\n378\t          ? buildOverlay(agentFunctions, { view: {}, form: {} })\n379\t          : '';\n380\t        const upstreamDts = task.upstreamOutputs\n381\t          ? Object.keys(task.upstreamOutputs).map((id) => {\n382\t              const meta = task.upstreamOutputSchemas?.[id];\n383\t              const base = taskOutputDts(meta?.fields);\n384\t              // A forEach dependency's collected value is an ARRAY of its output shape.\n385\t              const type = meta?.isArray ? `Array<${base}>` : base;\n386\t              return `declare const ${id}: ${type};`;\n387\t            }).join('\\n')\n388\t          : '';\n389\t        const seedDts = task.seed\n390\t          ? Object.keys(task.seed).map((k) => `declare const ${k}: any;`).join('\\n')\n391\t          : '';\n392\t        const ambientDts = buildAmbientDts({\n393\t          capabilities,\n394\t          overlay: functionsOverlay,\n395\t          currentTask: true,\n396\t          projectRoot: !!this.opts.projectRoot,\n397\t          extraDecls: [upstreamDts, seedDts].filter(Boolean),\n398\t        });\n399\t\n400\t        // Build system prompt: include FULL function signatures incl. return types\n401\t        // (AST-based, not a truncating regex) so the subagent destructures results\n402\t        // like readFile(...).content / glob(...).paths without a wasted retry.\n403\t        const functionList = Object.keys(agentFunctions).length > 0\n404\t          ? `\\n# Available Space Functions (already in scope — call directly with correct args, do NOT redefine):\\n${Object.entries(agentFunctions).map(([name, src]) => {\n405\t              const decl = extractFunctionSignature(name, src)\n406\t                .replace(/^declare\\s+(async\\s+)?function\\s+/, '')\n407\t                .replace(/;$/, '');\n408\t              return `- ${decl}`;\n409\t            }).filter(Boolean).join('\\n')}`\n410\t          : '';\n411\t\n412\t        // Standing context: the parent agent's charter (fork-safe identity/guardrails) and the\n413\t        // overall tasklist goal, so an isolated task knows who it works for and what pipeline it\n414\t        // serves. Kept short and placed before the task instruction. (instruct.md is deliberately\n415\t        // NOT injected — it carries ask/delegate/UI prose a fork cannot honor.)\n416\t        const charterSection = this.opts.parentAgentCharter?.trim()\n417\t          ? `# Agent\\n${this.opts.parentAgentCharter.trim()}\\n`\n418\t          : '';\n419\t        const tasklistSection = task.tasklistDescription?.trim()\n420\t          ? `# Tasklist (overall goal — your task is one step in it)\\n${task.tasklistDescription.trim()}\\n`\n421\t          : '';\n422\t\n423\t        // Generic filesystem/shell exists ONLY in the engineer's `fs:scratch` sandbox. A fork\n424\t        // inherits it only when the parent agent has it (an engineer general fork). Every other\n425\t        // fork has no fs/shell at all — advertise only what the VM actually carries, so a fork is\n426\t        // never told about execShell and then errors on it. A fork needing to run code returns the\n427\t        // code to its delegator; persistence goes through the delegator's typed writers.\n428\t        const scratchFs = capabilities.scratchFs;\n429\t        const ioLine = scratchFs\n430\t          ? '- createScratch() → string: create your throwaway scratch dir FIRST, then readFile(path)/writeFile(path, content)/editFile(...) operate inside it (jailed to scratch).'\n431\t          : '- There is NO filesystem here — you cannot read or write files. Work from your seed/inputs; if a task needs files persisted, return the content to your delegator (only the engineer persists code, via the delegator\\'s typed writers).';\n432\t        const shellLine = scratchFs\n433\t          ? '- execShell(cmd) → { ok, stdout, stderr }: run a command INSIDE your scratch dir (e.g. `execShell(\"npx tsc --noEmit x.ts\")`). Jailed to scratch.'\n434\t          : '- There is NO shell/subprocess — execShell is unavailable. To run or test code, return it to your delegator so the engineer can run it.';\n435\t        const noRuntimeLine =\n436\t          'There is NO Node/Bun/Deno runtime: `require`, `import(\"child_process\")`, `Bun`, `Deno`, `process.cwd()`, `TextDecoder`, and `Buffer` are NOT available.' +\n437\t          (scratchFs\n438\t            ? ' Use `execShell` (scratch-jailed) to run anything and `fetch` for HTTP.'\n439\t            : ' Use `fetch` for HTTP; there is no local file or subprocess access in this context.');\n440\t\n441\t        const systemBlock = [\n442\t          // Shared statement-emission rules (single source: exec/preamble.ts).\n443\t          STATEMENT_PROTOCOL,\n444\t          '',\n445\t          ...(charterSection ? [charterSection] : []),\n446\t          ...(tasklistSection ? [tasklistSection] : []),\n447\t          rolePreamble(task.role),\n448\t          '',\n449\t          '# Available Built-in Globals (already provided — do NOT redefine any of these):',\n450\t          '- sleep(duration: string) — pause for a duration, e.g. `await sleep(\"2s\")`',\n451\t          '- display(content: string | JSXDescriptor) — render output',\n452\t          '- loadKnowledge(domain: string, field: string, option: string) → Promise<string> — load a knowledge file shipped with this space, e.g. `const k = await loadKnowledge(\"espresso\", \"fundamentals\", \"overview.md\");`',\n453\t          '- inspect(...values) — inspect variables',\n454\t          shellLine,\n455\t          '- fetch(url, opts?) → Promise<{ ok, status, text(), json() }> — `await fetch(...)` (real, non-blocking HTTP)',\n456\t          ioLine,\n457\t          '',\n458\t          noRuntimeLine,\n459\t          '',\n460\t          ...(canDelegate\n461\t            ? [\n462\t                '',\n463\t                '# Delegation (allowed for this task)',\n464\t                ...(delegatePolicy.mode === 'unrestricted'\n465\t                  ? ['You MAY call `delegate(packageName, agentName, action?, { query, context })` (yields) — any target.']\n466\t                  : [\n467\t                      'You MAY call `delegate(packageName, agentName, action?, { query, context })` (yields) — but ONLY to:',\n468\t                      ...delegatePolicy.entries.map((t) => `  - ${t}`),\n469\t                      ...(delegatePolicy.allowRegistered\n470\t                        ? ['  - any space registered at runtime via registerSpace()']\n471\t                        : []),\n472\t                    ]),\n473\t                'It returns the delegate\\'s result; cast it. Keep the call FLAT at top level (never inside if/try/loop).',\n474\t              ]\n475\t            : []),\n476\t          '',\n477\t          'When your task is complete, call `currentTask.resolve(value)` with an object matching the output schema.',\n478\t          'The request and every input you need are in the seed variables / Inputs above — work with what you have, assume sensible defaults where details are missing, and resolve. Do not wait for input.',\n479\t          functionList,\n480\t        ].join('\\n');\n481\t\n482\t        // Shared yield routing (eval/yield-router.ts). A fork leaf resolves its own\n483\t        // sleep/fetch/loadKnowledge/registerSpace, and gates delegate() on the task's\n484\t        // canDelegateTo allowlist + the engine's delegateRunner. fork/tasklist are\n485\t        // deliberately unhandled here (no getForkEngine): the globals are not\n486\t        // injected, so such a yield cannot occur — and if it somehow did, it binds\n487\t        // undefined exactly as before.\n488\t        const yieldCtx: YieldRouterContext = {\n489\t          clock: this.opts.clock,\n490\t          knowledgeSpaceDir: this.opts.parentSpaceDir,\n491\t          resolveRegisterSpace: true,\n492\t          dynamicSpaces: this.opts.dynamicSpaces,\n493\t          apiCallResolver: this.opts.appGlobals?.apiCall,\n494\t          connectionResolver: this.opts.appGlobals?.callConnection,\n495\t          documentResolver: this.opts.documentResolver,\n496\t          // Store discovery + manual emits follow the (role-intersected) app\n497\t          // grants into forks; consent-marked kinds (installSpace) FAIL CLOSED —\n498\t          // no requestConsent is ever wired for a headless fork leaf.\n499\t          storeResolver: this.opts.appGlobals?.store,\n500\t          emitEventResolver: this.opts.appGlobals?.emitEvent,\n501\t          // delegate: gated by the task's canDelegateTo policy via the unified\n502\t          // yield-time gate (exec/target-match.ts isDelegateAllowed — same gate the\n503\t          // session and delegate VMs use); routed to the engine's delegateRunner\n504\t          // (which owns the registry + recursion bound). A disallowed target throws\n505\t          // a clear error naming the allowed targets, surfaced to the model\n506\t          // (retryable) rather than silently binding undefined. `registered:*`\n507\t          // consults the session-shared dynamicSpaces map at call time.\n508\t          runDelegate: (packageName, agentName, action, delegateOpts) => {\n509\t            const allow = isDelegateAllowed(delegatePolicy, packageName, agentName, this.opts.dynamicSpaces);\n510\t            if (!allow.allowed) {\n511\t              throw new Error(formatDelegateDenial(delegatePolicy, packageName, agentName, 'task'));\n512\t            }\n513\t            if (!this.opts.delegateRunner) throw new Error('delegation is not available in this context');\n514\t            return this.opts.delegateRunner(packageName, agentName, action, delegateOpts, allow.allowedActions);\n515\t          },\n516\t        };\n517\t\n518\t        // Single yield resolver shared by the prelude and the turn loop — the\n519\t        // prelude's webSearch/webFetch/fetch/sleep/loadKnowledge yields route\n520\t        // exactly like any fork statement's.\n521\t        const processYield = async (req: import('../eval/yield.js').YieldRequest): Promise<unknown> => {\n522\t          const routed = await routeCommonYield(req, yieldCtx);\n523\t          return routed.handled ? routed.value : undefined;\n524\t        };\n525\t\n526\t        // Phase 4: host-executed prelude. Runs the task's deterministic setup\n527\t        // statements in THIS fork VM before the model's first turn (seed vars —\n528\t        // including forEach `item`/`index` — were already injected by\n529\t        // createChildVM above, so the prelude can read them). Its accumulated\n530\t        // context seeds the turn loop's initialContext so the model's later\n531\t        // statements typecheck against the prelude's bound names; failed\n532\t        // statements' names become ambient `any` declarations instead.\n533\t        let turnLoopAmbient = ambientDts;\n534\t        let preludeContext: string | undefined;\n535\t        if (task.prelude?.trim()) {\n536\t          // The prelude typechecks against an ambient WITHOUT `currentTask`:\n537\t          // resolving is the MODEL's job, so a prelude statement that calls\n538\t          // currentTask.resolve() fails typecheck — a per-statement prelude\n539\t          // error (noted in the VARIABLES block), never a silent pre-resolve.\n540\t          const preludeAmbient = buildAmbientDts({\n541\t            capabilities,\n542\t            overlay: functionsOverlay,\n543\t            currentTask: false,\n544\t            projectRoot: !!this.opts.projectRoot,\n545\t            extraDecls: [upstreamDts, seedDts].filter(Boolean),\n546\t          });\n547\t          const prelude = await runPrelude({\n548\t            vm,\n549\t            source: task.prelude,\n550\t            ambientDts: preludeAmbient,\n551\t            processYield,\n552\t            renderHost: this.opts.renderHost,\n553\t            budget,\n554\t            tracer: forkTracer,\n555\t            scope: forkScope,\n556\t          });\n557\t          preludeContext = prelude.context || undefined;\n558\t          if (prelude.failedNames.length > 0) {\n559\t            turnLoopAmbient =\n560\t              ambientDts + '\\n' + prelude.failedNames.map((n) => `declare const ${n}: any;`).join('\\n');\n561\t          }\n562\t          // The model's first user message ends with the prelude's VARIABLES\n563\t          // block (same standing mechanism the turn loop uses after yields), so\n564\t          // it SEES the bound values — search results, not just names.\n565\t          if (prelude.variablesBlock) {\n566\t            history.append({ role: 'user', content: prelude.variablesBlock, blockType: 'variables' });\n567\t          }\n568\t        }\n569\t\n570\t        const forkLoopOpts = {\n571\t          vm,\n572\t          history,\n573\t          systemBlock,\n574\t          ambientDts: turnLoopAmbient,\n575\t          initialContext: preludeContext,\n576\t          renderHost: this.opts.renderHost,\n577\t          streamFn: this.opts.streamFn,\n578\t          processYield,\n579\t          maxRetries: 3,\n580\t          tracer: this.opts.tracer ?? NULL_TRACER,\n581\t          traceContext: `fork:${task.taskId ?? task.role ?? 'general'}`,\n582\t          scope: forkScope,\n583\t          budget,\n584\t          model: modelForRole(task.role, this.opts.roleModels) ?? this.opts.defaultModel,\n585\t        };\n586\t\n587\t        // A BudgetExceededError here propagates to the outer catch and rejects: the\n588\t        // budget is a HARD cost ceiling, so we honor it rather than spending more turns.\n589\t        await runTurnLoop(forkLoopOpts);\n590\t\n591\t        // GUARANTEE: a fork that returned WITHOUT exceeding budget must still produce a\n592\t        // usable result. If the model finished (or exhausted its retries) without calling\n593\t        // resolve(), force resolve-only turns with a FRESH small budget (separate from the\n594\t        // session cap) and tools forbidden — hammered with an impossible-to-misread\n595\t        // single instruction. (Skip entirely once a timeout has already settled the fork.)\n596\t        let nudgeBudgetExceeded = false;\n597\t        for (let nudge = 0; nudge < 2 && !didResolve && !settled; nudge++) {\n598\t          this.opts.renderHost.log(`[fork] no resolve — forcing resolve (attempt ${nudge + 1})`);\n599\t          history.append({\n600\t            role: 'user',\n601\t            content: [\n602\t              'STOP. Do NOT search, fetch, read files, run shell, or call ANY tool now.',\n603\t              'You must return your result THIS TURN by calling currentTask.resolve().',\n604\t              'Emit EXACTLY ONE statement: a single currentTask.resolve({...}) call that',\n605\t              'synthesizes everything already gathered above. Do not gather more — use only',\n606\t              'what is already in context. Any other code (searches, fetches, prose) is rejected.',\n607\t              '',\n608\t              `Output schema — fill EVERY field with a real value:\\n${outputSchemaStr}`,\n609\t              '',\n610\t              'If you genuinely found nothing usable, still resolve with your best summary of',\n611\t              'what was attempted. Returning a partial result is REQUIRED; returning nothing fails the task.',\n612\t            ].join('\\n'),\n613\t            blockType: 'normal',\n614\t          });\n615\t          try {\n616\t            await runTurnLoop({\n617\t              ...forkLoopOpts,\n618\t              maxRetries: 3,\n619\t              budget: new Budget({ maxEpisodes: 4 }),\n620\t              traceContext: `fork:${task.taskId ?? task.role ?? 'general'}:resolve_nudge`,\n621\t            });\n622\t          } catch (err) {\n623\t            if (!(err instanceof BudgetExceededError)) throw err;\n624\t            nudgeBudgetExceeded = true;\n625\t          }\n626\t        }\n627\t\n628\t        // Last resort: the model refused to resolve across every forced turn. Rather\n629\t        // than fail the parent (which would abort the whole tasklist/run), salvage a\n630\t        // schema-valid NEUTRAL placeholder so orchestration can proceed. Degradation is\n631\t        // signalled via forkWithMeta's typed metadata (→ TaskEnvelope), NEVER as prose\n632\t        // inside the data plane.\n633\t        //\n634\t        // EXCEPTION: a fork given an explicit `timeout` opted into a hard time bound —\n635\t        // the caller wants failure on non-completion, not a salvaged guess. So we skip\n636\t        // salvage there and let the no-resolve rejection (or the timeout) stand. Tasklist\n637\t        // tasks, delegates and role forks set no timeout, so they always salvage.\n638\t        if (!didResolve && !task.timeout && !settled) {\n639\t          this.opts.renderHost.log(`[fork] model never resolved — salvaging a neutral schema-valid placeholder`);\n640\t          resolvedValue = salvageData(task.output);\n641\t          resolvedError = undefined;\n642\t          didResolve = true;\n643\t          salvaged = true;\n644\t          // 'budget': the forced-resolve nudge turns themselves ran out of their fresh\n645\t          // budget. Otherwise the model simply finished without resolving: 'no_resolve'.\n646\t          // (A hard cap on the MAIN turn loop still PROPAGATES as BudgetExceededError\n647\t          // and an explicit timeout still rejects — neither reaches this salvage path.)\n648\t          salvageReason = nudgeBudgetExceeded ? 'budget' : 'no_resolve';\n649\t        }\n650\t\n651\t        // All QuickJS call frames have exited — safe to dispose.\n652\t        vm.dispose();\n653\t        vm = undefined;\n654\t\n655\t        settle(() => {\n656\t          if (didResolve && !resolvedError) {\n657\t            resolve({ value: resolvedValue as T, degraded: salvaged, ...(salvageReason ? { reason: salvageReason } : {}) });\n658\t          } else {\n659\t            reject(resolvedError ?? new Error('Fork completed without calling currentTask.resolve()'));\n660\t          }\n661\t        }, didResolve && !resolvedError ? 'done' : 'error',\n662\t          (!didResolve || resolvedError) ? (resolvedError?.message ?? 'no resolve called') : undefined);\n663\t      } catch (err) {\n664\t        if (vm) {\n665\t          try { vm.dispose(); } catch { /* ignore dispose errors in error path */ }\n666\t          vm = undefined;\n667\t        }\n668\t        const errMsg = err instanceof Error ? err.message : String(err);\n669\t        settle(() => reject(err), 'error', errMsg);\n670\t      }\n671\t    });\n672\t  }\n673\t}\n674\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"49c01069-c5b7-4bf4-9591-356c0e7664e9","timestamp":"2026-07-16T22:24:33.966Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
