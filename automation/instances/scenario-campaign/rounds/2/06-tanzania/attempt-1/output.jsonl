{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_aCp344hk1MO3usruBoTUjOZf","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { resolve } from 'node:path';\n3\timport { loadSpace } from './load.js';\n4\timport { loadTasklistFromSpace } from './tasklist-load.js';\n5\timport type { Space, TasklistDir } from './load.js';\n6\timport type { TaskNode } from './tasklist-load.js';\n7\timport { validateDag, resolveGoalTask } from '../tasklist/dag.js';\n8\timport { splitPreludeStatements } from '../exec/prelude.js';\n9\timport { runTsc } from '../typecheck/tsc.js';\n10\timport { buildOverlay } from '../typecheck/overlay.js';\n11\timport { buildAmbientDts } from '../exec/bootstrap.js';\n12\timport { forkCapabilities } from '../exec/capability.js';\n13\timport { evaluateDelegatePolicy } from '../exec/target-match.js';\n14\t\n15\t/**\n16\t * Structural guard for the shipped system spaces after the role/forEach/charter rewrite:\n17\t * every system-space tasklist must load, validate as a DAG (incl. forEach refs), declare\n18\t * exactly one resolvable goal, and every agent must ship a charter.md. Catches authoring\n19\t * regressions (bad forEach ref, missing goal, dropped charter) without hitting a model.\n20\t *\n21\t * P6 additions: the `prelude:` sources of the migrated system-research / user-thing tasks\n22\t * must parse into the expected statements AND typecheck against a fork-shaped ambient DTS\n23\t * (the same one `runFork` builds) — the cheap static guarantee the preludes aren't typo'd.\n24\t */\n25\t\n26\tconst SYS = resolve(__dirname, '..', '..', 'system-spaces');\n27\t\n28\t/** The system-global space's function sources (webSearch/webFetch live there). */\n29\tasync function globalFunctions(): Promise<Record<string, string>> {\n30\t  const g = await loadSpace(resolve(SYS, 'system-global'), { requireAgents: false });\n31\t  return g.functions;\n32\t}\n33\t\n34\t/**\n35\t * Rebuild the prelude's typecheck ambient exactly the way `fork.ts runFork` does:\n36\t * fork capabilities from the task's role + canDelegateTo, the task's allowlisted\n37\t * function overlay, NO currentTask (a prelude cannot resolve), and ambient `any`\n38\t * declarations for the tasklist's declared input keys, the task's upstream\n39\t * outputs (dependsOn ids), and forEach's `item`/`index`.\n40\t */\n41\tfunction preludeAmbientFor(task: TaskNode, tl: TasklistDir, allFns: Record<string, string>): string {\n42\t  const policy = evaluateDelegatePolicy(task.canDelegateTo, 'task');\n43\t  const capabilities = forkCapabilities(task.role, policy.mode !== 'none');\n44\t  const picked: Record<string, string> = {};\n45\t  for (const name of task.functions ?? []) if (name in allFns) picked[name] = allFns[name]!;\n46\t  const overlay = Object.keys(picked).length > 0 ? buildOverlay(picked, { view: {}, form: {} }) : '';\n47\t  const seedDts = Object.keys(tl.input ?? {}).map((k) => `declare const ${k}: any;`).join('\\n');\n48\t  const upstreamDts = (task.dependsOn ?? []).map((id) => `declare const ${id}: any;`).join('\\n');\n49\t  const forEachDts = task.forEach ? 'declare const item: any;\\ndeclare const index: number;' : '';\n50\t  return buildAmbientDts({\n51\t    capabilities,\n52\t    overlay,\n53\t    currentTask: false,\n54\t    extraDecls: [seedDts, upstreamDts, forEachDts].filter(Boolean),\n55\t  });\n56\t}\n57\t\n58\t/** Typecheck each prelude statement in order, accumulating context like runPrelude does. */\n59\tfunction typecheckPrelude(task: TaskNode, tl: TasklistDir, allFns: Record<string, string>): void {\n60\t  const ambientDts = preludeAmbientFor(task, tl, allFns);\n61\t  const statements = splitPreludeStatements(task.prelude!);\n62\t  expect(statements.length, `${task.id} prelude statements`).toBeGreaterThan(0);\n63\t  let context = '';\n64\t  for (const stmt of statements) {\n65\t    const r = runTsc({ ambientDts, sessionContext: context, statement: stmt });\n66\t    const errs = r.ok ? '' : r.diagnostics.map((d) => d.message).join('; ');\n67\t    expect(r.ok, `${task.id} prelude statement typecheck failed:\\n${stmt}\\n→ ${errs}`).toBe(true);\n68\t    context += (context ? '\\n' : '') + stmt;\n69\t  }\n70\t}\n71\t\n72\tdescribe('shipped system spaces load + validate', () => {\n73\t  for (const name of ['system-architect', 'system-research', 'system-appbuilder', 'user-thing', 'user-memory']) {\n74\t    it(`${name}: agents have charters and all tasklists are valid DAGs`, async () => {\n75\t      const space = await loadSpace(resolve(SYS, name), { requireAgents: false });\n76\t      // Every agent ships a non-trivial charter (fork-safe identity).\n77\t      for (const slug of Object.keys(space.agents)) {\n78\t        expect(space.agents[slug]!.charterBody.length, `${name}/${slug} charter`).toBeGreaterThan(20);\n79\t      }\n80\t      // Every tasklist validates and resolves a goal.\n81\t      for (const tlName of Object.keys(space.tasklists)) {\n82\t        const tasks = await loadTasklistFromSpace(space, tlName);\n83\t        expect(() => validateDag(tasks), `${name}/${tlName} DAG`).not.toThrow();\n84\t        expect(resolveGoalTask(tasks), `${name}/${tlName} goal`).toBeTruthy();\n85\t      }\n86\t    });\n87\t  }\n88\t\n89\t  it('THING lifecycle tasklists narrow db:write to only the mutating node', async () => {\n90\t    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });"}]},"parent_tool_use_id":null,"session_id":"9c7a9dc1-bb8c-4315-b194-e357aac0f2c7","uuid":"a704ff65-ad6d-4e2b-b4e2-8a204a077be8","timestamp":"2026-07-16T18:32:50.539Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/spaces/system-spaces-dag.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { resolve } from 'node:path';\nimport { loadSpace } from './load.js';\nimport { loadTasklistFromSpace } from './tasklist-load.js';\nimport type { Space, TasklistDir } from './load.js';\nimport type { TaskNode } from './tasklist-load.js';\nimport { validateDag, resolveGoalTask } from '../tasklist/dag.js';\nimport { splitPreludeStatements } from '../exec/prelude.js';\nimport { runTsc } from '../typecheck/tsc.js';\nimport { buildOverlay } from '../typecheck/overlay.js';\nimport { buildAmbientDts } from '../exec/bootstrap.js';\nimport { forkCapabilities } from '../exec/capability.js';\nimport { evaluateDelegatePolicy } from '../exec/target-match.js';\n\n/**\n * Structural guard for the shipped system spaces after the role/forEach/charter rewrite:\n * every system-space tasklist must load, validate as a DAG (incl. forEach refs), declare\n * exactly one resolvable goal, and every agent must ship a charter.md. Catches authoring\n * regressions (bad forEach ref, missing goal, dropped charter) without hitting a model.\n *\n * P6 additions: the `prelude:` sources of the migrated system-research / user-thing tasks\n * must parse into the expected statements AND typecheck against a fork-shaped ambient DTS\n * (the same one `runFork` builds) — the cheap static guarantee the preludes aren't typo'd.\n */\n\nconst SYS = resolve(__dirname, '..', '..', 'system-spaces');\n\n/** The system-global space's function sources (webSearch/webFetch live there). */\nasync function globalFunctions(): Promise<Record<string, string>> {\n  const g = await loadSpace(resolve(SYS, 'system-global'), { requireAgents: false });\n  return g.functions;\n}\n\n/**\n * Rebuild the prelude's typecheck ambient exactly the way `fork.ts runFork` does:\n * fork capabilities from the task's role + canDelegateTo, the task's allowlisted\n * function overlay, NO currentTask (a prelude cannot resolve), and ambient `any`\n * declarations for the tasklist's declared input keys, the task's upstream\n * outputs (dependsOn ids), and forEach's `item`/`index`.\n */\nfunction preludeAmbientFor(task: TaskNode, tl: TasklistDir, allFns: Record<string, string>): string {\n  const policy = evaluateDelegatePolicy(task.canDelegateTo, 'task');\n  const capabilities = forkCapabilities(task.role, policy.mode !== 'none');\n  const picked: Record<string, string> = {};\n  for (const name of task.functions ?? []) if (name in allFns) picked[name] = allFns[name]!;\n  const overlay = Object.keys(picked).length > 0 ? buildOverlay(picked, { view: {}, form: {} }) : '';\n  const seedDts = Object.keys(tl.input ?? {}).map((k) => `declare const ${k}: any;`).join('\\n');\n  const upstreamDts = (task.dependsOn ?? []).map((id) => `declare const ${id}: any;`).join('\\n');\n  const forEachDts = task.forEach ? 'declare const item: any;\\ndeclare const index: number;' : '';\n  return buildAmbientDts({\n    capabilities,\n    overlay,\n    currentTask: false,\n    extraDecls: [seedDts, upstreamDts, forEachDts].filter(Boolean),\n  });\n}\n\n/** Typecheck each prelude statement in order, accumulating context like runPrelude does. */\nfunction typecheckPrelude(task: TaskNode, tl: TasklistDir, allFns: Record<string, string>): void {\n  const ambientDts = preludeAmbientFor(task, tl, allFns);\n  const statements = splitPreludeStatements(task.prelude!);\n  expect(statements.length, `${task.id} prelude statements`).toBeGreaterThan(0);\n  let context = '';\n  for (const stmt of statements) {\n    const r = runTsc({ ambientDts, sessionContext: context, statement: stmt });\n    const errs = r.ok ? '' : r.diagnostics.map((d) => d.message).join('; ');\n    expect(r.ok, `${task.id} prelude statement typecheck failed:\\n${stmt}\\n→ ${errs}`).toBe(true);\n    context += (context ? '\\n' : '') + stmt;\n  }\n}\n\ndescribe('shipped system spaces load + validate', () => {\n  for (const name of ['system-architect', 'system-research', 'system-appbuilder', 'user-thing', 'user-memory']) {\n    it(`${name}: agents have charters and all tasklists are valid DAGs`, async () => {\n      const space = await loadSpace(resolve(SYS, name), { requireAgents: false });\n      // Every agent ships a non-trivial charter (fork-safe identity).\n      for (const slug of Object.keys(space.agents)) {\n        expect(space.agents[slug]!.charterBody.length, `${name}/${slug} charter`).toBeGreaterThan(20);\n      }\n      // Every tasklist validates and resolves a goal.\n      for (const tlName of Object.keys(space.tasklists)) {\n        const tasks = await loadTasklistFromSpace(space, tlName);\n        expect(() => validateDag(tasks), `${name}/${tlName} DAG`).not.toThrow();\n        expect(resolveGoalTask(tasks), `${name}/${tlName} goal`).toBeTruthy();\n      }\n    });\n  }\n\n  it('THING lifecycle tasklists narrow db:write to only the mutating node', async () => {\n    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });","numLines":90,"startLine":1,"totalLines":337}}}
