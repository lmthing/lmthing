hroom/permit conversation added topical spaces', spaces.own.length > beforeSpaces && spaces.own.some((id) => /bathroom|permit|wetroom/.test(id)), spaces.own.join(', '));","+  report.check('existing app gained a table', (after.tables ?? []).length > (before.tables ?? []).length, `tables ${(before.tables ?? []).length} to ${(after.tables ?? []).length}`);","+  report.check('existing app gained a page', (after.pages ?? []).length > (before.pages ?? []).length, `pages ${(before.pages ?? []).length} to ${(after.pages ?? []).length}`);","+  report.check('self-evolution did not end in unrecovered errors', unrecovered(bathroom).length === 0 && unrecovered(permit).length === 0, 'no unrecovered errors');","+  cp.acts.X = { passed: report.stepPassed };","+  saveCheckpoint(cp);","+}","+if (ACTS.includes(11)) {","+  report.step('Act XI — Non-additive drift fails loud while additive change works', 'direct incompatible schema drift is isolated; an additive nullable field remains available');","+  const names = await tableNames(pod);","+  const target = names[0];","+  report.check('there is a table to verify for schema safety', !!target, names.join(', ') || 'none');","+  const beforeRows = target ? (await pod.appData(PROJECT, target).catch(() => ({ rows: [] }))).rows ?? [] : [];","+  const schemaPath = `database/${target}.json`;","+  const schema = target ? await pod.readProjectFile(PROJECT, schemaPath) : '';","+  let parsed = {};","+  try { parsed = JSON.parse(schema); } catch {}","+  if (target && parsed.columns) {","+    parsed.columns.scenario_added_note = { type: 'string', nullable: true };","+    await pod.writeFile(`${PROJECT}/${schemaPath}`, JSON.stringify(parsed, null, 2));","+  }","+  const build = await pod.appBuild(PROJECT).catch((error) => ({ built: false, error: String(error) }));","+  const afterRows = target ? (await pod.appData(PROJECT, target).catch(() => ({ rows: [] }))).rows ?? [] : [];","+  report.check('additive schema field does not drop old rows', afterRows.