n174\t   *   TS7005: Variable 'functions' implicitly has an 'any[]' type.\n175\t   *\n176\t   * The model copies the example, so this fired on EVERY specialist build — and the retry cascade\n177\t   * from there is a trap: redeclaring it gives \"Cannot redeclare block-scoped variable\", and\n178\t   * assigning to it gives \"Cannot assign to 'functions' because it is a constant\". Observed live\n179\t   * (10-family-recipes Act I) as unrecovered typecheck errors that burned the authoring turn.\n180\t   *\n181\t   * A prompt that hands the model uncompilable code is a bug in the prompt.\n182\t   */\n183\t  it('annotates the empty `functions` array instead of leaving it to be inferred', () => {\n184\t    const design = readFileSync(\n185\t      join(SYSTEM_SPACES, 'system-architect', 'tasklists', 'synthesize_and_run', '01-design.md'),\n186\t      'utf8',\n187\t    );\n188\t\n189\t    expect(\n190\t      design,\n191\t      'a bare `const functions = [];` cannot typecheck once it is passed to currentTask.resolve — annotate the element type',\n192\t    ).not.toMatch(/const\\s+functions\\s*=\\s*\\[\\s*\\]\\s*;/);\n193\t\n194\t    expect(\n195\t      design,\n196\t      'the design node must declare `functions` with an explicit element type',\n197\t    ).toMatch(/const\\s+functions\\s*:\\s*(Array<|\\{[\\s\\S]*?\\}\\[)/);\n198\t  });\n199\t});\n200\t\n201\tdescribe('no system-space prompt is overfitted to a scenario', () => {\n202\t  /**\n203\t   * A system-space prompt is a brain EVERY user shares. A literal borrowed from one scenario\n204\t   * (a persona's name, a fixture's contents, a scenario's table name) teaches the agent the answer\n205\t   * to one exam question and makes it dumber everywhere else — and examples in a prompt get COPIED\n206\t   * INTO REAL OUTPUT (hardcoded example values have previously landed verbatim in real users' data).\n207\t   * A \"don't do this\" example is one careless read away from becoming a \"do this\" template, so this\n208\t   * guard applies to negative examples too.\n209\t   *\n210\t   * These are literals from the live scenario suite. None of them belongs in any agent's brain.\n211\t   */\n212\t  const SCENARIO_LITERALS = [\n213\t    'Huchuypicchu',   // 05-latam — the Machu Picchu PDF's circuit name\n214\t    'Churuquella',    // 05-latam — the voice memo's Sucre viewpoint\n215\t    'Wild Rover',     // 05-latam — the trip-notes hostel\n216\t    'Red Planet Expedition', // 05-latam — the screenshot's Uyuni operator\n217\t    'Torres del Paine',      // 05-latam — the spreadsheet's park-fee line\n218\t    'ZZJQUU',         // a booking ref that once leaked into real users' data\n219\t    'boiler_service_log',\n220\t    'household_items',\n221\t  ];\n222\t\n223\t  it('contains no scenario-specific literal in any instruct.md / charter.md / knowledge file', () => {\n224\t    const offenders: string[] = [];\n225\t    for (const file of walk(SYSTEM_SPACES)) {\n226\t      const body = readFileSync(file, 'utf8');\n227\t      for (const lit of SCENARIO_LITERALS) {\n228\t        if (body.includes(lit)) offenders.push(`${relative(SYSTEM_SPACES, file)} contains \"${lit}\"`);\n229\t      }\n230\t    }\n231\t    expect(\n232\t      offenders,\n233\t      'a scenario literal in a system-space prompt is overfitting: it teaches the agent one exam answer and can be copied verbatim into a real user\\'s data',\n234\t    ).toEqual([]);\n235\t  });\n236\t});\n237\t"}]},"parent_tool_use_id":null,"session_id":"2142c1ae-f65f-4763-943d-8eaf39a5f62b","uuid":"9b0304ca-488f-438f-87a1-8decc3d00c52","timestamp":"2026-07-15T18:34:43.401Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/spaces/prompt-contract.test.ts","content":"      src,\n      'THING must be warned that deferring the reply loses the value: variables do not persist between statements',\n    ).toMatch(/do not persist between statements|DO NOT PERSIST between statements/i);\n  });\n});\n\ndescribe('