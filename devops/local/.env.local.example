# Copy to .env.local and fill in your values.
# This file is committed; .env.local is git-ignored.

# LiteLLM master key (must match cloud/gateway/.env.local)
LITELLM_MASTER_KEY=sk-lmt-local-dev

# LLM provider — add the key for whichever model you chose in litellm-config.yaml
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://...
