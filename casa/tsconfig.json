{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lmthing/ui": ["../sdk/org/libs/ui/src"],
      "@lmthing/ui/*": ["../sdk/org/libs/ui/src/*"],
      "@lmthing/css/*": ["../sdk/org/libs/css/src/*"],
      "@lmthing/state": ["../sdk/org/libs/state/src"],
      "lmthing": ["../sdk/org/cli/src"]
    },
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "module": "ESNext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
