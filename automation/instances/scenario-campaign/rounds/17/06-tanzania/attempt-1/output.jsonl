{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4wB5MGFzCyFSS1ddf4GWBMI8","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { readFileSync, readdirSync, statSync } from 'node:fs';\n3\timport { dirname, join, relative } from 'node:path';\n4\timport { fileURLToPath } from 'node:url';\n5\t\n6\tconst __dirname = dirname(fileURLToPath(import.meta.url));\n7\tconst SYSTEM_SPACES = join(__dirname, '..', '..', 'system-spaces');\n8\t\n9\tfunction walk(dir: string, out: string[] = []): string[] {\n10\t  for (const e of readdirSync(dir)) {\n11\t    const p = join(dir, e);\n12\t    if (statSync(p).isDirectory()) walk(p, out);\n13\t    else if (p.endsWith('.md')) out.push(p);\n14\t  }\n15\t  return out;\n16\t}\n17\t\n18\tdescribe('system-appbuilder/automator — the empty-app failure', () => {\n19\t  /**\n20\t   * A big first build (many tables, a large attached file) can burn the whole turn on SEEDING and\n21\t   * leave the agent reporting \"all tables created and seeded!\" with no page ever written. Observed\n22\t   * live: THING delegated an explicit app build (\"a trip overview page ... per-country sections\"),\n23\t   * and the automator returned 8 tables and ZERO pages — `/app/<id>/` 404'd. A direct probe on a\n24\t   * SMALL app (3 tables) authored index + detail + _layout + 2 API routes and served 200, which is\n25\t   * what isolates the cause: not a missing gate, but a missing ORDERING rule. The existing gate says\n26\t   * a page is required; it did not say to write it EARLY, before the data can eat the turn.\n27\t   */\n28\t  it('tells the builder to make the app OPENABLE EARLY, not to leave the page until after the data', () => {\n29\t    const instruct = readFileSync(join(SYSTEM_SPACES, 'system-appbuilder', 'agents', 'automator', 'instruct.md'), 'utf8');\n30\t\n31\t    // The page-required gate (the quality rule).\n32\t    expect(instruct).toMatch(/not done until it serves at least one PAGE/i);\n33\t\n34\t    // The ordering rule (the one that survives running out of turn) — this is the regression guard.\n35\t    expect(\n36\t      instruct,\n37\t      'the automator must be told to author the home page EARLY (right after the first table), or a large seed run will consume the turn and ship an app with no page',\n38\t    ).toMatch(/openable first|make it openable early/i);\n39\t    expect(instruct).toMatch(/run out of turn|cut off/i);\n40\t  });\n41\t});\n42\t\n43\tdescribe('system-appbuilder/automator — attribution survives the seed', () => {\n44\t  /**\n45\t   * Observed live (10-family-recipes): the builder seeded a row from material the user handed over\n46\t   * and captured every operational detail of it perfectly — while dropping WHO the material was\n47\t   * credited to. It even chose a `source` column, then filled it with the CHANNEL the material\n48\t   * arrived on rather than the name the material itself states. The user had asked, in as many\n49\t   * words, not to lose any of it.\n50\t   *\n51\t   * The operational content is the half a person can always look up again; the attribution is the\n52\t   * half they cannot reconstruct from anywhere else — and is very often why the material was kept.\n53\t   * The existing rule covers figures and contacts the source STATES; it did not cover the name it\n54\t   * is credited to, nor the near-miss of recording the envelope instead of the fact.\n55\t   */\n56\t  it('tells the builder to keep the attribution the material carries — and not to record the transport instead', () => {\n57\t    const instruct = readFileSync(join(SYSTEM_SPACES, 'system-appbuilder', 'agents', 'automator', 'instruct.md'), 'utf8');\n58\t\n59\t    expect(\n60\t      instruct,\n61\t      'the automator must be told to keep WHO/WHERE material came from on the record, not just its operational content',\n62\t    ).toMatch(/attribution|credited_to|provenance/i);\n63\t\n64\t    // The near-miss guard: a `source` field filled with \"from an attachment\" LOOKS done and is not.\n65\t    expect(\n66\t      instruct,\n67\t      'the automator must be warned that recording the CHANNEL the material arrived on is not the attribution',\n68\t    ).toMatch(/transport is not the attribution|channel the material arrived on/i);\n69\t  });\n70\t});\n71\t\n72\tdescribe('system-architect/architect — custom choice components', () => {\n73\t  it('tells the space builder to handle a dismissed tailored form as no change', () => {\n74\t    const instruct = readFileSync(join(SYSTEM_SPACES, 'system-architect', 'agents', 'architect', 'instruct.md'), 'utf8');\n75\t    expect(instruct).toMatch(/components\\/view\\/<Name>\\.tsx/);\n76\t    expect(instruct).toMatch(/components\\/form\\/<Name>\\.tsx/);\n77\t    expect(instruct).toMatch(/dismissed.*null|null.*no decision/i);\n78\t    expect(instruct).toMatch(/make no write/i);\n79\t  });\n80\t});\n81\t\n82\tdescribe('user-thing/thing — the ingest turn must ASK, and must not leak its plumbing', () => {\n83\t  const instruct = () => readFileSync(join(SYSTEM_SPACES, 'user-thing', 'agents', 'thing', 'instruct.md'), 'utf8');\n84\t\n85\t  /**\n86\t   * Observed live (10-family-recipes, Act I): handed a pile of material and a description of a\n87\t   * recurring frustration, THING read everything correctly, summarised it beautifully — and then\n88\t   * stopped. No question. The user, who does not know that building something is even an option,\n89\t   * has nothing to say yes to, and the turn dies there.\n90\t   *\n91\t   * Withholding the BUILD until they agree is right (that gate exists). Withholding the QUESTION\n92\t   * is not: it turns \"propose, then build on a plain yes\" into \"report, then wait forever\".\n93\t   */\n94\t  it('tells THING to end a turn it has decided on with the plain question, then stop', () => {\n95\t    expect(\n96\t      instruct(),\n97\t      'THING must be told to END the ingest turn with the one-sentence offer — a summary that stops without a question leaves the user nothing to answer',\n98\t    ).toMatch(/ask,? then stop|end with the decision|END WITH THE DECISION/i);\n99\t    expect(instruct()).toMatch(/nothing to answer|say yes/i);\n100\t  });\n101\t\n102\t  /**\n103\t   * Same turn, second failure: the reply ended with a KeyValue panel of the model's own internals —\n104\t   * variable names, their TYPES, and their string LENGTHS. It had been taught to: the instructions'\n105\t   * own examples ended `display(seen)` and `display(JSON.stringify(auto, null, 2))`.\n106\t   *\n107\t   * An example in an agent's brain gets copied into real output. These two were, verbatim.\n108\t   */\n109\t  it('does not teach THING to display raw specialist/writer return values', () => {\n110\t    const src = instruct();\n111\t    expect(\n112\t      src,\n113\t      'the attachment example must not end by displaying the raw specialist return value — the model copies it straight into the user\\'s reply',\n114\t    ).not.toMatch(/^\\s*display\\(seen\\);?\\s*$/m);\n115\t    expect(\n116\t      src,\n117\t      'the build example must not end by dumping the writer\\'s return value as JSON',\n118\t    ).not.toMatch(/display\\(JSON\\.stringify\\(auto/);\n119\t    // And the principle that generalises past those two examples.\n120\t    expect(src).toMatch(/never show them your plumbing|debugging output/i);\n121\t  });\n122\t\n123\t  /**\n124\t   * The near-miss that the first cut of the fix above walked straight into. Deleting `display(seen)`\n125\t   * removed the dump — but it also removed the only thing showing the model that the delegate's\n126\t   * return value must be CONSUMED IN THE SAME STATEMENT. Told merely \"read it, then tell the user\",\n127\t   * the model deferred the reply to a later statement, where `seen`/`fileAnswer` no longer exist\n128\t   * (variables do not persist between statements) — and thrashed on `Cannot find name '…'`,\n129\t   * re-reading files it had already read.\n130\t   *\n131\t   * \"Don't dump the value\" must always come with \"write the prose out of it, here, now\".\n132\t   */\n133\t  it('shows the reply being composed in the SAME statement as the delegate that produced it', () => {\n134\t    const src = instruct();\n135\t    expect(\n136\t      src,\n137\t      'the attachment example must still END in a display(...) — composing prose from the returned values, in the same statement',\n138\t    ).toMatch(/attachmentIds:[\\s\\S]{0,600}?\\bdisplay\\(/);\n139\t    expect(\n140\t      src,\n141\t      'THING must be warned that deferring the reply loses the value: variables do not persist between statements',\n142\t    ).toMatch(/do not persist between statements|DO NOT PERSIST between statements/i);\n143\t  });\n144\t\n145\t  it('identifies attachment delegate results as plain text rather than object-shaped data', () => {\n146\t    const src = instruct();\n147\t    expect(\n148\t      src,\n149\t      'the dispatcher and vision delegates resolve plain-text summaries, so THING must compose with them rather than inspect object fields that do not exist',\n150\t    ).toMatch(/delegates resolve to plain text/i);\n151\t    expect(src).toMatch(/Do NOT inspect them as objects/i);\n152\t  });\n153\t});\n154\t\n155\tdescribe('system-files readers — source text stays data, never executable code', () => {\n156\t  it('tells document and spreadsheet readers to synthesize source material instead of pasting it into TypeScript', () => {\n157\t    for (const agent of ['reader', 'sheet']) {\n158\t      const instruct = readFileSync(\n159\t        join(SYSTEM_SPACES, 'system-files', 'agents', agent, 'instruct.md'),\n160\t        'utf8',\n161\t      );\n162\t      expect(\n163\t        instruct,\n164\t        `${agent} must be told that raw uploaded material is data rather than code`,\n165\t      ).toMatch(/source material is data|sheet contents are data/i);\n166\t      expect(\n167\t        instruct,\n168\t        `${agent} must be told to synthesize rather than paste raw document text into TypeScript`,\n169\t      ).toMatch(/synthesize; never paste/i);\n170\t      expect(instruct).toMatch(/parse\\/typecheck failures/i);\n171\t    }\n172\t  });\n173\t});\n174\t\n175\tdescribe('system-architect/synthesize_and_run — the design node must hand the model code that TYPECHECKS', () => {\n176\t  /**\n177\t   * The design node's own example declared `const functions = [];` and then passed it straight to\n178\t   * `currentTask.resolve({ slug, goal, actionId, fields, functions })`. A bare empty array literal\n179\t   * is an \"evolving array\": push to it and TS infers the element type, but USE it before anything\n180\t   * has been pushed and the type can never be determined. That exact shape fails typecheck:\n181\t   *\n182\t   *   TS7034: Variable 'functions' implicitly has type 'any[]' in some locations…\n183\t   *   TS7005: Variable 'functions' implicitly has an 'any[]' type.\n184\t   *\n185\t   * The model copies the example, so this fired on EVERY specialist build — and the retry cascade\n186\t   * from there is a trap: redeclaring it gives \"Cannot redeclare block-scoped variable\", and\n187\t   * assigning to it gives \"Cannot assign to 'functions' because it is a constant\". Observed live\n188\t   * (10-family-recipes Act I) as unrecovered typecheck errors that burned the authoring turn.\n189\t   *\n190\t   * A prompt that hands the model uncompilable code is a bug in the prompt.\n191\t   */\n192\t  it('annotates the empty `functions` array instead of leaving it to be inferred', () => {\n193\t    const design = readFileSync(\n194\t      join(SYSTEM_SPACES, 'system-architect', 'tasklists', 'synthesize_and_run', '01-design.md'),\n195\t      'utf8',\n196\t    );\n197\t\n198\t    expect(\n199\t      design,\n200\t      'a bare `const functions = [];` cannot typecheck once it is passed to currentTask.resolve — annotate the element type',\n201\t    ).not.toMatch(/const\\s+functions\\s*=\\s*\\[\\s*\\]\\s*;/);\n202\t\n203\t    expect(\n204\t      design,\n205\t      'the design node must declare `functions` with an explicit element type',\n206\t    ).toMatch(/const\\s+functions\\s*:\\s*(Array<|\\{[\\s\\S]*?\\}\\[)/);\n207\t  });\n208\t});\n209\t\n210\tdescribe('system-appbuilder repair turns', () => {\n211\t  it('requires a missing-page repair to write the page rather than inventory the project', () => {\n212\t    const automator = readFileSync(\n213\t      join(SYSTEM_SPACES, 'system-appbuilder', 'agents', 'automator', 'instruct.md'),\n214\t      'utf8',\n215\t    );\n216\t\n217\t    expect(automator).toMatch(/A repair request naming a missing page is a WRITE, not a diagnosis/i);\n218\t    expect(automator).toMatch(/write the `index` page and its needed read API immediately/i);\n219\t  });\n220\t});\n221\t\n222\tdescribe('user-thing supplied-material organization', () => {\n223\t  it('consumes the organizer envelope inline without re-entering the build', () => {\n224\t    const thing = readFileSync(\n225\t      join(SYSTEM_SPACES, 'user-thing', 'agents', 'thing', 'instruct.md'),\n226\t      'utf8',\n227\t    );\n228\t\n229\t    expect(thing).toMatch(/organize_material[\\s\\S]{0,700}?\\.then\\(\\(organized\\) => display/);\n230\t    expect(thing).toMatch(/Do NOT delegate to the automator or architect, call the\\n   organizer again, or continue authoring/i);\n231\t    expect(thing).toMatch(/Its envelope is the proof of the workflow's outcome/i);\n232\t    expect(thing).toMatch(/do not inspect the project or try to\\n   validate individual builder results afterwards/i);\n233\t    expect(thing).toMatch(/values do not persist into a later statement/i);\n234\t  });\n235\t});\n236\t\n237\tdescribe('system-architect synthesis setup', () => {\n238\t  it('returns the synthesized tasklist envelope without a fragile manual continuation', () => {\n239\t    const architect = readFileSync(\n240\t      join(SYSTEM_SPACES, 'system-architect', 'agents', 'architect', 'instruct.md'),\n241\t      'utf8',\n242\t    );\n243\t    const writeAgent = readFileSync(\n244\t      join(SYSTEM_SPACES, 'system-architect', 'tasklists', 'synthesize_and_run', '04-write_agent.md'),\n245\t      'utf8',\n246\t    );\n247\t\n248\t    expect(architect).toMatch(/exactly ONE statement/i);\n249\t    expect(architect).toMatch(/action runtime returns this tasklist's envelope to the caller/i);\n250\t    expect(architect).not.toMatch(/const built = t\\.data/);\n251\t    expect(architect).not.toMatch(/const\\s+built\\s*=\\s*t\\.data/);\n252\t    expect(writeAgent).toMatch(/must NOT delegate to the newly-created agent during\\nsetup/i);\n253\t  });\n254\t});\n255\t\n256\tdescribe('no system-space prompt is overfitted to a scenario', () => {\n257\t  /**\n258\t   * A system-space prompt is a brain EVERY user shares. A literal borrowed from one scenario\n259\t   * (a persona's name, a fixture's contents, a scenario's table name) teaches the agent the answer\n260\t   * to one exam question and makes it dumber everywhere else — and examples in a prompt get COPIED\n261\t   * INTO REAL OUTPUT (hardcoded example values have previously landed verbatim in real users' data).\n262\t   * A \"don't do this\" example is one careless read away from becoming a \"do this\" template, so this\n263\t   * guard applies to negative examples too.\n264\t   *\n265\t   * These are literals from the live scenario suite. None of them belongs in any agent's brain.\n266\t   */\n267\t  const SCENARIO_LITERALS = [\n268\t    'Huchuypicchu',   // 05-latam — the Machu Picchu PDF's circuit name\n269\t    'Churuquella',    // 05-latam — the voice memo's Sucre viewpoint\n270\t    'Wild Rover',     // 05-latam — the trip-notes hostel\n271\t    'Red Planet Expedition', // 05-latam — the screenshot's Uyuni operator\n272\t    'Torres del Paine',      // 05-latam — the spreadsheet's park-fee line\n273\t    'ZZJQUU',         // a booking ref that once leaked into real users' data\n274\t    'boiler_service_log',\n275\t    'household_items',\n276\t  ];\n277\t\n278\t  it('contains no scenario-specific literal in any instruct.md / charter.md / knowledge file', () => {\n279\t    const offenders: string[] = [];\n280\t    for (const file of walk(SYSTEM_SPACES)) {\n281\t      const body = readFileSync(file, 'utf8');\n282\t      for (const lit of SCENARIO_LITERALS) {\n283\t        if (body.includes(lit)) offenders.push(`${relative(SYSTEM_SPACES, file)} contains \"${lit}\"`);\n284\t      }\n285\t    }\n286\t    expect(\n287\t      offenders,\n288\t      'a scenario literal in a system-space prompt is overfitting: it teaches the agent one exam answer and can be copied verbatim into a real user\\'s data',\n289\t    ).toEqual([]);\n290\t  });\n291\t});\n292\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"b2f0115a-3dfb-4214-b8eb-b5d43ec2086c","timestamp":"2026-07-16T06:15:05.628Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
