{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_bmGIOl4H8X06MQ6FpdzXAz2w","type":"tool_result","content":"1\t/**\n2\t * Plan S9 — headless SPACE-tasklist runner + the code-node execution context.\n3\t *\n4\t * Two seams live here, both consumed by {@link ../session-manager.js SessionManager}:\n5\t *\n6\t *   1. {@link createCodeNodeCtxFactory} — builds the `codeNodeCtxFactory` the core\n7\t *      tasklist orchestrator (`libs/core` S2) calls for every `kind:'code'` node.\n8\t *      For each node it loads the node module's `run(ctx, inputs)` in a Node worker\n9\t *      ({@link invokeNamedFnInWorker}) with a ctx whose `db`/`delegate`/`callConnection`\n10\t *      are serviced main-side — store-downloaded node code never runs in-proc. The\n11\t *      SAME factory is threaded into (a) the interactive session (so an agent's\n12\t *      `tasklist()` yield can run code nodes) and (b) the headless runner below.\n13\t *\n14\t *   2. {@link runTasklistHeadless} — the standalone entry point (the `TasklistRunner`\n15\t *      a hook handler's `ctx.tasklist.run('<spaceId>/<slug>', seed)` calls). It parses\n16\t *      the `<spaceId>/<slug>` ref and delegates to `manager.runTasklistHeadless`,\n17\t *      which owns the fork-engine + session-record plumbing (it needs the manager's\n18\t *      private streamFn/resolvers). Keeping the heavy path on the manager maximizes\n19\t *      reuse of the existing headless wiring; this module stays the thin, importable\n20\t *      seam that `routes/hooks.ts` injects.\n21\t *\n22\t * Security (plan \"Security invariants\"): a space tasklist's code nodes are store\n23\t * code — they execute ONLY worker-isolated + timeout-bounded, and their\n24\t * `callConnection` is locked to the tasklist's declared `connections:` INTERSECT\n25\t * the owning space's own provider(s), so a space can never reach beyond what it\n26\t * itself declared (mirrors the space-hook gate in `routes/hooks.ts`).\n27\t */\n28\timport { readFileSync } from 'node:fs';\n29\timport { basename, dirname, join } from 'node:path';\n30\timport { parseFrontmatter } from '@lmthing/core';\n31\timport type { ConnectionRequest, ConnectionResolver, CodeNodeCtxFactory, TaskNode } from '@lmthing/core';\n32\timport { invokeNamedFnInWorker, type WorkerInvokeHandlers } from '../app/worker-load.js';\n33\t\n34\t/** Dependencies {@link createCodeNodeCtxFactory} needs from the host (SessionManager).\n35\t *  All are project-scoped closures the manager already has the pieces to build. */\n36\texport interface CodeNodeFactoryDeps {\n37\t  /** Lazily resolve the project's async db (or `null` for a spaces-only project).\n38\t   *  Called per code-node run so an interactive session that built the factory\n39\t   *  before its db booted still gets a live handle. */\n40\t  getDb: () => Promise<{ async: unknown } | null>;\n41\t  /** Run a headless agent for a code node's `ctx.delegate(spaceRef, action?, opts?)`\n42\t   *  — mirrors the hook ctx's delegate (returns the run's `DelegateResult`). */\n43\t  delegate: (spaceRef: string, action?: string, opts?: unknown) => Promise<unknown>;\n44\t  /** Pod connection resolver (bring-your-own-token). Gated per call by the\n45\t   *  tasklist's `connections:` ∩ the owning space's own provider(s). */\n46\t  connectionResolver: ConnectionResolver;\n47\t  /** Per-node worker wall-clock budget (ms). Omit for the worker-load default. */\n48\t  timeoutMs?: number;\n49\t}\n50\t\n51\t/** Read a space's OWN connection provider(s) from `<spaceDir>/package.json`\n52\t *  (`lmthing.connection.provider`). Best-effort — a missing/malformed manifest ⇒\n53\t *  no own providers (every `callConnection` in the tasklist then throws). */\n54\tfunction spaceOwnProviders(spaceDir: string): Set<string> {\n55\t  try {\n56\t    const pkg = JSON.parse(readFileSync(join(spaceDir, 'package.json'), 'utf8')) as {\n57\t      lmthing?: { connection?: { provider?: unknown } };\n58\t    };\n59\t    const provider = pkg.lmthing?.connection?.provider;\n60\t    return typeof provider === 'string' && provider ? new Set([provider]) : new Set();\n61\t  } catch {\n62\t    return new Set();\n63\t  }\n64\t}\n65\t\n66\t/** Read a tasklist's declared `connections:` from `<tasklistDir>/index.md`\n67\t *  frontmatter (the tasklist-level gate). Best-effort — no index / no key ⇒ []. */\n68\tfunction tasklistDeclaredConnections(tasklistDir: string): string[] {\n69\t  try {\n70\t    const raw = readFileSync(join(tasklistDir, 'index.md'), 'utf8');\n71\t    const { data } = parseFrontmatter(raw, join(tasklistDir, 'index.md'));\n72\t    return Array.isArray(data['connections']) ? data['connections'].map(String) : [];\n73\t  } catch {\n74\t    return [];\n75\t  }\n76\t}\n77\t\n78\t/**\n79\t * Build the {@link CodeNodeCtxFactory} the orchestrator calls per `kind:'code'`\n80\t * node. The allowed-provider set for a node is derived ENTIRELY from its\n81\t * `codeModulePath` (`.../<space>/tasklists/<slug>/NN-<id>.ts`): the owning space\n82\t * dir and the tasklist dir are path-relative, so ONE session-wide factory works\n83\t * for any tasklist the agent runs (the in-session path) and for the resolved\n84\t * headless run alike. Result is cached per tasklist dir.\n85\t */\n86\texport function createCodeNodeCtxFactory(deps: CodeNodeFactoryDeps): CodeNodeCtxFactory {\n87\t  const allowedCache = new Map<string, Set<string>>();\n88\t\n89\t  const allowedFor = (codeModulePath: string): Set<string> => {\n90\t    const tasklistDir = dirname(codeModulePath);\n91\t    const cached = allowedCache.get(tasklistDir);\n92\t    if (cached) return cached;\n93\t    // .../<space>/tasklists/<slug>/NN-<id>.ts → space dir is two levels above the\n94\t    // tasklist dir (tasklists/<slug> → tasklists → <space>).\n95\t    const spaceDir = dirname(dirname(tasklistDir));\n96\t    const own = spaceOwnProviders(spaceDir);\n97\t    const declared = tasklistDeclaredConnections(tasklistDir);\n98\t    // Space tasklist: locked to declared ∩ own (a space can never reach beyond\n99\t    // what it itself declared AND owns).\n100\t    const allowed = new Set(declared.filter((p) => own.has(p)));\n101\t    allowedCache.set(tasklistDir, allowed);\n102\t    return allowed;\n103\t  };\n104\t\n105\t  return (node: TaskNode) => ({\n106\t    runCodeNode: async (inputs) => {\n107\t      const modulePath = node.codeModulePath;\n108\t      if (!modulePath) {\n109\t        throw new Error(`code node \"${node.id}\" has no codeModulePath — cannot run`);\n110\t      }\n111\t      const allowed = allowedFor(modulePath);\n112\t      const db = await deps.getDb();\n113\t      const handlers: WorkerInvokeHandlers = {\n114\t        ...(db ? { db: db.async as WorkerInvokeHandlers['db'] } : {}),\n115\t        delegate: deps.delegate,\n116\t        callConnection: (provider, req) => {\n117\t          if (!allowed.has(provider)) {\n118\t            throw new Error(\n119\t              `callConnection(\"${provider}\"): not allowed for tasklist \"${basename(dirname(modulePath))}\"` +\n120\t                (allowed.size\n121\t                  ? ` (allowed: ${[...allowed].sort().join(', ')})`\n122\t                  : ' — the tasklist declared no connections owned by its space'),\n123\t            );\n124\t          }\n125\t          return deps.connectionResolver(provider, req as ConnectionRequest);\n126\t        },\n127\t      };\n128\t      const out = await invokeNamedFnInWorker(\n129\t        modulePath,\n130\t        'run',\n131\t        [inputs],\n132\t        handlers,\n133\t        deps.timeoutMs ? { timeoutMs: deps.timeoutMs } : {},\n134\t      );\n135\t      return out && typeof out === 'object' ? (out as Record<string, unknown>) : {};\n136\t    },\n137\t  });\n138\t}\n139\t\n140\t/** The manager surface {@link runTasklistHeadless} needs — the heavy fork-engine +\n141\t *  session-record path lives on `SessionManager.runTasklistHeadless` (it needs the\n142\t *  manager's private streamFn/resolvers). Structural so this module never imports\n143\t *  the concrete `SessionManager` (and tests can fake it). */\n144\texport interface TasklistRunnerManager {\n145\t  runTasklistHeadless(args: {\n146\t    projectId: string;\n147\t    spaceId: string;\n148\t    slug: string;\n149\t    seed?: Record<string, unknown>;\n150\t  }): Promise<unknown>;\n151\t}\n152\t\n153\t/** Parse a `<spaceId>/<slug>` tasklist ref. Extra path segments are folded back\n154\t *  into the slug is NOT supported — a tasklist ref is exactly two segments. */\n155\tfunction parseTasklistRef(ref: string): { spaceId: string; slug: string } {\n156\t  const slash = ref.indexOf('/');\n157\t  if (slash < 0) {\n158\t    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n159\t  }\n160\t  const spaceId = ref.slice(0, slash);\n161\t  const slug = ref.slice(slash + 1);\n162\t  if (!spaceId || !slug) {\n163\t    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n164\t  }\n165\t  return { spaceId, slug };\n166\t}\n167\t\n168\t/**\n169\t * Run a SPACE tasklist headless (plan S9). Resolves `<spaceId>/<slug>` from the\n170\t * ref and delegates to `manager.runTasklistHeadless`. This is the callable a hook\n171\t * handler's `ctx.tasklist.run(ref, seed)` routes to; `routes/hooks.ts` injects a\n172\t * per-project binding of it via {@link makeHookTasklistRunner}.\n173\t */\n174\texport function runTasklistHeadless(opts: {\n175\t  root: string;\n176\t  projectId: string;\n177\t  ref: string;\n178\t  seed?: Record<string, unknown>;\n179\t  manager: TasklistRunnerManager;\n180\t}): Promise<unknown> {\n181\t  const { spaceId, slug } = parseTasklistRef(opts.ref);\n182\t  return opts.manager.runTasklistHeadless({ projectId: opts.projectId, spaceId, slug, seed: opts.seed });\n183\t}\n184\t\n185\t/** Build the per-project `TasklistRunner` (`(ref, seed) => Promise`) that\n186\t *  `routes/hooks.ts` injects into `runHook` so a hook handler's\n187\t *  `ctx.tasklist.run('<spaceId>/<slug>', seed)` runs the resolved space tasklist\n188\t *  headless. */\n189\texport function makeHookTasklistRunner(\n190\t  manager: TasklistRunnerManager,\n191\t  root: string,\n192\t  projectId: string,\n193\t): (ref: string, seed?: unknown) => Promise<unknown> {\n194\t  return (ref, seed) =>\n195\t    runTasklistHeadless({ root, projectId, ref, seed: seed as Record<string, unknown> | undefined, manager });\n196\t}\n197\t"}]},"parent_tool_use_id":null,"session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"cea8709a-ccf8-436e-9302-cfee7628d117","timestamp":"2026-07-16T19:26:32.286Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/tasklist-runner.ts","content":"/**\n * Plan S9 — headless SPACE-tasklist runner + the code-node execution context.\n *\n * Two seams live here, both consumed by {@link ../session-manager.js SessionManager}:\n *\n *   1. {@link createCodeNodeCtxFactory} — builds the `codeNodeCtxFactory` the core\n *      tasklist orchestrator (`libs/core` S2) calls for every `kind:'code'` node.\n *      For each node it loads the node module's `run(ctx, inputs)` in a Node worker\n *      ({@link invokeNamedFnInWorker}) with a ctx whose `db`/`delegate`/`callConnection`\n *      are serviced main-side — store-downloaded node code never runs in-proc. The\n *      SAME factory is threaded into (a) the interactive session (so an agent's\n *      `tasklist()` yield can run code nodes) and (b) the headless runner below.\n *\n *   2. {@link runTasklistHeadless} — the standalone entry point (the `TasklistRunner`\n *      a hook handler's `ctx.tasklist.run('<spaceId>/<slug>', seed)` calls). It parses\n *      the `<spaceId>/<slug>` ref and delegates to `manager.runTasklistHeadless`,\n *      which owns the fork-engine + session-record plumbing (it needs the manager's\n *      private streamFn/resolvers). Keeping the heavy path on the manager maximizes\n *      reuse of the existing headless wiring; this module stays the thin, importable\n *      seam that `routes/hooks.ts` injects.\n *\n * Security (plan \"Security invariants\"): a space tasklist's code nodes are store\n * code — they execute ONLY worker-isolated + timeout-bounded, and their\n * `callConnection` is locked to the tasklist's declared `connections:` INTERSECT\n * the owning space's own provider(s), so a space can never reach beyond what it\n * itself declared (mirrors the space-hook gate in `routes/hooks.ts`).\n */\nimport { readFileSync } from 'node:fs';\nimport { basename, dirname, join } from 'node:path';\nimport { parseFrontmatter } from '@lmthing/core';\nimport type { ConnectionRequest, ConnectionResolver, CodeNodeCtxFactory, TaskNode } from '@lmthing/core';\nimport { invokeNamedFnInWorker, type WorkerInvokeHandlers } from '../app/worker-load.js';\n\n/** Dependencies {@link createCodeNodeCtxFactory} needs from the host (SessionManager).\n *  All are project-scoped closures the manager already has the pieces to build. */\nexport interface CodeNodeFactoryDeps {\n  /** Lazily resolve the project's async db (or `null` for a spaces-only project).\n   *  Called per code-node run so an interactive session that built the factory\n   *  before its db booted still gets a live handle. */\n  getDb: () => Promise<{ async: unknown } | null>;\n  /** Run a headless agent for a code node's `ctx.delegate(spaceRef, action?, opts?)`\n   *  — mirrors the hook ctx's delegate (returns the run's `DelegateResult`). */\n  delegate: (spaceRef: string, action?: string, opts?: unknown) => Promise<unknown>;\n  /** Pod connection resolver (bring-your-own-token). Gated per call by the\n   *  tasklist's `connections:` ∩ the owning space's own provider(s). */\n  connectionResolver: ConnectionResolver;\n  /** Per-node worker wall-clock budget (ms). Omit for the worker-load default. */\n  timeoutMs?: number;\n}\n\n/** Read a space's OWN connection provider(s) from `<spaceDir>/package.json`\n *  (`lmthing.connection.provider`). Best-effort — a missing/malformed manifest ⇒\n *  no own providers (every `callConnection` in the tasklist then throws). */\nfunction spaceOwnProviders(spaceDir: string): Set<string> {\n  try {\n    const pkg = JSON.parse(readFileSync(join(spaceDir, 'package.json'), 'utf8')) as {\n      lmthing?: { connection?: { provider?: unknown } };\n    };\n    const provider = pkg.lmthing?.connection?.provider;\n    return typeof provider === 'string' && provider ? new Set([provider]) : new Set();\n  } catch {\n    return new Set();\n  }\n}\n\n/** Read a tasklist's declared `connections:` from `<tasklistDir>/index.md`\n *  frontmatter (the tasklist-level gate). Best-effort — no index / no key ⇒ []. */\nfunction tasklistDeclaredConnections(tasklistDir: string): string[] {\n  try {\n    const raw = readFileSync(join(tasklistDir, 'index.md'), 'utf8');\n    const { data } = parseFrontmatter(raw, join(tasklistDir, 'index.md'));\n    return Array.isArray(data['connections']) ? data['connections'].map(String) : [];\n  } catch {\n    return [];\n  }\n}\n\n/**\n * Build the {@link CodeNodeCtxFactory} the orchestrator calls per `kind:'code'`\n * node. The allowed-provider set for a node is derived ENTIRELY from its\n * `codeModulePath` (`.../<space>/tasklists/<slug>/NN-<id>.ts`): the owning space\n * dir and the tasklist dir are path-relative, so ONE session-wide factory works\n * for any tasklist the agent runs (the in-session path) and for the resolved\n * headless run alike. Result is cached per tasklist dir.\n */\nexport function createCodeNodeCtxFactory(deps: CodeNodeFactoryDeps): CodeNodeCtxFactory {\n  const allowedCache = new Map<string, Set<string>>();\n\n  const allowedFor = (codeModulePath: string): Set<string> => {\n    const tasklistDir = dirname(codeModulePath);\n    const cached = allowedCache.get(tasklistDir);\n    if (cached) return cached;\n    // .../<space>/tasklists/<slug>/NN-<id>.ts → space dir is two levels above the\n    // tasklist dir (tasklists/<slug> → tasklists → <space>).\n    const spaceDir = dirname(dirname(tasklistDir));\n    const own = spaceOwnProviders(spaceDir);\n    const declared = tasklistDeclaredConnections(tasklistDir);\n    // Space tasklist: locked to declared ∩ own (a space can never reach beyond\n    // what it itself declared AND owns).\n    const allowed = new Set(declared.filter((p) => own.has(p)));\n    allowedCache.set(tasklistDir, allowed);\n    return allowed;\n  };\n\n  return (node: TaskNode) => ({\n    runCodeNode: async (inputs) => {\n      const modulePath = node.codeModulePath;\n      if (!modulePath) {\n        throw new Error(`code node \"${node.id}\" has no codeModulePath — cannot run`);\n      }\n      const allowed = allowedFor(modulePath);\n      const db = await deps.getDb();\n      const handlers: WorkerInvokeHandlers = {\n        ...(db ? { db: db.async as WorkerInvokeHandlers['db'] } : {}),\n        delegate: deps.delegate,\n        callConnection: (provider, req) => {\n          if (!allowed.has(provider)) {\n            throw new Error(\n              `callConnection(\"${provider}\"): not allowed for tasklist \"${basename(dirname(modulePath))}\"` +\n                (allowed.size\n                  ? ` (allowed: ${[...allowed].sort().join(', ')})`\n                  : ' — the tasklist declared no connections owned by its space'),\n            );\n          }\n          return deps.connectionResolver(provider, req as ConnectionRequest);\n        },\n      };\n      const out = await invokeNamedFnInWorker(\n        modulePath,\n        'run',\n        [inputs],\n        handlers,\n        deps.timeoutMs ? { timeoutMs: deps.timeoutMs } : {},\n      );\n      return out && typeof out === 'object' ? (out as Record<string, unknown>) : {};\n    },\n  });\n}\n\n/** The manager surface {@link runTasklistHeadless} needs — the heavy fork-engine +\n *  session-record path lives on `SessionManager.runTasklistHeadless` (it needs the\n *  manager's private streamFn/resolvers). Structural so this module never imports\n *  the concrete `SessionManager` (and tests can fake it). */\nexport interface TasklistRunnerManager {\n  runTasklistHeadless(args: {\n    projectId: string;\n    spaceId: string;\n    slug: string;\n    seed?: Record<string, unknown>;\n  }): Promise<unknown>;\n}\n\n/** Parse a `<spaceId>/<slug>` tasklist ref. Extra path segments are folded back\n *  into the slug is NOT supported — a tasklist ref is exactly two segments. */\nfunction parseTasklistRef(ref: string): { spaceId: string; slug: string } {\n  const slash = ref.indexOf('/');\n  if (slash < 0) {\n    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n  }\n  const spaceId = ref.slice(0, slash);\n  const slug = ref.slice(slash + 1);\n  if (!spaceId || !slug) {\n    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n  }\n  return { spaceId, slug };\n}\n\n/**\n * Run a SPACE tasklist headless (plan S9). Resolves `<spaceId>/<slug>` from the\n * ref and delegates to `manager.runTasklistHeadless`. This is the callable a hook\n * handler's `ctx.tasklist.run(ref, seed)` routes to; `routes/hooks.ts` injects a\n * per-project binding of it via {@link makeHookTasklistRunner}.\n */\nexport function runTasklistHeadless(opts: {\n  root: string;\n  projectId: string;\n  ref: string;\n  seed?: Record<string, unknown>;\n  manager: TasklistRunnerManager;\n}): Promise<unknown> {\n  const { spaceId, slug } = parseTasklistRef(opts.ref);\n  return opts.manager.runTasklistHeadless({ projectId: opts.projectId, spaceId, slug, seed: opts.seed });\n}\n\n/** Build the per-project `TasklistRunner` (`(ref, seed) => Promise`) that\n *  `routes/hooks.ts` injects into `runHook` so a hook handler's\n *  `ctx.tasklist.run('<spaceId>/<slug>', seed)` runs the resolved space tasklist\n *  headless. */\nexport function makeHookTasklistRunner(\n  manager: TasklistRunnerManager,\n  root: string,\n  projectId: string,\n): (ref: string, seed?: unknown) => Promise<unknown> {\n  return (ref, seed) =>\n    runTasklistHeadless({ root, projectId, ref, seed: seed as Record<string, unknown> | undefined, manager });\n}\n","numLines":197,"startLine":1,"totalLines":197}}}
