{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_d9lftjsNyrX7pAD6WqQ4d6yU","type":"tool_result","content":"1\timport { fileURLToPath } from 'node:url';\n2\timport { dirname, join, resolve, basename } from 'node:path';\n3\timport { existsSync } from 'node:fs';\n4\timport { loadSpace } from './load.js';\n5\timport type { Space, AgentDef } from './load.js';\n6\t\n7\t/**\n8\t * System spaces are always-loaded baseline capability spaces. Their\n9\t * components/knowledge/agents/tasklists are merged into every user space, and\n10\t * their AGENTS are universally delegatable.\n11\t *\n12\t * FUNCTIONS, however, are universal ONLY when they live in the `system-global`\n13\t * system space (the always-on toolkit: file editing, search, web, memory, todos).\n14\t * Every other system space's functions are SCOPED to its own agent(s) — they reach\n15\t * an agent solely through the per-agent path (getAgentFunctions), so a system space\n16\t * that ships an agent (system-architect, system-research) keeps its specialist\n17\t * functions out of every other space's prompt and VM. See systemFunctionSources below.\n18\t *\n19\t * Capabilities live in spaces, not in ad-hoc core globals (the runtime stays a\n20\t * thin substrate). The host primitives those functions wrap (readFileRaw,\n21\t * writeFileRaw, execShell, fetch) are injected separately by host-tools.ts.\n22\t */\n23\t\n24\tconst __dirname = dirname(fileURLToPath(import.meta.url));\n25\t\n26\t/** The single function-only system space whose functions are injected universally. */\n27\texport const GLOBAL_SPACE_NAME = 'system-global';\n28\t\n29\t/** The bundled system spaces shipped with @lmthing/core. */\n30\texport const SYSTEM_SPACE_NAMES = [\n31\t  'system-global',\n32\t  'system-engineer',\n33\t  'system-architect',\n34\t  'system-research',\n35\t  'system-appbuilder',\n36\t  'system-vision',\n37\t  'system-files',\n38\t  'system-store',\n39\t  'user-memory',\n40\t  'user-thing',\n41\t] as const;\n42\t\n43\t/**\n44\t * Resolve the directory holding the bundled system spaces. At runtime this file\n45\t * lives in dist/ (so system-spaces/ is one level up); under vitest it runs from\n46\t * src/spaces/ (two levels up). Probe both so the path resolves in either layout\n47\t * rather than silently yielding a nonexistent dir.\n48\t * Overridable via LM_SYSTEM_SPACES (csv of dirs) handled by the caller.\n49\t */\n50\texport function defaultSystemSpaceDirs(): string[] {\n51\t  const candidates = [\n52\t    resolve(__dirname, '..', 'system-spaces'), // dist/ layout: dist → core/system-spaces\n53\t    resolve(__dirname, '..', '..', 'system-spaces'), // src/ layout: src/spaces → core/system-spaces\n54\t  ];\n55\t  const base = candidates.find((c) => existsSync(c)) ?? candidates[0]!;\n56\t  return SYSTEM_SPACE_NAMES.map((n) => join(base, n));\n57\t}\n58\t\n59\t/** Load each system space directory (tolerating function-only spaces with no agents/). */\n60\texport async function loadSystemSpaces(dirs: string[]): Promise<Space[]> {\n61\t  const spaces: Space[] = [];\n62\t  for (const dir of dirs) {\n63\t    try {\n64\t      spaces.push(await loadSpace(dir, { requireAgents: false }));\n65\t    } catch {\n66\t      // A missing/invalid system space dir should not break the session.\n67\t    }\n68\t  }\n69\t  return spaces;\n70\t}\n71\t\n72\t/** True for the always-on toolkit space whose functions are injected universally. */\n73\tfunction isGlobalSpace(s: Space): boolean {\n74\t  return basename(s.dir) === GLOBAL_SPACE_NAME;\n75\t}\n76\t\n77\t/** Names of the UNIVERSAL functions (the `system-global` toolkit only). */\n78\texport function systemFunctionNames(systemSpaces: Space[]): Set<string> {\n79\t  const names = new Set<string>();\n80\t  for (const s of systemSpaces) {\n81\t    if (!isGlobalSpace(s)) continue;\n82\t    for (const n of Object.keys(s.functions)) names.add(n);\n83\t  }\n84\t  return names;\n85\t}\n86\t\n87\t/** The TS source of every UNIVERSAL function (the `system-global` toolkit; used for the typecheck overlay). */\n88\texport function systemFunctionSources(systemSpaces: Space[]): Record<string, string> {\n89\t  const out: Record<string, string> = {};\n90\t  for (const s of systemSpaces) {\n91\t    if (!isGlobalSpace(s)) continue;\n92\t    for (const [name, src] of Object.entries(s.functions)) out[name] = src;\n93\t  }\n94\t  return out;\n95\t}\n96\t\n97\t/** The bundled JS of every UNIVERSAL function (when the `system-global` space had node_modules). */\n98\texport function systemFunctionsBundled(systemSpaces: Space[]): Record<string, string> {\n99\t  const out: Record<string, string> = {};\n100\t  for (const s of systemSpaces) {\n101\t    if (!isGlobalSpace(s)) continue;\n102\t    for (const [name, src] of Object.entries(s.functionsBundled)) out[name] = src;\n103\t  }\n104\t  return out;\n105\t}\n106\t\n107\t/**\n108\t * Merge system spaces into a user space. The user space wins on every name\n109\t * collision (so a space can override a system tool). Returns a NEW Space; the\n110\t * inputs are not mutated.\n111\t */\n112\texport function mergeSystemInto(userSpace: Space, systemSpaces: Space[]): Space {\n113\t  const functions: Record<string, string> = {};\n114\t  const functionsBundled: Record<string, string> = {};\n115\t  const view: Record<string, string> = {};\n116\t  const form: Record<string, string> = {};\n117\t  const agents: Record<string, AgentDef> = {};\n118\t  const tasklists: Record<string, import('./load.js').TasklistDir> = {};\n119\t  const knowledgeDomains = { ...userSpace.knowledge.domains };\n120\t\n121\t  // System first (lower priority)…\n122\t  for (const s of systemSpaces) {\n123\t    Object.assign(functions, s.functions);\n124\t    Object.assign(functionsBundled, s.functionsBundled);\n125\t    Object.assign(view, s.components.view);\n126\t    Object.assign(form, s.components.form);\n127\t    Object.assign(agents, s.agents);\n128\t    Object.assign(tasklists, s.tasklists);\n129\t    for (const [slug, domain] of Object.entries(s.knowledge.domains)) {\n130\t      if (!(slug in knowledgeDomains)) knowledgeDomains[slug] = domain;\n131\t    }\n132\t  }\n133\t\n134\t  // …user space overlays (higher priority).\n135\t  Object.assign(functions, userSpace.functions);\n136\t  Object.assign(functionsBundled, userSpace.functionsBundled);\n137\t  Object.assign(view, userSpace.components.view);\n138\t  Object.assign(form, userSpace.components.form);\n139\t  // Agents: a user agent normally wins on a slug collision — BUT an EMPTY placeholder\n140\t  // agent (an `agents/<slug>/` dir with no instruct.md → no instructBody and no actions)\n141\t  // must NOT shadow a real system agent of the same slug. That silent shadowing is what\n142\t  // stripped the system `architect` (its instructions, actions, and defaultAction) when a\n143\t  // space happened to contain an empty `agents/architect/` dir.\n144\t  for (const [slug, agent] of Object.entries(userSpace.agents)) {\n145\t    const isEmptyPlaceholder = !agent.instructBody?.trim() && agent.actions.length === 0;\n146\t    if (isEmptyPlaceholder && agents[slug]) continue; // keep the system agent\n147\t    agents[slug] = agent;\n148\t  }\n149\t  // Tasklists: user wins, except an EMPTY user tasklist dir (no .md files) must not\n150\t  // shadow a system tasklist of the same slug — same placeholder-shadowing trap as agents\n151\t  // (an empty `tasklists/synthesize_and_run/` would otherwise hide the architect's real DAG).\n152\t  for (const [slug, tl] of Object.entries(userSpace.tasklists)) {\n153\t    if (tl.files.length === 0 && tasklists[slug]) continue; // keep the system tasklist\n154\t    tasklists[slug] = tl;\n155\t  }\n156\t\n157\t  return {\n158\t    ...userSpace,\n159\t    functions,\n160\t    functionsBundled,\n161\t    agents,\n162\t    tasklists,\n163\t    components: { view, form },\n164\t    knowledge: { domains: knowledgeDomains },\n165\t  };\n166\t}\n167\t"}]},"parent_tool_use_id":"call_G4vK6Ya5Jy5gTGzjEff4VitG","session_id":"7193a049-8ab5-4b33-ba1c-323f4246ccc2","uuid":"74600c3e-7983-4e0b-84b1-7791a3d16c5a","timestamp":"2026-07-16T00:54:12.141Z","subagent_type":"Explore","task_description":"Trace Tanzania fan-out failure"}
