> sum + (c.amount ?? 0), 0);\n\n  // Countdown: find earliest leg and compute days until its dateRange start\n  const legs = itinerary.data?.items ?? [];\n  const firstLeg = legs.length > 0 ? legs[0] : null;\n  const countdownDays = firstLeg\n    ? Math.max(0, Math.ceil((new Date(firstLeg.dateRange.split(' – ')[0]).getTime() - Date.now()) / 86400000))\n    : null;\n\n  // Next up: the first leg whose dateRange start is today or later\n  const now = Date.now();\n  const nextLeg = legs.find(leg => new Date(leg.dateRange.split(' – ')[0]).getTime() >= now) ?? (legs.length > 0 ? legs[0] : null);\n\n  // Top 5 cost items by category for mini breakdown\n  const catBreakdown = (costsByCat.data?.items ?? []).slice(0, 5);\n\n  // Contacts: first 2\n  const keyContacts = (contacts.data?.items ?? []).slice(0, 2);\n\n  // Sub-page quick links\n  const subPages = [\n    { label: 'Itinerary', href: '/itinerary', desc: 'Day-by-day plan, lodging, nights' },\n    { label: 'Costs', href: '/costs', desc: 'All trip expenses by category' },\n    { label: 'Park Fees', href: '/park-fees', desc: 'Ngorongoro tariff reference' },\n    { label: 'Contacts', href: '/contacts', desc: 'Richard & Emmanuel at-a-glance' },\n    { label: 'Notes', href: '/notes', desc: 'Observations & action items' },\n  ];\n\n  return (\n    <main className=\"space-y-6 p-4\">\n      {/* Trip Stats Row */}\n      <section className=\"grid grid-cols-2 gap-3 md:grid-cols-4\">\n        <TripStatCard\n          label=\"Total Cost\"\n          value={totalCost.toLocaleString()}\n          subtitle=\"TZS / USD\"\n          href=\"/costs\"\n        />\n        countdownDays !== null ? (\n          <TripStatCard\n            label=\"Countdown\"\n            value={countdownDays}\n            subtitle=\"days to departure\"\n          />\n        ) : (\n          <TripStatCard label=\"Countdown\" value=\"—\" subtitle=\"no dates yet\" />\n        ),\n        <TripStatCard\n          label=\"Total Nights\"\n          value={totalNights}\n          subtitle={totalNights === 1 ? 'night in TZ' : 'nights in TZ'}\n        />,\n        <TripStatCard\n          label=\"Park Fees\"\n          value={totalParkFees.toLocaleString()}\n          subtitle=\"TZS / USD\"\n          href=\"/park-fees\"\n        />,\n      </section>\n\n      {/* Next Up Itinerary Leg */}\n      <section>\n        <h2 className=\"text-lg font-semibold text-foreground mb-2\">Next Up</h2>\n        {nextLeg ? (\n          <ItineraryRow leg={nextLeg} />\n        ) : (\n          <EmptyState title=\"No upcoming legs\" description=\"Add itinerary legs to see what's next.\" />\n        )}\n      </section>\n\n      {/* Mini Cost Breakdown by Category */}\n      <section>\n        <h2 className=\"text-lg font-semibold text-foreground mb-2\">Costs by Category</h2>\n        {catBreakdown.length > 0 ? (\n          <div className=\"space-y-1\">\n            {catBreakdown.map((grp) => (\n              <div key={grp.category} className=\"border-b border-border pb-1\">\n                <p className=\"text-sm font-medium text-foreground capitalize\">{grp.category.replace(/_/g, ' ')}</p>\n                <p className=\"text-xs text-muted\">{grp.total.toLocaleString()} {grp.currency}</p>\n              </div>\n            ))}\n          </div>\n        ) : (\n          <EmptyState title=\"No cost data\" description=\"Cost line items will appear here once added.\" />\n        )}\n      </section>\n\n      {/* Key Contacts */}\n      <section>\n        <h2 className=\"text-lg font-semibold text-foreground mb-2\">Key Contacts</h2>\n        {keyContacts.length > 0 ? (\n          <div className=\"grid grid-cols-1 gap-2 sm:grid-cols-2\">\n            {keyContacts.map((c) => (\n              <ContactCard key={c.id} contact={c} />\n            ))}\n          </div>\n        ) : (\n          <EmptyState title=\"No contacts yet\" description=\"Add Richard and Emmanuel to see them here.\" />\n        )}\n      </section>\n\n      {/* Quick-Link Cards to