 undefined);\n      } catch (err) {\n        if (vm) {\n          try { vm.dispose(); } catch { /* ignore dispose errors in error path */ }\n          vm = undefined;\n        }\n        const errMsg = err instanceof Error ? err.message : String(err);\n        settle(() => reject(err), 'error', errMsg);\n      }\n    });\n  }\n}\n","structuredPatch":[{"oldStart":372,"oldLines":7,"newStart":372,"newLines":7,"lines":["           : '';","         const seedDts = task.seed","           ? Object.keys(task.seed).map((k) => {","-              const type = k === 'item' ? 'Record<string, any>' : 'any';","+              const type = k === 'item' ? 'Record<string, any[]>' : 'any';","               return `declare const ${k}: ${type};`;","             }).join('\\n')","           : '';"]}],"userModified":false,"replaceAll":false}}
