# Azure Foundry
AZURE_API_KEY=your-azure-api-key

# Zitadel (self-hosted at auth.lmthing.cloud)
ZITADEL_URL=http://zitadel:8080
ZITADEL_ISSUER=https://auth.lmthing.cloud
ZITADEL_SERVICE_ACCOUNT_ID=your-machine-user-client-id
ZITADEL_SERVICE_ACCOUNT_KEY=your-machine-user-client-secret
ZITADEL_CLIENT_ID=your-web-app-client-id
ZITADEL_CLIENT_SECRET=your-web-app-client-secret

# PostgreSQL (K8s StatefulSet in lmthing namespace)
DATABASE_URL=postgresql://lmthing:password@postgres:5432/lmthing

# Stripe (live mode)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_MAX=price_xxx

# LiteLLM master key (generate: openssl rand -hex 32)
LITELLM_MASTER_KEY=sk-lmt-xxx
