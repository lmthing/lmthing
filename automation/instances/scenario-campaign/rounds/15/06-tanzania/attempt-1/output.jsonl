n,\n282\t        allowedActions,\n283\t        delegateOpts: childOpts,\n284\t        scope: delegateScope,\n285\t        depth: opts.depth + 1,\n286\t      });\n287\t\n288\t    const { ForkEngine } = await import('../fork/fork.js');\n289\t    // THE A1 FIX: the delegate-side ForkEngine is built through the same\n290\t    // exhaustively-typed options builder as the session's, so it can no longer\n291\t    // silently drop fields — it now inherits budgetLimits (leaf forks get real\n292\t    // budgets + the near-limit nudge), roleModels (right per-role model),\n293\t    // forkDepth (meaningful nesting accounting) and dynamicSpaces (a fork's\n294\t    // registerSpace() propagates back to the session) from its parent context.\n295\t    const forkEngine = new ForkEngine(forkEngineOptsFrom({\n296\t      maxConcurrentForks: opts.maxConcurrentForks,\n297\t      parentHistory: history.messages,\n298\t      parentSpaceDir: space.dir,\n299\t      parentAgentSlug: agent.slug,\n300\t      parentAgentCharter: agent.charterBody,\n301\t      agentFunctions: functions,\n302\t      agentFunctionsBundled: functionsBundled,\n303\t      renderHost: opts.renderHost,\n304\t      streamFn: opts.streamFn,\n305\t      clock: opts.clock,\n306\t      tracer: opts.tracer,\n307\t      projectSpacesDir: opts.projectSpacesDir,\n308\t      projectRoot: opts.projectRoot,\n309\t      projectId: opts.projectId,\n310\t      // This delegate's forks inherit ITS app grants (role-intersected in forkCapabilities).\n311\t      parentAppCapabilities: capabilities.app,\n312\t      appGlobals: opts.appGlobals,\n313\t      defaultModel: opts.model,\n314\t      budgetLimits: opts.budgetLimits,\n315\t      roleModels: opts.roleModels,\n316\t      // Forks spawned by this delegate nest one level below its delegation depth:\n317\t      // a top-level delegate (depth 0) spawns depth-1 forks (same as session forks);\n318\t      // each nested delegate layer pushes its forks one level deeper.\n319\t      forkDepth: opts.depth + 1,\n320\t      dynamicSpaces: opts.dynamicSpaces,\n321\t      // A task in this agent's tasklist may delegate (gated by its own canDelegateTo); route it\n322\t      // through the same depth-incrementing runner this agent uses for its own delegate() calls.\n323\t      delegateRunner: (packageName, agentName2, action, childOpts, allowedActions) =>\n324\t        runChildDelegate(packageName, agentName2, action, childOpts as DelegateOpts | undefined, allowedActions),\n325\t      // Forks under this delegate may read attachments too — thread the resolver.\n326\t      documentResolver: opts.documentResolver,\n327\t    }));\n328\t\n329\t    try {\n330\t      await runTurnLoop({\n331\t        vm,\n332\t        history,\n333\t        systemBlock,\n334\t        ambientDts,\n335\t        renderHost: opts.renderHost,\n336\t        streamFn: opts.streamFn,\n337\t        processYield: async (req) => {\n338\t          // sleep / fork / tasklist / delegate share the central router. The two\n339\t          // delegate-specific behaviours are passed as hooks: auto-capture of the\n340\t          // action's tasklist result, and depth-incremented recursion.\n341\t          const routed = await routeCommonYield(req, {\n342\t            space,\n343\t            clock: opts.clock,\n344\t            tracer: opts.tracer,\n345\t            scope: delegateScope,\n346\t            apiCallResolver: opts.appGlobals?.apiCall,\n347\t            apiCallAllow: capabilities.app['api:call']?.allow,\n348\t            connectionResolver: opts.appGlobals?.callConnection,\n349\t            documentResolver: opts.documentResolver,\n350\t            // Store search/inspect + manual emits work in delegates (system-store\n351\t            // runs AS a delegate of THING); consent-marked kinds (installSpace)\n352\t            // still FAIL CLOSED here — no requestConsent is wired (delegates are\n353\t            // headless), so the router's consent gate refuses before install.\n354\t            storeResolver: opts.appGlobals?.store,\n355\t            emitEventResolver: opts.appGlobals?.emitEvent,\n356\t            // installSpace live-registers into the session-shared map (visible to\n357\t            // the parent's later delegate()) — same reference forks receive.\n358\t            dynamicSpaces: opts.dynamicSpaces,\n359\t            getForkEngine: () => forkEngine,\n360\t            // `result` is the tasklist's TaskEnvelope ({ ok, degraded, data, … })\n361\t            // since Phase 3 — captured and returned UNTOUCHED, so the delegator\n362\t            // sees the same envelope contract as a direct tasklist() caller.\n363\t            onTasklistResult: (name, result) => {\n364\t              if (capturableTasklists.has(name) && !resultCaptured) {\n365\t                capturedResult = result;\n366\t                resultCaptured = true;\n367\t              }\n368\t            },\n369\t            runDelegate: (packageName, agentName, action, delegateOpts2) => {\n370\t              // Yield-time canDelegateTo gate (unified semantics): this agent's\n371\t              // policy decides whether the target is callable at all — an\n372\t              // out-of-list target throws an actionable, retryable error naming\n373\t              // the allowed targets. `registered:*` consults the session-shared\n374\t              // dynamicSpaces map at call time. On an allowlist match, the\n375\t              // entries' `#action` suffixes narrow the allowed actions (the same\n376\t              // enforcement the old directDeps lookup fed into runDelegate).\n377\t              const allow = isDelegateAllowed(delegatePolicy, packageName, agentName, opts.dynamicSpaces);\n378\t              if (!allow.allowed) {\n379\t                throw new Error(formatDelegateDenial(delegatePolicy, packageName, agentName, 'agent'));\n380\t              }\n381\t              return runChildDelegate(packageName, agentName, action, delegateOpts2, allow.allowedActions);\n382\t            },\n383\t          });\n384\t          return routed.handled ? routed.value : undefined;\n385\t        },\n386\t        maxRetries: 3,\n387\t        tracer: tracer,\n388\t        traceContext: delegateLabel,\n389\t        scope: delegateScope,\n390\t        model: turnModel,\n391\t      });\n392\t      // GUARANTEE (mirrors fork.ts): a delegate whose model finished without calling\n393\t      // currentTask.resolve() — and without running a capturable tasklist — must not\n394\t      // hand `undefined` back to the delegator. The live E4 failure: the engineer did\n395\t      // all the work (wrote files, ran tests) but never resolved, the delegator got\n396\t      // null twice, gave up on the specialist, and improvised the work inline. Force\n397\t      // resolve-only turns with a fresh small budget before returning.\n398\t      for (let nudge = 0; nudge < 2 && !resultCaptured; nudge++) {\n399\t        opts.renderHost.log(`[delegate] no resolve — forcing resolve (attempt ${nudge + 1})`);"}]},"parent_tool_use_id":"call_XOUkCCKPWXZ8vWn7RxhEWgPz","session_id":"625ee3e5-57b1-42a3-9cc2-762259deb6f8","uuid":"2c7fff90-935a-4244-a75e-f9b5309cb3c1","timestamp":"2026-07-16T03:56:04.368Z","subagent_type":"Explore","task_description":"Trace automator build failure"}
