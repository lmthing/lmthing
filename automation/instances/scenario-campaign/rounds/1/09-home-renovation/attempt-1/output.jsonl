val/typecheck errors', fatal.length === 0, fatal.map((error) => error.message).join(' | ') || 'none');","+report.metric('recovered eval/typecheck errors', whole.errors.length - fatal.length);","+report.metric('LLM calls', thing.stats().llmCalls);","+report.metric('wall clock', ((now() - started) / 60_000).toFixed(1), ' min');","+report.metric('total tokens in/out', `${metrics.in} / ${metrics.out}`);","+report.save(`${RESULTS}/report.md`);","+report.saveTrace(`${RESULTS}/trace.json`, thing);","+cp.done = true;","+cp.summary = report.summary();","+saveCheckpoint(cp);","+process.exit(report.passed ? 0 : 1);"]}],"userModified":false,"replaceAll":false}}
