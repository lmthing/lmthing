res('idle'), idleMs); });\n435\t        let step: IteratorResult<string> | 'idle';\n436\t        try {\n437\t          step = await Promise.race([iterator.next(), idle]);\n438\t        } finally {\n439\t          if (idleTimer) clearTimeout(idleTimer);\n440\t        }\n441\t        if (step === 'idle') {\n442\t          renderHost.log(`[turn ${attempt}] stream idle >${idleMs}ms — treating as transient error, will retry`);\n443\t          streamErrored = true;\n444\t          try { stream.abort(); } catch { /* ignore */ }\n445\t          break;\n446\t        }\n447\t        if (step.done) break;\n448\t        const chunk = step.value;\n449\t        assistantContent += chunk;"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"af248a7f-e3c6-45be-b884-00f00f5c27b6","timestamp":"2026-07-15T23:55:10.534Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
