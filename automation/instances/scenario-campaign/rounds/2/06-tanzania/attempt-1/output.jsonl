t forward every verb to whatever db is\n620\t   *  CURRENTLY booted for the project (the {@link projectDbs} cache) — see\n621\t   *  {@link liveProjectDb}. */\n622\t  private liveDbProxies = new Map<string, ProjectDb['db']>();\n623\t\n624\t  /**\n625\t   * A STABLE `db` handle bound to a project, forwarding each verb to whatever db is\n626\t   * booted for it AT CALL TIME (the {@link projectDbs} cache).\n627\t   *\n628\t   * This is what lets a long-lived INTERACTIVE session (THING) expose a working `db`\n629\t   * to its DELEGATES. THING's `appGlobals` is built ONCE — at project open, when the\n630\t   * app usually has no tables yet, so {@link getProjectDb} returns `null`. A delegate\n631\t   * (e.g. the automator) inherits the parent's `appGlobals` and injects `db` at\n632\t   * child-VM creation, reading `impls.db` THEN. A static `db.db` snapshot would freeze\n633\t   * that `null`, so an automator delegated AFTER the first table was authored (which\n634\t   * reboots the cached db) would still find no `db` and fail a row update with\n635\t   * `'db' is not defined` (S06 Act V). A forwarder read at injection time always\n636\t   * reflects the live db. It is also why `db` is now injected on the CAPABILITY grant\n637\t   * alone (matching the DTS, which declares `db` from `db:*` regardless of tables) —\n638\t   * `impls.db` is always present; the verbs throw a clear error, not a ReferenceError,\n639\t   * when the project genuinely has no database yet.\n640\t   */\n641\t  private liveProjectDb(projectId: string): ProjectDb['db'] {\n642\t    const existing = this.liveDbProxies.get(projectId);\n643\t    if (existing) return existing;\n644\t    const live = (): ProjectDb['db'] => {\n645\t      const pdb = this.projectDbs.get(projectId);\n646\t      if (!pdb) {\n647\t        throw new Error(\n648\t          `project \"${projectId}\" has no database yet — author a table first ` +\n649\t            `(writeProjectTable), then the db verbs become available`,\n650\t        );\n651\t      }\n652\t      return pdb.db;\n653\t    };\n654\t    const proxy: ProjectDb['db'] = {\n655\t      query: (t, o) => live().query(t, o),\n656\t      // The natural \"what exists?\" probe: answer [] for a db-less project rather than\n657\t      // throw, so a caller can branch on it safely (never a ReferenceError).\n658\t      tables: () => this.projectDbs.get(projectId)?.db.tables() ?? [],\n659\t      insert: (t, v) => live().insert(t, v),\n660\t      update: (t, o) => live().update(t, o),\n661\t      remove: (t, o) => live().remove(t, o),\n662\t      createTable: (s) => live().createTable(s),\n663\t      addColumn: (t, n, c) => live().addColumn(t, n, c),\n664\t    };\n665\t    this.liveDbProxies.set(projectId, proxy);\n666\t    return proxy;\n667\t  }\n668\t\n669\t  private async getProjectAppGlobals(root: string, projectId: string): Promise<AppGlobalImpls | undefined> {\n670\t    // Warm the db cache + wire the db-write→event dispatch runtime (side effects). The\n671\t    // returned `db` is the live forwarder, not this snapshot — see {@link liveProjectDb}.\n672\t    await this.getProjectDb(root, projectId);\n673\t    const authoring = this.getAuthoringGlobals();\n674\t    const apiRt = await this.getApiRuntime(root, projectId);\n675\t    // LIVE-PROJECT authoring writers (S11) — bound to THIS project's own dir (not the\n676\t    // catalog), republishing after each write so the new event hook / emitter def /\n677\t    // crontab goes live without a pod restart. Injected only on `hooks:write` (core's\n678\t    // injectAppGlobals), so THING/ordinary agents never see them; the automator writes\n679\t    // hooks+events, the engineer writes functions.\n680\t    const projectAuthoring = this.buildProjectAuthoring(root, projectId);\n681\t    return {\n682\t      // Live forwarder (NOT a build-time snapshot): reflects whatever db is booted for\n683\t      // the project when a session/delegate injects it. Present on the CAPABILITY grant\n684\t      // alone — matching the DTS — so a db-granted delegate always finds `db`.\n685\t      db: this.liveProjectDb(projectId),\n686\t      // Agent-facing apiCall — re-enter the project's OWN api endpoints by name\n687\t      // (same runtime the browser + hooks use). Only present when the project has\n688\t      // an `api/` dir; the yield router rejects apiCall() otherwise.\n689\t      ...(apiRt ? { apiCall: (name: string, input?: unknown) => unwrapApiCall(apiRt, name, input) } : undefined),\n690\t      writePage: authoring.writePage,\n691\t      writeApi: authoring.writeApi,\n692\t      writeHook: authoring.writeHook,\n693\t      writeTableSchema: authoring.writeTableSchema,\n694\t      createProject: authoring.createProject,\n695\t      selectProject: authoring.selectProject,\n696\t      writeProjectHook: projectAuthoring.writeProjectHook,\n697\t      writeProjectEvent: projectAuthoring.writeProjectEvent,\n698\t      writeProjectFunction: projectAuthoring.writeProjectFunction,\n699\t      writeProjectTable: projectAuthoring.writeProjectTable,\n700\t      writeProjectPage: projectAuthoring.writeProjectPage,\n701\t      writeProjectComponent: projectAuthoring.writeProjectComponent,\n702\t      writeProjectApi: projectAuthoring.writeProjectApi,\n703\t      listProjectDir: projectAuthoring.listProjectDir,\n704\t      readProjectFile: projectAuthoring.readProjectFile,"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"9ef3b48e-300d-4a91-827a-31e4d5c48869","timestamp":"2026-07-16T22:26:21.676Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
