{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Q6zr5SdMqFD9AGjyOkXyp3K3","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { resolve } from 'node:path';\n3\timport { loadSpace } from './load.js';\n4\timport { runTasklist } from '../tasklist/orchestrator.js';\n5\timport { ForkEngine } from '../fork/fork.js';\n6\timport { createMockStreamFn } from '../testing/mock-provider.js';\n7\timport type { RenderHost } from '../session/types.js';\n8\timport type { StreamOpts } from '../eval/stream-types.js';\n9\t\n10\t/**\n11\t * Mock end-to-end coverage for P6's design guarantee: `user-thing`'s\n12\t * `build_specialist` tasklist ALWAYS runs the build step, even when the\n13\t * upstream research task degrades/salvages\n14\t * (.issues/thing-abandons-build-on-salvaged-research.md /\n15\t * .issues/investigate-forks-degrade-under-delegate-nesting.md — the exact\n16\t * failure mode this tasklist shape was built to route around structurally).\n17\t *\n18\t * Runs the REAL shipped `libs/core/system-spaces/user-thing/tasklists/\n19\t * build_specialist` files through the real orchestrator + ForkEngine, with a\n20\t * scripted `streamFn` standing in for the model and a scripted\n21\t * `delegateRunner` standing in for the real `system-research` / `system-architect`\n22\t * spaces (those are exercised by other e2e tests — this test isolates the\n23\t * \"degraded upstream doesn't abort downstream\" DAG behavior).\n24\t *\n25\t * Degrading the `research` task: its prelude ALREADY performs the\n26\t * `delegate('system-research', 'researcher', 'deep_research', …)` call (see\n27\t * `01-research.md`) — the model's only job is a single\n28\t * `currentTask.resolve({ report: … })` statement. Returning `''` for every one\n29\t * of the research fork's turns (initial + the 2 forced resolve-nudge turns)\n30\t * means the model NEVER calls resolve, so `fork.ts`'s guarantee kicks in: it\n31\t * salvages a NEUTRAL schema-valid placeholder (`{ report: {} }`, reason\n32\t * `no_resolve`) rather than throwing — this is the established\n33\t * \"mock model never resolves\" salvage pattern used by\n34\t * `tasklist/delegate-in-task.test.ts`.\n35\t */\n36\t\n37\tconst SYS = resolve(__dirname, '..', '..', 'system-spaces');\n38\tconst USER_THING_DIR = resolve(SYS, 'user-thing');\n39\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n40\t\n41\t// Markers unique to each task's instruction body (see the real .md files) —\n42\t// robust against wording tweaks elsewhere in the file, since these are the\n43\t// exact contract sentences the task files are built around.\n44\tconst RESEARCH_MARKER = 'Package the domain research for the build step.';\n45\tconst BUILD_MARKER = \"Hand the user's `request`\";\n46\t\n47\tdescribe('build_specialist mock e2e: degraded research → build still runs', () => {\n48\t  it('salvages the optional research task but still delegates the build task to the architect, producing a schema-shaped (non-prose) TaskEnvelope', async () => {\n49\t    const space = await loadSpace(USER_THING_DIR, { requireAgents: false });\n50\t\n51\t    const delegateCalls: Array<{ pkg: string; agent: string; action?: string }> = [];\n52\t    let buildTurn = 0;\n53\t\n54\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n55\t      const text = o.system + '\\n' + o.messages.map((m) => m.content).join('\\n');\n56\t\n57\t      if (text.includes(RESEARCH_MARKER)) {\n58\t        // The research fork's model never resolves on ANY of its turns (initial\n59\t        // call + 2 forced resolve-nudges) — forces fork.ts's salvage path.\n60\t        return '';\n61\t      }\n62\t\n63\t      if (text.includes(BUILD_MARKER)) {\n64\t        buildTurn++;\n65\t        if (buildTurn === 1) {\n66\t          // Mirrors 02-build.md's first statement verbatim.\n67\t          return `const t = await delegate('system-architect', 'architect', 'synthesize_and_run', { query: String(request), context: { topic: String(request), goal: String(request), research: (research && research.report) ? research.report : {} } });`;\n68\t        }\n69\t        // Mirrors 02-build.md's packaging + resolve statements verbatim.\n70\t        return [\n71\t          'const built = (t && t.data) ? t.data : { spaceKey: \"\", agentSlug: \"\", actionId: \"\", query: \"\", ok: false, errors: \"the architect returned no result\" };',\n72\t          'currentTask.resolve({ spaceKey: String(built.spaceKey || \"\"), agentSlug: String(built.agentSlug || \"\"), actionId: String(built.actionId || \"\"), query: String(built.query || request), ok: !!(t && t.ok === true && built.ok === true), errors: String(built.errors || \"\") });',\n73\t        ].join('\\n');\n74\t      }\n75\t\n76\t      throw new Error(`unexpected fork prompt (no marker matched):\\n${text.slice(0, 300)}`);\n77\t    });\n78\t\n79\t    const engine = new ForkEngine({\n80\t      maxConcurrentForks: 2,\n81\t      parentHistory: [],\n82\t      parentSpaceDir: USER_THING_DIR,\n83\t      parentAgentSlug: 'thing',\n84\t      renderHost: silentHost,\n85\t      streamFn,\n86\t      delegateRunner: async (pkg, agent, action) => {\n87\t        delegateCalls.push({ pkg, agent, action });\n88\t        if (pkg === 'system-research' && agent === 'researcher' && action === 'deep_research') {\n89\t          // Stand-in for a degraded researcher run (the real failure mode in\n90\t          // the linked .issues/ — the report comes back empty/salvaged).\n91\t          // Neutral/schema-shaped per exec/envelope.ts, never prose.\n92\t          return { ok: false, degraded: true, data: {}, reason: 'no_resolve', degradedTasks: ['scope', 'investigate[0]'] };\n93\t        }\n94\t        if (pkg === 'system-architect' && agent === 'architect' && action === 'synthesize_and_run') {\n95\t          return {\n96\t            ok: true,\n97\t            degraded: false,\n98\t            data: { spaceKey: 'user/dog-expert', agentSlug: 'dog-expert', actionId: 'answer', query: 'a dog breed helper', ok: true, errors: '' },\n99\t          };\n100\t        }\n101\t        throw new Error(`unexpected delegate target in mock: ${pkg}/${agent}#${action}`);\n102\t      },\n103\t    });\n104\t\n105\t    const env = await runTasklist({\n106\t      name: 'build_specialist',\n107\t      space,\n108\t      forkEngine: engine,\n109\t      seed: { request: 'a dog breed helper' },\n110\t    });\n111\t\n112\t    // (a) The build task's delegate to the architect was actually reached —"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"9ebe9dcb-889e-4eb8-b037-18dbcdb14492","timestamp":"2026-07-16T02:07:45.860Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
