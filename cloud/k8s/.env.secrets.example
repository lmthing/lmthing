# Domain
DOMAIN=lmthing.cloud
ACME_EMAIL=admin@lmthing.cloud
BASE_URL=https://lmthing.cloud

# VM access
VM_HOST=135.116.57.95
VM_USER=azureuser
SSH_KEY_PATH=~/LMTHING/litellm_key.pem

# Azure Foundry
AZURE_API_KEY=your-azure-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# IMPORTANT: Use session mode (port 5432), NOT transaction mode (6543).
# IMPORTANT: URL-encode special chars in password (# → %23, ! → %21, @ → %40).
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_MAX=price_xxx

# LiteLLM (generate with: echo "sk-lmt-$(openssl rand -hex 32)")
LITELLM_MASTER_KEY=sk-lmt-xxx
