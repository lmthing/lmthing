 and it silently corrupts data that arrived correct.\n134\t  - When you genuinely need to READ the full content of a truncated field (e.g. to split it across files, or to quote it), pull it back into scope FIRST with inspect — and BIND the result: \\`const full = await inspect([report, { path: 'executive_summary' }]);\\` or \\`const head = await inspect([items, { slice: [0, 10] }]);\\`. Only after inspecting should you use the value.\n135\t`.trim();\n136\t\n137\tfunction globalsSummary(omitAsk: boolean, omitDelegate: boolean): string {\n138\t  const askBullet = omitAsk\n139\t    ? ''\n140\t    : '- `ask(descriptor)` — render an interactive form and await user input (yields). Compose built-in UI components — see # UI Components.\\n';\n141\t  const delegateBullet = omitDelegate\n142\t    ? ''\n143\t    : '\\n- `delegate(packageName, agentName, action?, opts?)` — delegate to another agent (yields). With an `action` id it runs that action; omit `action` to let the agent run model-driven and pick one of its own actions/tasklists.';\n144\t  const yieldList = [\n145\t    ...(omitAsk ? [] : ['ask']),\n146\t    'inspect',\n147\t    'loadKnowledge',"}]},"parent_tool_use_id":"call_0lb5WCKZ0OPAnEXw8oFAxUMW","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"f4ba483d-cc28-4f40-9bdf-6c31514411cc","timestamp":"2026-07-16T22:48:00.492Z","subagent_type":"Explore","task_description":"Trace source-data loss"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_yFaNXWsJ12xwUZxIhrnI2CI4","type":"tool_result","content":"270\texport async function readUploadBytes(uploadsDir: string, id: string): Promise<Uint8Array | null> {\n271\t  if (!isSafeUploadId(id)) return null;\n272\t  try {\n273\t    return await readFile(join(uploadsDir, id));\n274\t  } catch {\n275\t    return null;\n276\t  }\n277\t}\n278\t\n279\t/** Default cap for the text `readDocument` returns to an agent (guards context size). */\n280\tconst READ_DOCUMENT_MAX_CHARS = 100_000;\n281\t\n282\t/**\n283\t * Host implementation of the `readDocument` global (the {@link DocumentResolver}):\n284\t * extract a stored upload's content from the uploads dir — audio → transcript,\n285\t * text media → utf8, PDF → unpdf-extracted text, everything else → unsupported.\n286\t * Server-authoritative: only the id is trusted; bytes/metadata are re-read from\n287\t * disk. Never throws — a bad id / unsupported type resolves to a `kind:'unsupported'`\n288\t * result the agent can relay. Text is capped at `opts.maxChars` (default 100k).\n289\t */\n290\texport async function resolveUploadDocument(\n291\t  uploadsDir: string,\n292\t  attachmentId: string,\n293\t  opts?: { maxChars?: number },\n294\t): Promise<ReadDocumentResult> {\n295\t  const maxChars = opts?.maxChars ?? READ_DOCUMENT_MAX_CHARS;\n296\t  if (!isSafeUploadId(attachmentId)) {\n297\t    return { ok: false, attachmentId, mediaType: '', kind: 'unsupported', error: 'invalid attachment id' };\n298\t  }\n299\t  const meta = await readUploadMeta(uploadsDir, attachmentId);\n300\t  if (!meta) {\n301\t    return { ok: false, attachmentId, mediaType: '', kind: 'unsupported', error: 'attachment not found' };\n302\t  }\n303\t  const common = { attachmentId, mediaType: meta.mediaType, ...(meta.filename ? { filename: meta.filename } : {}) };\n304\t  // Audio is transcribed at upload time — hand back the transcript as text.\n305\t  if (meta.kind === 'audio') {\n306\t    return { ok: true, ...common, kind: 'text', text: meta.transcript ?? '' };\n307\t  }\n308\t  // Images belong to the vision specialist, not the document reader.\n309\t  if (meta.kind === 'image') {\n310\t    return { ok: false, ...common, kind: 'unsupported', error: 'image — use system-vision instead' };\n311\t  }\n312\t  const bytes = await readUploadBytes(uploadsDir, attachmentId);\n313\t  if (!bytes) {\n314\t    return { ok: false, ...common, kind: 'unsupported', error: 'attachment bytes not found' };\n315\t  }\n316\t  // Spreadsheet family (Excel/ODS/CSV/TSV) → SheetJS renders every sheet to CSV.\n317\t  // Checked BEFORE the text branch so a binary .xlsx/.ods isn't utf8-garbled, and\n318\t  // so a .csv sent as octet-stream is still parsed rather than falling to unsupported.\n319\t  if (isSpreadsheet(meta.mediaType, meta.filename)) {\n320\t    const extracted = await extractSpreadsheetText(bytes);\n321\t    if (extracted && extracted.trim()) {\n322\t      const text = extracted.slice(0, maxChars);\n323\t      return { ok: true, ...common, kind: 'text', text, ...(extracted.length > maxChars ? { truncated: true } : {}) };\n324\t    }\n325\t    return { ok: false, ...common, kind: 'unsupported', error: 'spreadsheet could not be parsed or is empty' };\n326\t  }\n327\t  // Plain-text media: decode utf8 directly (capped). Guard against the OOXML/office\n328\t  // container family (docx/…), whose media types contain the substring \"xml\" and so\n329\t  // slip past the loose isTextMediaType check even though they are binary zips.\n330\t  const isBinaryOffice = /officedocument|opendocument|msword|ms-powerpoint/i.test(meta.mediaType);\n331\t  if (isTextMediaType(meta.mediaType) && !isBinaryOffice) {\n332\t    const full = Buffer.from(bytes).toString('utf8');\n333\t    const text = full.slice(0, maxChars);\n334\t    return { ok: true, ...common, kind: 'text', text, ...(full.length > maxChars ? { truncated: true } : {}) };\n335\t  }\n336\t  // PDF: extract text via unpdf (reused from the upload path).\n337\t  if (meta.mediaType === 'application/pdf') {\n338\t    const extracted = await extractDocumentText('application/pdf', bytes);\n339\t    if (extracted && extracted.trim()) {\n340\t      const text = extracted.slice(0, maxChars);\n341\t      return { ok: true, ...common, kind: 'text', text, ...(extracted.length > maxChars ? { truncated: true } : {}) };\n342\t    }\n343\t    // A scan is a PHOTOGRAPH of a document: there is no text to extract, and saying\n344\t    // only \"unsupported\" leaves the agent with nowhere to go. Its pages were stored as\n345\t    // image attachments at upload time — name them, so the agent hands THOSE to the\n346\t    // vision specialist instead of guessing at the contents or giving up.\n347\t    const pages = meta.pages ?? [];\n348\t    return {\n349\t      ok: false,\n350\t      ...common,\n351\t      kind: 'unsupported',\n352\t      error:\n353\t        pages.length > 0\n354\t          ? `scanned/image-only PDF — no text to extract. Its ${pages.length} page image(s) are attached: ` +\n355\t            `${pages.join(', ')} — look at them with system-vision (pass the page id as an attachment).`\n356\t          : 'no extractable text (likely a scanned/image-only PDF)',\n357\t    };\n358\t  }\n359\t  // Office documents (Word/PowerPoint/OpenDocument text+presentation) → officeparser.\n360\t  if (isOfficeDocument(meta.mediaType, meta.filename)) {\n361\t    const extracted = await extractOfficeText(bytes);\n362\t    if (extracted && extracted.trim()) {\n363\t      const text = extracted.slice(0, maxChars);\n364\t      return { ok: true, ...common, kind: 'text', text, ...(extracted.length > maxChars ? { truncated: true } : {}) };\n365\t    }\n366\t    return { ok: false, ...common, kind: 'unsupported', error: 'office document could not be parsed or has no text' };\n367\t  }\n368\t  // Everything else (legacy binary, unknown types) is not yet supported host-side.\n369\t  return { ok: false, ...common, kind: 'unsupported', error: `file type not yet supported: ${meta.mediaType}` };\n370\t}\n371\t\n372\t/** The result of turning stored uploads into delegatable attachments + metadata. */\n373\texport interface AssembledAttachments {\n374\t  /** Image/file attachments (keyed by upload id). A text agent (THING) delegates"}]},"parent_tool_use_id":"call_0lb5WCKZ0OPAnEXw8oFAxUMW","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"9cfe0f3f-b02c-4693-af52-65fe2ef526d8","timestamp":"2026-07-16T22:48:00.493Z","subagent_type":"Explore","task_description":"Trace source-data loss"}
