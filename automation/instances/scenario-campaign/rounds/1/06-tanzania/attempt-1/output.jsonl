1);\n53\t\n54\t    // Pending safari balance highlight — match flagged safari items that are pending\n55\t    if (r.flagged && st === 'pending' && r.category === 'safari') {\n56\t      safariBalance = {\n57\t        label: r.label,\n58\t        amount: r.amount,\n59\t        currency: cur,\n60\t        notes: r.notes || '',\n61\t      };\n62\t    }\n63\t  }\n64\t\n65\t  const currency_summaries: CurrencySummary[] = Array.from(currencyMap.entries()).map(([currency, sums]) => ({\n66\t    currency,\n67\t    total_paid: sums.paid,\n68\t    total_pending: sums.pending,\n69\t    total_estimated: sums.estimated,\n70\t  }));\n71\t\n72\t  const status_counts: StatusCount[] = Array.from(statusMap.entries()).map(([status, count]) => ({\n73\t    status,\n74\t    count,\n75\t  }));\n76\t\n77\t  return { currency_summaries, status_counts, pending_safari_balance: safariBalance };\n78\t}"}]},"parent_tool_use_id":null,"session_id":"4abecf79-4263-4bbb-a5c4-a77231683cc7","uuid":"99421a4d-6ee4-49ab-b86e-47f55dd013a1","timestamp":"2026-07-16T15:14:59.020Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/.state/local-server/pod-root/.lmthing/tanzania-trip/api/cost-summary/GET.ts","content":"export const name = 'costsummary';\nexport const description = 'Aggregated totals: sum of amount grouped by currency, count by status, plus the pending safari balance highlight. Computed from cost_line_items on the fly.';\n\nexport interface Input {}\n\nexport interface CurrencySummary {\n  currency: string;\n  total_paid: number;\n  total_pending: number;\n  total_estimated: number;\n}\n\nexport interface StatusCount {\n  status: string;\n  count: number;\n}\n\nexport interface Output {\n  currency_summaries: CurrencySummary[];\n  status_counts: StatusCount[];\n  pending_safari_balance: {\n    label: string;\n    amount: number | null;\n    currency: string;\n    notes: string;\n  } | null;\n}\n\nexport default async function handler(_input: Input, ctx: { db: any }): Promise<Output> {\n  const rows = await ctx.db.query('cost_line_items');\n\n  // Aggregate sums by currency and status\n  const currencyMap = new Map<string, { paid: number; pending: number; estimated: number }>();\n  const statusMap = new Map<string, number>();\n  let safariBalance: Output['pending_safari_balance'] = null;\n\n  for (const r of rows) {\n    const cur = r.currency || 'USD';\n    const amt = typeof r.amount === 'number' ? r.amount : 0;\n    const st = r.status || 'unknown';\n\n    // Currency aggregates\n    if (!currencyMap.has(cur)) {\n      currencyMap.set(cur, { paid: 0, pending: 0, estimated: 0 });\n    }\n    const cs = currencyMap.get(cur)!;\n    if (st === 'paid') cs.paid += amt;\n    else if (st === 'pending') cs.pending += amt;\n    else if (st === 'estimated') cs.estimated += amt;\n\n    // Status counts\n    statusMap.set(st, (statusMap.get(st) || 0) + 1);\n\n    // Pending safari balance highlight — match flagged safari items that are pending\n    if (r.flagged && st === 'pending' && r.category === 'safari') {\n      safariBalance = {\n        label: r.label,\n        amount: r.amount,\n        currency: cur,\n        notes: r.notes || '',\n      };\n    }\n  }\n\n  const currency_summaries: CurrencySummary[] = Array.from(currencyMap.entries()).map(([currency, sums]) => ({\n    currency,\n    total_paid: sums.paid,\n    total_pending: sums.pending,\n    total_estimated: sums.estimated,\n  }));\n\n  const status_counts: StatusCount[] = Array.from(statusMap.entries()).map(([status, count]) => ({\n    status,\n    count,\n  }));\n\n  return { currency_summaries, status_counts, pending_safari_balance: safariBalance };\n}","numLines":78,"startLine":1,"totalLines":78}}}
