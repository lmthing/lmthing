{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_mjVBlyZAQO8eq5Sw3gVTkd5R","type":"tool_result","content":"1\timport type { YieldRequest } from '../eval/yield.js';\n2\t\n3\t/**\n4\t * The result of a `readDocument()` call — the host-extracted content of a stored\n5\t * upload. `kind:'text'` carries the decoded/extracted `text`; `kind:'unsupported'`\n6\t * carries a human-readable `error` explaining why (image, scanned PDF, unhandled\n7\t * binary type, missing/invalid id). Mirrors the shape of a ConnectionResponse: a\n8\t * plain, serializable object the sandbox can branch on.\n9\t */\n10\texport interface ReadDocumentResult {\n11\t  ok: boolean;\n12\t  attachmentId: string;\n13\t  mediaType: string;\n14\t  filename?: string;\n15\t  kind: 'text' | 'unsupported';\n16\t  /** Extracted/decoded document text (present when kind==='text'). */\n17\t  text?: string;\n18\t  /** Set when the text was capped at `opts.maxChars`. */\n19\t  truncated?: boolean;\n20\t  /** Present when !ok or kind==='unsupported'. */\n21\t  error?: string;\n22\t}\n23\t\n24\t/**\n25\t * Resolve a `readDocument()` yield — extract a stored upload's content in Node\n26\t * (unpdf for PDF, utf8 passthrough for text/csv, transcript for audio). Host-\n27\t * supplied (libs/cli, where the uploads dir is known); absent outside a pod/CLI\n28\t * with an uploads dir, in which case a `readDocument` yield rejects with a clear,\n29\t * retryable error. Exactly the ConnectionResolver pattern, but for local uploads.\n30\t * @param attachmentId The upload id from the user message's attachment list.\n31\t * @param opts         `maxChars` caps the returned text (default 100_000).\n32\t */\n33\texport type DocumentResolver = (\n34\t  attachmentId: string,\n35\t  opts?: { maxChars?: number },\n36\t) => Promise<ReadDocumentResult>;\n37\t\n38\t/**\n39\t * Create the `readDocument` global — the agent/space-function entry to a stored\n40\t * upload's text. Value-yielding, exactly like `callConnection`/`fetch`: it ends\n41\t * the current turn and resumes once the host resolver reads + extracts the file.\n42\t * Injected UNIVERSALLY (like `fetch`, never gated) so any agent/fork/delegate can\n43\t * read an attachment by id. The host resolver is threaded through the yield router\n44\t * (`YieldRouterContext.documentResolver`); if absent (no uploads dir configured)\n45\t * the yield rejects with a clear, retryable error rather than binding undefined.\n46\t *\n47\t * The bytes never enter the sandbox: the sandbox supplies only the `attachmentId`\n48\t * (+ optional `maxChars`); the host reads the file from the uploads dir and hands\n49\t * back the extracted text.\n50\t */\n51\texport function createReadDocumentGlobal(\n52\t  pushYield: (req: YieldRequest) => void,\n53\t): (attachmentId: string, opts?: { maxChars?: number }) => Promise<ReadDocumentResult> {\n54\t  return function readDocument(\n55\t    attachmentId: string,\n56\t    opts?: { maxChars?: number },\n57\t  ): Promise<ReadDocumentResult> {\n58\t    return new Promise<ReadDocumentResult>((resolve, reject) => {\n59\t      pushYield({\n60\t        kind: 'readDocument',\n61\t        args: [attachmentId, opts],\n62\t        deferred: { resolve: resolve as (v: unknown) => void, reject },\n63\t        vmPromiseHandle: undefined,\n64\t      });\n65\t    });\n66\t  };\n67\t}\n68\t"}]},"parent_tool_use_id":"call_uxqb06RglxS9Y92kx5H5jMqM","session_id":"08b44427-7432-4e2d-a9c3-d9296f1761a5","uuid":"37011c67-8c38-43e8-84c6-8366fcc089f0","timestamp":"2026-07-16T04:44:50.708Z","subagent_type":"Explore","task_description":"Design lowest rung partition fix"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_s41vxtET47F4QXFvvlGfko1C","type":"tool_result","content":"1\timport type { RenderHost, Clock } from '../session/types.js';\n2\timport type { StreamOpts, StreamSession } from '../eval/stream-types.js';\n3\timport type { Message } from '../context/history.js';\n4\timport type { VM } from '../sandbox/quickjs.js';\n5\timport { MessageHistory } from '../context/history.js';\n6\timport { runTurnLoop } from '../eval/turn-loop.js';\n7\timport { routeCommonYield, type YieldRouterContext } from '../eval/yield-router.js';\n8\timport { rolePreamble, modelForRole, type RoleModelConfig } from './roles.js';\n9\timport { buildOverlay, extractFunctionSignature } from '../typecheck/overlay.js';\n10\timport { validateOutput } from '../tasklist/schema.js';\n11\timport { NULL_TRACER } from '../sandbox/trace.js';\n12\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n13\timport { Budget, BudgetExceededError, type BudgetLimits } from '../eval/budget.js';\n14\timport { forkCapabilities, narrowAppCaps } from '../exec/capability.js';\n15\timport type { AppCapabilities } from '../spaces/capabilities.js';\n16\timport { createChildVM, buildAmbientDts } from '../exec/bootstrap.js';\n17\timport type { AppGlobalImpls } from '../exec/app-globals.js';\n18\timport type { DocumentResolver } from '../globals/read-document.js';\n19\timport { resolveTaskDelegate, evaluateDelegatePolicy, isDelegateAllowed, formatDelegateDenial } from '../exec/target-match.js';\n20\timport { STATEMENT_PROTOCOL } from '../exec/preamble.js';\n21\timport { salvageData, type DegradeReason } from '../exec/envelope.js';\n22\timport { runPrelude } from '../exec/prelude.js';\n23\t\n24\t// Re-exported for compatibility: the allowlist matcher moved to exec/target-match.ts\n25\t// (Phase 2 exec unification) but was historically imported from fork.ts.\n26\texport { resolveTaskDelegate };\n27\t\n28\t/** Per-fork degradation metadata surfaced by `forkWithMeta` (Phase 3 envelopes). */\n29\texport interface ForkResultMeta<T = unknown> {\n30\t  value: T;\n31\t  /** true when the value was salvaged (the model never produced a schema-valid resolve). */\n32\t  degraded: boolean;\n33\t  reason?: DegradeReason;\n34\t}\n35\t\n36\texport interface ForkTask {\n37\t  instruction: string;\n38\t  output: Record<string, string>;\n39\t  seed?: Record<string, unknown>;\n40\t  timeout?: number;\n41\t  taskId?: string;\n42\t  upstreamOutputs?: Record<string, unknown>;\n43\t  /** Subagent role controlling capability profile + system-prompt preamble. */\n44\t  role?: 'explore' | 'plan' | 'general';\n45\t  /** Allowlist of space-function names to inject + advertise (least privilege). When set,\n46\t   *  only these of the engine's agentFunctions are injected and listed; omit for all. */\n47\t  functions?: string[];\n48\t  /** Overall tasklist goal (tasklists/<name>/index.md body), injected as standing context\n49\t   *  so an isolated task knows the pipeline it serves. */\n50\t  tasklistDescription?: string;\n51\t  /** Per-task delegation policy (unified canDelegateTo semantics — see\n52\t   *  exec/target-match.ts `evaluateDelegatePolicy`). Entries `\"space/agent\"`\n53\t   *  (any action) or `\"space/agent#action\"`; `[\"*\"]` = unrestricted;\n54\t   *  `\"registered:*\"` = any runtime-registered space. When the policy is not\n55\t   *  'none' AND the engine has a `delegateRunner`, `delegate()` is injected\n56\t   *  into the fork and gated at yield time. Empty/omitted → no delegation\n57\t   *  (the task-level default). */\n58\t  canDelegateTo?: string[];\n59\t  /** Per-node capability NARROWING (task frontmatter `capabilities:`). When set, the fork runs\n60\t   *  with only the intersection of these ids and the parent agent's declared caps — least\n61\t   *  privilege per step, never widening (see `narrowAppCaps`). Omit to inherit the parent's set. */\n62\t  capabilities?: import('../spaces/capabilities.js').CapabilityId[];\n63\t  /** Host-executed TS statements (task frontmatter `prelude:`) run in the fork VM BEFORE the\n64\t   *  model's first turn, through the same statement pipeline as the turn loop (yields allowed).\n65\t   *  Bound values are surfaced as the fork's first VARIABLES block; per-statement failures bind\n66\t   *  the names `undefined` and are noted there (they never kill the fork). See exec/prelude.ts. */\n67\t  prelude?: string;\n68\t  /** Parent execution scope for hierarchical observability. Set by the yield router\n69\t   *  before each fork() call so each invocation carries the right parentId. */\n70\t  parentScope?: TraceScope;\n71\t}\n72\t\n73\texport interface ForkEngineOpts {\n74\t  maxConcurrentForks: number;\n75\t  parentHistory: Message[];\n76\t  parentSpaceDir: string;\n77\t  parentAgentSlug: string;\n78\t  renderHost: RenderHost;\n79\t  streamFn: (opts: StreamOpts) => Promise<StreamSession>;\n80\t  clock?: Clock;\n81\t  tracer?: Tracer;\n82\t  /** Agent functions (TS source) available in the parent session — injected into fork VMs */\n83\t  agentFunctions?: Record<string, string>;\n84\t  /** Bundled JS versions of agent functions (when space has node_modules) */\n85\t  agentFunctionsBundled?: Record<string, string>;\n86\t  /** Host budget caps applied to each fork's own turn loop (fresh Budget per fork). */\n87\t  budgetLimits?: BudgetLimits;\n88\t  /** Nesting depth of forks spawned by this engine. A session's top-level forks are depth 1. */\n89\t  forkDepth?: number;\n90\t  /** Optional per-role model assignment (e.g. explore/plan → cheap model). */\n91\t  roleModels?: RoleModelConfig;\n92\t  /** Default model alias used for any fork role that has no explicit roleModels entry.\n93\t   *  Propagated from the parent session so llm_request events carry a model field. */\n94\t  defaultModel?: string;\n95\t  /** Body of the parent agent's charter.md — short, fork-safe identity/guardrails injected\n96\t   *  into every fork's system prompt. Unlike instruct.md it carries no ask/delegate/UI prose. */\n97\t  parentAgentCharter?: string;\n98\t  /** Runs a delegate on behalf of a task that declares `canDelegateTo`. Provided by the\n99\t   *  Session / delegate runtime (which own the registry + recursion-depth bound). When absent,\n100\t   *  a task's delegate() yield fails with a clear \"delegation not available\" error. */\n101\t  delegateRunner?: (\n102\t    packageName: string,\n103\t    agentName: string,\n104\t    action: string | undefined,\n105\t    delegateOpts: unknown,\n106\t    allowedActions: string[] | undefined,\n107\t  ) => Promise<unknown>;\n108\t  /** Spaces registered at runtime via registerSpace(). Shared (same Map reference) with\n109\t   *  the parent Session so a fork's registerSpace() is visible to later parent delegate()\n110\t   *  calls — the documented dynamicSpaces invariant. */\n111\t  dynamicSpaces?: Map<string, import('../spaces/load.js').Space>;\n112\t  /** Absolute path to the project's spaces/ dir. Propagated into each fork VM as\n113\t   *  LMTHING_PROJECT_SPACES_DIR so the architect can target it when scaffolding. */\n114\t  projectSpacesDir?: string;\n115\t  /** Absolute project root — propagated into each fork VM as LMTHING_PROJECT_DIR and\n116\t   *  gating app-global injection (a fork inside a project reads/writes that project's app). */\n117\t  projectRoot?: string;\n118\t  /** Project id — propagated as LMTHING_PROJECT_ID. */\n119\t  projectId?: string;\n120\t  /** The parent agent's app-capability grants. A fork task receives the\n121\t   *  `allowWrite`-intersected subset (read-only roles keep only db:read/api:call). */\n122\t  parentAppCapabilities?: AppCapabilities;\n123\t  /** Host-provided app-global engine impls (libs/cli, P2+), passed through to the fork VM. */\n124\t  appGlobals?: AppGlobalImpls;\n125\t  /** Host resolver for the universal `readDocument` global — threaded from the parent\n126\t   *  session/delegate so a fork leaf can read an attached upload's text by id. */\n127\t  documentResolver?: DocumentResolver;\n128\t}\n129\t\n130\texport class ForkEngine {\n131\t  private activeForks = 0;\n132\t  private queue: Array<() => void> = [];\n133\t\n134\t  constructor(private opts: ForkEngineOpts) {}\n135\t\n136\t  /** Model-facing shape (the bare `fork()` global): resolves to just the value. */\n137\t  async fork<T>(task: ForkTask): Promise<T> {\n138\t    return (await this.forkWithMeta<T>(task)).value;\n139\t  }\n140\t\n141\t  /**\n142\t   * Internal variant that also reports whether the value was SALVAGED (and why),\n143\t   * so the tasklist orchestrator can aggregate degradation into a TaskEnvelope\n144\t   * instead of the old prose-placeholder signal. Same execution path as fork().\n145\t   */\n146\t  async forkWithMeta<T>(task: ForkTask): Promise<ForkResultMeta<T>> {\n147\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n148\t    const label = `fork:${task.taskId ?? task.role ?? 'general'}`;\n149\t    // Mint scope as 'queued' before acquiring the slot so wait time is visible\n150\t    const forkScope = tracer.child(task.parentScope, 'fork', label, {\n151\t      role: task.role,\n152\t      taskId: task.taskId,\n153\t      instruction: task.instruction.slice(0, 120),\n154\t      timeout: task.timeout,\n155\t    }, 'queued');\n156\t\n157\t    // Wait for concurrency slot, then activate\n158\t    await this.acquireSlot();\n159\t    tracer.activate(forkScope);\n160\t\n161\t    try {\n162\t      return await this.runFork<T>(task, forkScope);\n163\t    } finally {\n164\t      this.releaseSlot();\n165\t    }\n166\t  }\n167\t\n168\t\n169\t\n170\t  private acquireSlot(): Promise<void> {\n171\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n172\t    if (this.activeForks < this.opts.maxConcurrentForks) {\n173\t      this.activeForks++;\n174\t      tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n175\t      return Promise.resolve();\n176\t    }\n177\t\n178\t    return new Promise((resolve) => {\n179\t      this.queue.push(() => {\n180\t        this.activeForks++;\n181\t        tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n182\t        resolve();\n183\t      });\n184\t    });\n185\t  }\n186\t\n187\t  private releaseSlot(): void {\n188\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n189\t    this.activeForks--;\n190\t    const next = this.queue.shift();\n191\t    if (next) next();\n192\t    else tracer.write({ ts: Date.now(), type: 'fork_queue', active: this.activeForks, queued: this.queue.length, max: this.opts.maxConcurrentForks });\n193\t  }\n194\t\n195\t  private async runFork<T>(task: ForkTask, forkScope: TraceScope): Promise<ForkResultMeta<T>> {\n196\t    const tracer = this.opts.tracer ?? NULL_TRACER;\n197\t\n198\t    return new Promise<ForkResultMeta<T>>(async (resolve, reject) => {\n199\t      let settled = false;\n200\t      let didResolve = false;\n201\t      let resolvedValue: unknown;\n202\t      let resolvedError: Error | undefined;\n203\t      let timeoutId: ReturnType<typeof setTimeout> | undefined;\n204\t      // Degradation tracking (Phase 3): set when the value is salvaged rather than\n205\t      // genuinely resolved, so forkWithMeta callers can branch on typed metadata.\n206\t      let salvaged = false;\n207\t      let salvageReason: DegradeReason | undefined;\n208\t\n209\t      const settle = (fn: () => void, endStatus: 'done' | 'error' = 'done', errMsg?: string): void => {\n210\t        if (settled) return;\n211\t        settled = true;\n212\t        if (timeoutId) clearTimeout(timeoutId);\n213\t        tracer.end(forkScope, endStatus, errMsg ? { error: errMsg } : undefined);\n214\t        fn();\n215\t      };\n216\t\n217\t      // Set up timeout\n218\t      if (task.timeout && task.timeout > 0) {\n219\t        const clock = this.opts.clock;\n220\t        if (clock) {\n221\t          clock.setTimeout(() => {\n222\t            const msg = `Fork timed out after ${task.timeout}ms`;\n223\t            settle(() => reject(new Error(msg)), 'error', msg);\n224\t          }, task.timeout);\n225\t        } else {\n226\t          timeoutId = setTimeout(() => {\n227\t            const msg = `Fork timed out after ${task.timeout}ms`;\n228\t            settle(() => reject(new Error(msg)), 'error', msg);\n229\t          }, task.timeout);\n230\t        }\n231\t      }\n232\t\n233\t      // Per-fork budget. Assert nesting depth before spending anything on a VM —\n234\t      // a depth-exceeded fork rejects cleanly with BudgetExceededError.\n235\t      const budget = new Budget(this.opts.budgetLimits ?? {});\n236\t      const depth = this.opts.forkDepth ?? 1;\n237\t\n238\t      let vm: VM | undefined;\n239\t      try {\n240\t        budget.assertForkDepth(depth);\n241\t\n242\t        // Delegation: a task may delegate ONLY per its `canDelegateTo` policy (unified\n243\t        // semantics: omitted/[] = none, [\"*\"] = unrestricted, list = allowlist with\n244\t        // optional \"registered:*\"), and ONLY when the engine was given a delegateRunner\n245\t        // (the Session / delegate runtime owns the registry + recursion bound).\n246\t        // Default: no delegate global — keeps forks isolated and headless as before.\n247\t        const delegatePolicy = evaluateDelegatePolicy(task.canDelegateTo, 'task');\n248\t        const canDelegate = delegatePolicy.mode !== 'none' && typeof this.opts.delegateRunner === 'function';\n249\t        // Per-node capability narrowing FIRST (select a subset of the parent agent's grants,\n250\t        // never widening), THEN the role's read-only intersection on top — so both the injected\n251\t        // globals and the ambient DTS narrow together and a sibling node's stray write fails typecheck.\n252\t        const nodeApp = narrowAppCaps(this.opts.parentAppCapabilities ?? {}, task.capabilities);\n253\t        const capabilities = forkCapabilities(task.role, canDelegate, nodeApp);\n254\t\n255\t        // Space functions from the parent agent. When the task declares a `functions`\n256\t        // allowlist, scope to exactly those (least privilege — fewer tools to misuse,\n257\t        // shorter prompt). An empty array means \"no space functions\".\n258\t        const allFns = this.opts.agentFunctions ?? {};\n259\t        const allFnsBundled = this.opts.agentFunctionsBundled ?? {};\n260\t        const fnAllow = task.functions;\n261\t        const pickAllowed = <T,>(rec: Record<string, T>): Record<string, T> => {\n262\t          if (!fnAllow) return rec;\n263\t          const out: Record<string, T> = {};\n264\t          for (const name of fnAllow) if (name in rec) out[name] = rec[name]!;\n265\t          return out;\n266\t        };\n267\t        const agentFunctions = pickAllowed(allFns);\n268\t        const agentFunctionsBundled = pickAllowed(allFnsBundled);\n269\t\n270\t        // currentTask.resolve records the (schema-validated) result.\n271\t        // IMPORTANT: do NOT call vm.dispose() from inside this callback. We are\n272\t        // executing inside a QuickJS function call frame; disposing the runtime here\n273\t        // causes JS_FreeRuntime to abort because live GC handles are still on the\n274\t        // stack. Instead we record the result and dispose the VM after runTurnLoop exits.\n275\t        const outputSchema = task.output;\n276\t        const currentTaskResolve = (value: unknown): void => {\n277\t          if (didResolve) return;\n278\t          didResolve = true;\n279\t          if (!validateOutput(outputSchema, value)) {\n280\t            resolvedError = new Error(`Fork output does not match schema ${JSON.stringify(outputSchema)}`);\n281\t          } else {\n282\t            resolvedValue = value;\n283\t          }\n284\t        };\n285\t\n286\t        const forkTracer = this.opts.tracer ?? NULL_TRACER;\n287\t        // Shared child-VM bootstrap: seed/upstream vars, currentTask, allowlisted\n288\t        // functions, host tools (role-gated write), yielding globals per the\n289\t        // capability profile (no ask/fork/tasklist; delegate/registerSpace gated),\n290\t        // and the JSX runtime (catalog stubs only — forks get no agent components).\n291\t        vm = await createChildVM({\n292\t          capabilities,\n293\t          renderHost: this.opts.renderHost,\n294\t          clock: this.opts.clock,\n295\t          spaceDir: this.opts.parentSpaceDir,\n296\t          projectSpacesDir: this.opts.projectSpacesDir,\n297\t          projectRoot: this.opts.projectRoot,\n298\t          projectId: this.opts.projectId,\n299\t          appGlobals: this.opts.appGlobals,\n300\t          progress: () => budget.snapshot(),"}]},"parent_tool_use_id":"call_uxqb06RglxS9Y92kx5H5jMqM","session_id":"08b44427-7432-4e2d-a9c3-d9296f1761a5","uuid":"d1a52fd7-77cb-44b5-a297-7976442a0f7e","timestamp":"2026-07-16T04:44:50.710Z","subagent_type":"Explore","task_description":"Design lowest rung partition fix"}
