{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_L3jZ0dgrmKUrNKix9UWcCjta","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { createServer, type Server } from 'node:http';\n6\timport { runTasklist } from './orchestrator.js';\n7\timport { ForkEngine } from '../fork/fork.js';\n8\timport { loadSpace } from '../spaces/load.js';\n9\timport { createMockStreamFn } from '../testing/mock-provider.js';\n10\timport type { RenderHost } from '../session/types.js';\n11\timport type { StreamOpts } from '../eval/stream-types.js';\n12\t\n13\t/**\n14\t * End-to-end coverage for the `plan -> investigate (forEach) -> synthesize` shape\n15\t * that `system-research`'s `deep_research` tasklist uses — a gap the system-space\n16\t * authoring notes flagged (\"no dedicated tests for deep_research tasklist logic\").\n17\t * Mirrors the real\n18\t * tasklist's structure with a stand-in `fetcher` space function that, like\n19\t * `webSearch`/`webFetch`, internally `await fetch(...)`s — a yield NESTED inside\n20\t * another async function. `fetcher`'s return value (`{ tag, status }`) is shaped\n21\t * so that binding the raw inner `fetch()` result instead of `fetcher`'s own\n22\t * processed return (the bug fixed in turn-loop's post-yield binding) would be\n23\t * immediately visible: the raw fetch response has no `tag` field.\n24\t */\n25\t\n26\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n27\t\n28\tconst tmpDirs: string[] = [];\n29\tafterAll(async () => {\n30\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n31\t});\n32\t\n33\tasync function makeDeepResearchShapedSpace(port: number): Promise<string> {\n34\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-deepresearch-'));\n35\t  tmpDirs.push(dir);\n36\t  await mkdir(join(dir, 'agents', 'researcher'), { recursive: true });\n37\t  await writeFile(join(dir, 'agents', 'researcher', 'instruct.md'), 'You are a researcher.\\n', 'utf8');\n38\t\n39\t  await mkdir(join(dir, 'functions'), { recursive: true });\n40\t  // Mirrors webSearch/webFetch's shape: a plain async function that internally\n41\t  // awaits the (now yield-based) `fetch` global, then post-processes the result.\n42\t  await writeFile(\n43\t    join(dir, 'functions', 'fetcher.ts'),\n44\t    [\n45\t      'export async function fetcher(q: string): Promise<{ tag: string; status: number }> {',\n46\t      `  const r = await fetch('http://127.0.0.1:${port}/?q=' + encodeURIComponent(q));`,\n47\t      '  return { tag: `processed:${q}`, status: r.status };',\n48\t      '}',\n49\t    ].join('\\n'),\n50\t    'utf8',\n51\t  );\n52\t\n53\t  const tl = join(dir, 'tasklists', 'deep_research');\n54\t  await mkdir(tl, { recursive: true });\n55\t  await writeFile(join(tl, 'index.md'), '---\\ninput:\\n  query: string\\n---\\n\\nGOAL: produce a report.', 'utf8');\n56\t  await writeFile(\n57\t    join(tl, '01-plan.md'),\n58\t    '---\\nid: plan\\noutput:\\n  questions: array\\ndependsOn: []\\nrole: explore\\nfunctions: []\\n---\\n\\nPLAN_T: decompose the query.',\n59\t    'utf8',\n60\t  );\n61\t  await writeFile(\n62\t    join(tl, '02-investigate.md'),\n63\t    [\n64\t      '---',\n65\t      'id: investigate',\n66\t      'output:',\n67\t      '  question: string',\n68\t      '  tag: string',\n69\t      '  status: number',\n70\t      'dependsOn: [plan]',\n71\t      'forEach: plan.questions',\n72\t      'role: explore',\n73\t      'functions:',\n74\t      '  - fetcher',\n75\t      '---',\n76\t      '',\n77\t      'INVESTIGATE_T: investigate one question.',\n78\t    ].join('\\n'),\n79\t    'utf8',\n80\t  );\n81\t  await writeFile(\n82\t    join(tl, '03-synthesize.md'),\n83\t    '---\\nid: synthesize\\noutput:\\n  count: number\\n  tags: array\\ngoal: true\\ndependsOn: [plan, investigate]\\nrole: explore\\nfunctions: []\\n---\\n\\nSYNTHESIZE_T: roll up the investigations.',\n84\t    'utf8',\n85\t  );\n86\t  return dir;\n87\t}\n88\t\n89\tdescribe('deep_research-shaped tasklist (plan -> investigate forEach -> synthesize)', () => {\n90\t  it('propagates each investigate fork\\'s OWN processed return value (not the raw nested fetch) into synthesize', async () => {\n91\t    // A local server records each request's arrival time (to also prove the forEach\n92\t    // fan-out's fetches run concurrently, not serialized) and answers 200.\n93\t    const arrivals: number[] = [];\n94\t    const server: Server = createServer((_req, res) => {\n95\t      arrivals.push(Date.now());\n96\t      setTimeout(() => res.end('ok'), 50);\n97\t    });\n98\t    await new Promise<void>((resolve) => server.listen(0, resolve));\n99\t    const address = server.address();\n100\t    const port = typeof address === 'object' && address ? address.port : 0;\n101\t\n102\t    try {\n103\t      const dir = await makeDeepResearchShapedSpace(port);\n104\t      const space = await loadSpace(dir);\n105\t\n106\t      const seen: string[] = [];\n107\t      const streamFn = createMockStreamFn((o: StreamOpts) => {\n108\t        const user = o.messages.map((m) => m.content).join('\\n');\n109\t        if (user.includes('PLAN_T')) {\n110\t          seen.push('plan');\n111\t          return `currentTask.resolve({ questions: [\"q1\", \"q2\", \"q3\"] });`;\n112\t        }\n113\t        if (user.includes('INVESTIGATE_T')) {\n114\t          // `fetcher` yields (nested inside its own `await fetch(...)`), so the turn\n115\t          // aborts right after that statement — the resolve must wait for the NEXT\n116\t          // turn, once `r` is bound. Detect which turn this is from whether the\n117\t          // fetcher call already appears in this fork's accumulated history.\n118\t          if (user.includes('await fetcher(')) {\n119\t            return 'currentTask.resolve({ question, tag: r.tag, status: r.status });';\n120\t          }\n121\t          seen.push('investigate');\n122\t          // `item` is the forEach element (one planned question). `fetcher` is a\n123\t          // nested yield (awaits the yield-based `fetch` global internally) — this\n124\t          // is exactly the shape that exposed the turn-loop binding bug.\n125\t          return [\n126\t            'const question = String(item);',\n127\t            'const r = await fetcher(question);',\n128\t          ].join('\\n');\n129\t        }\n130\t        if (user.includes('SYNTHESIZE_T')) {"}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"c063245c-5454-4a3e-99f1-90ee1f11c9de","timestamp":"2026-07-16T19:22:52.044Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
