();\n213\t    expect(() => validateDag(tasks)).not.toThrow();\n214\t    expect(Object.keys(tasks).sort()).toEqual(['build', 'research']);\n215\t    expect(space.tasklists['build_specialist']!.input).toEqual({ request: 'string' });\n216\t\n217\t    const research = tasks['research']!;\n218\t    expect(research.optional).toBe(true);\n219\t    expect(research.role).toBe('explore');\n220\t    expect(research.functions).toEqual([]);\n221\t    expect(research.output).toEqual({ report: 'object' });\n222\t    expect(research.canDelegateTo).toEqual(['system-research/researcher#deep_research']);\n223\t\n224\t    const build = tasks['build']!;\n225\t    expect(build.goal).toBe(true);\n226\t    expect(resolveGoalTask(tasks)!.id).toBe('build');\n227\t    expect(build.dependsOn).toEqual(['research']);\n228\t    expect(build.role).toBe('general');\n229\t    expect(build.functions).toEqual([]);\n230\t    expect(build.canDelegateTo).toEqual(['system-architect/architect#synthesize_and_run']);\n231\t  });\n232\t\n233\t  it(\"build's output schema mirrors the architect finalize task field-for-field\", async () => {\n234\t    const { tasks } = await load();\n235\t    const architect = await loadSpace(resolve(SYS, 'system-architect'), { requireAgents: false });\n236\t    const synth = await loadTasklistFromSpace(architect, 'synthesize_and_run');\n237\t    expect(tasks['build']!.output).toEqual(synth['finalize']!.output);\n238\t  });\n239\t\n240\t  it(\"research's prelude performs the delegation itself and typechecks against the fork ambient\", async () => {\n241\t    const { space, tasks } = await load();\n242\t    const research = tasks['research']!;\n243\t    expect(research.prelude).toBeTruthy();\n244\t    const stmts = splitPreludeStatements(research.prelude!);\n245\t    expect(stmts).toHaveLength(1);\n246\t    expect(stmts[0]).toContain(\"await delegate('system-research', 'researcher', 'deep_research'\");\n247\t    typecheckPrelude(research, space.tasklists['build_specialist']!, {});\n248\t  });\n249\t});\n250\t\n251\tdescribe('system-research preludes (deterministic gather moved to the host)', () => {\n252\t  it('every gather task ships a prelude with the expected statements; pure-reasoning tasks do not', async () => {\n253\t    const space = await loadSpace(resolve(SYS, 'system-research'), { requireAgents: false });\n254\t    const deep = await loadTasklistFromSpace(space, 'deep_research');\n255\t    const shallow = await loadTasklistFromSpace(space, 'research');\n256\t\n257\t    // scope: topic + 2 searches.\n258\t    expect(splitPreludeStatements(deep['scope']!.prelude ?? '')).toHaveLength(3);\n259\t    // investigate: question + search + top + 3 fetches.\n260\t    expect(splitPreludeStatements(deep['investigate']!.prelude ?? '')).toHaveLength(6);\n261\t    // synthesize: mechanical aggregation (entries/seedSources/rawSources/all_sources/\n262\t    // combined_findings/gap_notes) — kills the 'sourceMap is not defined' improvisation.\n263\t    const synthStmts = splitPreludeStatements(deep['synthesize']!.prelude ?? '');\n264\t    expect(synthStmts).toHaveLength(6);\n265\t    expect(deep['synthesize']!.prelude).toContain('all_sources');\n266\t    // answer: q + search + top + 1 fetch.\n267\t    expect(splitPreludeStatements(shallow['answer']!.prelude ?? '')).toHaveLength(4);\n268\t    // Pure-reasoning tasks carry NO prelude.\n269\t    expect(deep['plan']!.prelude).toBeUndefined();"}]},"parent_tool_use_id":null,"session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"4e9a748b-091a-4d8e-8ac7-d7603c6c8373","timestamp":"2026-07-16T02:10:23.573Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/spaces/system-spaces-dag.test.ts","content":"    expect(space.tasklists['iterate_space']!.input).toEqual({\n      spaceKey: 'string',\n      feedback: 'string',\n    });\n  });\n\n  it('research agent exposes shallow research + deep_research (forEach) actions', async () => {\n    const space = awa