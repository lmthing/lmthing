max(0, ...queueEvents.map((e) => e.max ?? 0));\n580\t  const overCap = queueEvents.filter((e) => e.active > (e.max ?? 4));\n581\t  report.check('forks never ran past the concurrency cap', queueEvents.length > 0 && overCap.length === 0, `${queueEvents.length} fork_queue events, max=${maxSeen}, over-cap=${overCap.length}`);\n582\t  report.check('…and the excess QUEUED (queued > 0 at least once)', queueEvents.some((e) => e.queued > 0), `peak queued=${Math.max(0, ...queueEvents.map((e) => e.queued ?? 0))}`);\n583\t\n584\t  cp.acts.VII = { passed: report.stepPassed, forks: forks.length, explore: explore.length, plan: plan.length };\n585\t  saveCheckpoint(cp);\n586\t}\n587\t\n588\t// ═══ ACT VIII — A THROWING API ROUTE: THE CRASH BOUNDARY HOLDS ═════════════════\n589\tif (ACTS.includes(8)) {\n590\t  report.step(\n591\t    'Act VIII — one broken route must not take the trip down',\n592\t    'a route that throws returns a clean HttpError-shaped response (and a bare throw a generic 500); ' +\n593\t      'the pod keeps serving and the very next real route still returns 200 with real rows',\n594\t  );\n595\t  const t8 = now();\n596\t  const httpErrSrc = `import { HttpError } from '@app/runtime';\n597\texport const name = 'scenarioThrow';\n598\texport const description = 'Scenario probe: always throws an HttpError.';\n599\texport default async function handler(): Promise<never> {\n600\t  throw new HttpError(400, 'simulated failure');\n601\t}\n602\t`;\n603\t  const bareSrc = `export const name = 'scenarioBareThrow';\n604\texport const description = 'Scenario probe: always throws a bare Error (generic-500 path).';\n605\texport default async function handler(): Promise<never> {\n606\t  throw new Error('kaboom — a bug the author never meant to ship');\n607\t}\n608\t`;\n609\t  await pod.writeFile(`${PROJECT}/api/_scenario-throw/GET.ts`, httpErrSrc);\n610\t  await pod.writeFile(`${PROJECT}/api/_scenario-bare-throw/GET.ts`, bareSrc);\n611\t  await pod.appBuild(PROJECT).catch(() => {})