{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_XXdRTbraYAURX2mXvKzqdAd4","type":"tool_result","content":"130\t */\n131\texport async function routeCommonYield(\n132\t  req: YieldRequest,\n133\t  ctx: YieldRouterContext,\n134\t): Promise<RouteResult> {\n135\t  // Generic HOST-ENFORCED consent (plan S10): a consent-marked yield kind (the\n136\t  // registry in globals/consent.ts — `installSpace` today) must be approved by\n137\t  // the USER before its resolver runs. No prompter (headless/fork/delegate/hook\n138\t  // contexts) ⇒ FAIL CLOSED; denial ⇒ a structured refusal the agent sees. This\n139\t  // runs BEFORE the switch so no resolver below can execute unapproved.\n140\t  if (CONSENT_MARKED_YIELD_KINDS.has(req.kind)) {\n141\t    await enforceConsent(ctx.requestConsent, {\n142\t      function: req.kind,\n143\t      argsSummary: summarizeConsentArgs(req.args),\n144\t    });\n145\t  }\n146\t  switch (req.kind) {\n147\t    case 'sleep': {\n148\t      const ms = req.args[1] as number;\n149\t      await new Promise<void>((resolve) => {\n150\t        if (ctx.clock) ctx.clock.setTimeout(resolve, ms);\n151\t        else setTimeout(resolve, ms);\n152\t      });\n153\t      return { handled: true, value: undefined };\n154\t    }\n155\t    case 'fork': {\n156\t      if (!ctx.getForkEngine) return { handled: false }; // fork leaves have no fork()\n157\t      const engine = await ctx.getForkEngine();\n158\t      const task = req.args[0] as ForkTask;\n159\t      // Attach the current scope as parent so the fork's node is correctly nested\n160\t      if (ctx.scope && !task.parentScope) task.parentScope = ctx.scope;\n161\t      const value = await engine.fork(task);\n162\t      return { handled: true, value };\n163\t    }\n164\t    case 'tasklist': {\n165\t      if (!ctx.getForkEngine || !ctx.space) return { handled: false }; // fork leaves have no tasklist()\n166\t      const name = req.args[0] as string;\n167\t      const seed = req.args[1] as Record<string, unknown> | undefined;\n168\t      const engine = await ctx.getForkEngine();\n169\t      const { runTasklist } = await import('../tasklist/orchestrator.js');\n170\t      const result = await runTasklist({ name, space: ctx.space, forkEngine: engine, seed, tracer: ctx.tracer, parentScope: ctx.scope, codeNodeCtxFactory: ctx.codeNodeCtxFactory });\n171\t      ctx.onTasklistResult?.(name, result);\n172\t      return { handled: true, value: result };\n173\t    }\n174\t    case 'delegate': {\n175\t      const [packageName, agentName, action, delegateOpts] = req.args as [\n176\t        string,\n177\t        string,\n178\t        string | undefined,\n179\t        DelegateOpts | undefined,\n180\t      ];\n181\t      const value = await ctx.runDelegate(packageName, agentName, action, delegateOpts);\n182\t      return { handled: true, value };\n183\t    }\n184\t    case 'fetch': {\n185\t      const [url, fetchOpts] = req.args as [string, import('../globals/fetch.js').FetchOpts | undefined];\n186\t      const { resolveFetchYield } = await import('./fetch-yield.js');\n187\t      const value = await resolveFetchYield(url, fetchOpts);\n188\t      return { handled: true, value };\n189\t    }\n190\t    case 'apiCall': {\n191\t      // Enter the project's own api endpoint by name (agent-facing `apiCall`).\n192\t      // A missing resolver means this context has no project api runtime — throw\n193\t      // an actionable, retryable error rather than binding undefined.\n194\t      if (!ctx.apiCallResolver) {\n195\t        throw new Error('apiCall is not available here: this session has no project api runtime');\n196\t      }\n197\t      const [name, input] = req.args as [string, unknown];\n198\t      // ENFORCE the `api:call: { allow: [...] }` grant. Holding the capability is what\n199\t      // injects the global; the allowlist is what says WHICH endpoints it may enter, and"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8