,                     // gates ctx.callConnection to these providers\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:555:  \"  handler: async ({ input, delegate, callConnection }) => {\",\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:558:  \"    await callConnection('slack', { method: 'POST', path: '/chat.postMessage',\",\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:578:  \"  on: { event: 'integration-demo/message.received' },\",   // the REAL event integration-demo declares\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:584:  \"    await db.insert('tips', { headline: body.slice(0, 160), body, source: 'integration-demo', status: 'new', summary: '' });\",\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:606:passes structured input through and RETURNS the agent's result, and `ctx.callConnection`\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:692:`emit(ctx)` that polls via `ctx.callConnection`, and a persisted `ctx.state` KV it uses as a\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:702:  \"  connections: ['demo'],\",                         // the installed provider ctx.callConnection may reach\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/agents/automator/instruct.md:707:  \"    try { const res = await ctx.callConnection('demo', { method: 'GET', path: '/items', query: { since } });\",\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/tasklists/build_app/06-build_hook.md:20:  LLM) or `trigger` an agent. A code handler receives `ctx = { input, db, delegate, callConnection,\nsdk/org/libs/ui/node_modules/@lmthing/core/src/tasklist/orchestrator.ts:26: * `connections:` (db, callConnection, delegate). `inputs` is the SAME data an\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:197:  // callConnection: value-yielding entry to a user-connected external service, gated on the\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:200:  if (caps.app['connections:use']) injectGlobal(ctx, 'callConnection', createCallConnectionGlobal(pushYield) as AnyFn);\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:201:  // integrationStatus: presence-only config check for an installed integration space,\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:205:  // (integrationStatusResolver); absent ⇒ a clear \"no project scope\" error.\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:206:  if (opts.projectRoot) injectGlobal(ctx, 'integrationStatus', createIntegrationStatusGlobal(pushYield) as AnyFn);\nsdk/org/libs/ui/node_modules/@lmthing/core/src/exec/bootstrap.ts:324:  // connections:use — emit the typed `callConnection` with `provider` narrowed to the\nsdk/org/libs/ui/node_modules/@lmthing/core/src/fork/fork.ts:440:          connectionResolver: this.opts.appGlobals?.callConnection,\nsdk/org/libs/ui/node_modules/@lmthing/core/system-spaces/system-appbuilder/knowledge/app_building/model/capability-model.md:20:| `connections:use` | `callConnection`, `integrationStatus` | optional `{ providers: [...] }` |\nsdk/org/libs/ui/node_modules/@lmthing/core/src/delegate/delegate.ts:348:            connectionResolver: opts.appGlobals?.callConnection,\nsdk/org/libs/ui/node_modules/@lmthing/core/src/eval/yield-router.test.ts:136:  it('routes callConnection through the connectionResolver with (provider, request)', async () => {\nsdk/org/libs/ui/node_modules/@lmthing/core/src/eval/yield-router.test.ts:140:      req('callConnection', ['google', request]),\nsdk/org/libs/ui/node_modules/@lmthing/core/src/eval/yield-router.test.ts:152:  it('c