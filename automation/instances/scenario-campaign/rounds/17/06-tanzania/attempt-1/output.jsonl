allFns);\n293\t      }\n294\t    }\n295\t  });\n296\t});\n297\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"7cdcb4b8-9bf7-4167-b70f-bdfbbf071685","timestamp":"2026-07-16T06:15:12.097Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_bBuE89MewxHCLn90XIgCa1k7","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport { ForkEngine, resolveTaskDelegate } from '../fork/fork.js';\n7\timport { loadSpace } from '../spaces/load.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamOpts } from '../eval/stream-types.js';\n11\t\n12\tconst tmpDirs: string[] = [];\n13\tafterAll(async () => { await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true }))); });\n14\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n15\t\n16\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n17\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-deleg-'));\n18\t  tmpDirs.push(dir);\n19\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n20\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'runner\\n', 'utf8');\n21\t  const tl = join(dir, 'tasklists', 'flow');\n22\t  await mkdir(tl, { recursive: true });\n23\t  for (const [n, c] of Object.entries(files)) await writeFile(join(tl, n), c, 'utf8');\n24\t  return dir;\n25\t}\n26\t\n27\tdescribe('resolveTaskDelegate (allowlist)', () => {\n28\t  it('allows a matching target and scopes the action', () => {\n29\t    const r = resolveTaskDelegate(['system-research/researcher#deep_research'], 'system-research', 'researcher');\n30\t    expect(r).toEqual({ allowedActions: ['deep_research'] });\n31\t  });\n32\t  it('allows ANY action when the entry has no #action', () => {\n33\t    expect(resolveTaskDelegate(['sp/ag'], 'sp', 'ag')).toEqual({ allowedActions: undefined });\n34\t  });\n35\t  it('denies a target not in the allowlist', () => {\n36\t    expect(resolveTaskDelegate(['sp/ag#x'], 'other', 'ag')).toBeNull();\n37\t    expect(resolveTaskDelegate(['sp/ag#x'], 'sp', 'nope')).toBeNull();\n38\t  });\n39\t});\n40\t\n41\tdescribe('delegate inside a task (canDelegateTo)', () => {\n42\t  it('routes an allowed delegate through the engine delegateRunner and returns its result', async () => {\n43\t    const dir = await makeTasklistSpace({\n44\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nCALL_T: delegate then resolve.`,\n45\t    });\n46\t    const space = await loadSpace(dir);\n47\t    const calls: Array<{ pkg: string; agent: string; action?: string; allowed?: string[] }> = [];\n48\t    // Turn 1: emit the delegate binding (it yields). Turn 2 (after `r` is bound from the resolved\n49\t    // delegate): emit the resolve. (A single mock that re-emits both each turn would re-delegate.)\n50\t    let turn = 0;\n51\t    const streamFn = createMockStreamFn(() => {\n52\t      turn++;\n53\t      if (turn === 1) return `const r = await delegate('helper', 'agent', 'act', { query: 'hi' });`;\n54\t      return `currentTask.resolve({ v: r.n });`;\n55\t    });\n56\t    const engine = new ForkEngine({\n57\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n58\t      renderHost: silentHost, streamFn,\n59\t      delegateRunner: async (pkg, agent, action, _opts, allowed) => {\n60\t        calls.push({ pkg, agent, action, allowed });\n61\t        return { n: 42 };\n62\t      },\n63\t    });\n64\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { v: number };\n65\t    expect(goal).toEqual({ v: 42 });\n66\t    expect(calls).toEqual([{ pkg: 'helper', agent: 'agent', action: 'act', allowed: ['act'] }]);\n67\t  });\n68\t\n69\t  it('blocks a delegate to a non-allowlisted target (runner never called; fork salvages)', async () => {\n70\t    const dir = await makeTasklistSpace({\n71\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nBAD_T: delegate to a forbidden target.`,\n72\t    });\n73\t    const space = await loadSpace(dir);\n74\t    let runnerCalls = 0;\n75\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n76\t      const u = o.messages.map((m) => m.content).join('\\n');\n77\t      // 'evil/agent' is NOT in canDelegateTo → the delegate yield throws, fork never resolves → salvage.\n78\t      if (u.includes('BAD_T')) return `const r = await delegate('evil', 'agent', 'act', { query: 'x' }) as { n: number };\\ncurrentTask.resolve({ v: r.n });`;\n79\t      return '';\n80\t    });\n81\t    const engine = new ForkEngine({\n82\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n83\t      renderHost: silentHost, streamFn,\n84\t      delegateRunner: async () => { runnerCalls++; return { n: 1 }; },\n85\t    });\n86\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n87\t    expect(runnerCalls).toBe(0);            // forbidden target never reached the runner\n88\t    expect(env.data).toEqual({ v: 0 });     // fork salvaged a NEUTRAL schema-valid placeholder\n89\t    expect(env.ok).toBe(false);             // …and the envelope signals the degradation\n90\t    expect(env.degraded).toBe(true);\n91\t  });\n92\t\n93\t  it('canDelegateTo: [\"*\"] gives the task an UNSCOPED delegate (any target routes to the runner)', async () => {\n94\t    const dir = await makeTasklistSpace({\n95\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"*\"\\noutput:\\n  v: number\\n---\\n\\nSTAR_T: delegate anywhere then resolve.`,\n96\t    });\n97\t    const space = await loadSpace(dir);\n98\t    const calls: Array<{ pkg: string; agent: string; allowed?: string[] }> = [];\n99\t    let turn = 0;\n100\t    const streamFn = createMockStreamFn(() => {\n101\t      turn++;\n102\t      if (turn === 1) return `const r = await delegate('any-space-at-all', 'whoever', 'act', { query: 'hi' });`;\n103\t      return `currentTask.resolve({ v: r.n });`;\n104\t    });\n105\t    const engine = new ForkEngine({\n106\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n107\t      renderHost: silentHost, streamFn,\n108\t      delegateRunner: async (pkg, agent, _action, _opts, allowed) => {\n109\t        calls.push({ pkg, agent, allowed });\n110\t        return { n: 7 };\n111\t      },\n112\t    });\n113\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n114\t    expect(env.ok).toBe(true);\n115\t    expect(env.data).toEqual({ v: 7 });\n116\t    // Unrestricted: no target gate, no action narrowing.\n117\t    expect(calls).toEqual([{ pkg: 'any-space-at-all', agent: 'whoever', allowed: undefined }]);\n118\t  });\n119\t\n120\t  it('canDelegateTo: [\"registered:*\"] admits a dynamicSpaces-registered target and blocks others', async () => {\n121\t    const dir = await makeTasklistSpace({\n122\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"registered:*\"\\noutput:\\n  v: number\\n---\\n\\nREG_T: delegate to the registered space.`,\n123\t    });\n124\t    const space = await loadSpace(dir);\n125\t    const regDir = '/dyn/built-space';\n126\t    const dynamicSpaces = new Map([[regDir, space]]); // any Space value; the gate matches keys/dirs\n127\t    const calls: string[] = [];\n128\t    let turn = 0;\n129\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n130\t      turn++;\n131\t      // Turn 1: an UNREGISTERED target — the gate throws (retryable error).\n132\t      if (turn === 1) return `const r = await delegate('never-registered', 'agent', 'act', { query: 'x' });`;\n133\t      // Turn 2 (retry with the ERROR block): the registered one.\n134\t      if (turn === 2) {\n135\t        const last = o.messages[o.messages.length - 1]?.content ?? '';\n136\t        if (!last.includes('is not permitted')) return `currentTask.resolve({ v: -1 });`;\n137\t        return `const r = await delegate('${regDir}', 'agent', 'act', { query: 'x' });`;\n138\t      }\n139\t      return `currentTask.resolve({ v: r.n });`;\n140\t    });\n141\t    const engine = new ForkEngine({\n142\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n143\t      renderHost: silentHost, streamFn, dynamicSpaces,\n144\t      delegateRunner: async (pkg) => { calls.push(pkg); return { n: 9 }; },\n145\t    });\n146\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n147\t    expect(env.ok).toBe(true);\n148\t    expect(env.data).toEqual({ v: 9 });\n149\t    expect(calls).toEqual([regDir]); // only the registered target reached the runner\n150\t  });\n151\t});\n152\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"adade156-4174-403f-96c6-d6a5a079c429","timestamp":"2026-07-16T06:15:12.098Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_mM41KTGmvyARKICRFjfTx9mW","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport { ForkEngine } from '../fork/fork.js';\n7\timport { loadSpace } from '../spaces/load.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport { Tracer } from '../sandbox/trace.js';\n10\timport type { TraceEvent } from '../sandbox/trace.js';\n11\timport type { RenderHost } from '../session/types.js';\n12\timport type { StreamOpts } from '../eval/stream-types.js';\n13\t\n14\t/**\n15\t * Orchestrator branch coverage: drives the REAL runTasklist + ForkEngine with the\n16\t * scripted mock provider (no API keys). Exercises the scheduling paths that the\n17\t * happy-path session test in testing/harness-features.test.ts doesn't reach —\n18\t * parallel-ready fan-out, optional-task skip on failure, condition skip, and the\n19\t * required-task-failure throw.\n20\t */\n21\t\n22\tconst tmpDirs: string[] = [];\n23\tafterAll(async () => {\n24\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n25\t});\n26\t\n27\t/** Write a one-agent space whose `flow` tasklist is the given { filename: contents } map. */\n28\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n29\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-orch-'));\n30\t  tmpDirs.push(dir);\n31\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n32\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n33\t  const tl = join(dir, 'tasklists', 'flow');\n34\t  await mkdir(tl, { recursive: true });\n35\t  for (const [name, contents] of Object.entries(files)) {\n36\t    await writeFile(join(tl, name), contents, 'utf8');\n37\t  }\n38\t  return dir;\n39\t}\n40\t\n41\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n42\t\n43\t/** ForkEngine wired to a mock streamFn; `seen` records every task token the mock answered. */\n44\tfunction engineFor(\n45\t  dir: string,\n46\t  answers: Array<{ token: string; code: string }>,\n47\t  seen: string[],\n48\t  budgetLimits?: Record<string, number>,\n49\t): ForkEngine {\n50\t  const streamFn = createMockStreamFn((o: StreamOpts) => {\n51\t    const user = o.messages.map((m) => m.content).join('\\n');\n52\t    for (const a of answers) {\n53\t      if (user.includes('Output schema:') && user.includes(a.token)) {\n54\t        seen.push(a.token);\n55\t        return a.code;\n56\t      }\n57\t    }\n58\t    // A task with no scripted answer never resolves. The fork salvages a schema-valid\n59\t    // placeholder (graceful degradation) UNLESS a hard budget cap forces a real failure.\n60\t    return budgetLimits ? `await sleep(\"1ms\");` : '';\n61\t  });\n62\t  return new ForkEngine({\n63\t    maxConcurrentForks: 4,\n64\t    parentHistory: [],\n65\t    parentSpaceDir: dir,\n66\t    parentAgentSlug: 'main',\n67\t    renderHost: silentHost,\n68\t    streamFn,\n69\t    ...(budgetLimits ? { budgetLimits } : {}),\n70\t  });\n71\t}\n72\t\n73\tdescribe('runTasklist orchestrator', () => {\n74\t  it('fans out independent ready tasks in parallel and seeds every task', async () => {\n75\t    // left + right have no deps → both are ready in the first scheduling round.\n76\t    const dir = await makeTasklistSpace({\n77\t      '01-left.md': `---\\nid: left\\noutput:\\n  v: number\\n---\\n\\nLEFT_T: derive from seed.`,\n78\t      '02-right.md': `---\\nid: right\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nRIGHT_T: derive from seed.`,\n79\t    });\n80\t    const space = await loadSpace(dir);\n81\t    const seen: string[] = [];\n82\t    const engine = engineFor(\n83\t      dir,\n84\t      [\n85\t        { token: 'LEFT_T', code: `currentTask.resolve({ v: base + 1 });` },\n86\t        { token: 'RIGHT_T', code: `currentTask.resolve({ v: base + 2 });` },\n87\t      ],\n88\t      seen,\n89\t    );\n90\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine, seed: { base: 10 } });\n91\t    // Both ready tasks ran (seed reached both); the goal task's output is the envelope payload.\n92\t    expect(seen.sort()).toEqual(['LEFT_T', 'RIGHT_T']);\n93\t    expect(goal.data).toEqual({ v: 12 });\n94\t    expect(goal.ok).toBe(true);\n95\t    expect(goal.degraded).toBe(false);\n96\t  });\n97\t\n98\t  it('skips an optional task whose fork fails, and still completes the goal', async () => {\n99\t    const dir = await makeTasklistSpace({\n100\t      '01-flaky.md': `---\\nid: flaky\\noptional: true\\noutput:\\n  v: number\\n---\\n\\nFLAKY_T: this one never resolves.`,\n101\t      '02-main.md': `---\\nid: main\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nMAIN_T: the real work.`,\n102\t    });\n103\t    const space = await loadSpace(dir);\n104\t    const seen: string[] = [];\n105\t    // flaky has no scripted answer → its fork rejects → optional → skipped (no throw).\n106\t    const engine = engineFor(dir, [{ token: 'MAIN_T', code: `currentTask.resolve({ v: 5 });` }], seen);\n107\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n108\t    expect(goal.data).toEqual({ v: 5 });\n109\t    expect(goal.ok).toBe(true); // the GOAL task itself resolved cleanly\n110\t    expect(seen).toEqual(['MAIN_T']); // main ran; the flaky fork produced no answer\n111\t  });\n112\t\n113\t  it('skips a task whose condition is not met (its fork never runs)', async () => {\n114\t    const dir = await makeTasklistSpace({\n115\t      '01-gate.md': `---\\nid: gate\\noutput:\\n  go: boolean\\n---\\n\\nGATE_T: decide the gate.`,\n116\t      '02-branch.md': `---\\nid: branch\\ndependsOn:\\n  - gate\\ncondition: \"gate.go == true\"\\noutput:\\n  v: number\\n---\\n\\nBRANCH_T: only when gate is open.`,\n117\t      '03-final.md': `---\\nid: final\\ndependsOn:\\n  - gate\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nFINAL_T: always the goal.`,\n118\t    });\n119\t    const space = await loadSpace(dir);\n120\t    const seen: string[] = [];\n121\t    const engine = engineFor(\n122\t      dir,\n123\t      [\n124\t        { token: 'GATE_T', code: `currentTask.resolve({ go: false });` }, // gate closed\n125\t        { token: 'BRANCH_T', code: `currentTask.resolve({ v: 1 });` },\n126\t        { token: 'FINAL_T', code: `currentTask.resolve({ v: 9 });` },\n127\t      ],\n128\t      seen,\n129\t    );\n130\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n131\t    expect(goal.data).toEqual({ v: 9 });\n132\t    // The conditional branch was skipped — its fork was never dispatched.\n133\t    expect(seen).toContain('GATE_T');\n134\t    expect(seen).toContain('FINAL_T');\n135\t    expect(seen).not.toContain('BRANCH_T');\n136\t  });\n137\t\n138\t  it('throws (not silent undefined) when the goal task is skipped, folding in upstream errors', async () => {\n139\t    // Regression for the architect \"returned null\" failure: build fails validation →\n140\t    // register's `build.ok == true` condition skips it → the goal task (execute), which\n141\t    // depends on register, is skipped too. Previously runTasklist returned `undefined`,\n142\t    // surfacing to the caller as a silent `null`. Now it throws with the upstream reason.\n143\t    const dir = await makeTasklistSpace({\n144\t      '01-build.md': `---\\nid: build\\noutput:\\n  ok: boolean\\n  errors: string\\n---\\n\\nBUILD_T: build + validate.`,\n145\t      '02-register.md': `---\\nid: register\\ndependsOn:\\n  - build\\ncondition: \"build.ok == true\"\\noutput:\\n  spaceKey: string\\n---\\n\\nREG_T: register the space.`,\n146\t      '03-execute.md': `---\\nid: execute\\ndependsOn:\\n  - register\\ngoal: true\\ncondition: \"register.spaceKey != ''\"\\noutput:\\n  v: number\\n---\\n\\nEXEC_T: the goal.`,\n147\t    });\n148\t    const space = await loadSpace(dir);\n149\t    const seen: string[] = [];\n150\t    const engine = engineFor(\n151\t      dir,\n152\t      [\n153\t        { token: 'BUILD_T', code: `currentTask.resolve({ ok: false, errors: 'validation failed: knowledge missing' });` },\n154\t        { token: 'REG_T', code: `currentTask.resolve({ spaceKey: 'k' });` },\n155\t        { token: 'EXEC_T', code: `currentTask.resolve({ v: 1 });` },\n156\t      ],\n157\t      seen,\n158\t    );\n159\t    await expect(runTasklist({ name: 'flow', space, forkEngine: engine })).rejects.toThrow(\n160\t      /goal task \"execute\" was skipped.*validation failed: knowledge missing/s,\n161\t    );\n162\t    // The downstream tasks never ran — only build was dispatched.\n163\t    expect(seen).toEqual(['BUILD_T']);\n164\t  });\n165\t\n166\t  it('emits a tasklist node with per-task children (done + skipped) when given a tracer', async () => {\n167\t    const dir = await makeTasklistSpace({\n168\t      '01-gate.md': `---\\nid: gate\\noutput:\\n  go: boolean\\n---\\n\\nGATE_T: decide the gate.`,\n169\t      '02-branch.md': `---\\nid: branch\\ndependsOn:\\n  - gate\\ncondition: \"gate.go == true\"\\noutput:\\n  v: number\\n---\\n\\nBRANCH_T: only when gate is open.`,\n170\t      '03-final.md': `---\\nid: final\\ndependsOn:\\n  - gate\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nFINAL_T: always the goal.`,\n171\t    });\n172\t    const space = await loadSpace(dir);\n173\t    const seen: string[] = [];\n174\t    const events: TraceEvent[] = [];\n175\t    const tracer = new Tracer(null);\n176\t    tracer.subscribe((e) => events.push(e));\n177\t    const engine = new ForkEngine({\n178\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n179\t      renderHost: silentHost, tracer,\n180\t      streamFn: createMockStreamFn((o: StreamOpts) => {\n181\t        const user = o.messages.map((m) => m.content).join('\\n');\n182\t        for (const a of [\n183\t          { token: 'GATE_T', code: `currentTask.resolve({ go: false });` },\n184\t          { token: 'FINAL_T', code: `currentTask.resolve({ v: 9 });` },\n185\t        ]) {\n186\t          if (user.includes('Output schema:') && user.includes(a.token)) { seen.push(a.token); return a.code; }\n187\t        }\n188\t        return '';\n189\t      }),\n190\t    });\n191\t    const parentScope = tracer.child(undefined, 'run', 'session');\n192\t    await runTasklist({ name: 'flow', space, forkEngine: engine, tracer, parentScope });\n193\t\n194\t    const starts = events.filter((e): e is Extract<TraceEvent, { type: 'node_start' }> => e.type === 'node_start');\n195\t    const ends = events.filter((e): e is Extract<TraceEvent, { type: 'node_end' }> => e.type === 'node_end');\n196\t\n197\t    // One tasklist node, parented under the run scope.\n198\t    const tasklistNode = starts.find((s) => s.kind === 'tasklist');\n199\t    expect(tasklistNode).toBeDefined();\n200\t    expect(tasklistNode!.parentId).toBe(parentScope.nodeId);\n201\t\n202\t    // Task nodes nest under the tasklist node; gate/final done, branch skipped.\n203\t    const taskNodes = starts.filter((s) => s.kind === 'task');\n204\t    expect(taskNodes.every((t) => t.parentId === tasklistNode!.nodeId)).toBe(true);\n205\t    const branch = taskNodes.find((t) => t.label.includes('branch'));\n206\t    expect(branch!.detail?.dependsOn).toContain('gate');\n207\t    const branchEnd = ends.find((e) => e.nodeId === branch!.nodeId);\n208\t    expect(branchEnd!.status).toBe('skipped');\n209\t    // The tasklist node itself completed.\n210\t    expect(ends.find((e) => e.nodeId === tasklistNode!.nodeId)!.status).toBe('done');\n211\t  });\n212\t\n213\t  it('salvages a never-resolving required task so the tasklist still completes, signalled via the envelope', async () => {\n214\t    // Robustness contract: a required task whose fork never calls resolve() is salvaged\n215\t    // (NEUTRAL schema-valid placeholder) rather than aborting the whole tasklist. The\n216\t    // degradation is a TYPED signal on the envelope — never prose inside the data.\n217\t    const dir = await makeTasklistSpace({\n218\t      '01-boom.md': `---\\nid: boom\\ngoal: true\\noutput:\\n  v: number\\n  note: string\\n---\\n\\nBOOM_T: this required task never resolves.`,\n219\t    });\n220\t    const space = await loadSpace(dir);\n221\t    const engine = engineFor(dir, [], []); // no answer → boom's fork salvages\n222\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine });\n223\t    expect(result.ok).toBe(false);\n224\t    expect(result.degraded).toBe(true);\n225\t    expect(result.reason).toBe('no_resolve');\n226\t    expect(result.degradedTasks).toEqual(['boom']);\n227\t    expect(result.data).toEqual({ v: 0, note: '' }); // neutral empties, schema-shaped\n228\t    // The alarming prose placeholder is GONE from the data plane entirely.\n229\t    expect(JSON.stringify(result)).not.toContain('(unavailable');\n230\t  });\n231\t\n232\t  it('labels a degraded forEach ELEMENT as \"task[i]\" in degradedTasks', async () => {\n233\t    // Only element index 2 (item 30) never resolves — its fork salvages. The envelope\n234\t    // must name exactly that element, and the goal (a forEach task) counts as degraded.\n235\t    const dir = await makeTasklistSpace({\n236\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n237\t      '02-each.md': `---\\nid: each\\ndependsOn: [list]\\nforEach: list.items\\ngoal: true\\noutput:\\n  n: number\\n---\\n\\nEACH_T: process one item.`,\n238\t    });\n239\t    const space = await loadSpace(dir);\n240\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n241\t      const user = o.messages.map((m) => m.content).join('\\n');\n242\t      if (user.includes('LIST_T')) return `currentTask.resolve({ items: [10, 20, 30] });`;\n243\t      if (user.includes('EACH_T')) {\n244\t        if (user.includes('- item: 30')) return ''; // this element never resolves → salvage\n245\t        return `currentTask.resolve({ n: item });`;\n246\t      }\n247\t      return '';\n248\t    });\n249\t    const engine = new ForkEngine({\n250\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n251\t      renderHost: silentHost, streamFn,\n252\t    });\n253\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine });\n254\t    expect(result.degraded).toBe(true);\n255\t    expect(result.degradedTasks).toEqual(['each[2]']);\n256\t    expect(result.ok).toBe(false); // the goal task itself had a salvaged element\n257\t    expect(result.reason).toBe('no_resolve');\n258\t    // Element outputs stay RAW schema data — the salvaged element is a neutral empty.\n259\t    expect(result.data).toEqual([{ n: 10 }, { n: 20 }, { n: 0 }]);\n260\t  });\n261\t\n262\t  it('a degraded NON-goal task marks the envelope degraded but keeps ok:true', async () => {\n263\t    const dir = await makeTasklistSpace({\n264\t      '01-shaky.md': `---\\nid: shaky\\noutput:\\n  hint: string\\n---\\n\\nSHAKY_T: never resolves.`,\n265\t      '02-main.md': `---\\nid: main\\ndependsOn: [shaky]\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nMAIN_T: the goal.`,\n266\t    });\n267\t    const space = await loadSpace(dir);\n268\t    const engine = engineFor(dir, [{ token: 'MAIN_T', code: `currentTask.resolve({ v: 3 });` }], []);\n269\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine });\n270\t    expect(result.ok).toBe(true); // the GOAL resolved un-salvaged\n271\t    expect(result.degraded).toBe(true); // …but the pipeline carried a salvage\n272\t    expect(result.degradedTasks).toEqual(['shaky']);\n273\t    expect(result.reason).toBeUndefined(); // reason describes the goal only\n274\t    expect(result.data).toEqual({ v: 3 });\n275\t  });\n276\t\n277\t  it('hard-filters the seed to the DECLARED input keys before forking', async () => {\n278\t    // Root cause A2: the whole seed used to spread into every fork, so delegator baggage\n279\t    // (e.g. parentHistory) rode into leaf prompts under nesting. With a declared input\n280\t    // schema, forks receive ONLY the declared keys.\n281\t    const dir = await mkdtemp(join(tmpdir(), 'lmthing-orch-'));\n282\t    tmpDirs.push(dir);\n283\t    await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n284\t    await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n285\t    const tl = join(dir, 'tasklists', 'flow');\n286\t    await mkdir(tl, { recursive: true });\n287\t    await writeFile(join(tl, 'index.md'), `---\\ninput:\\n  query: string\\n---\\n\\nEcho the query.`, 'utf8');\n288\t    await writeFile(join(tl, '01-main.md'), `---\\nid: main\\ngoal: true\\noutput:\\n  echo: string\\n---\\n\\nECHO_T: echo the query seed var.`, 'utf8');\n289\t    const space = await loadSpace(dir);\n290\t    let forkPrompt = '';\n291\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n292\t      const user = o.messages.map((m) => m.content).join('\\n');\n293\t      if (user.includes('ECHO_T')) {\n294\t        forkPrompt = user;\n295\t        return `currentTask.resolve({ echo: query });`;\n296\t      }\n297\t      return '';\n298\t    });\n299\t    const engine = new ForkEngine({\n300\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n301\t      renderHost: silentHost, streamFn,\n302\t    });\n303\t    const result = await runTasklist({\n304\t      name: 'flow', space, forkEngine: engine,\n305\t      seed: { query: 'x', junk: 'y', parentHistory: 'z' },\n306\t    });\n307\t    // The declared key made it through — as a real seed VAR (the fork read it) and in the prompt.\n308\t    expect(result.data).toEqual({ echo: 'x' });\n309\t    expect(forkPrompt).toContain('query');\n310\t    // The undeclared baggage did NOT reach the fork's prompt/seed.\n311\t    expect(forkPrompt).not.toContain('junk');\n312\t    expect(forkPrompt).not.toContain('parentHistory');\n313\t  });\n314\t\n315\t  it('passes the full seed through when the tasklist declares NO input schema (back-compat)', async () => {\n316\t    const dir = await makeTasklistSpace({\n317\t      '01-main.md': `---\\nid: main\\ngoal: true\\noutput:\\n  echo: string\\n---\\n\\nPASS_T: echo the junk seed var.`,\n318\t    });\n319\t    const space = await loadSpace(dir);\n320\t    let forkPrompt = '';\n321\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n322\t      const user = o.messages.map((m) => m.content).join('\\n');\n323\t      if (user.includes('PASS_T')) {\n324\t        forkPrompt = user;\n325\t        return `currentTask.resolve({ echo: junk });`;\n326\t      }\n327\t      return '';\n328\t    });\n329\t    const engine = new ForkEngine({\n330\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n331\t      renderHost: silentHost, streamFn,\n332\t    });\n333\t    const result = await runTasklist({\n334\t      name: 'flow', space, forkEngine: engine,\n335\t      seed: { query: 'x', junk: 'y' },\n336\t    });\n337\t    expect(result.data).toEqual({ echo: 'y' }); // undeclared-input tasklist: everything flows\n338\t    expect(forkPrompt).toContain('junk');\n339\t  });\n340\t\n341\t  it('throws when a required task hits a hard budget cap (genuine failure)', async () => {\n342\t    // A hard limit (budget) is NOT salvaged — it propagates so a runaway task fails loudly.\n343\t    const dir = await makeTasklistSpace({\n344\t      '01-boom.md': `---\\nid: boom\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nBOOM_T: this required task loops forever.`,\n345\t    });\n346\t    const space = await loadSpace(dir);\n347\t    const engine = engineFor(dir, [], [], { maxEpisodes: 3 }); // loops on sleep → budget cap fires\n348\t    await expect(runTasklist({ name: 'flow', space, forkEngine: engine })).rejects.toThrow(\n349\t      /Required task \"boom\" failed/,\n350\t    );\n351\t  });\n352\t\n353\t  it('with no goal: true task, resolves the effective goal to the LAST task (file order)', async () => {\n354\t    // Neither task declares goal: true — the effective goal falls back to the\n355\t    // last task in file order (02-second), not the first.\n356\t    const dir = await makeTasklistSpace({\n357\t      '01-first.md': `---\\nid: first\\noutput:\\n  v: number\\n---\\n\\nFIRST_T: runs first, not the goal.`,\n358\t      '02-second.md': `---\\nid: second\\ndependsOn:\\n  - first\\noutput:\\n  v: number\\n---\\n\\nSECOND_T: runs last, is the effective goal.`,\n359\t    });\n360\t    const space = await loadSpace(dir);\n361\t    const seen: string[] = [];\n362\t    const engine = engineFor(\n363\t      dir,\n364\t      [\n365\t        { token: 'FIRST_T', code: `currentTask.resolve({ v: 1 });` },\n366\t        { token: 'SECOND_T', code: `currentTask.resolve({ v: 2 });` },\n367\t      ],\n368\t      seen,\n369\t    );\n370\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine });\n371\t    expect(result.data).toEqual({ v: 2 });\n372\t    expect(seen).toEqual(['FIRST_T', 'SECOND_T']);\n373\t  });\n374\t\n375\t  it('throws when two tasks declare goal: true', async () => {\n376\t    const dir = await makeTasklistSpace({\n377\t      '01-a.md': `---\\nid: a\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nA_T: first goal.`,\n378\t      '02-b.md': `---\\nid: b\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nB_T: second goal.`,\n379\t    });\n380\t    const space = await loadSpace(dir);\n381\t    const engine = engineFor(dir, [], []);\n382\t    await expect(runTasklist({ name: 'flow', space, forkEngine: engine })).rejects.toThrow(\n383\t      /multiple goal tasks/,\n384\t    );\n385\t  });\n386\t\n387\t  it('validates the seed against the tasklist index.md input schema', async () => {\n388\t    const dir = await mkdtemp(join(tmpdir(), 'lmthing-orch-'));\n389\t    tmpDirs.push(dir);\n390\t    await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n391\t    await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n392\t    const tl = join(dir, 'tasklists', 'flow');\n393\t    await mkdir(tl, { recursive: true });\n394\t    await writeFile(\n395\t      join(tl, 'index.md'),\n396\t      `---\\ninput:\\n  topic: string\\n---\\n\\nDescribes the flow tasklist.`,\n397\t      'utf8',\n398\t    );\n399\t    await writeFile(\n400\t      join(tl, '01-main.md'),\n401\t      `---\\nid: main\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nMAIN_T: the real work.`,\n402\t      'utf8',\n403\t    );\n404\t    const space = await loadSpace(dir);\n405\t    const seen: string[] = [];\n406\t    const engine = engineFor(dir, [{ token: 'MAIN_T', code: `currentTask.resolve({ v: 5 });` }], seen);\n407\t\n408\t    // Missing the required \"topic\" field — should throw a clear, actionable error.\n409\t    await expect(\n410\t      runTasklist({ name: 'flow', space, forkEngine: engine, seed: { other: 1 } }),\n411\t    ).rejects.toThrow(/topic/);\n412\t\n413\t    // Wrong type for \"topic\" — should also throw.\n414\t    await expect(\n415\t      runTasklist({ name: 'flow', space, forkEngine: engine, seed: { topic: 42 } }),\n416\t    ).rejects.toThrow(/topic/);\n417\t\n418\t    // A valid seed is accepted and the tasklist runs to completion.\n419\t    const result = await runTasklist({ name: 'flow', space, forkEngine: engine, seed: { topic: 'pasta' } });\n420\t    expect(result.data).toEqual({ v: 5 });\n421\t  });\n422\t});\n423\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"6060e6db-e6d5-43ff-8ad1-7681186bb68c","timestamp":"2026-07-16T06:15:12.099Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
