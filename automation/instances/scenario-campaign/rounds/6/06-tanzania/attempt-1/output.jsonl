{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_p8ZqLnwPA2MHACtI6k4J7iZe","type":"tool_result","content":"1\t/** A non-text attachment on a user message.\n2\t *\n3\t *  To support vision (images) and documents (PDFs, etc.), a user message can\n4\t *  carry attachments alongside its text `content`. Field names mirror the AI SDK\n5\t *  v5 user-message content parts: images/files carry a `mediaType` (IANA type,\n6\t *  e.g. `image/png`, `application/pdf`). Audio is transcribed to text upstream\n7\t *  (see the server upload handler), so it never appears as an attachment here.\n8\t *  The provider layer (`libs/cli/src/stream/stream.ts`) merges `content` +\n9\t *  `attachments` into the SDK's `ModelMessage` content.\n10\t */\n11\texport interface ImagePart {\n12\t  type: 'image';\n13\t  /** A URL, a `data:` URL, or a raw base64 string of the image bytes. */\n14\t  image: string;\n15\t  /** IANA media type, e.g. `image/png`. Optional — the provider can sniff it. */\n16\t  mediaType?: string;\n17\t}\n18\texport interface FilePart {\n19\t  type: 'file';\n20\t  /** A URL, a `data:` URL, or a raw base64 string of the file bytes. */\n21\t  data: string;\n22\t  /** IANA media type, e.g. `application/pdf`. Required by the SDK for files. */\n23\t  mediaType: string;\n24\t  /** Original filename, surfaced to the model when the provider supports it. */\n25\t  filename?: string;\n26\t}\n27\texport type MediaPart = ImagePart | FilePart;\n28\t\n29\texport interface StreamMessage {\n30\t  role: 'user' | 'assistant';\n31\t  content: string;\n32\t  /** Multimodal attachments (images/files) for this message. Only user messages\n33\t   *  carry these; the provider layer merges them with `content`. */\n34\t  attachments?: MediaPart[];\n35\t}\n36\t\n37\texport interface StreamOpts {\n38\t  system: string;\n39\t  messages: StreamMessage[];\n40\t  /** Optional model spec/alias override for this request. Forks set this from\n41\t   *  their role (see modelForRole); the provider layer resolves it, falling back\n42\t   *  to the session default when unset. */\n43\t  model?: string;\n44\t}\n45\t"}]},"parent_tool_use_id":"call_DTWyob8TJtBDOIwxjDDTvEGN","session_id":"c2f33b80-852a-433e-8510-ac2647f435a2","uuid":"cc5a9ada-e3ae-4665-9513-97708d472236","timestamp":"2026-07-15T19:34:15.133Z","subagent_type":"Explore","task_description":"Trace voice attachment routing"}
