65\t\n366\t        // Standing context: the parent agent's charter (fork-safe identity/guardrails) and the\n367\t        // overall tasklist goal, so an isolated task knows who it works for and what pipeline it\n368\t        // serves. Kept short and placed before the task instruction. (instruct.md is deliberately\n369\t        // NOT injected — it carries ask/delegate/UI prose a fork cannot honor.)\n370\t        const charterSection = this.opts.parentAgentCharter?.trim()\n371\t          ? `# Agent\\n${this.opts.parentAgentCharter.trim()}\\n`\n372\t          : '';\n373\t        const tasklistSection = task.tasklistDescription?.trim()\n374\t          ? `# Tasklist (overall goal — your task is one step in it)\\n${task.tasklistDescription.trim()}\\n`\n375\t          : '';\n376\t\n377\t        // Generic filesystem/shell exists ONLY in the engineer's `fs:scratch` sandbox. A fork\n378\t        // inherits it only when the parent agent has it (an engineer general fork). Every other\n379\t        // fork has no fs/shell at all — advertise only what the VM actually carries, so a fork is\n380\t        // never told about execShell and then errors on it. A fork needing to run code returns the\n381\t        // code to its delegator; persistence goes through the delegator's typed writers.\n382\t        const scratchFs = capabilities.scratchFs;\n383\t        const ioLine = scratchFs\n384\t          ? '- createScratch() → string: create your throwaway scratch dir FIRST, then readFile(path)/writeFile(path, content)/editFile(...) operate inside it (jailed to scratch).'\n385\t          : '- There is NO filesystem here — you cannot read or write files. Work from your seed/inputs; if a task needs files persisted, return the content to your delegator (only the engineer persists code, via the delegator\\'s typed writers).';\n386\t        const shellLine = scratchFs\n387\t          ? '- execShell(cmd) → { ok, stdout, stderr }: run a command INSIDE your scratch dir (e.g. `execShell(\"npx 