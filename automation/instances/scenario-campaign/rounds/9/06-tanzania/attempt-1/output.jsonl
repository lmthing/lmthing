{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_FwyXTlwb620dNKkNkZv6RdzL","type":"tool_result","content":"185\t    // synthesize clusters/dedupes but is no longer the goal — summarize writes the final report.\n186\t    expect(deep['synthesize']!.goal).toBeFalsy();\n187\t    expect(resolveGoalTask(deep)!.id).toBe('summarize');\n188\t    // research: a single shallow quick-answer task.\n189\t    const shallow = await loadTasklistFromSpace(space, 'research');\n190\t    expect(Object.keys(shallow)).toEqual(['answer']);\n191\t    expect(resolveGoalTask(shallow)!.id).toBe('answer');\n192\t  });\n193\t});\n194\t\n195\tdescribe('user-thing build_specialist (structural build pipeline)', () => {\n196\t  async function load(): Promise<{ space: Space; tasks: Record<string, TaskNode> }> {\n197\t    const space = await loadSpace(resolve(SYS, 'user-thing'), { requireAgents: false });\n198\t    const tasks = await loadTasklistFromSpace(space, 'build_specialist');\n199\t    return { space, tasks };\n200\t  }\n201\t\n202\t  it('is a valid 2-task DAG (optional research → build goal) with the declared input schema', async () => {\n203\t    const { space, tasks } = await load();\n204\t    expect(() => validateDag(tasks)).not.toThrow();\n205\t    expect(Object.keys(tasks).sort()).toEqual(['build', 'research']);\n206\t    expect(space.tasklists['build_specialist']!.input).toEqual({ request: 'string' });\n207\t\n208\t    const research = tasks['research']!;\n209\t    expect(research.optional).toBe(true);\n210\t    expect(research.role).toBe('explore');\n211\t    expect(research.functions).toEqual([]);\n212\t    expect(research.output).toEqual({ report: 'object' });\n213\t    expect(research.canDelegateTo).toEqual(['system-research/researcher#deep_research']);\n214\t\n215\t    const build = tasks['build']!;\n216\t    expect(build.goal).toBe(true);\n217\t    expect(resolveGoalTask(tasks)!.id).toBe('build');\n218\t    expect(build.dependsOn).toEqual(['research']);\n219