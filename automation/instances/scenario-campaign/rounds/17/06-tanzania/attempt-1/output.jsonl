{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_TZ7Gbf45OE1PLQv6PM5EZ2oS","type":"tool_result","content":"90\t}\n91\t\n92\t/**\n93\t * Split trusted prelude source into top-level statements with a single TS\n94\t * parse. The streaming BoundaryDetector heuristics are unnecessary here — the\n95\t * source is a static string, so `ts.createSourceFile` + top-level statements\n96\t * is exact. Exported for direct testing.\n97\t */\n98\texport function splitPreludeStatements(source: string): string[] {\n99\t  const sf = ts.createSourceFile('_prelude.tsx', source, ts.ScriptTarget.ES2022, true, ts.ScriptKind.TSX);\n100\t  return sf.statements\n101\t    .map((s) => source.slice(s.getStart(sf), s.end).trim())\n102\t    .filter(Boolean);\n103\t}\n104\t\n105\t/** Bound so a pathological space function that yields forever cannot wedge the host. */\n106\tconst MAX_NESTED_YIELD_ROUNDS = 32;\n107\t\n108\texport async function runPrelude(opts: RunPreludeOpts): Promise<PreludeResult> {\n109\t  const { vm, renderHost, processYield } = opts;\n110\t  const tracer = opts.tracer ?? NULL_TRACER;\n111\t  const scope = opts.scope;\n112\t  const ctx = `${scope?.label ?? 'fork'}:prelude`;\n113\t  const nodeId = scope?.nodeId;\n114\t  let yieldCounter = 0;\n115\t\n116\t  const statements = splitPreludeStatements(opts.source);\n117\t\n118\t  let context = '';\n119\t  const vars: Record<string, unknown> = {};\n120\t  const failedNames: string[] = [];\n121\t  const failures: PreludeFailure[] = [];\n122\t\n123\t  // Ambient decls for failed statements' names, so LATER prelude statements\n124\t  // (and eventually the model, via the caller) referencing them still typecheck\n125\t  // — same mechanism as the turn loop's yieldErrorNames.\n126\t  const fullAmbient = (): string =>\n127\t    failedNames.length > 0\n128\t      ? opts.ambientDts + '\\n' + failedNames.map((n) => `declare const ${n}: any;`).join('\\n')\n129\t      : opts.ambientDts;\n130\t\n131\t  const fail = (index: number, statement: string, names: string[], error: string): void => {\n132\t    failures.push({ index, statement, names, error });\n133\t    for (const name of names) {\n134\t      if (!failedNames.includes(name)) failedNames.push(name);\n135\t      // Seed undefined in the VM so a later statement that references the name\n136\t      // cannot ReferenceError (it evaluates against a defined-but-undefined global).\n137\t      vm.setVar(name, undefined);\n138\t      vars[name] = undefined;\n139\t    }\n140\t    renderHost.log(`[prelude] statement ${index + 1} failed: ${error}`);\n141\t  };\n142\t\n143\t  for (let i = 0; i < statements.length; i++) {\n144\t    const stmt = statements[i]!;\n145\t    tracer.write({ ts: Date.now(), type: 'statement', context: ctx, ...(nodeId ? { nodeId } : {}), code: stmt });\n146\t    renderHost.log(`[prelude stmt] ${stmt}`);\n147\t\n148\t    // 1. Typecheck against the fork's ambient DTS + accumulated prelude context.\n149\t    const tscResult = runTsc({ ambientDts: fullAmbient(), sessionContext: context, statement: stmt });\n150\t    if (!tscResult.ok) {\n151\t      const errMsg = tscResult.diagnostics.map((d) => d.message).join('; ');\n152\t      tracer.write({ ts: Date.now(), type: 'typecheck_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: errMsg, attempt: 1 });\n153\t      fail(i, stmt, extractBindingNames(stmt), errMsg);\n154\t      continue;\n155\t    }\n156\t\n157\t    // 2. Transpile + globalThis propagation per bound name (each evalStatement\n158\t    //    is an isolated module — identical to the turn loop's pipeline).\n159\t    const boundNames = extractBindingNames(stmt);\n160\t    let jsCode = transpileStatement(stmt);\n161\t    if (boundNames.length > 0) {\n162\t      const assigns = boundNames.map((n) => `try { globalThis['${n}'] = ${n}; } catch {}`).join('\\n');\n163\t      jsCode += '\\n' + assigns;\n164\t    }\n165\t\n166\t    // 3. Eval.\n167\t    const evalResult = vm.evalStatement(jsCode);\n168\t    if (!evalResult.ok) {\n169\t      tracer.write({ ts: Date.now(), type: 'eval_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: evalResult.error });\n170\t      fail(i, stmt, boundNames, evalResult.error);\n171\t      continue;\n172\t    }\n173\t\n174\t    // 4. Resolve yields through the fork's OWN router. A resolved yield can\n175\t    //    surface FURTHER pending yields once jobs are driven (a space function\n176\t    //    awaiting fetch() more than once), so drain in rounds. The FIRST round's\n177\t    //    count/values carry the combinator semantics for bindYieldResults; the\n178\t    //    getVar preference inside it recovers the real outer value for nested\n179\t    //    yields (webSearch internally awaiting fetch — the load-bearing fix).\n180\t    if (vm.pendingYields.length > 0) {\n181\t      const pattern = extractBindingPattern(stmt);\n182\t      let firstRoundCount = 0;\n183\t      let firstRoundValues: unknown[] = [];\n184\t      let yieldError: string | null = null;\n185\t\n186\t      for (let round = 0; round < MAX_NESTED_YIELD_ROUNDS && vm.pendingYields.length > 0; round++) {\n187\t        const yields = vm.pendingYields.splice(0);\n188\t        // Budget: prelude yields are real tool calls — tick the fork's counter.\n189\t        // Throws BudgetExceededError (propagates: hard caps are honored).\n190\t        opts.budget?.tickToolCalls(yields.length);\n191\t\n192\t        const resolvedValues: unknown[] = new Array(yields.length);\n193\t        const roundErrors: string[] = [];\n194\t        await Promise.all(yields.map(async (yieldReq, j) => {\n195\t          const yieldId = `${nodeId ?? ctx}_p${++yieldCounter}`;\n196\t          tracer.write({ ts: Date.now(), type: 'yield', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, args: yieldReq.args, yieldId });\n197\t          try {\n198\t            const resolved = await processYield(yieldReq);\n199\t            tracer.write({ ts: Date.now(), type: 'yield_resolved', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, value: resolved, yieldId });\n200\t            yieldReq.deferred.resolve(resolved);\n201\t            resolvedValues[j] = resolved;\n202\t          } catch (err) {\n203\t            // Hard budget breaches (fork-depth, tool-call cap inside a nested\n204\t            // yield) propagate — everything else degrades this statement only.\n205\t            if (err instanceof BudgetExceededError) throw err;\n206\t            yieldReq.deferred.reject(err);\n207\t            resolvedValues[j] = undefined;\n208\t            roundErrors.push(`${yieldReq.kind}() failed: ${err instanceof Error ? err.message : String(err)}`);\n209\t          }\n210\t        }));\n211\t        vm.drivePendingJobs();\n212\t\n213\t        if (round === 0) {\n214\t          firstRoundCount = yields.length;\n215\t          firstRoundValues = resolvedValues;\n216\t        }\n217\t        if (roundErrors.length > 0) {\n218\t          yieldError = roundErrors.join('; ');\n219\t          break;\n220\t        }\n221\t      }\n222\t\n223\t      if (yieldError) {\n224\t        fail(i, stmt, pattern.names, yieldError);\n225\t        continue;\n226\t      }\n227\t\n228\t      // Bind results with the EXPORTED turn-loop helper — do NOT reimplement:\n229\t      // the getVar preference is load-bearing for nested yields.\n230\t      const bound = bindYieldResults(vm, pattern, firstRoundCount, firstRoundValues);\n231\t      for (const [name, value] of Object.entries(bound)) {\n232\t        vm.setVar(name, value);\n233\t        vars[name] = value;\n234\t      }\n235\t    } else if (boundNames.length > 0) {\n236\t      // Plain (non-yielding) binding: surface the VM's computed values so the\n237\t      // model SEES them, not just the names.\n238\t      for (const name of boundNames) {\n239\t        vars[name] = vm.getVar(name);\n240\t      }\n241\t    }\n242\t\n243\t    // 5. Commit to the accumulated typecheck context (successful statements only).\n244\t    context += (context ? '\\n' : '') + stmt;\n245\t  }\n246\t\n247\t  // Variables snapshot for the observability tree (same event shape as the turn loop).\n248\t  if (Object.keys(vars).length > 0) {\n249\t    const serialized: Record<string, unknown> = {};\n250\t    for (const [k, v] of Object.entries(vars)) serialized[k] = serialize(v);\n251\t    tracer.write({ ts: Date.now(), type: 'variables', context: ctx, ...(nodeId ? { nodeId } : {}), vars: serialized });\n252\t  }\n253\t\n254\t  // First VARIABLES block for the model. emitVariables(vars, context) also\n255\t  // lists SCOPE + ALREADY EXECUTED so the model knows not to re-run the prelude.\n256\t  let variablesBlock = '';\n257\t  if (statements.length > 0) {\n258\t    variablesBlock =\n259\t      'A host-executed PRELUDE already ran the setup statements for this task. ' +\n260\t      'Their results are bound in scope — read them below; do NOT re-run these statements.\\n\\n' +\n261\t      emitVariables(vars, context || undefined);\n262\t    if (failures.length > 0) {\n263\t      variablesBlock += '\\n\\n' + failures\n264\t        .map((f) => {\n265\t          const firstLine = f.error.split('\\n')[0]!;\n266\t          const namesNote = f.names.length > 0 ? ` (${f.names.join(', ')} bound undefined)` : '';\n267\t          return `// prelude: statement ${f.index + 1} failed: ${firstLine}${namesNote}`;\n268\t        })\n269\t        .join('\\n');\n270\t    }\n271\t  }\n272\t\n273\t  return { context, vars, failedNames, failures, variablesBlock };\n274\t}\n275\t"}]},"parent_tool_use_id":"call_FFJKMOVjsfKJlWJZsycaWrdj","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"5390febc-dd32-4c4e-8ed9-c3c453ddd9bc","timestamp":"2026-07-16T06:23:28.189Z","subagent_type":"general-purpose","task_description":"Review live-build tasklist"}
