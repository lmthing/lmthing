{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_3Yz2ScYL7eyaIeji7qdcKre3","type":"tool_result","content":"1\t/**\n2\t * API **endpoint discovery** (Phase 3, 3A).\n3\t *\n4\t * Walks `<projectRoot>/api/`. Each `GET.ts`/`POST.ts`/`PUT.ts`/`PATCH.ts`/\n5\t * `DELETE.ts` under a route directory is an endpoint: **the endpoint route is the\n6\t * directory, the HTTP method is the filename**. The route pattern derives from\n7\t * the dir path with `[id]` segments → `:id` params:\n8\t *\n9\t *   api/feed-list/GET.ts        → GET    /feed-list           (name \"feedList\")\n10\t *   api/mark-read/POST.ts       → POST   /mark-read           (name \"markRead\")\n11\t *   api/items/[id]/GET.ts       → GET    /items/:id           (name \"getItem\")\n12\t *   api/items/[id]/PATCH.ts     → PATCH  /items/:id           (name \"updateItem\")\n13\t *\n14\t * Non-method `.ts` files in a route dir (helpers, `types.ts`) are **ignored**.\n15\t * Each endpoint's `name` (from `export const name`) is the stable agent-facing\n16\t * id; it is **unique per project** — a duplicate is a **fail-loud** throw.\n17\t *\n18\t * `name`/`description` are read by a light **static parse** (not by evaluating\n19\t * the module) — deliberately: evaluating handler code in the main process would\n20\t * breach the crash-boundary invariant, so discovery never runs handler code.\n21\t */\n22\t\n23\timport { readdir, readFile } from 'node:fs/promises';\n24\timport type { Dirent } from 'node:fs';\n25\timport { join } from 'node:path';\n26\t\n27\timport type { HttpMethod } from './input.js';\n28\t\n29\t/** The five HTTP methods the file-based router maps from a filename. */\n30\texport const HTTP_METHODS: readonly HttpMethod[] = ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'];\n31\t\n32\tconst METHOD_FILE_RE = /^(GET|POST|PUT|PATCH|DELETE)\\.ts$/;\n33\t\n34\t/** A single discovered endpoint. */\n35\texport interface Endpoint {\n36\t  /** The HTTP method (from the filename). */\n37\t  method: HttpMethod;\n38\t  /** The route pattern, `[id]` → `:id` (e.g. `/items/:id`; the api root is `/`). */\n39\t  pattern: string;\n40\t  /** Ordered dynamic-param names in the pattern (e.g. `['id']`). */\n41\t  paramNames: string[];\n42\t  /** Absolute path to the handler `.ts` file. */\n43\t  file: string;\n44\t  /** The stable agent-facing id (`export const name`) — unique per project. */\n45\t  name: string;\n46\t  /** Optional description (`export const description`). */\n47\t  description?: string;\n48\t}\n49\t\n50\t/** The route table: endpoints indexed by `(method, pattern)` and by `name`. */\n51\texport interface RouteTable {\n52\t  endpoints: Endpoint[];\n53\t  /** Keyed `\"<METHOD> <pattern>\"` (e.g. `\"GET /items/:id\"`). */\n54\t  byMethodPattern: Map<string, Endpoint>;\n55\t  /** Keyed by the endpoint `name`. */\n56\t  byName: Map<string, Endpoint>;\n57\t}\n58\t\n59\t/** The key for {@link RouteTable.byMethodPattern}. */\n60\texport function routeKey(method: string, pattern: string): string {\n61\t  return `${method} ${pattern}`;\n62\t}\n63\t\n64\t/**\n65\t * Discover every endpoint under `<projectRoot>/api/`. Returns an empty table when\n66\t * there is no `api/` dir (a spaces-only or api-less project). Throws fail-loud on\n67\t * a duplicate `name` or a method file missing `export const name`.\n68\t */\n69\texport async function loadApiRoutes(projectRoot: string): Promise<RouteTable> {\n70\t  const apiDir = join(projectRoot, 'api');\n71\t  const endpoints: Endpoint[] = [];\n72\t  await walk(apiDir, [], endpoints);\n73\t\n74\t  // Deterministic order — stable diagnostics + first-defined wins nothing (dups throw).\n75\t  endpoints.sort((a, b) => routeKey(a.method, a.pattern).localeCompare(routeKey(b.method, b.pattern)));\n76\t\n77\t  const byMethodPattern = new Map<string, Endpoint>();\n78\t  const byName = new Map<string, Endpoint>();\n79\t  for (const ep of endpoints) {\n80\t    const key = routeKey(ep.method, ep.pattern);\n81\t    if (byMethodPattern.has(key)) {\n82\t      throw new Error(`[api-loader] duplicate route \"${key}\" (${ep.file})`);\n83\t    }\n84\t    byMethodPattern.set(key, ep);\n85\t    const existing = byName.get(ep.name);\n86\t    if (existing) {\n87\t      throw new Error(\n88\t        `[api-loader] duplicate endpoint name \"${ep.name}\" — ${existing.file} and ${ep.file}`,\n89\t      );\n90\t    }\n91\t    byName.set(ep.name, ep);\n92\t  }\n93\t\n94\t  return { endpoints, byMethodPattern, byName };\n95\t}\n96\t\n97\t/** Recursively collect method files, tracking the route segments so far. */\n98\tasync function walk(dir: string, segments: string[], out: Endpoint[]): Promise<void> {\n99\t  let entries: Dirent[];\n100\t  try {\n101\t    entries = await readdir(dir, { withFileTypes: true });\n102\t  } catch (err) {\n103\t    if ((err as NodeJS.ErrnoException).code === 'ENOENT') return; // no api/ dir\n104\t    throw err;\n105\t  }\n106\t\n107\t  for (const entry of entries) {\n108\t    const abs = join(dir, entry.name);\n109\t    if (entry.isDirectory()) {\n110\t      await walk(abs, [...segments, entry.name], out);\n111\t      continue;\n112\t    }\n113\t    if (!entry.isFile()) continue;\n114\t    const m = METHOD_FILE_RE.exec(entry.name);\n115\t    if (!m) continue; // ignore non-method .ts (helpers/types) and other files\n116\t    const method = m[1] as HttpMethod;\n117\t    const { pattern, paramNames } = patternFromSegments(segments);\n118\t    const source = await readFile(abs, 'utf8');\n119\t    const contractErr = apiEndpointContractError(source);\n120\t    if (contractErr) {\n121\t      throw new Error(`[api-loader] ${abs}: ${contractErr}`);\n122\t    }\n123\t    const name = parseExportedString(source, 'name')!;\n124\t    const description = parseExportedString(source, 'description');\n125\t    out.push({ method, pattern, paramNames, file: abs, name, description });\n126\t  }\n127\t}\n128\t\n129\t/** Build a `/`-rooted route pattern (`[id]` → `:id`) + its param names. */\n130\tfunction patternFromSegments(segments: string[]): { pattern: string; paramNames: string[] } {\n131\t  const paramNames: string[] = [];\n132\t  const parts = segments.map((seg) => {\n133\t    const dyn = /^\\[(.+)\\]$/.exec(seg);\n134\t    if (dyn) {\n135\t      paramNames.push(dyn[1]);\n136\t      return `:${dyn[1]}`;\n137\t    }\n138\t    return seg;\n139\t  });\n140\t  return { pattern: '/' + parts.join('/'), paramNames };\n141\t}\n142\t\n143\t/**\n144\t * Static-parse `export const <key> = '<value>'` (single/double/backtick quotes)\n145\t * from handler source, without evaluating it. Returns `undefined` if absent.\n146\t * Exported so the write-time lint can run the SAME name/uniqueness contract this loader enforces.\n147\t */\n148\texport function parseExportedString(source: string, key: string): string | undefined {\n149\t  const re = new RegExp(`export\\\\s+const\\\\s+${key}\\\\s*=\\\\s*(['\"\\`])((?:\\\\\\\\.|(?!\\\\1).)*)\\\\1`);\n150\t  const m = re.exec(source);\n151\t  return m ? m[2] : undefined;\n152\t}\n153\t\n154\t/**\n155\t * The API-endpoint MODULE contract, as ONE reusable check shared by the loader `walk` (which wraps\n156\t * the message with the file path) and the write-time lint. Static — never evaluates the module.\n157\t * Returns a human message describing the first violation, or null when the source satisfies it.\n158\t */\n159\texport function apiEndpointContractError(source: string): string | null {\n160\t  if (!parseExportedString(source, 'name')) {\n161\t    return 'missing `export const name` (every endpoint must be named)';\n162\t  }\n163\t  return null;\n164\t}\n165\t\n166\t/**\n167\t * Match a concrete request `path` against a method's routes. Returns the matched\n168\t * endpoint + extracted path params (`Record<string, string>`), or `null`.\n169\t */\n170\texport function matchRoute(\n171\t  table: RouteTable,\n172\t  method: string,\n173\t  path: string,\n174\t): { endpoint: Endpoint; params: Record<string, string> } | null {\n175\t  const req