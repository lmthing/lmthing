{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_8h3nRPVNF4nyXJvhDc896drQ","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * run-yaml.mjs — the GENERIC scenario runner.\n4\t *\n5\t * Plays a declarative `scenario.yaml` (persona · promise · invariants · steps) against a LOCAL\n6\t * `lmthing serve`, driving the pod through the harness exactly as the /chat SPA would, and writes\n7\t * per-step EVIDENCE (the execution trace + the real spaces/DB/app state after each step) for the\n8\t * JUDGE to read. It does NOT judge — the judge (see automation/instances/scenario-campaign/judge.md)\n9\t * reads this output, decides pass/fail per step, and fixes at the right rung.\n10\t *\n11\t * Local only: SCENARIO_TARGET defaults to 'local' here (getUser → http://localhost:8080, no auth).\n12\t *\n13\t *   node scenarios/run-yaml.mjs 06-tanzania                 # play the whole scenario, fresh project\n14\t *   node scenarios/run-yaml.mjs 06-tanzania --through 5     # play steps 1..5 (the judge's verify rerun)\n15\t *   node scenarios/run-yaml.mjs 06-tanzania --out <dir>     # where to write evidence (default <sc>/.run)\n16\t *\n17\t * Step verbs (see scenario-spec.md): attach[] · say · then_say · open_app · in_app_chat ·\n18\t * fresh_session · restart_pod · if_asked{} · expect[] (expect is passed through, never executed).\n19\t */\n20\timport { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync, rmSync } from 'node:fs';\n21\timport { join, resolve, dirname, basename } from 'node:path';\n22\timport { fileURLToPath } from 'node:url';\n23\timport { parseYaml } from './lib/yaml.mjs';\n24\timport { getUser } from './harness/provision.mjs';\n25\timport { Pod } from './harness/lib/pod.mjs';\n26\timport { ThingSession, approveAllConsent, denyAllConsent } from './harness/lib/thing.mjs';\n27\timport { restartLocalServer, freshLocalServer, serverUp, podRoot } from './harness/lib/local.mjs';\n28\t\n29\tprocess.env.SCENARIO_TARGET ??= 'local'; // this runner is local-only by design\n30\t\n31\tconst HERE = dirname(fileURLToPath(import.meta.url));\n32\tconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n33\t\n34\t// ── args ─────────────────────────────────────────────────────────────────────\n35\tconst argv = process.argv.slice(2);\n36\tconst flag = (name, def) => {\n37\t  const i = argv.indexOf(name);\n38\t  return i >= 0 && argv[i + 1] ? argv[i + 1] : def;\n39\t};\n40\tconst idOrPath = argv.find((a) => !a.startsWith('--')) ?? '06-tanzania';\n41\tconst verbose = argv.includes('--verbose');\n42\tconst keepProject = argv.includes('--keep-project');\n43\tconst planOnly = argv.includes('--plan'); // parse + print the plan, never connect to a pod\n44\tconst freshServer = argv.includes('--fresh-server'); // WIPE the pod data dir (0 projects) + start clean first\n45\t\n46\t// Resolve scenario dir + yaml.\n47\tconst scenarioDir = idOrPath.endsWith('.yaml')\n48\t  ? dirname(resolve(idOrPath))\n49\t  : resolve(HERE, idOrPath);\n50\tconst yamlPath = idOrPath.endsWith('.yaml') ? resolve(idOrPath) : join(scenarioDir, 'scenario.yaml');\n51\tif (!existsSync(yamlPath)) fail(`no scenario.yaml at ${yamlPath}`);\n52\tconst fixturesDir = join(scenarioDir, 'fixtures');\n53\t\n54\tconst scenario = parseYaml(readFileSync(yamlPath, 'utf8'));\n55\tconst steps = scenario.steps ?? [];\n56\tconst through = Number(flag('--through', String(steps.length)));\n57\tconst outDir = resolve(flag('--out', join(scenarioDir, '.run')));\n58\t// A fresh server means an empty runtime root, so the stable scenario project id is collision-free\n59\t// and keeps evidence readable. Without --fresh-server (dev re-runs on a dirty root) a unique suffix\n60\t// avoids clobbering an existing project.\n61\tconst projectId = flag('--project', freshServer ? (scenario.project ?? scenario.id) : `${scenario.project ?? scenario.id}-${Date.now().toString(36)}`);\n62\t\n63\tmkdirSync(outDir, { recursive: true });\n64\tconst traceMd = [];\n65\tfunction log(...a) {\n66\t  if (verbose) console.log('[run-yaml]', ...a);\n67\t}\n68\tfunction fail(msg) {\n69\t  console.error(`run-yaml: ${msg}`);\n70\t  process.exit(1);\n71\t}\n72\tfunction readdirSyncSafe(dir) {\n73\t  try {\n74\t    return readdirSync(dir);\n75\t  } catch {\n76\t    return [];\n77\t  }\n78\t}\n79\t\n80\t// ── ask handling: the driver answers in-persona; the JUDGE later scores the ask ────────────────\n81\t// A step's `if_asked` map + the scenario `knows` list ground the load-bearing answers. Consent is\n82\t// approved by default (a step may set `deny_consent: true`). Every ask + how it was answered is\n83\t// recorded so the judge can score whether asking was correct (and whether the answer was right).\n84\tlet currentStep = {};\n85\tconst asksThisStep = [];\n86\tfunction onAsk(descriptor) {\n87\t  const text = JSON.stringify(descriptor ?? {});\n88\t  // Consent cards: approve unless the step opts into denial.\n89\t  if (descriptor?.type === 'ConsentCard') {\n90\t    const answer = currentStep.deny_consent ? false : true;\n91\t    asksThisStep.push({ kind: 'consent', answer, descriptor });\n92\t    return answer;\n93\t  }\n94\t  // Clarifying question / form: match the step's if_asked, else best-effort from its single entry.\n95\t  const ifAsked = currentStep.if_asked ?? {};\n96\t  const keys = Object.keys(ifAsked);\n97\t  let matched =\n98\t    keys.find((k) => text.toLowerCase().includes(k.toLowerCase().slice(0, 24))) ??\n99\t    (keys.length === 1 ? keys[0] : undefined);\n100\t  const answer = matched ? ifAsked[matched] : '';\n101\t  asksThisStep.push({ kind: 'question', matched: matched ?? null, answer, descriptor });\n102\t  // Return the string answer; unmatched → '' (recorded prominently so the judge sees an unhandled ask).\n103\t  return answer;\n104\t}\n105\t\n106\t// ── state capture: what the judge verifies token-in-state against ──────────────────────────────\n107\tasync function snapshot(pod) {\n108\t  const snap = { spaces: [], appTables: {}, appManifest: null, error: null };\n109\t  try {\n110\t    const sp = await pod.listSpaces(projectId).catch(() => null);\n111\t    snap.spaces = (sp?.spaces ?? sp ?? []).map((s) => s.slug ?? s.name ?? s.id ?? s);\n112\t  } catch (e) {\n113\t    snap.error = String(e?.message ?? e);\n114\t  }\n115\t  try {\n116\t    const man = await pod.appManifest(projectId).catch(() => null);\n117\t    if (man) {\n118\t      snap.appManifest = { tables: man.tables ?? man.database ?? [], pages: man.pages ?? [], built: man.build?.built ?? null };\n119\t      const tableNames = (snap.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean);\n120\t      for (const t of tableNames) {\n121\t        const rows = await pod.appData(projectId, t).catch(() => null);\n122\t        if (rows) snap.appTables[t] = rows.rows ?? rows.data ?? rows;\n123\t      }\n124\t    }\n125\t  } catch (e) {\n126\t    snap.appError = String(e?.message ?? e);\n127\t  }\n128\t  return snap;\n129\t}\n130\t\n131\t// ── dry plan: parse + print the step plan, never touch a pod ───────────────────────────────────\n132\tif (planOnly) {\n133\t  console.log(`scenario ${scenario.id} — \"${scenario.title}\"  (project ${scenario.project})`);\n134\t  console.log(`persona: ${String(scenario.persona).slice(0, 90)}…`);\n135\t  console.log(`invariants: ${scenario.invariants?.length}  ·  knows: ${scenario.knows?.length}  ·  steps: ${steps.length}\\n`);\n136\t  const allFixtures = new Set();\n137\t  steps.forEach((s, i) => {\n138\t    const verbs = Object.keys(s).filter((k) => k !== 'expect');\n139\t    (s.attach ?? []).forEach((f) => allFixtures.add(f));\n140\t    const msg = (s.say ?? s.then_say ?? s.in_app_chat ?? '').toString().replace(/\\n/g, ' ').slice(0, 64);\n141\t    console.log(`  ${String(i + 1).padStart(2)}. [${verbs.join(', ')}]  ${msg}${msg.length >= 64 ? '…' : ''}`);\n142\t    if (s.attach) console.log(`       attach: ${s.attach.join(', ')}`);\n143\t    console.log(`       expect: ${s.expect?.length ?? 0}${s.if_asked ? '  if_asked: ' + Object.keys(s.if_asked).length : ''}`);\n144\t  });\n145\t  // Fixture coverage: does every file in fixtures/ get used, and does every attach exist?\n146\t  const used = [...allFixtures];\n147\t  console.log(`\\nfixtures attached across the scenario (${used.length}): ${used.join(', ')}`);\n148\t  const missing = used.filter((f) => !existsSync(join(fixturesDir, f)));\n149\t  if (missing.length) console.log(`⚠️  attached but NOT on disk: ${missing.join(', ')}`);\n150\t  try {\n151\t    const onDisk = readdirSyncSafe(fixturesDir).filter((f) => !/^(links\\.md|.*\\.txt)$/.test(f));\n152\t    const unused = onDisk.filter((f) => !allFixtures.has(f));\n153\t    if (unused.length) console.log(`⚠️  on disk but NEVER attached: ${unused.join(', ')}`);\n154\t    else console.log(`✅ every uploadable fixture on disk is attached by some step`);\n155\t  } catch { /* fixtures dir may be absent */ }\n156\t  process.exit(0);\n157\t}\n158\t\n159\t// ── main ─────────────────────────────────────────────────────────────────────────────────────\n160\t(async () => {\n161\t  log(`scenario ${scenario.id} · project ${projectId} · steps 1..${through}/${steps.length}`);\n162\t  // The RUNNER owns its own PID file (never rely on the caller's shell `$!`): a stopper does\n163\t  // `kill $(cat <out>/runner.pid)` and it is always correct. Cleared on clean exit.\n164\t  const pidFile = join(outDir, 'runner.pid');\n165\t  writeFileSync(pidFile, String(process.pid));\n166\t  process.on('exit', () => { try { rmSync(pidFile, { force: true }); } catch { /* ignore */ } });\n167\t  // Clean stale evidence from a REUSED --out dir (a stopped-then-rerun round), so a poller can't\n168\t  // read a prior run's step files / crash log as if they were this run's.\n169\t  for (const f of readdirSyncSafe(outDir)) {\n170\t    if (/^step-\\d+(\\.full)?\\.json$/.test(f) || f === 'summary.json' || f === 'trace.md') {\n171\t      try { rmSync(join(outDir, f), { force: true }); } catch { /* ignore */ }\n172\t    }\n173\t  }\n174\t  console.log(`[run-yaml] pid ${process.pid} → ${pidFile}`);\n175\t  if (freshServer) {\n176\t    console.log('[run-yaml] --fresh-server: wiping the pod runtime root (0 projects) and starting clean…');\n177\t    await freshLocalServer();\n178\t    console.log(`[run-yaml] fresh pod root: ${podRoot()}`);\n179\t  }\n180\t  if (!(await serverUp())) fail('local server not up — run: node harness/local-server.mjs up (or pass --fresh-server)');\n181\t\n182\t  const user = await getUser(scenario.id);\n183\t  const pod = new Pod({ base: user.pod, token: user.token });\n184\t  // Correctness check: a --fresh-server pod MUST start with no USER-created projects. A clean pod\n185\t  // always has the built-in `system` and `user` projects — those are infrastructure, not state leak.\n186\t  if (freshServer) {\n187\t    const all = (await pod.listProjects().catch(() => null))?.projects ?? [];\n188\t    const builtin = new Set(['system', 'user']);\n189\t    const leaked = all.map((p) => p.id ?? p).filter((id) => !builtin.has(id));\n190\t    console.log(\n191\t      leaked.length === 0\n192\t        ? `[run-yaml] confirmed: fresh pod has no user projects (built-ins only: ${all.map((p) => p.id ?? p).join(', ')})`\n193\t        : `[run-yaml] WARNING: fresh pod already has leaked project(s): ${leaked.join(', ')} — expected none`,\n194\t    );\n195\t  }\n196\t  // Fresh project (unique id per run unless --project pins one).\n197\t  try {\n198\t    await pod.createProject(projectId);\n199\t  } catch (e) {\n200\t    log(`createProject(${projectId}) — ${String(e?.message ?? e)} (continuing; may already exist)`);\n201\t  }\n202\t\n203\t  let thing = new ThingSession(pod, { projectId, onAsk, verbose });\n204\t  await thing.start();\n205\t\n206\t  const results = [];\n207\t  for (let n = 0; n < Math.min(through, steps.length); n++) {\n208\t    const step = steps[n];\n209\t    currentStep = step;\n210\t    asksThisStep.length = 0;\n211\t    const num = n + 1;\n212\t    const rec = { step: num, verbs: Object.keys(step).filter((k) => k !== 'expect'), expect: step.expect ?? [], turns: [], asks: [], notes: [] };\n213\t    log(`── step ${num}: ${rec.verbs.join(', ')}`);\n214\t\n215\t    try {\n216\t      if (step.fresh_session) {\n217\t        thing = new ThingSession(pod, { projectId, onAsk, verbose });\n218\t        await thing.start();\n219\t        await thing.syncToTail();\n220\t        rec.notes.push('started a fresh session (zero history)');\n221\t      }\n222\t      if (step.restart_pod) {\n223\t        rec.notes.push('restarting local server…');\n224\t        await restartLocalServer();\n225\t        for (let i = 0; i < 40 && !(await serverUp()); i++) await sleep(500);\n226\t        rec.notes.push((await serverUp()) ? 'server back up' : 'server did NOT come back up');\n227\t      }\n228\t\n229\t      // The message(s) for this step, with attachments if any.\n230\t      if (step.say != null) {\n231\t        let turn;\n232\t        if (Array.isArray(step.attach) && step.attach.length) {\n233\t          const refs = [];\n234\t          for (const f of step.attach) {\n235\t            const p = join(fixturesDir, f);\n236\t            if (!existsSync(p)) {\n237\t              rec.notes.push(`MISSING FIXTURE: ${f}`);\n238\t              continue;\n239\t            }\n240\t            refs.push(await pod.upload(p));\n241\t          }\n242\t          rec.attached = step.attach;\n243\t          turn = await thing.sendWithAttachments(step.say, refs);\n244\t        } else {\n245\t          turn = await thing.send(step.say);\n246\t        }\n247\t        rec.turns.push(summarizeTurn(turn, step.say));\n248\t      }\n249\t      if (step.then_say != null) {\n250\t        const t = await thing.send(step.then_say);\n251\t        rec.turns.push(summarizeTurn(t, step.then_say));\n252\t      }\n253\t      if (step.in_app_chat != null) {\n254\t        // The in-app chat is a project-scoped THING session with authoring caps — same project.\n255\t        const t = await thing.send(step.in_app_chat);\n256\t        rec.turns.push(summarizeTurn(t, `[in-app] ${step.in_app_chat}`));\n257\t      }\n258\t      if (step.open_app) {\n259\t        const build = await pod.appBuild(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n260\t        rec.appBuild = { built: build?.built ?? build?.build?.built ?? null, routes: build?.routes ?? null, error: build?.error ?? null };\n261\t        const page = await pod.appPage(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n262\t        rec.appPageStatus = page?.status ?? (page?.error ? `error: ${page.error}` : 'ok');\n263\t        rec.notes.push('opened app (built + fetched root page; browser render is the judge\\'s job)');\n264\t      }\n265\t    } catch (e) {\n266\t      rec.error = String(e?.stack ?? e?.message ?? e);\n267\t      rec.notes.push(`STEP THREW: ${rec.error.split('\\n')[0]}`);\n268\t    }\n269\t\n270\t    rec.asks = [...asksThisStep];\n271\t    rec.state = await snapshot(pod);\n272\t    results.push(rec);\n273\t    const stem = join(outDir, `step-${String(num).padStart(2, '0')}`);\n274\t    // The judge reads step-NN.json every poll, often across several reruns — a full dump (every DB\n275\t    // row + every yield's args, ~80KB on a heavy build step) exhausts its context (\"Prompt is too\n276\t    // long\"). Write the COMPACT observables the judge actually scores to step-NN.json, and spill the\n277\t    // raw turn/state dump to step-NN.full.json for the rare deep-dive.\n278\t    writeFileSync(`${stem}.full.json`, JSON.stringify(rec, null, 2));\n279\t    writeFileSync(`${stem}.json`, JSON.stringify(compactStep(rec), null, 2));\n280\t    appendTrace(rec);\n281\t  }\n282\t\n283\t  // Summary.\n284\t  const summary = {\n285\t    scenario: scenario.id,\n286\t    project: projectId,\n287\t    ranSteps: results.length,\n288\t    ofSteps: steps.length,\n289\t    sessionStats: thing.stats?.() ?? null,\n290\t    outDir,\n291\t    finishedAt: new Date().toISOString(),\n292\t  };\n293\t  writeFileSync(join(outDir, 'summary.json'), JSON.stringify(summary, null, 2));\n294\t  writeFileSync(join(outDir, 'trace.md'), traceMd.join('\\n'));\n295\t  if (!keepProject) log(`project ${projectId} left in place (delete with: pod.deleteProject)`);\n296\t  console.log(`\\n✅ played ${results.length}/${steps.length} steps → ${outDir}`);\n297\t  console.log(`   read: ${join(outDir, 'trace.md')}  +  step-NN.json (compact; step-NN.full.json for drill-down)  +  summary.json`);\n298\t})().catch((e) => fail(String(e?.stack ?? e)));\n299\t\n300\t// ── helpers ────────────────────────────────────────────────────────────────────────────────────\n301\tfunction summarizeTurn(turn, sent) {\n302\t  if (!turn) return { sent, empty: true };\n303\t  return {\n304\t    sent,\n305\t    lastText: turn.lastText,\n306\t    delegates: turn.delegates,\n307\t    yieldKinds: [...new Set((turn.yields ?? []).map((y) => y.kind))],\n308\t    yields: (turn.yields ?? []).map((y) => ({ kind: y.kind, args: compact(y.args) })),\n309\t    errors: turn.errors ?? [],\n310\t    nodes: turn.nodes ?? [],\n311\t    tokens: turn.tokens,\n312\t    durationMs: turn.durationMs,\n313\t    interrupted: turn.interrupted ?? false,\n314\t  };\n315\t}\n316\tfunction compact(args) {\n317\t  try {\n318\t    const s = JSON.stringify(args);\n319\t    return s && s.length > 400 ? s.slice(0, 400) + '…' : args;\n320\t  } catch {\n321\t    return String(args);\n322\t  }\n323\t}\n324\t// The observables a step is JUDGED on — space names, table names + ROW COUNTS (not the rows),\n325\t// delegate names + outcomes, yield KINDS + count (not full args), errors, the reply, the asks.\n326\t// Everything a full dump carries for drill-down (every row, every yield's args, node bodies) stays\n327\t// in step-NN.full.json. Keeps the judge's per-poll read ~10× smaller so a heavy build step (or a\n328\t// rerun of one) doesn't blow its context window.\n329\tfunction compactStep(rec) {\n330\t  const s = rec.state ?? {};\n331\t  const turns = (rec.turns ?? []).map((t) =>\n332\t    t.empty\n333\t      ? { sent: t.sent, empty: true }\n334\t      : {\n335\t          sent: t.sent,\n336\t          lastText: typeof t.lastText === 'string' && t.lastText.length > 1200 ? t.lastText.slice(0, 1200) + '…' : t.lastText,\n337\t          delegates: t.delegates,\n338\t          yieldKinds: t.yieldKinds,\n339\t          yieldCount: (t.yields ?? []).length,\n340\t          errors: t.errors,\n341\t          nodeCount: (t.nodes ?? []).length,\n342\t          tokens: t.tokens,\n343\t          durationMs: t.durationMs,\n344\t          interrupted: t.interrupted,\n345\t        },\n346\t  );\n347\t  const state = {\n348\t    spaces: s.spaces ?? [],\n349\t    spaceCount: (s.spaces ?? []).length,\n350\t    appTables: Object.fromEntries(Object.entries(s.appTables ?? {}).map(([k, v]) => [k, Array.isArray(v) ? v.length : v])),\n351\t    appManifest: s.appManifest\n352\t      ? { tableNames: (s.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean), pageCount: (s.appManifest.pages ?? []).length, built: s.appManifest.built }\n353\t      : null,\n354\t    error: s.error ?? null,\n355\t    appError: s.appError ?? null,\n356\t  };\n357\t  return {\n358\t    step: rec.step,\n359\t    verbs: rec.verbs,\n360\t    expect: rec.expect,\n361\t    attached: rec.attached,\n362\t    turns,\n363\t    asks: rec.asks,\n364\t    appBuild: rec.appBuild,\n365\t    appPageStatus: rec.appPageStatus,\n366\t    notes: rec.notes,\n367\t    error: rec.error,\n368\t    state,\n369\t    fullEvidence: `step-${String(rec.step).padStart(2, '0')}.full.json`,\n370\t  };\n371\t}\n372\tfunction appendTrace(rec) {\n373\t  const L = traceMd;\n374\t  L.push(`\\n## Step ${rec.step} — ${rec.verbs.join(', ')}`);\n375\t  for (const t of rec.turns) {\n376\t    L.push(`\\n**sent:** ${String(t.sent).replace(/\\n/g, ' ').slice(0, 200)}`);\n377\t    if (t.delegates?.length) L.push(`- delegates: ${t.delegates.join(', ')}`);\n378\t    if (t.yieldKinds?.length) L.push(`- yields: ${t.yieldKinds.join(', ')}`);\n379\t    if (t.errors?.length) L.push(`- errors: ${t.errors.map((e) => `${e.type}@${e.attempt}`).join(', ')}`);\n380\t    if (t.lastText) L.push(`- reply: ${String(t.lastText).replace(/\\n/g, ' ').slice(0, 240)}`);\n381\t  }\n382\t  if (rec.asks?.length) L.push(`- asks: ${rec.asks.map((a) => `${a.kind}${a.matched ? `(matched)` : a.kind === 'question' && !a.answer ? '(UNANSWERED)' : ''}`).join(', ')}`);\n383\t  if (rec.appBuild) L.push(`- app: built=${rec.appBuild.built} pageStatus=${rec.appPageStatus}`);\n384\t  if (rec.state) {\n385\t    L.push(`- spaces: ${(rec.state.spaces ?? []).join(', ') || '(none)'}`);\n386\t    const tables = Object.keys(rec.state.appTables ?? {});\n387\t    if (tables.length) L.push(`- app tables: ${tables.map((t) => `${t}(${(rec.state.appTables[t] ?? []).length})`).join(', ')}`);\n388\t  }\n389\t  if (rec.notes?.length) L.push(`- notes: ${rec.notes.join(' · ')}`);\n390\t  if (rec.error) L.push(`- ⚠️ ERROR: ${rec.error.split('\\n')[0]}`);\n391\t  L.push(`\\n**expect (judge verifies):**`);\n392\t  for (const e of rec.expect) L.push(`  - [ ] ${e}`);\n393\t}\n394\t"}]},"parent_tool_use_id":null,"session_id":"4abecf79-4263-4bbb-a5c4-a77231683cc7","uuid":"4d7a3f43-fd5a-46f9-906b-b4c5c64f8d93","timestamp":"2026-07-16T15:14:15.089Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/run-yaml.mjs","content":"#!/usr/bin/env node\n/**\n * run-yaml.mjs — the GENERIC scenario runner.\n *\n * Plays a declarative `scenario.yaml` (persona · promise · invariants · steps) against a LOCAL\n * `lmthing serve`, driving the pod through the harness exactly as the /chat SPA would, and writes\n * per-step EVIDENCE (the execution trace + the real spaces/DB/app state after each step) for the\n * JUDGE to read. It does NOT judge — the judge (see automation/instances/scenario-campaign/judge.md)\n * reads this output, decides pass/fail per step, and fixes at the right rung.\n *\n * Local only: SCENARIO_TARGET defaults to 'local' here (getUser → http://localhost:8080, no auth).\n *\n *   node scenarios/run-yaml.mjs 06-tanzania                 # play the whole scenario, fresh project\n *   node scenarios/run-yaml.mjs 06-tanzania --through 5     # play steps 1..5 (the judge's verify rerun)\n *   node scenarios/run-yaml.mjs 06-tanzania --out <dir>     # where to write evidence (default <sc>/.run)\n *\n * Step verbs (see scenario-spec.md): attach[] · say · then_say · open_app · in_app_chat ·\n * fresh_session · restart_pod · if_asked{} · expect[] (expect is passed through, never executed).\n */\nimport { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync, rmSync } from 'node:fs';\nimport { join, resolve, dirname, basename } from 'node:path';\nimport { fileURLToPath } from 'node:url';\nimport { parseYaml } from './lib/yaml.mjs';\nimport { getUser } from './harness/provision.mjs';\nimport { Pod } from './harness/lib/pod.mjs';\nimport { ThingSession, approveAllConsent, denyAllConsent } from './harness/lib/thing.mjs';\nimport { restartLocalServer, freshLocalServer, serverUp, podRoot } from './harness/lib/local.mjs';\n\nprocess.env.SCENARIO_TARGET ??= 'local'; // this runner is local-only by design\n\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n\n// ── args ─────────────────────────────────────────────────────────────────────\nconst argv = process.argv.slice(2);\nconst flag = (name, def) => {\n  const i = argv.indexOf(name);\n  return i >= 0 && argv[i + 1] ? argv[i + 1] : def;\n};\nconst idOrPath = argv.find((a) => !a.startsWith('--')) ?? '06-tanzania';\nconst verbose = argv.includes('--verbose');\nconst keepProject = argv.includes('--keep-project');\nconst planOnly = argv.includes('--plan'); // parse + print the plan, never connect to a pod\nconst freshServer = argv.includes('--fresh-server'); // WIPE the pod data dir (0 projects) + start clean first\n\n// Resolve scenario dir + yaml.\nconst scenarioDir = idOrPath.endsWith('.yaml')\n  ? dirname(resolve(idOrPath))\n  : resolve(HERE, idOrPath);\nconst yamlPath = idOrPath.endsWith('.yaml') ? resolve(idOrPath) : join(scenarioDir, 'scenario.yaml');\nif (!existsSync(yamlPath)) fail(`no scenario.yaml at ${yamlPath}`);\nconst fixturesDir = join(scenarioDir, 'fixtures');\n\nconst scenario = parseYaml(readFileSync(yamlPath, 'utf8'));\nconst steps = scenario.steps ?? [];\nconst through = Number(flag('--through', String(steps.length)));\nconst outDir = resolve(flag('--out', join(scenarioDir, '.run')));\n// A fresh server means an empty runtime root, so the stable scenario project id is collision-free\n// and keeps evidence readable. Without --fresh-server (dev re-runs on a dirty root) a unique suffix\n// avoids clobbering an existing project.\nconst projectId = flag('--project', freshServer ? (scenario.project ?? scenario.id) : `${scenario.project ?? scenario.id}-${Date.now().toString(36)}`);\n\nmkdirSync(outDir, { recursive: true });\nconst traceMd = [];\nfunction log(...a) {\n  if (verbose) console.log('[run-yaml]', ...a);\n}\nfunction fail(msg) {\n  console.error(`run-yaml: ${msg}`);\n  process.exit(1);\n}\nfunction readdirSyncSafe(dir) {\n  try {\n    return readdirSync(dir);\n  } catch {\n    return [];\n  }\n}\n\n// ── ask handling: the driver answers in-persona; the JUDGE later scores the ask ────────────────\n// A step's `if_asked` map + the scenario `knows` list ground the load-bearing answers. Consent is\n// approved by default (a step may set `deny_consent: true`). Every ask + how it was answered is\n// recorded so the judge can score whether asking was correct (and whether the answer was right).\nlet currentStep = {};\nconst asksThisStep = [];\nfunction onAsk(descriptor) {\n  const text = JSON.stringify(descriptor ?? {});\n  // Consent cards: approve unless the step opts into denial.\n  if (descriptor?.type === 'ConsentCard') {\n    const answer = currentStep.deny_consent ? false : true;\n    asksThisStep.push({ kind: 'consent', answer, descriptor });\n    return answer;\n  }\n  // Clarifying question / form: match the step's if_asked, else best-effort from its single entry.\n  const ifAsked = currentStep.if_asked ?? {};\n  const keys = Object.keys(ifAsked);\n  let matched =\n    keys.find((k) => text.toLowerCase().includes(k.toLowerCase().slice(0, 24))) ??\n    (keys.length === 1 ? keys[0] : undefined);\n  const answer = matched ? ifAsked[matched] : '';\n  asksThisStep.push({ kind: 'question', matched: matched ?? null, answer, descriptor });\n  // Return the string answer; unmatched → '' (recorded prominently so the judge sees an unhandled ask).\n  return answer;\n}\n\n// ── state capture: what the judge verifies token-in-state against ──────────────────────────────\nasync function snapshot(pod) {\n  const snap = { spaces: [], appTables: {}, appManifest: null, error: null };\n  try {\n    const sp = await pod.listSpaces(projectId).catch(() => null);\n    snap.spaces = (sp?.spaces ?? sp ?? []).map((s) => s.slug ?? s.name ?? s.id ?? s);\n  } catch (e) {\n    snap.error = String(e?.message ?? e);\n  }\n  try {\n    const man = await pod.appManifest(projectId).catch(() => null);\n    if (man) {\n      snap.appManifest = { tables: man.tables ?? man.database ?? [], pages: man.pages ?? [], built: man.build?.built ?? null };\n      const tableNames = (snap.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean);\n      for (const t of tableNames) {\n        const rows = await pod.appData(projectId, t).catch(() => null);\n        if (rows) snap.appTables[t] = rows.rows ?? rows.data ?? rows;\n      }\n    }\n  } catch (e) {\n    snap.appError = String(e?.message ?? e);\n  }\n  return snap;\n}\n\n// ── dry plan: parse + print the step plan, never touch a pod ───────────────────────────────────\nif (planOnly) {\n  console.log(`scenario ${scenario.id} — \"${scenario.title}\"  (project ${scenario.project})`);\n  console.log(`persona: ${String(scenario.persona).slice(0, 90)}…`);\n  console.log(`invariants: ${scenario.invariants?.length}  ·  knows: ${scenario.knows?.length}  ·  steps: ${steps.length}\\n`);\n  const allFixtures = new Set();\n  steps.forEach((s, i) => {\n    const verbs = Object.keys(s).filter((k) => k !== 'expect');\n    (s.attach ?? []).forEach((f) => allFixtures.add(f));\n    const msg = (s.say ?? s.then_say ?? s.in_app_chat ?? '').toString().replace(/\\n/g, ' ').slice(0, 64);\n    console.log(`  ${String(i + 1).padStart(2)}. [${verbs.join(', ')}]  ${msg}${msg.length >= 64 ? '…' : ''}`);\n    if (s.attach) console.log(`       attach: ${s.attach.join(', ')}`);\n    console.log(`       expect: ${s.expect?.length ?? 0}${s.if_asked ? '  if_asked: ' + Object.keys(s.if_asked).length : ''}`);\n  });\n  // Fixture coverage: does every file in fixtures/ get used, and does every attach exist?\n  const used = [...allFixtures];\n  console.log(`\\nfixtures attached across the scenario (${used.length}): ${used.join(', ')}`);\n  const missing = used.filter((f) => !existsSync(join(fixturesDir, f)));\n  if (missing.length) console.log(`⚠️  attached but NOT on disk: ${missing.join(', ')}`);\n  try {\n    const onDisk = readdirSyncSafe(fixturesDir).filter((f) => !/^(links\\.md|.*\\.txt)$/.test(f));\n    const unused = onDisk.filter((f) => !allFixtures.has(f));\n    if (unused.length) console.log(`⚠️  on disk but NEVER attached: ${unused.join(', ')}`);\n    else console.log(`✅ every uploadable fixture on disk is attached by some step`);\n  } catch { /* fixtures dir may be absent */ }\n  process.exit(0);\n}\n\n// ── main ─────────────────────────────────────────────────────────────────────────────────────\n(async () => {\n  log(`scenario ${scenario.id} · project ${projectId} · steps 1..${through}/${steps.length}`);\n  // The RUNNER owns its own PID file (never rely on the caller's shell `$!`): a stopper does\n  // `kill $(cat <out>/runner.pid)` and it is always correct. Cleared on clean exit.\n  const pidFile = join(outDir, 'runner.pid');\n  writeFileSync(pidFile, String(process.pid));\n  process.on('exit', () => { try { rmSync(pidFile, { force: true }); } catch { /* ignore */ } });\n  // Clean stale evidence from a REUSED --out dir (a stopped-then-rerun round), so a poller can't\n  // read a prior run's step files / crash log as if they were this run's.\n  for (const f of readdirSyncSafe(outDir)) {\n    if (/^step-\\d+(\\.full)?\\.json$/.test(f) || f === 'summary.json' || f === 'trace.md') {\n      try { rmSync(join(outDir, f), { force: true }); } catch { /* ignore */ }\n    }\n  }\n  console.log(`[run-yaml] pid ${process.pid} → ${pidFile}`);\n  if (freshServer) {\n    console.log('[run-yaml] --fresh-server: wiping the pod runtime root (0 projects) and starting clean…');\n    await freshLocalServer();\n    console.log(`[run-yaml] fresh pod root: ${podRoot()}`);\n  }\n  if (!(await serverUp())) fail('local server not up — run: node harness/local-server.mjs up (or pass --fresh-server)');\n\n  const user = await getUser(scenario.id);\n  const pod = new Pod({ base: user.pod, token: user.token });\n  // Correctness check: a --fresh-server pod MUST start with no USER-created projects. A clean pod\n  // always has the built-in `system` and `user` projects — those are infrastructure, not state leak.\n  if (freshServer) {\n    const all = (await pod.listProjects().catch(() => null))?.projects ?? [];\n    const builtin = new Set(['system', 'user']);\n    const leaked = all.map((p) => p.id ?? p).filter((id) => !builtin.has(id));\n    console.log(\n      leaked.length === 0\n        ? `[run-yaml] confirmed: fresh pod has no user projects (built-ins only: ${all.map((p) => p.id ?? p).join(', ')})`\n        : `[run-yaml] WARNING: fresh pod already has leaked project(s): ${leaked.join(', ')} — expected none`,\n    );\n  }\n  // Fresh project (unique id per run unless --project pins one).\n  try {\n    await pod.createProject(projectId);\n  } catch (e) {\n    log(`createProject(${projectId}) — ${String(e?.message ?? e)} (continuing; may already exist)`);\n  }\n\n  let thing = new ThingSession(pod, { projectId, onAsk, verbose });\n  await thing.start();\n\n  const results = [];\n  for (let n = 0; n < Math.min(through, steps.length); n++) {\n    const step = steps[n];\n    currentStep = step;\n    asksThisStep.length = 0;\n    const num = n + 1;\n    const rec = { step: num, verbs: Object.keys(step).filter((k) => k !== 'expect'), expect: step.expect ?? [], turns: [], asks: [], notes: [] };\n    log(`── step ${num}: ${rec.verbs.join(', ')}`);\n\n    try {\n      if (step.fresh_session) {\n        thing = new ThingSession(pod, { projectId, onAsk, verbose });\n        await thing.start();\n        await thing.syncToTail();\n        rec.notes.push('started a fresh session (zero history)');\n      }\n      if (step.restart_pod) {\n        rec.notes.push('restarting local server…');\n        await restartLocalServer();\n        for (let i = 0; i < 40 && !(await serverUp()); i++) await sleep(500);\n        rec.notes.push((await serverUp()) ? 'server back up' : 'server did NOT come back up');\n      }\n\n      // The message(s) for this step, with attachments if any.\n      if (step.say != null) {\n        let turn;\n        if (Array.isArray(step.attach) && step.attach.length) {\n          const refs = [];\n          for (const f of step.attach) {\n            const p = join(fixturesDir, f);\n            if (!existsSync(p)) {\n              rec.notes.push(`MISSING FIXTURE: ${f}`);\n              continue;\n            }\n            refs.push(await pod.upload(p));\n          }\n          rec.attached = step.attach;\n          turn = await thing.sendWithAttachments(step.say, refs);\n        } else {\n          turn = await thing.send(step.say);\n        }\n        rec.turns.push(summarizeTurn(turn, step.say));\n      }\n      if (step.then_say != null) {\n        const t = await thing.send(step.then_say);\n        rec.turns.push(summarizeTurn(t, step.then_say));\n      }\n      if (step.in_app_chat != null) {\n        // The in-app chat is a project-scoped THING session with authoring caps — same project.\n        const t = await thing.send(step.in_app_chat);\n        rec.turns.push(summarizeTurn(t, `[in-app] ${step.in_app_chat}`));\n      }\n      if (step.open_app) {\n        const build = await pod.appBuild(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n        rec.appBuild = { built: build?.built ?? build?.build?.built ?? null, routes: build?.routes ?? null, error: build?.error ?? null };\n        const page = await pod.appPage(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n        rec.appPageStatus = page?.status ?? (page?.error ? `error: ${page.error}` : 'ok');\n        rec.notes.push('opened app (built + fetched root page; browser render is the judge\\'s job)');\n      }\n    } catch (e) {\n      rec.error = String(e?.stack ?? e?.message ?? e);\n      rec.notes.push(`STEP THREW: ${rec.error.split('\\n')[0]}`);\n    }\n\n    rec.asks = [...asksThisStep];\n    rec.state = await snapshot(pod);\n    results.push(rec);\n    const stem = join(outDir, `step-${String(num).padStart(2, '0')}`);\n    // The judge reads step-NN.json every poll, often across several reruns — a full dump (every DB\n    // row + every yield's args, ~80KB on a heavy build step) exhausts its context (\"Prompt is too\n    // long\"). Write the COMPACT observables the judge actually scores to step-NN.json, and spill the\n    // raw turn/state dump to step-NN.full.json for the rare deep-dive.\n    writeFileSync(`${stem}.full.json`, JSON.stringify(rec, null, 2));\n    writeFileSync(`${stem}.json`, JSON.stringify(compactStep(rec), null, 2));\n    appendTrace(rec);\n  }\n\n  // Summary.\n  const summary = {\n    scenario: scenario.id,\n    project: projectId,\n    ranSteps: results.length,\n    ofSteps: steps.length,\n    sessionStats: thing.stats?.() ?? null,\n    outDir,\n    finishedAt: new Date().toISOString(),\n  };\n  writeFileSync(join(outDir, 'summary.json'), JSON.stringify(summary, null, 2));\n  writeFileSync(join(outDir, 'trace.md'), traceMd.join('\\n'));\n  if (!keepProject) log(`project ${projectId} left in place (delete with: pod.deleteProject)`);\n  console.log(`\\n✅ played ${results.length}/${steps.length} steps → ${outDir}`);\n  console.log(`   read: ${join(outDir, 'trace.md')}  +  step-NN.json (compact; step-NN.full.json for drill-down)  +  summary.json`);\n})().catch((e) => fail(String(e?.stack ?? e)));\n\n// ── helpers ────────────────────────────────────────────────────────────────────────────────────\nfunction summarizeTurn(turn, sent) {\n  if (!turn) return { sent, empty: true };\n  return {\n    sent,\n    lastText: turn.lastText,\n    delegates: turn.delegates,\n    yieldKinds: [...new Set((turn.yields ?? []).map((y) => y.kind))],\n    yields: (turn.yields ?? []).map((y) => ({ kind: y.kind, args: compact(y.args) })),\n    errors: turn.errors ?? [],\n    nodes: turn.nodes ?? [],\n    tokens: turn.tokens,\n    durationMs: turn.durationMs,\n    interrupted: turn.interrupted ?? false,\n  };\n}\nfunction compact(args) {\n  try {\n    const s = JSON.stringify(args);\n    return s && s.length > 400 ? s.slice(0, 400) + '…' : args;\n  } catch {\n    return String(args);\n  }\n}\n// The observables a step is JUDGED on — space names, table names + ROW COUNTS (not the rows),\n// delegate names + outcomes, yield KINDS + count (not full args), errors, the reply, the asks.\n// Everything a full dump carries for drill-down (every row, every yield's args, node bodies) stays\n// in step-NN.full.json. Keeps the judge's per-poll read ~10× smaller so a heavy build step (or a\n// rerun of one) doesn't blow its context window.\nfunction compactStep(rec) {\n  const s = rec.state ?? {};\n  const turns = (rec.turns ?? []).map((t) =>\n    t.empty\n      ? { sent: t.sent, empty: true }\n      : {\n          sent: t.sent,\n          lastText: typeof t.lastText === 'string' && t.lastText.length > 1200 ? t.lastText.slice(0, 1200) + '…' : t.lastText,\n          delegates: t.delegates,\n          yieldKinds: t.yieldKinds,\n          yieldCount: (t.yields ?? []).length,\n          errors: t.errors,\n          nodeCount: (t.nodes ?? []).length,\n          tokens: t.tokens,\n          durationMs: t.durationMs,\n          interrupted: t.interrupted,\n        },\n  );\n  const state = {\n    spaces: s.spaces ?? [],\n    spaceCount: (s.spaces ?? []).length,\n    appTables: Object.fromEntries(Object.entries(s.appTables ?? {}).map(([k, v]) => [k, Array.isArray(v) ? v.length : v])),\n    appManifest: s.appManifest\n      ? { tableNames: (s.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean), pageCount: (s.appManifest.pages ?? []).length, built: s.appManifest.built }\n      : null,\n    error: s.error ?? null,\n    appError: s.appError ?? null,\n  };\n  return {\n    step: rec.step,\n    verbs: rec.verbs,\n    expect: rec.expect,\n    attached: rec.attached,\n    turns,\n    asks: rec.asks,\n    appBuild: rec.appBuild,\n    appPageStatus: rec.appPageStatus,\n    notes: rec.notes,\n    error: rec.error,\n    state,\n    fullEvidence: `step-${String(rec.step).padStart(2, '0')}.full.json`,\n  };\n}\nfunction appendTrace(rec) {\n  const L = traceMd;\n  L.push(`\\n## Step ${rec.step} — ${rec.verbs.join(', ')}`);\n  for (const t of rec.turns) {\n    L.push(`\\n**sent:** ${String(t.sent).replace(/\\n/g, ' ').slice(0, 200)}`);\n    if (t.delegates?.length) L.push(`- delegates: ${t.delegates.join(', ')}`);\n    if (t.yieldKinds?.length) L.push(`- yields: ${t.yieldKinds.join(', ')}`);\n    if (t.errors?.length) L.push(`- errors: ${t.errors.map((e) => `${e.type}@${e.attempt}`).join(', ')}`);\n    if (t.lastText) L.push(`- reply: ${String(t.lastText).replace(/\\n/g, ' ').slice(0, 240)}`);\n  }\n  if (rec.asks?.length) L.push(`- asks: ${rec.asks.map((a) => `${a.kind}${a.matched ? `(matched)` : a.kind === 'question' && !a.answer ? '(UNANSWERED)' : ''}`).join(', ')}`);\n  if (rec.appBuild) L.push(`- app: built=${rec.appBuild.built} pageStatus=${rec.appPageStatus}`);\n  if (rec.state) {\n    L.push(`- spaces: ${(rec.state.spaces ?? []).join(', ') || '(none)'}`);\n    const tables = Object.keys(rec.state.appTables ?? {});\n    if (tables.length) L.push(`- app tables: ${tables.map((t) => `${t}(${(rec.state.appTables[t] ?? []).length})`).join(', ')}`);\n  }\n  if (rec.notes?.length) L.push(`- notes: ${rec.notes.join(' · ')}`);\n  if (rec.error) L.push(`- ⚠️ ERROR: ${rec.error.split('\\n')[0]}`);\n  L.push(`\\n**expect (judge verifies):**`);\n  for (const e of rec.expect) L.push(`  - [ ] ${e}`);\n}\n","numLines":394,"startLine":1,"totalLines":394}}}
