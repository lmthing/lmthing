.mjs\n M automation/instances/scenario-campaign/judge.md\n D automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/runner.pid\n D automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/step-01.json\n D automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/step-02.json\n D automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/step-03.json\n D automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02/runner.pid\n M automation/instances/scenario-campaign/scenario-spec.md\n M org/docs/system-spaces/README.md\n M sdk/org\n?? automation/instances/scenario-campaign/attempts/\n?? automation/instances/scenario-campaign/rounds/10/06-tanzania/attempt-1/\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/report.md\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02-rerun-2/\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02/step-01.json\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02/step-02.json\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02/summary.json\n?? automation/instances/scenario-campaign/rounds/7/06-tanzania/attempt-1/verify-step-02/trace.md","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
