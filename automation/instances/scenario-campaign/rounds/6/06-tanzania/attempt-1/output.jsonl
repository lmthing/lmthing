{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Ocp1Xng8nJmX1pwKdgJCpzlc","type":"tool_result","content":"1\timport { experimental_transcribe as transcribe } from 'ai';\n2\t\n3\t/** The transcription model spec, `provider:modelId`. Configurable via\n4\t *  `LM_TRANSCRIBE_MODEL`; defaults to OpenAI Whisper. */\n5\tconst DEFAULT_TRANSCRIBE_MODEL = 'openai:whisper-1';\n6\t\n7\texport interface TranscriptionResult {\n8\t  text: string;\n9\t  language?: string;\n10\t  durationInSeconds?: number;\n11\t}\n12\t\n13\t/** Resolve a `provider:modelId` spec into an AI SDK transcription model.\n14\t *  Supports openai, lmthingcloud (the LiteLLM proxy) and azure — all expose\n15\t *  Whisper via the OpenAI-compatible transcription endpoint. Mirrors resolve.ts's\n16\t *  env handling so credentials are shared. */\n17\tasync function resolveTranscriptionModel(spec: string) {\n18\t  const idx = spec.indexOf(':');\n19\t  const provider = (idx === -1 ? 'openai' : spec.slice(0, idx)).toLowerCase();\n20\t  const modelId = idx === -1 ? spec : spec.slice(idx + 1);\n21\t  if (!modelId) throw new Error(`Invalid transcription model spec \"${spec}\"`);\n22\t\n23\t  switch (provider) {\n24\t    case 'openai': {\n25\t      const { createOpenAI } = await import('@ai-sdk/openai');\n26\t      const apiKey = process.env['OPENAI_API_KEY'];\n27\t      const baseURL = process.env['OPENAI_BASE_URL'];\n28\t      return createOpenAI(baseURL ? { baseURL, apiKey } : { apiKey }).transcription(modelId);\n29\t    }\n30\t    case 'lmthingcloud': {\n31\t      // Route transcription through the user's LiteLLM key (same as resolve.ts's\n32\t      // lmthingcloud: provider) so Azure creds stay off the pod and audio usage\n33\t      // bills against the user's budget. `modelId` is the LiteLLM model_name\n34\t      // (e.g. whisper-1), served at {baseURL}/audio/transcriptions.\n35\t      const { createOpenAI } = await import('@ai-sdk/openai');\n36\t      const apiKey = process.env['LMTHINGCLOUD_API_KEY'];\n37\t      if (!apiKey) throw new Error('LMTHINGCLOUD_API_KEY env var is required for lmthingcloud transcription');\n38\t      const baseURL = process.env['LMTHINGCLOUD_BASE_URL'] || 'https://lmthing.cloud/v1';\n39\t      return createOpenAI({ baseURL, apiKey }).transcription(modelId);\n40\t    }\n41\t    case 'azure': {\n42\t      const { createAzure } = await import('@ai-sdk/azure');\n43\t      const resourceName = process.env['AZURE_RESOURCE_NAME'];\n44\t      const apiKey = process.env['AZURE_API_KEY'];\n45\t      if (!resourceName) throw new Error('AZURE_RESOURCE_NAME env var is required for azure transcription');\n46\t      if (!apiKey) throw new Error('AZURE_API_KEY env var is required for azure transcription');\n47\t      // Whisper transcription is only served on the classic deployment-based URL\n48\t      // (…/openai/deployments/<name>/audio/transcriptions) with a dated api-version.\n49\t      // The provider's default \"v1\" surface (api-version=v1, …/openai/v1/…) 404s\n50\t      // with DeploymentNotFound, so pin both explicitly.\n51\t      const apiVersion = process.env['AZURE_TRANSCRIBE_API_VERSION'] || '2024-06-01';\n52\t      return createAzure({ resourceName, apiKey, apiVersion, useDeploymentBasedUrls: true }).transcription(modelId);\n53\t    }\n54\t    default:\n55\t      throw new Error(\n56\t        `Unsupported transcription provider \"${provider}\": supported providers are openai, lmthingcloud, azure`,\n57\t      );\n58\t  }\n59\t}\n60\t\n61\t/** Transcribe audio bytes to text via the configured transcription model.\n62\t *  Throws if no transcription provider is configured/credentialed. */\n63\texport async function transcribeAudio(audio: Uint8Array): Promise<TranscriptionResult> {\n64\t  const spec = process.env['LM_TRANSCRIBE_MODEL'] || DEFAULT_TRANSCRIBE_MODEL;\n65\t  const model = await resolveTranscriptionModel(spec);\n66\t  const result = await transcribe({ model, audio });\n67\t  return {\n68\t    text: result.text,\n69\t    ...(result.language ? { language: result.language } : {}),\n70\t    ...(typeof result.durationInSeconds === 'number' ? { durationInSeconds: result.durationInSeconds } : {}),\n71\t  };\n72\t}\n73\t"}]},"parent_tool_use_id":null,"session_id":"cfe78b6a-97f2-4499-9269-8aedfbe3c777","uuid":"b47126e1-5463-476c-bcc4-0a93ad6f30ae","timestamp":"2026-07-15T20:50:45.173Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/providers/transcribe.ts","content":"import { experimental_transcribe as transcribe } from 'ai';\n\n/** The transcription model spec, `provider:modelId`. Configurable via\n *  `LM_TRANSCRIBE_MODEL`; defaults to OpenAI Whisper. */\nconst DEFAULT_TRANSCRIBE_MODEL = 'openai:whisper-1';\n\nexport interface TranscriptionResult {\n  text: string;\n  language?: string;\n  durationInSeconds?: number;\n}\n\n/** Resolve a `provider:modelId` spec into an AI SDK transcription model.\n *  Supports openai, lmthingcloud (the LiteLLM proxy) and azure — all expose\n *  Whisper via the OpenAI-compatible transcription endpoint. Mirrors resolve.ts's\n *  env handling so credentials are shared. */\nasync function resolveTranscriptionModel(spec: string) {\n  const idx = spec.indexOf(':');\n  const provider = (idx === -1 ? 'openai' : spec.slice(0, idx)).toLowerCase();\n  const modelId = idx === -1 ? spec : spec.slice(idx + 1);\n  if (!modelId) throw new Error(`Invalid transcription model spec \"${spec}\"`);\n\n  switch (provider) {\n    case 'openai': {\n      const { createOpenAI } = await import('@ai-sdk/openai');\n      const apiKey = process.env['OPENAI_API_KEY'];\n      const baseURL = process.env['OPENAI_BASE_URL'];\n      return createOpenAI(baseURL ? { baseURL, apiKey } : { apiKey }).transcription(modelId);\n    }\n    case 'lmthingcloud': {\n      // Route transcription through the user's LiteLLM key (same as resolve.ts's\n      // lmthingcloud: provider) so Azure creds stay off the pod and audio usage\n      // bills against the user's budget. `modelId` is the LiteLLM model_name\n      // (e.g. whisper-1), served at {baseURL}/audio/transcriptions.\n      const { createOpenAI } = await import('@ai-sdk/openai');\n      const apiKey = process.env['LMTHINGCLOUD_API_KEY'];\n      if (!apiKey) throw new Error('LMTHINGCLOUD_API_KEY env var is required for lmthingcloud transcription');\n      const baseURL = process.env['LMTHINGCLOUD_BASE_URL'] || 'https://lmthing.cloud/v1';\n      return createOpenAI({ baseURL, apiKey }).transcription(modelId);\n    }\n    case 'azure': {\n      const { createAzure } = await import('@ai-sdk/azure');\n      const resourceName = process.env['AZURE_RESOURCE_NAME'];\n      const apiKey = process.env['AZURE_API_KEY'];\n      if (!resourceName) throw new Error('AZURE_RESOURCE_NAME env var is required for azure transcription');\n      if (!apiKey) throw new Error('AZURE_API_KEY env var is required for azure transcription');\n      // Whisper transcription is only served on the classic deployment-based URL\n      // (…/openai/deployments/<name>/audio/transcriptions) with a dated api-version.\n      // The provider's default \"v1\" surface (api-version=v1, …/openai/v1/…) 404s\n      // with DeploymentNotFound, so pin both explicitly.\n      const apiVersion = process.env['AZURE_TRANSCRIBE_API_VERSION'] || '2024-06-01';\n      return createAzure({ resourceName, apiKey, apiVersion, useDeploymentBasedUrls: true }).transcription(modelId);\n    }\n    default:\n      throw new Error(\n        `Unsupported transcription provider \"${provider}\": supported providers are openai, lmthingcloud, azure`,\n      );\n  }\n}\n\n/** Transcribe audio bytes to text via the configured transcription model.\n *  Throws if no transcription provider is configured/credentialed. */\nexport async function transcribeAudio(audio: Uint8Array): Promise<TranscriptionResult> {\n  const spec = process.env['LM_TRANSCRIBE_MODEL'] || DEFAULT_TRANSCRIBE_MODEL;\n  const model = await resolveTranscriptionModel(spec);\n  const result = await transcribe({ model, audio });\n  return {\n    text: result.text,\n    ...(result.language ? { language: result.language } : {}),\n    ...(typeof result.durationInSeconds === 'number' ? { durationInSeconds: result.durationInSeconds } : {}),\n  };\n}\n","numLines":73,"startLine":1,"totalLines":73}}}
