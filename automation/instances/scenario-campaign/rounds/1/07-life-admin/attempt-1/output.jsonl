{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_aY1WfaJSczBz9HztV0Nk5Rj4","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Stand up a disposable prod test user and print its session JSON.\n4\t *\n5\t *   node provision.mjs <label>            # register + pod + env + wait ready\n6\t *   node provision.mjs <label> --reuse    # reuse the cached user for <label> if it exists\n7\t *\n8\t * Writes `.state/users/<label>.json` (gitignored) so a scenario can be re-run against the same\n9\t * user, and so a subagent that hits a budget wall can just provision a new one and carry on.\n10\t */\n11\timport { mkdirSync, readFileSync, writeFileSync, existsSync } from 'node:fs';\n12\timport {\n13\t  provisionUser,\n14\t  budget,\n15\t  podBase,\n16\t  agentEnvFromSdk,\n17\t  mergePodEnv,\n18\t  waitPodReady,\n19\t  waitPodSettled,\n20\t} from './lib/gateway.mjs';\n21\timport { LOCAL } from './lib/local.mjs';\n22\timport { STATE_DIR } from './lib/paths.mjs';\n23\t\n24\tconst label = process.argv[2] ?? 'scn';\n25\tconst reuse = process.argv.includes('--reuse');\n26\tconst file = `${STATE_DIR}/users/${label}.json`;\n27\t\n28\t/** Load a cached user, refreshing its JWT (12h TTL) and re-asserting pod env. */\n29\texport async function loadUser(lbl = label) {\n30\t  const f = `${STATE_DIR}/users/${lbl}.json`;\n31\t  if (!existsSync(f)) return null;\n32\t  const u = JSON.parse(readFileSync(f, 'utf8'));\n33\t  const { mintSession } = await import('./lib/jwt.mjs');\n34\t  const session = mintSession(u.userId, u.email); // always re-mint: cheap, never stale\n35\t  return { ...u, session, token: session.accessToken, pod: podBase() };\n36\t}\n37\t\n38\t/** Provision (or reuse) and guarantee: pod exists, agent keys loaded, pod ready. */\n39\texport async function getUser(lbl = label, { fresh = false } = {}) {\n40\t  // Local target: no prod user, no cache file, no JWT — just ensure the shared server is up.\n41\t  if (LOCAL) return provisionUser({ label: lbl });\n42\t  if (!fresh) {\n43\t    const cached = await loadUser(lbl);\n44\t    if (cached) {\n45\t      // Re-assert env (a no-op PUT is skipped, so this usually does NOT restart the pod).\n46\t      const { changed } = await mergePodEnv(cached.token, agentEnvFromSdk()).catch(() => ({ changed: false }));\n47\t      await waitPodReady(cached.token).catch(() => {});\n48\t      if (changed) await waitPodSettled(cached.token);\n49\t      return cached;\n50\t    }\n51\t  }\n52\t  const u = await provisionUser({ label: lbl });\n53\t  mkdirSync(`${STATE_DIR}/users`, { recursive: true });\n54\t  writeFileSync(`${STATE_DIR}/users/${lbl}.json`, JSON.stringify({ email: u.email, userId: u.userId }, null, 2));\n55\t  return u;\n56\t}\n57\t\n58\tif (import.meta.url === `file://${process.argv[1]}`) {\n59\t  const u = await getUser(label, { fresh: !reuse });\n60\t  const b = await budget(u.token).catch((e) => ({ error: String(e) }));\n61\t  console.log(\n62\t    JSON.stringify(\n63\t      { label, email: u.email, userId: u.userId, pod: u.pod, token: u.token, budget: b },\n64\t      null,\n65\t      2,\n66\t    ),\n67\t  );\n68\t  console.log(`\\n# pod namespace: user-${u.userId}\\n# state: ${file}`);\n69\t}\n70\t"}]},"parent_tool_use_id":null,"session_id":"07505bfe-a0f1-4aee-a3f1-2914d0a4ae88","uuid":"6e588b6c-7c30-4fe0-95b3-db656f662241","timestamp":"2026-07-14T16:53:21.471Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/provision.mjs","content":"#!/usr/bin/env node\n/**\n * Stand up a disposable prod test user and print its session JSON.\n *\n *   node provision.mjs <label>            # register + pod + env + wait ready\n *   node provision.mjs <label> --reuse    # reuse the cached user for <label> if it exists\n *\n * Writes `.state/users/<label>.json` (gitignored) so a scenario can be re-run against the same\n * user, and so a subagent that hits a budget wall can just provision a new one and carry on.\n */\nimport { mkdirSync, readFileSync, writeFileSync, existsSync } from 'node:fs';\nimport {\n  provisionUser,\n  budget,\n  podBase,\n  agentEnvFromSdk,\n  mergePodEnv,\n  waitPodReady,\n  waitPodSettled,\n} from './lib/gateway.mjs';\nimport { LOCAL } from './lib/local.mjs';\nimport { STATE_DIR } from './lib/paths.mjs';\n\nconst label = process.argv[2] ?? 'scn';\nconst reuse = process.argv.includes('--reuse');\nconst file = `${STATE_DIR}/users/${label}.json`;\n\n/** Load a cached user, refreshing its JWT (12h TTL) and re-asserting pod env. */\nexport async function loadUser(lbl = label) {\n  const f = `${STATE_DIR}/users/${lbl}.json`;\n  if (!existsSync(f)) return null;\n  const u = JSON.parse(readFileSync(f, 'utf8'));\n  const { mintSession } = await import('./lib/jwt.mjs');\n  const session = mintSession(u.userId, u.email); // always re-mint: cheap, never stale\n  return { ...u, session, token: session.accessToken, pod: podBase() };\n}\n\n/** Provision (or reuse) and guarantee: pod exists, agent keys loaded, pod ready. */\nexport async function getUser(lbl = label, { fresh = false } = {}) {\n  // Local target: no prod user, no cache file, no JWT — just ensure the shared server is up.\n  if (LOCAL) return provisionUser({ label: lbl });\n  if (!fresh) {\n    const cached = await loadUser(lbl);\n    if (cached) {\n      // Re-assert env (a no-op PUT is skipped, so this usually does NOT restart the pod).\n      const { changed } = await mergePodEnv(cached.token, agentEnvFromSdk()).catch(() => ({ changed: false }));\n      await waitPodReady(cached.token).catch(() => {});\n      if (changed) await waitPodSettled(cached.token);\n      return cached;\n    }\n  }\n  const u = await provisionUser({ label: lbl });\n  mkdirSync(`${STATE_DIR}/users`, { recursive: true });\n  writeFileSync(`${STATE_DIR}/users/${lbl}.json`, JSON.stringify({ email: u.email, userId: u.userId }, null, 2));\n  return u;\n}\n\nif (import.meta.url === `file://${process.argv[1]}`) {\n  const u = await getUser(label, { fresh: !reuse });\n  const b = await budget(u.token).catch((e) => ({ error: String(e) }));\n  console.log(\n    JSON.stringify(\n      { label, email: u.email, userId: u.userId, pod: u.pod, token: u.token, budget: b },\n      null,\n      2,\n    ),\n  );\n  console.log(`\\n# pod namespace: user-${u.userId}\\n# state: ${file}`);\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
