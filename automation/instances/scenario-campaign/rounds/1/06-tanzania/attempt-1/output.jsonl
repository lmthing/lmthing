es: notes-memories, index)';\n\nexport interface Input {\n  status?: string; // open (default), in-progress, resolved, or 'all'\n}\n\nexport interface Output {\n  items: Array<{\n    id: string;\n    title: string;\n    description: string;\n    priority: string;\n    status: string;\n    due_by: string;\n    related_contact_id: string | null;\n    related_leg_id: string | null;\n    related_cost_id: string | null;\n    source: string;\n    sort_order: number;\n  }>;\n}\n\nexport default async function handler(input: Input, ctx: { db: any }): Promise<Output> {\n  const statusFilter = input.status || 'open';\n  const allItems = await ctx.db.query('action_items');\n  // Sort by sort_order ASC\n  const sorted = [...allItems].sort((a, b) => a.sort_order - b.sort_order);\n  // Filter by status unless status='all'\n  const items = statusFilter === 'all'\n    ? sorted\n    : sorted.filter((item) => item.status === statusFilter);\n  return { items };\n}","numLines":34,"startLine":1,"totalLines":34}}}
