{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_eHOgbH7wW0bDFKCq8gnC3arK","type":"tool_result","content":"1\t/**\n2\t * API **endpoint discovery** (Phase 3, 3A).\n3\t *\n4\t * Walks `<projectRoot>/api/`. Each `GET.ts`/`POST.ts`/`PUT.ts`/`PATCH.ts`/\n5\t * `DELETE.ts` under a route directory is an endpoint: **the endpoint route is the\n6\t * directory, the HTTP method is the filename**. The route pattern derives from\n7\t * the dir path with `[id]` segments → `:id` params:\n8\t *\n9\t *   api/feed-list/GET.ts        → GET    /feed-list           (name \"feedList\")\n10\t *   api/mark-read/POST.ts       → POST   /mark-read           (name \"markRead\")\n11\t *   api/items/[id]/GET.ts       → GET    /items/:id           (name \"getItem\")\n12\t *   api/items/[id]/PATCH.ts     → PATCH  /items/:id           (name \"updateItem\")\n13\t *\n14\t * Non-method `.ts` files in a route dir (helpers, `types.ts`) are **ignored**.\n15\t * Each endpoint's `name` (from `export const name`) is the stable agent-facing\n16\t * id; it is **unique per project** — a duplicate is a **fail-loud** throw.\n17\t *\n18\t * `name`/`description` are read by a light **static parse** (not by evaluating\n19\t * the module) — deliberately: evaluating handler code in the main process would\n20\t * breach the crash-boundary invariant, so discovery never runs handler code.\n21\t */\n22\t\n23\timport { readdir, readFile } from 'node:fs/promises';\n24\timport type { Dirent } from 'node:fs';\n25\timport { join } from 'node:path';\n26\t\n27\timport type { HttpMethod } from './input.js';\n28\t\n29\t/** The five HTTP methods the file-based router maps from a filename. */\n30\texport const HTTP_METHODS: readonly HttpMethod[] = ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'];\n31\t\n32\tconst METHOD_FILE_RE = /^(GET|POST|PUT|PATCH|DELETE)\\.ts$/;\n33\t\n34\t/** A single discovered endpoint. */\n35\texport interface Endpoint {\n36\t  /** The HTTP method (from the filename). */\n37\t  method: HttpMethod;\n38\t  /** The route pattern, `[id]` → `:id` (e.g. `/items/:id`; the api root is `/`). */\n39\t  pattern: string;\n40\t  /** Ordered dynamic-param names in the pattern (e.g. `['id']`). */\n41\t  paramNames: string[];\n42\t  /** Absolute path to the handler `.ts` file. */\n43\t  file: string;\n44\t  /** The stable agent-facing id (`export const name`) — unique per project. */\n45\t  name: string;\n46\t  /** Optional description (`export const description`). */\n47\t  description?: string;\n48\t}\n49\t\n50\t/** The route table: endpoints indexed by `(method, pattern)` and by `name`. */\n51\texport interface RouteTable {\n52\t  endpoints: Endpoint[];\n53\t  /** Keyed `\"<METHOD> <pattern>\"` (e.g. `\"GET /items/:id\"`). */\n54\t  byMethodPattern: Map<string, Endpoint>;\n55\t  /** Keyed by the endpoint `name`. */\n56\t  byName: Map<string, Endpoint>;\n57\t}\n58\t\n59\t/** The key for {@link RouteTable.byMethodPattern}. */\n60\texport function routeKey(method: string, pattern: string): string {\n61\t  return `${method} ${pattern}`;\n62\t}\n63\t\n64\t/**\n65\t * Discover every endpoint under `<projectRoot>/api/`. Returns an empty table when\n66\t * there is no `api/` dir (a spaces-only or api-less project). Throws fail-loud on\n67\t * a duplicate `name` or a method file missing `export const name`.\n68\t */\n69\texport async function loadApiRoutes(projectRoot: string): Promise<RouteTable> {\n70\t  const apiDir = join(projectRoot, 'api');\n71\t  const endpoints: Endpoint[] = [];\n72\t  await walk(apiDir, [], endpoints);\n73\t\n74\t  // Deterministic order — stable diagnostics + first-defined wins nothing (dups throw).\n75\t  endpoints.sort((a, b) => routeKey(a.method, a.pattern).localeCompare(routeKey(b.method, b.pattern)));\n76\t\n77\t  const byMethodPattern = new Map<string, Endpoint>();\n78\t  const byName = new Map<string, Endpoint>();\n79\t  for (const ep of endpoints) {\n80\t    const key = routeKey(ep.method, ep.pattern);\n81\t    if (byMethodPattern.has(key)) {\n82\t      throw new Error(`[api-loader] duplicate route \"${key}\" (${ep.file})`);\n83\t    }\n84\t    byMethodPattern.set(key, ep);\n85\t    const existing = byName.get(ep.name);\n86\t    if (existing) {\n87\t      throw new Error(\n88\t        `[api-loader] duplicate endpoint name \"${ep.name}\" — ${existing.file} and ${ep.file}`,\n89\t      );\n90\t    }\n91\t    byName.set(ep.name, ep);\n92\t  }\n93\t\n94\t  return { endpoints, byMethodPattern, byName };\n95\t}\n96\t\n97\t/** Recursively collect method files, tracking the route segments so far. */\n98\tasync function walk(dir: string, segments: string[], out: Endpoint[]): Promise<void> {\n99\t  let entries: Dirent[];\n100\t  try {\n101\t    entries = await readdir(dir, { withFileTypes: true });\n102\t  } catch (err) {\n103\t    if ((err as NodeJS.ErrnoException).code === 'ENOENT') return; // no api/ dir\n104\t    throw err;\n105\t  }\n106\t\n107\t  for (const entry of entries) {\n108\t    const abs = join(dir, entry.name);\n109\t    if (entry.isDirectory()) {\n110\t      await walk(abs, [...segments, entry.name], out);\n111\t      continue;\n112\t    }\n113\t    if (!entry.isFile()) continue;\n114\t    const m = METHOD_FILE_RE.exec(entry.name);\n115\t    if (!m) continue; // ignore non-method .ts (helpers/types) and other files\n116\t    const method = m[1] as HttpMethod;\n117\t    const { pattern, paramNames } = patternFromSegments(segments);\n118\t    const source = await readFile(abs, 'utf8');\n119\t    const name = parseExportedString(source, 'name');\n120\t    if (!name) {\n121\t      throw new Error(\n122\t        `[api-loader] ${abs}: missing \\`export const name\\` (every endpoint must be named)`,\n123\t      );\n124\t    }\n125\t    const description = parseExportedString(source, 'description');\n126\t    out.push({ method, pattern, paramNames, file: abs, name, description });\n127\t  }\n128\t}\n129\t\n130\t/** Build a `/`-rooted route pattern (`[id]` → `:id`) + its param names. */\n131\tfunction patternFromSegments(segments: string[]): { pattern: string; paramNames: string[] } {\n132\t  const paramNames: string[] = [];\n133\t  const parts = segments.map((seg) => {\n134\t    const dyn = /^\\[(.+)\\]$/.exec(seg);\n135\t    if (dyn) {\n136\t      paramNames.push(dyn[1]);\n137\t      return `:${dyn[1]}`;\n138\t    }\n139\t    return seg;\n140\t  });\n141\t  return { pattern: '/' + parts.join('/'), paramNames };\n142\t}\n143\t\n144\t/**\n145\t * Static-parse `export const <key> = '<value>'` (single/double/backtick quotes)\n146\t * from handler source, without evaluating it. Returns `undefined` if absent.\n147\t */\n148\tfunction parseExportedString(source: string, key: string): string | undefined {\n149\t  const re = new RegExp(`export\\\\s+const\\\\s+${key}\\\\s*=\\\\s*(['\"\\`])((?:\\\\\\\\.|(?!\\\\1).)*)\\\\1`);\n150\t  const m = re.exec(source);\n151\t  return m ? m[2] : undefined;\n152\t}\n153\t\n154\t/**\n155\t * Match a concrete request `path` against a method's routes. Returns the matched\n156\t * endpoint + extracted path params (`Record<string, string>`), or `null`.\n157\t */\n158\texport function matchRoute(\n159\t  table: RouteTable,\n160\t  method: string,\n161\t  path: string,\n162\t): { endpoint: Endpoint; params: Record<string, string> } | null {\n163\t  const reqSegs = splitPath(path);\n164\t  for (const ep of table.endpoints) {\n165\t    if (ep.method !== method) continue;\n166\t    const patSegs = splitPath(ep.pattern);\n167\t    if (patSegs.length !== reqSegs.length) continue;\n168\t    const params: Record<string, string> = {};\n169\t    let ok = true;\n170\t    for (let i = 0; i < patSegs.length; i++) {\n171\t      const p = patSegs[i];\n172\t      if (p.startsWith(':')) params[p.slice(1)] = decodeURIComponent(reqSegs[i]);\n173\t      else if (p !== reqSegs[i]) {\n174\t        ok = false;\n175\t        break;\n176\t      }\n177\t    }\n178\t    if (ok) return { endpoint: ep, params };\n179\t  }\n180\t  return null;\n181\t}\n182\t\n183\t/** Split a `/`-path into non-empty segments (the root `/` → `[]`). */\n184\tfunction splitPath(path: string): string[] {\n185\t  return path.split('/').filter((s) => s.length > 0);\n186\t}\n187\t"}]},"parent_tool_use_id":null,"session_id":"a5bdaf5f-36c3-4bd0-a7f1-82b85daace12","uuid":"8beae5c5-a763-4d50-a99a-7e42b047b109","timestamp":"2026-07-16T09:10:46.169Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/app/api/loader.ts","content":"/**\n * API **endpoint discovery** (Phase 3, 3A).\n *\n * Walks `<projectRoot>/api/`. Each `GET.ts`/`POST.ts`/`PUT.ts`/`PATCH.ts`/\n * `DELETE.ts` under a route directory is an endpoint: **the endpoint route is the\n * directory, the HTTP method is the filename**. The route pattern derives from\n * the dir path with `[id]` segments → `:id` params:\n *\n *   api/feed-list/GET.ts        → GET    /feed-list           (name \"feedList\")\n *   api/mark-read/POST.ts       → POST   /mark-read           (name \"markRead\")\n *   api/items/[id]/GET.ts       → GET    /items/:id           (name \"getItem\")\n *   api/items/[id]/PATCH.ts     → PATCH  /items/:id           (name \"updateItem\")\n *\n * Non-method `.ts` files in a route dir (helpers, `types.ts`) are **ignored**.\n * Each endpoint's `name` (from `export const name`) is the stable agent-facing\n * id; it is **unique per project** — a duplicate is a **fail-loud** throw.\n *\n * `name`/`description` are read by a light **static parse** (not by evaluating\n * the module) — deliberately: evaluating handler code in the main process would\n * breach the crash-boundary invariant, so discovery never runs handler code.\n */\n\nimport { readdir, readFile } from 'node:fs/promises';\nimport type { Dirent } from 'node:fs';\nimport { join } from 'node:path';\n\nimport type { HttpMethod } from './input.js';\n\n/** The five HTTP methods the file-based router maps from a filename. */\nexport const HTTP_METHODS: readonly HttpMethod[] = ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'];\n\nconst METHOD_FILE_RE = /^(GET|POST|PUT|PATCH|DELETE)\\.ts$/;\n\n/** A single discovered endpoint. */\nexport interface Endpoint {\n  /** The HTTP method (from the filename). */\n  method: HttpMethod;\n  /** The route pattern, `[id]` → `:id` (e.g. `/items/:id`; the api root is `/`). */\n  pattern: string;\n  /** Ordered dynamic-param names in the pattern (e.g. `['id']`). */\n  paramNames: string[];\n  /** Absolute path to the handler `.ts` file. */\n  file: string;\n  /** The stable agent-facing id (`export const name`) — unique per project. */\n  name: string;\n  /** Optional description (`export const description`). */\n  description?: string;\n}\n\n/** The route table: endpoints indexed by `(method, pattern)` and by `name`. */\nexport interface RouteTable {\n  endpoints: Endpoint[];\n  /** Keyed `\"<METHOD> <pattern>\"` (e.g. `\"GET /items/:id\"`). */\n  byMethodPattern: Map<string, Endpoint>;\n  /** Keyed by the endpoint `name`. */\n  byName: Map<string, Endpoint>;\n}\n\n/** The key for {@link RouteTable.byMethodPattern}. */\nexport function routeKey(method: string, pattern: string): string {\n  return `${method} ${pattern}`;\n}\n\n/**\n * Discover every endpoint under `<projectRoot>/api/`. Returns an empty table when\n * there is no `api/` dir (a spaces-only or api-less project). Throws fail-loud on\n * a duplicate `name` or a method file missing `export const name`.\n */\nexport async function loadApiRoutes(projectRoot: string): Promise<RouteTable> {\n  const apiDir = join(projectRoot, 'api');\n  const endpoints: Endpoint[] = [];\n  await walk(apiDir, [], endpoints);\n\n  // Deterministic order — stable diagnostics + first-defined wins nothing (dups throw).\n  endpoints.sort((a, b) => routeKey(a.method, a.pattern).localeCompare(routeKey(b.method, b.pattern)));\n\n  const byMethodPattern = new Map<string, Endpoint>();\n  const byName = new Map<string, Endpoint>();\n  for (const ep of endpoints) {\n    const key = routeKey(ep.method, ep.pattern);\n    if (byMethodPattern.has(key)) {\n      throw new Error(`[api-loader] duplicate route \"${key}\" (${ep.file})`);\n    }\n    byMethodPattern.set(key, ep);\n    const existing = byName.get(ep.name);\n    if (existing) {\n      throw new Error(\n        `[api-loader] duplicate endpoint name \"${ep.name}\" — ${existing.file} and ${ep.file}`,\n      );\n    }\n    byName.set(ep.name, ep);\n  }\n\n  return { endpoints, byMethodPattern, byName };\n}\n\n/** Recursively collect method files, tracking the route segments so far. */\nasync function walk(dir: string, segments: string[], out: Endpoint[]): Promise<void> {\n  let entries: Dirent[];\n  try {\n    entries = await readdir(dir, { withFileTypes: true });\n  } catch (err) {\n    if ((err as NodeJS.ErrnoException).code === 'ENOENT') return; // no api/ dir\n    throw err;\n  }\n\n  for (const entry of entries) {\n    const abs = join(dir, entry.name);\n    if (entry.isDirectory()) {\n      await walk(abs, [...segments, entry.name], out);\n      continue;\n    }\n    if (!entry.isFile()) continue;\n    const m = METHOD_FILE_RE.exec(entry.name);\n    if (!m) continue; // ignore non-method .ts (helpers/types) and other files\n    const method = m[1] as HttpMethod;\n    const { pattern, paramNames } = patternFromSegments(segments);\n    const source = await readFile(abs, 'utf8');\n    const name = parseExportedString(source, 'name');\n    if (!name) {\n      throw new Error(\n        `[api-loader] ${abs}: missing \\`export const name\\` (every endpoint must be named)`,\n      );\n    }\n    const description = parseExportedString(source, 'description');\n    out.push({ method, pattern, paramNames, file: abs, name, description });\n  }\n}\n\n/** Build a `/`-rooted route pattern (`[id]` → `:id`) + its param names. */\nfunction patternFromSegments(segments: string[]): { pattern: string; paramNames: string[] } {\n  const paramNames: string[] = [];\n  const parts = segments.map((seg) => {\n    const dyn = /^\\[(.+)\\]$/.exec(seg);\n    if (dyn) {\n      paramNames.push(dyn[1]);\n      return `:${dyn[1]}`;\n    }\n    return seg;\n  });\n  return { pattern: '/' + parts.join('/'), paramNames };\n}\n\n/**\n * Static-parse `export const <key> = '<value>'` (single/double/backtick quotes)\n * from handler source, without evaluating it. Returns `undefined` if absent.\n */\nfunction parseExportedString(source: string, key: string): string | undefined {\n  const re = new RegExp(`export\\\\s+const\\\\s+${key}\\\\s*=\\\\s*(['\"\\`])((?:\\\\\\\\.|(?!\\\\1).)*)\\\\1`);\n  const m = re.exec(source);\n  return m ? m[2] : undefined;\n}\n\n/**\n * Match a concrete request `path` against a method's routes. Returns the matched\n * endpoint + extracted path params (`Record<string, string>`), or `null`.\n */\nexport function matchRoute(\n  table: RouteTable,\n  method: string,\n  path: string,\n): { endpoint: Endpoint; params: Record<string, string> } | null {\n  const reqSegs = splitPath(path);\n  for (const ep of table.endpoints) {\n    if (ep.method !== method) continue;\n    const patSegs = splitPath(ep.pattern);\n    if (patSegs.length !== reqSegs.length) continue;\n    const params: Record<string, string> = {};\n    let ok = true;\n    for (let i = 0; i < patSegs.length; i++) {\n      const p = patSegs[i];\n      if (p.startsWith(':')) params[p.slice(1)] = decodeURIComponent(reqSegs[i]);\n      else if (p !== reqSegs[i]) {\n        ok = false;\n        break;\n      }\n    }\n    if (ok) return { endpoint: ep, params };\n  }\n  return null;\n}\n\n/** Split a `/`-path into non-empty segments (the root `/` → `[]`). */\nfunction splitPath(path: string): string[] {\n  return path.split('/').filter((s) => s.length > 0);\n}\n","numLines":187,"startLine":1,"totalLines":187}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_pmlReKudxOIRyOOgDAGwXb2W","type":"tool_result","content":"1\t# File formats\n2\t\n3\tThe exact on-disk shapes each authoring global writes.\n4\t\n5\t## Table schema — `writeTableSchema(name, schema)` → `database/<name>.json`\n6\t\n7\t`name` is a lowercase slug. `schema` is an object:\n8\t\n9\t```json\n10\t{\n11\t  \"title\": \"Feed items\",\n12\t  \"description\": \"One personalized item in the user's feed.\",\n13\t  \"columns\": {\n14\t    \"id\":        { \"type\": \"string\",  \"description\": \"unique id\", \"primaryKey\": true, \"generated\": \"uuid\" },\n15\t    \"title\":     { \"type\": \"string\",  \"description\": \"headline\", \"required\": true },\n16\t    \"url\":       { \"type\": \"string\",  \"description\": \"source URL\", \"required\": true, \"unique\": true },\n17\t    \"score\":     { \"type\": \"number\",  \"description\": \"relevance rank\", \"default\": 0 },\n18\t    \"read\":      { \"type\": \"boolean\", \"description\": \"opened yet\", \"default\": false },\n19\t    \"createdAt\": { \"type\": \"date\",    \"description\": \"when it entered the feed\", \"generated\": \"now\" }\n20\t  },\n21\t  \"relations\": {\n22\t    \"comments\": { \"hasMany\": \"comments\", \"via\": \"feedItemId\", \"description\": \"notes attached\" }\n23\t  }\n24\t}\n25\t```\n26\t\n27\t- Column `type`: `string` | `number` | `boolean` | `date` | `json`.\n28\t- Exactly one column sets `primaryKey: true` (use `generated: \"uuid\"`). `generated` is `uuid`|`now`.\n29\t- `references`: `{ table, column?, onDelete? }` (`onDelete`: `cascade`|`setNull`|`restrict`) is a\n30\t  real SQLite foreign key.\n31\t- Relations: `belongsTo` (this table holds the FK, `via` = its column) or `hasMany` (target holds\n32\t  the FK back). Both need a `description`. Validation fails loud on any missing description.\n33\t\n34\t## API handler — `writeApi('<name>/<METHOD>', src)` → `api/<name>/<METHOD>.ts`\n35\t\n36\tThe route's LAST segment is the HTTP method (`GET`|`POST`|`PUT`|`PATCH`|`DELETE`); the rest is the\n37\tendpoint path. `src` is a full ESM handler module:\n38\t\n39\t```ts\n40\texport const name = 'items-list';\n41\texport const description = 'List all items, newest first.';\n42\texport interface Input {}\n43\texport interface Output { items: { id: string; title: string }[] }\n44\texport default async function handler(input: Input, ctx: { db: any }): Promise<Output> {\n45\t  const items = await ctx.db.query('items', { orderBy: { column: 'createdAt', dir: 'desc' } });\n46\t  return { items };\n47\t}\n48\t```\n49\t\n50\t`ctx.db` is the async data API: `await ctx.db.query/insert/update/remove/tables(...)`. `Input`/\n51\t`Output` become the endpoint's JSON-Schema contract. `import { HttpError } from '@app/runtime'` to\n52\tsignal 4xx/5xx.\n53\t\n54\t## Page — `writePage(route, src)` → `pages/<route>.tsx`\n55\t\n56\t`route` is `index` (root) or a path like `items/[id]` (a `[seg]` is dynamic, read via\n57\t`useParams`). `src` is a full `.tsx` module with a default-exported component. Data hooks come from\n58\t`@app/runtime`: `useApi(name, input?, opts?)` (GET/DELETE reads → `{ data, error, isLoading,\n59\trefetch }`), `useApiMutation(name, { invalidates? })` (POST/PATCH/PUT → `{ mutate }`), `apiCall`,\n60\t`Link`, `navigate`. Style with design tokens ONLY.\n61\t\n62\t## Hook — `writeHook(slug, src)` → `hooks/<slug>.ts`\n63\t\n64\tDefault export is one of:\n65\t\n66\t```ts\n67\t// cron — time-based\n68\texport default { type: 'cron', every: '30m', trigger: 'space/agent#action' };\n69\t// database — write-triggered (declarative)\n70\texport default { type: 'database', on: { table: 'raw_items', event: 'insert' }, trigger: 'space/agent#action' };\n71\t// database — imperative\n72\texport default {\n73\t  type: 'database', on: { table: 'raw_items', event: 'insert' },\n74\t  handler: async ({ row, db, delegate }) => { /* ... */ },\n75\t};\n76\t```\n77\t\n78\t`every` is `<n>m|h|d` (mutually exclusive with `daily: 'HH:MM'`). A database hook's `event` is\n79\t`insert`|`update`|`remove`, and it has EXACTLY ONE of `trigger` / `handler`.\n80\t"}]},"parent_tool_use_id":null,"session_id":"a5bdaf5f-36c3-4bd0-a7f1-82b85daace12","uuid":"9bb44f99-4405-4b50-8aad-e5710c306795","timestamp":"2026-07-16T09:10:46.170Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/system-spaces/system-appbuilder/knowledge/app_building/model/file-formats.md","content":"# File formats\n\nThe exact on-disk shapes each authoring global writes.\n\n## Table schema — `writeTableSchema(name, schema)` → `database/<name>.json`\n\n`name` is a lowercase slug. `schema` is an object:\n\n```json\n{\n  \"title\": \"Feed items\",\n  \"description\": \"One personalized item in the user's feed.\",\n  \"columns\": {\n    \"id\":        { \"type\": \"string\",  \"description\": \"unique id\", \"primaryKey\": true, \"generated\": \"uuid\" },\n    \"title\":     { \"type\": \"string\",  \"description\": \"headline\", \"required\": true },\n    \"url\":       { \"type\": \"string\",  \"description\": \"source URL\", \"required\": true, \"unique\": true },\n    \"score\":     { \"type\": \"number\",  \"description\": \"relevance rank\", \"default\": 0 },\n    \"read\":      { \"type\": \"boolean\", \"description\": \"opened yet\", \"default\": false },\n    \"createdAt\": { \"type\": \"date\",    \"description\": \"when it entered the feed\", \"generated\": \"now\" }\n  },\n  \"relations\": {\n    \"comments\": { \"hasMany\": \"comments\", \"via\": \"feedItemId\", \"description\": \"notes attached\" }\n  }\n}\n```\n\n- Column `type`: `string` | `number` | `boolean` | `date` | `json`.\n- Exactly one column sets `primaryKey: true` (use `generated: \"uuid\"`). `generated` is `uuid`|`now`.\n- `references`: `{ table, column?, onDelete? }` (`onDelete`: `cascade`|`setNull`|`restrict`) is a\n  real SQLite foreign key.\n- Relations: `belongsTo` (this table holds the FK, `via` = its column) or `hasMany` (target holds\n  the FK back). Both need a `description`. Validation fails loud on any missing description.\n\n## API handler — `writeApi('<name>/<METHOD>', src)` → `api/<name>/<METHOD>.ts`\n\nThe route's LAST segment is the HTTP method (`GET`|`POST`|`PUT`|`PATCH`|`DELETE`); the rest is the\nendpoint path. `src` is a full ESM handler module:\n\n```ts\nexport const name = 'items-list';\nexport const description = 'List all items, newest first.';\nexport interface Input {}\nexport interface Output { items: { id: string; title: string }[] }\nexport default async function handler(input: Input, ctx: { db: any }): Promise<Output> {\n  const items = await ctx.db.query('items', { orderBy: { column: 'createdAt', dir: 'desc' } });\n  return { items };\n}\n```\n\n`ctx.db` is the async data API: `await ctx.db.query/insert/update/remove/tables(...)`. `Input`/\n`Output` become the endpoint's JSON-Schema contract. `import { HttpError } from '@app/runtime'` to\nsignal 4xx/5xx.\n\n## Page — `writePage(route, src)` → `pages/<route>.tsx`\n\n`route` is `index` (root) or a path like `items/[id]` (a `[seg]` is dynamic, read via\n`useParams`). `src` is a full `.tsx` module with a default-exported component. Data hooks come from\n`@app/runtime`: `useApi(name, input?, opts?)` (GET/DELETE reads → `{ data, error, isLoading,\nrefetch }`), `useApiMutation(name, { invalidates? })` (POST/PATCH/PUT → `{ mutate }`), `apiCall`,\n`Link`, `navigate`. Style with design tokens ONLY.\n\n## Hook — `writeHook(slug, src)` → `hooks/<slug>.ts`\n\nDefault export is one of:\n\n```ts\n// cron — time-based\nexport default { type: 'cron', every: '30m', trigger: 'space/agent#action' };\n// database — write-triggered (declarative)\nexport default { type: 'database', on: { table: 'raw_items', event: 'insert' }, trigger: 'space/agent#action' };\n// database — imperative\nexport default {\n  type: 'database', on: { table: 'raw_items', event: 'insert' },\n  handler: async ({ row, db, delegate }) => { /* ... */ },\n};\n```\n\n`every` is `<n>m|h|d` (mutually exclusive with `daily: 'HH:MM'`). A database hook's `event` is\n`insert`|`update`|`remove`, and it has EXACTLY ONE of `trigger` / `handler`.\n","numLines":80,"startLine":1,"totalLines":80}}}
