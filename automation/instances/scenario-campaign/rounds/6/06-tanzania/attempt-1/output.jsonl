{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_QJTf9mkdb5OpKP1P2Xc3T6hU","type":"tool_result","content":"1\t/**\n2\t * Attachment pipeline (keyless). Two layers:\n3\t *   - assembleParts: the pure transform from stored uploads → model parts +\n4\t *     trace metadata + transcript blocks (the heart of the vision/audio/file\n5\t *     feature), tested exhaustively without any session or disk.\n6\t *   - SessionManager.saveUpload/readUpload: the disk round-trip an HTTP upload\n7\t *     and the serving route rely on.\n8\t */\n9\timport { describe, it, expect, afterAll } from 'vitest';\n10\timport { mkdtemp, rm } from 'node:fs/promises';\n11\timport { join } from 'node:path';\n12\timport { tmpdir } from 'node:os';\n13\timport { createMockStreamFn } from '@lmthing/core';\n14\timport type { StreamOpts } from '@lmthing/core';\n15\timport { SessionManager } from './session-manager.js';\n16\timport { assembleParts, type UploadMeta } from './uploads.js';\n17\t\n18\tconst tmpDirs: string[] = [];\n19\tafterAll(async () => {\n20\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n21\t});\n22\t\n23\tconst meta = (m: Partial<UploadMeta> & Pick<UploadMeta, 'id' | 'kind' | 'mediaType'>): UploadMeta => m;\n24\t\n25\tdescribe('assembleParts', () => {\n26\t  it('maps an image to a delegatable attachment carrying its id + image part', () => {\n27\t    const r = assembleParts([\n28\t      { meta: meta({ id: 'i1', kind: 'image', mediaType: 'image/png', filename: 'a.png' }), bytes: new Uint8Array([1, 2, 3]) },\n29\t    ]);\n30\t    expect(r.attachments).toEqual([\n31\t      { id: 'i1', kind: 'image', mediaType: 'image/png', filename: 'a.png', part: { type: 'image', image: `data:image/png;base64,${Buffer.from([1, 2, 3]).toString('base64')}`, mediaType: 'image/png' } },\n32\t    ]);\n33\t    expect(r.traceAttachments).toEqual([\n34\t      { kind: 'image', url: '/api/uploads/i1', mediaType: 'image/png', filename: 'a.png' },\n35\t    ]);\n36\t    expect(r.transcripts).toEqual([]);\n37\t  });\n38\t\n39\t  it('carries a binary doc (PDF) as an id-only attachment — no text, no part (read on demand)', () => {\n40\t    const r = assembleParts([\n41\t      { meta: meta({ id: 'f1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf', text: 'the mascot is Pico' }), bytes: new Uint8Array([9]) },\n42\t    ]);\n43\t    // The delegated files agent fetches content itself via readDocument(id): the\n44\t    // attachment carries ONLY its id + metadata, never inlined text or a file part.\n45\t    expect(r.attachments).toEqual([\n46\t      { id: 'f1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf' },\n47\t    ]);\n48\t    expect(r.attachments[0]!.part).toBeUndefined(); // NEVER a file part — no chat model reads one\n49\t    expect(r.attachments[0]!.text).toBeUndefined(); // NEVER inlined — read via readDocument(id)\n50\t  });\n51\t\n52\t  it('carries a text file as an id-only attachment too (uniform readDocument path)', () => {\n53\t    const r = assembleParts([\n54\t      { meta: meta({ id: 't1', kind: 'file', mediaType: 'text/plain', filename: 'notes.txt' }), bytes: new TextEncoder().encode('the code is BANANA42') },\n55\t    ]);\n56\t    expect(r.attachments).toEqual([\n57\t      { id: 't1', kind: 'file', mediaType: 'text/plain', filename: 'notes.txt' },\n58\t    ]);\n59\t    expect(r.attachments[0]!.part).toBeUndefined();\n60\t    expect(r.attachments[0]!.text).toBeUndefined(); // text files ALSO go through readDocument now\n61\t    expect(r.transcripts).toEqual([]);\n62\t    expect(r.traceAttachments[0]).toMatchObject({ kind: 'file', mediaType: 'text/plain' });\n63\t  });\n64\t\n65\t  it('turns audio into a transcript block (no attachment, no bytes to the model)', () => {\n66\t    const r = assembleParts([\n67\t      { meta: meta({ id: 'a1', kind: 'audio', mediaType: 'audio/mpeg', filename: 'clip.mp3', transcript: 'hello there' }), bytes: null },\n68\t    ]);\n69\t    expect(r.attachments).toEqual([]); // audio → text, handled by the text model directly\n70\t    expect(r.transcripts).toEqual(['[Transcript of clip.mp3]:\\nhello there']);\n71\t    expect(r.traceAttachments[0]).toMatchObject({ kind: 'audio', url: '/api/uploads/a1', transcript: 'hello there' });\n72\t  });\n73\t\n74\t  it('skips missing metadata and image bytes that failed to read', () => {\n75\t    const r = assembleParts([\n76\t      { meta: null, bytes: null },\n77\t      { meta: meta({ id: 'i2', kind: 'image', mediaType: 'image/png' }), bytes: null },\n78\t    ]);\n79\t    expect(r.attachments).toEqual([]);\n80\t    expect(r.traceAttachments).toHaveLength(1); // the image's metadata still surfaces to the UI\n81\t  });\n82\t\n83\t  it('handles a mixed batch (image + pdf + audio) preserving order', () => {\n84\t    const r = assembleParts([\n85\t      { meta: meta({ id: 'i', kind: 'image', mediaType: 'image/jpeg' }), bytes: new Uint8Array([1]) },\n86\t      { meta: meta({ id: 'f', kind: 'file', mediaType: 'application/pdf' }), bytes: new Uint8Array([2]) },\n87\t      { meta: meta({ id: 'a', kind: 'audio', mediaType: 'audio/wav', transcript: 'spoken' }), bytes: null },\n88\t    ]);\n89\t    expect(r.attachments.map((a) => a.kind)).toEqual(['image', 'file']);\n90\t    // image → image part; pdf → an id-only attachment (read on demand), never a part/text\n91\t    expect(r.attachments[0]!.part?.type).toBe('image');\n92\t    expect(r.attachments[1]!.part).toBeUndefined();\n93\t    expect(r.attachments[1]!.text).toBeUndefined();\n94\t    expect(r.transcripts).toEqual(['[Transcript of audio]:\\nspoken']);\n95\t    expect(r.traceAttachments.map((t) => t.kind)).toEqual(['image', 'file', 'audio']);\n96\t  });\n97\t});\n98\t\n99\tdescribe('SessionManager upload storage', () => {\n100\t  async function makeManager(): Promise<SessionManager> {\n101\t    const root = await mkdtemp(join(tmpdir(), 'lmthing-attach-root-'));\n102\t    tmpDirs.push(root);\n103\t    return new SessionManager({\n104\t      streamFn: createMockStreamFn((_o: StreamOpts) => ''),\n105\t      lmthingRoot: root,\n106\t      snapshotsDir: join(root, 'snaps'),\n107\t    });\n108\t  }\n109\t\n110\t  it('stores an upload and serves it back with its media type', async () => {\n111\t    const manager = await makeManager();\n112\t    const ref = await manager.saveUpload({\n113\t      bytes: Buffer.from([0x89, 0x50, 0x4e, 0x47]),\n114\t      mediaType: 'image/png',\n115\t      filename: 'shot.png',\n116\t    });\n117\t    expect(ref.kind).toBe('image');\n118\t    expect(ref.url).toBe(`/api/uploads/${ref.id}`);\n119\t\n120\t    const served = await manager.readUpload(ref.id);\n121\t    expect(served?.mediaType).toBe('image/png');\n122\t    expect(Array.from(served!.bytes)).toEqual([0x89, 0x50, 0x4e, 0x47]);\n123\t  });\n124\t\n125\t  it('returns null when serving an unknown id', async () => {"}]},"parent_tool_use_id":null,"session_id":"cfe78b6a-97f2-4499-9269-8aedfbe3c777","uuid":"65c3c7a7-0d5d-4e2a-a7a2-d9adf3d0e57f","timestamp":"2026-07-15T20:51:07.475Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/attachments.test.ts","content":"/**\n * Attachment pipeline (keyless). Two layers:\n *   - assembleParts: the pure transform from stored uploads → model parts +\n *     trace metadata + transcript blocks (the heart of the vision/audio/file\n *     feature), tested exhaustively without any session or disk.\n *   - SessionManager.saveUpload/readUpload: the disk round-trip an HTTP upload\n *     and the serving route rely on.\n */\nimport { describe, it, expect, afterAll } from 'vitest';\nimport { mkdtemp, rm } from 'node:fs/promises';\nimport { join } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport { createMockStreamFn } from '@lmthing/core';\nimport type { StreamOpts } from '@lmthing/core';\nimport { SessionManager } from './session-manager.js';\nimport { assembleParts, type UploadMeta } from './uploads.js';\n\nconst tmpDirs: string[] = [];\nafterAll(async () => {\n  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n});\n\nconst meta = (m: Partial<UploadMeta> & Pick<UploadMeta, 'id' | 'kind' | 'mediaType'>): UploadMeta => m;\n\ndescribe('assembleParts', () => {\n  it('maps an image to a delegatable attachment carrying its id + image part', () => {\n    const r = assembleParts([\n      { meta: meta({ id: 'i1', kind: 'image', mediaType: 'image/png', filename: 'a.png' }), bytes: new Uint8Array([1, 2, 3]) },\n    ]);\n    expect(r.attachments).toEqual([\n      { id: 'i1', kind: 'image', mediaType: 'image/png', filename: 'a.png', part: { type: 'image', image: `data:image/png;base64,${Buffer.from([1, 2, 3]).toString('base64')}`, mediaType: 'image/png' } },\n    ]);\n    expect(r.traceAttachments).toEqual([\n      { kind: 'image', url: '/api/uploads/i1', mediaType: 'image/png', filename: 'a.png' },\n    ]);\n    expect(r.transcripts).toEqual([]);\n  });\n\n  it('carries a binary doc (PDF) as an id-only attachment — no text, no part (read on demand)', () => {\n    const r = assembleParts([\n      { meta: meta({ id: 'f1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf', text: 'the mascot is Pico' }), bytes: new Uint8Array([9]) },\n    ]);\n    // The delegated files agent fetches content itself via readDocument(id): the\n    // attachment carries ONLY its id + metadata, never inlined text or a file part.\n    expect(r.attachments).toEqual([\n      { id: 'f1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf' },\n    ]);\n    expect(r.attachments[0]!.part).toBeUndefined(); // NEVER a file part — no chat model reads one\n    expect(r.attachments[0]!.text).toBeUndefined(); // NEVER inlined — read via readDocument(id)\n  });\n\n  it('carries a text file as an id-only attachment too (uniform readDocument path)', () => {\n    const r = assembleParts([\n      { meta: meta({ id: 't1', kind: 'file', mediaType: 'text/plain', filename: 'notes.txt' }), bytes: new TextEncoder().encode('the code is BANANA42') },\n    ]);\n    expect(r.attachments).toEqual([\n      { id: 't1', kind: 'file', mediaType: 'text/plain', filename: 'notes.txt' },\n    ]);\n    expect(r.attachments[0]!.part).toBeUndefined();\n    expect(r.attachments[0]!.text).toBeUndefined(); // text files ALSO go through readDocument now\n    expect(r.transcripts).toEqual([]);\n    expect(r.traceAttachments[0]).toMatchObject({ kind: 'file', mediaType: 'text/plain' });\n  });\n\n  it('turns audio into a transcript block (no attachment, no bytes to the model)', () => {\n    const r = assembleParts([\n      { meta: meta({ id: 'a1', kind: 'audio', mediaType: 'audio/mpeg', filename: 'clip.mp3', transcript: 'hello there' }), bytes: null },\n    ]);\n    expect(r.attachments).toEqual([]); // audio → text, handled by the text model directly\n    expect(r.transcripts).toEqual(['[Transcript of clip.mp3]:\\nhello there']);\n    expect(r.traceAttachments[0]).toMatchObject({ kind: 'audio', url: '/api/uploads/a1', transcript: 'hello there' });\n  });\n\n  it('skips missing metadata and image bytes that failed to read', () => {\n    const r = assembleParts([\n      { meta: null, bytes: null },\n      { meta: meta({ id: 'i2', kind: 'image', mediaType: 'image/png' }), bytes: null },\n    ]);\n    expect(r.attachments).toEqual([]);\n    expect(r.traceAttachments).toHaveLength(1); // the image's metadata still surfaces to the UI\n  });\n\n  it('handles a mixed batch (image + pdf + audio) preserving order', () => {\n    const r = assembleParts([\n      { meta: meta({ id: 'i', kind: 'image', mediaType: 'image/jpeg' }), bytes: new Uint8Array([1]) },\n      { meta: meta({ id: 'f', kind: 'file', mediaType: 'application/pdf' }), bytes: new Uint8Array([2]) },\n      { meta: meta({ id: 'a', kind: 'audio', mediaType: 'audio/wav', transcript: 'spoken' }), bytes: null },\n    ]);\n    expect(r.attachments.map((a) => a.kind)).toEqual(['image', 'file']);\n    // image → image part; pdf → an id-only attachment (read on demand), never a part/text\n    expect(r.attachments[0]!.part?.type).toBe('image');\n    expect(r.attachments[1]!.part).toBeUndefined();\n    expect(r.attachments[1]!.text).toBeUndefined();\n    expect(r.transcripts).toEqual(['[Transcript of audio]:\\nspoken']);\n    expect(r.traceAttachments.map((t) => t.kind)).toEqual(['image', 'file', 'audio']);\n  });\n});\n\ndescribe('SessionManager upload storage', () => {\n  async function makeManager(): Promise<SessionManager> {\n    const root = await mkdtemp(join(tmpdir(), 'lmthing-attach-root-'));\n    tmpDirs.push(root);\n    return new SessionManager({\n      streamFn: createMockStreamFn((_o: StreamOpts) => ''),\n      lmthingRoot: root,\n      snapshotsDir: join(root, 'snaps'),\n    });\n  }\n\n  it('stores an upload and serves it back with its media type', async () => {\n    const manager = await makeManager();\n    const ref = await manager.saveUpload({\n      bytes: Buffer.from([0x89, 0x50, 0x4e, 0x47]),\n      mediaType: 'image/png',\n      filename: 'shot.png',\n    });\n    expect(ref.kind).toBe('image');\n    expect(ref.url).toBe(`/api/uploads/${ref.id}`);\n\n    const served = await manager.readUpload(ref.id);\n    expect(served?.mediaType).toBe('image/png');\n    expect(Array.from(served!.bytes)).toEqual([0x89, 0x50, 0x4e, 0x47]);\n  });\n\n  it('returns null when serving an unknown id', async () => {","numLines":125,"startLine":1,"totalLines":130}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_qwn3AnbT8fQXQWAZ6N5UBIjd","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * run-yaml.mjs — the GENERIC scenario runner.\n4\t *\n5\t * Plays a declarative `scenario.yaml` (persona · promise · invariants · steps) against a LOCAL\n6\t * `lmthing serve`, driving the pod through the harness exactly as the /chat SPA would, and writes\n7\t * per-step EVIDENCE (the execution trace + the real spaces/DB/app state after each step) for the\n8\t * JUDGE to read. It does NOT judge — the judge (see automation/instances/scenario-campaign/judge.md)\n9\t * reads this output, decides pass/fail per step, and fixes at the right rung.\n10\t *\n11\t * Local only: SCENARIO_TARGET defaults to 'local' here (getUser → http://localhost:8080, no auth).\n12\t *\n13\t *   node scenarios/run-yaml.mjs 06-tanzania                 # play the whole scenario, fresh project\n14\t *   node scenarios/run-yaml.mjs 06-tanzania --through 5     # play steps 1..5 (the judge's verify rerun)\n15\t *   node scenarios/run-yaml.mjs 06-tanzania --out <dir>     # where to write evidence (default <sc>/.run)\n16\t *\n17\t * Step verbs (see scenario-spec.md): attach[] · say · then_say · open_app · in_app_chat ·\n18\t * fresh_session · restart_pod · if_asked{} · expect[] (expect is passed through, never executed).\n19\t */\n20\timport { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync, rmSync } from 'node:fs';\n21\timport { join, resolve, dirname, basename } from 'node:path';\n22\timport { fileURLToPath } from 'node:url';\n23\timport { parseYaml } from './lib/yaml.mjs';\n24\timport { getUser } from './harness/provision.mjs';\n25\timport { Pod } from './harness/lib/pod.mjs';\n26\timport { ThingSession, approveAllConsent, denyAllConsent } from './harness/lib/thing.mjs';\n27\timport { restartLocalServer, freshLocalServer, serverUp, podRoot } from './harness/lib/local.mjs';\n28\t\n29\tprocess.env.SCENARIO_TARGET ??= 'local'; // this runner is local-only by design\n30\t\n31\tconst HERE = dirname(fileURLToPath(import.meta.url));\n32\tconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n33\t\n34\t// ── args ─────────────────────────────────────────────────────────────────────\n35\tconst argv = process.argv.slice(2);\n36\tconst flag = (name, def) => {\n37\t  const i = argv.indexOf(name);\n38\t  return i >= 0 && argv[i + 1] ? argv[i + 1] : def;\n39\t};\n40\tconst idOrPath = argv.find((a) => !a.startsWith('--')) ?? '06-tanzania';\n41\tconst verbose = argv.includes('--verbose');\n42\tconst keepProject = argv.includes('--keep-project');\n43\tconst planOnly = argv.includes('--plan'); // parse + print the plan, never connect to a pod\n44\tconst freshServer = argv.includes('--fresh-server'); // WIPE the pod data dir (0 projects) + start clean first\n45\t\n46\t// Resolve scenario dir + yaml.\n47\tconst scenarioDir = idOrPath.endsWith('.yaml')\n48\t  ? dirname(resolve(idOrPath))\n49\t  : resolve(HERE, idOrPath);\n50\tconst yamlPath = idOrPath.endsWith('.yaml') ? resolve(idOrPath) : join(scenarioDir, 'scenario.yaml');\n51\tif (!existsSync(yamlPath)) fail(`no scenario.yaml at ${yamlPath}`);\n52\tconst fixturesDir = join(scenarioDir, 'fixtures');\n53\t\n54\tconst scenario = parseYaml(readFileSync(yamlPath, 'utf8'));\n55\tconst steps = scenario.steps ?? [];\n56\tconst through = Number(flag('--through', String(steps.length)));\n57\tconst outDir = resolve(flag('--out', join(scenarioDir, '.run')));\n58\t// A fresh server means an empty runtime root, so the stable scenario project id is collision-free\n59\t// and keeps evidence readable. Without --fresh-server (dev re-runs on a dirty root) a unique suffix\n60\t// avoids clobbering an existing project.\n61\tconst projectId = flag('--project', freshServer ? (scenario.project ?? scenario.id) : `${scenario.project ?? scenario.id}-${Date.now().toString(36)}`);\n62\t\n63\tmkdirSync(outDir, { recursive: true });\n64\tconst traceMd = [];\n65\tfunction log(...a) {\n66\t  if (verbose) console.log('[run-yaml]', ...a);\n67\t}\n68\tfunction fail(msg) {\n69\t  console.error(`run-yaml: ${msg}`);\n70\t  process.exit(1);\n71\t}\n72\tfunction readdirSyncSafe(dir) {\n73\t  try {\n74\t    return readdirSync(dir);\n75\t  } catch {\n76\t    return [];\n77\t  }\n78\t}\n79\t\n80\t// ── ask handling: the driver answers in-persona; the JUDGE later scores the ask ────────────────\n81\t// A step's `if_asked` map + the scenario `knows` list ground the load-bearing answers. Consent is\n82\t// approved by default (a step may set `deny_consent: true`). Every ask + how it was answered is\n83\t// recorded so the judge can score whether asking was correct (and whether the answer was right).\n84\tlet currentStep = {};\n85\tconst asksThisStep = [];\n86\tfunction onAsk(descriptor) {\n87\t  const text = JSON.stringify(descriptor ?? {});\n88\t  // Consent cards: approve unless the step opts into denial.\n89\t  if (descriptor?.type === 'ConsentCard') {\n90\t    const answer = currentStep.deny_consent ? false : true;\n91\t    asksThisStep.push({ kind: 'consent', answer, descriptor });\n92\t    return answer;\n93\t  }\n94\t  // Clarifying question / form: match the step's if_asked, else best-effort from its single entry.\n95\t  const ifAsked = currentStep.if_asked ?? {};\n96\t  const keys = Object.keys(ifAsked);\n97\t  let matched =\n98\t    keys.find((k) => text.toLowerCase().includes(k.toLowerCase().slice(0, 24))) ??\n99\t    (keys.length === 1 ? keys[0] : undefined);\n100\t  const answer = matched ? ifAsked[matched] : '';\n101\t  asksThisStep.push({ kind: 'question', matched: matched ?? null, answer, descriptor });\n102\t  // Return the string answer; unmatched → '' (recorded prominently so the judge sees an unhandled ask).\n103\t  return answer;\n104\t}\n105\t\n106\t// ── state capture: what the judge verifies token-in-state against ──────────────────────────────\n107\tasync function snapshot(pod) {\n108\t  const snap = { spaces: [], appTables: {}, appManifest: null, error: null };\n109\t  try {\n110\t    const sp = await pod.listSpaces(projectId).catch(() => null);\n111\t    snap.spaces = (sp?.spaces ?? sp ?? []).map((s) => s.slug ?? s.name ?? s.id ?? s);\n112\t  } catch (e) {\n113\t    snap.error = String(e?.message ?? e);\n114\t  }\n115\t  try {\n116\t    const man = await pod.appManifest(projectId).catch(() => null);\n117\t    if (man) {\n118\t      snap.appManifest = { tables: man.tables ?? man.database ?? [], pages: man.pages ?? [], built: man.build?.built ?? null };\n119\t      const tableNames = (snap.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean);\n120\t      for (const t of tableNames) {\n121\t        const rows = await pod.appData(projectId, t).catch(() => null);\n122\t        if (rows) snap.appTables[t] = rows.rows ?? rows.data ?? rows;\n123\t      }\n124\t    }\n125\t  } catch (e) {\n126\t    snap.appError = String(e?.message ?? e);\n127\t  }\n128\t  return snap;\n129\t}\n130\t\n131\t// ── dry plan: parse + print the step plan, never touch a pod ───────────────────────────────────\n132\tif (planOnly) {\n133\t  console.log(`scenario ${scenario.id} — \"${scenario.title}\"  (project ${scenario.project})`);\n134\t  console.log(`persona: ${String(scenario.persona).slice(0, 90)}…`);\n135\t  console.log(`invariants: ${scenario.invariants?.length}  ·  knows: ${scenario.knows?.length}  ·  steps: ${steps.length}\\n`);\n136\t  const allFixtures = new Set();\n137\t  steps.forEach((s, i) => {\n138\t    const verbs = Object.keys(s).filter((k) => k !== 'expect');\n139\t    (s.attach ?? []).forEach((f) => allFixtures.add(f));\n140\t    const msg = (s.say ?? s.then_say ?? s.in_app_chat ?? '').toString().replace(/\\n/g, ' ').slice(0, 64);\n141\t    console.log(`  ${String(i + 1).padStart(2)}. [${verbs.join(', ')}]  ${msg}${msg.length >= 64 ? '…' : ''}`);\n142\t    if (s.attach) console.log(`       attach: ${s.attach.join(', ')}`);\n143\t    console.log(`       expect: ${s.expect?.length ?? 0}${s.if_asked ? '  if_asked: ' + Object.keys(s.if_asked).length : ''}`);\n144\t  });\n145\t  // Fixture coverage: does every file in fixtures/ get used, and does every attach exist?\n146\t  const used = [...allFixtures];\n147\t  console.log(`\\nfixtures attached across the scenario (${used.length}): ${used.join(', ')}`);\n148\t  const missing = used.filter((f) => !existsSync(join(fixturesDir, f)));\n149\t  if (missing.length) console.log(`⚠️  attached but NOT on disk: ${missing.join(', ')}`);\n150\t  try {\n151\t    const onDisk = readdirSyncSafe(fixturesDir).filter((f) => !/^(links\\.md|.*\\.txt)$/.test(f));\n152\t    const unused = onDisk.filter((f) => !allFixtures.has(f));\n153\t    if (unused.length) console.log(`⚠️  on disk but NEVER attached: ${unused.join(', ')}`);\n154\t    else console.log(`✅ every uploadable fixture on disk is attached by some step`);\n155\t  } catch { /* fixtures dir may be absent */ }\n156\t  process.exit(0);\n157\t}\n158\t\n159\t// ── main ─────────────────────────────────────────────────────────────────────────────────────\n160\t(async () => {\n161\t  log(`scenario ${scenario.id} · project ${projectId} · steps 1..${through}/${steps.length}`);\n162\t  // The RUNNER owns its own PID file (never rely on the caller's shell `$!`): a stopper does\n163\t  // `kill $(cat <out>/runner.pid)` and it is always correct. Cleared on clean exit.\n164\t  const pidFile = join(outDir, 'runner.pid');\n165\t  writeFileSync(pidFile, String(process.pid));\n166\t  process.on('exit', () => { try { rmSync(pidFile, { force: true }); } catch { /* ignore */ } });\n167\t  // Clean stale evidence from a REUSED --out dir (a stopped-then-rerun round), so a poller can't\n168\t  // read a prior run's step files / crash log as if they were this run's.\n169\t  for (const f of readdirSyncSafe(outDir)) {\n170\t    if (/^step-\\d+\\.json$/.test(f) || f === 'summary.json' || f === 'trace.md') {\n171\t      try { rmSync(join(outDir, f), { force: true }); } catch { /* ignore */ }\n172\t    }\n173\t  }\n174\t  console.log(`[run-yaml] pid ${process.pid} → ${pidFile}`);\n175\t  if (freshServer) {\n176\t    console.log('[run-yaml] --fresh-server: wiping the pod runtime root (0 projects) and starting clean…');\n177\t    await freshLocalServer();\n178\t    console.log(`[run-yaml] fresh pod root: ${podRoot()}`);\n179\t  }\n180\t  if (!(await serverUp())) fail('local server not up — run: node harness/local-server.mjs up (or pass --fresh-server)');\n181\t\n182\t  const user = await getUser(scenario.id);\n183\t  const pod = new Pod({ base: user.pod, token: user.token });\n184\t  // Correctness check: a --fresh-server pod MUST start with no USER-created projects. A clean pod\n185\t  // always has the built-in `system` and `user` projects — those are infrastructure, not state leak.\n186\t  if (freshServer) {\n187\t    const all = (await pod.listProjects().catch(() => null))?.projects ?? [];\n188\t    const builtin = new Set(['system', 'user']);\n189\t    const leaked = all.map((p) => p.id ?? p).filter((id) => !builtin.has(id));\n190\t    console.log(\n191\t      leaked.length === 0\n192\t        ? `[run-yaml] confirmed: fresh pod has no user projects (built-ins only: ${all.map((p) => p.id ?? p).join(', ')})`\n193\t        : `[run-yaml] WARNING: fresh pod already has leaked project(s): ${leaked.join(', ')} — expected none`,\n194\t    );\n195\t  }\n196\t  // Fresh project (unique id per run unless --project pins one).\n197\t  try {\n198\t    await pod.createProject(projectId);\n199\t  } catch (e) {\n200\t    log(`createProject(${projectId}) — ${String(e?.message ?? e)} (continuing; may already exist)`);\n201\t  }\n202\t\n203\t  let thing = new ThingSession(pod, { projectId, onAsk, verbose });\n204\t  await thing.start();\n205\t\n206\t  const results = [];\n207\t  for (let n = 0; n < Math.min(through, steps.length); n++) {\n208\t    const step = steps[n];\n209\t    currentStep = step;\n210\t    asksThisStep.length = 0;\n211\t    const num = n + 1;\n212\t    const rec = { step: num, verbs: Object.keys(step).filter((k) => k !== 'expect'), expect: step.expect ?? [], turns: [], asks: [], notes: [] };\n213\t    log(`── step ${num}: ${rec.verbs.join(', ')}`);\n214\t\n215\t    try {\n216\t      if (step.fresh_session) {\n217\t        thing = new ThingSession(pod, { projectId, onAsk, verbose });\n218\t        await thing.start();\n219\t        await thing.syncToTail();\n220\t        rec.notes.push('started a fresh session (zero history)');\n221\t      }\n222\t      if (step.restart_pod) {\n223\t        rec.notes.push('restarting local server…');\n224\t        await restartLocalServer();\n225\t        for (let i = 0; i < 40 && !(await serverUp()); i++) await sleep(500);\n226\t        rec.notes.push((await serverUp()) ? 'server back up' : 'server did NOT come back up');\n227\t      }\n228\t\n229\t      // The message(s) for this step, with attachments if any.\n230\t      if (step.say != null) {\n231\t        let turn;\n232\t        if (Array.isArray(step.attach) && step.attach.length) {\n233\t          const refs = [];\n234\t          for (const f of step.attach) {\n235\t            const p = join(fixturesDir, f);\n236\t            if (!existsSync(p)) {\n237\t              rec.notes.push(`MISSING FIXTURE: ${f}`);\n238\t              continue;\n239\t            }\n240\t            refs.push(await pod.upload(p));\n241\t          }\n242\t          rec.attached = step.attach;\n243\t          turn = await thing.sendWithAttachments(step.say, refs);\n244\t        } else {\n245\t          turn = await thing.send(step.say);\n246\t        }\n247\t        rec.turns.push(summarizeTurn(turn, step.say));\n248\t      }\n249\t      if (step.then_say != null) {\n250\t        const t = await thing.send(step.then_say);\n251\t        rec.turns.push(summarizeTurn(t, step.then_say));\n252\t      }\n253\t      if (step.in_app_chat != null) {\n254\t        // The in-app chat is a project-scoped THING session with authoring caps — same