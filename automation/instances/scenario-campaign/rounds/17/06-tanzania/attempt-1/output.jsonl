{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_vBx149v4StWOjnIpgCSfZ62x","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join, resolve } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { loadTasklist, extractCodeNodeMeta } from './tasklist-load.js';\n6\timport { loadSpace } from './load.js';\n7\t\n8\t/**\n9\t * Code-node loading (plan step S2): a `NN-<id>.ts` file beside the `.md` nodes is\n10\t * a `kind:'code'` TaskNode whose `node` metadata is extracted STATICALLY (no\n11\t * import/execution — core stays free of any transpile/worker runtime). Its\n12\t * id/dependsOn/condition/forEach/output behave identically to an md node's.\n13\t */\n14\t\n15\tconst tmpDirs: string[] = [];\n16\tafterAll(async () => {\n17\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n18\t});\n19\t\n20\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n21\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-codeload-'));\n22\t  tmpDirs.push(dir);\n23\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n24\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n25\t  const tl = join(dir, 'tasklists', 'flow');\n26\t  await mkdir(tl, { recursive: true });\n27\t  for (const [name, contents] of Object.entries(files)) {\n28\t    await writeFile(join(tl, name), contents, 'utf8');\n29\t  }\n30\t  return dir;\n31\t}\n32\t\n33\tdescribe('extractCodeNodeMeta', () => {\n34\t  it('reads the `node` object literal and confirms a `run` export without executing it', () => {\n35\t    const src = `\n36\t      import { anything } from './nope.js';\n37\t      export const node = {\n38\t        id: 'summarize',\n39\t        dependsOn: ['fetch'],\n40\t        condition: \"fetch.ok == true\",\n41\t        forEach: 'fetch.items',\n42\t        output: { summary: 'string', count: 'number' },\n43\t      };\n44\t      export async function run(ctx, inputs) {\n45\t        throw new Error('run must NOT be called during load');\n46\t      }\n47\t    `;\n48\t    const { node, hasRun } = extractCodeNodeMeta(src, '/x/01-summarize.ts');\n49\t    expect(hasRun).toBe(true);\n50\t    expect(node).toEqual({\n51\t      id: 'summarize',\n52\t      dependsOn: ['fetch'],\n53\t      condition: 'fetch.ok == true',\n54\t      forEach: 'fetch.items',\n55\t      output: { summary: 'string', count: 'number' },\n56\t    });\n57\t  });\n58\t\n59\t  it('accepts an arrow-function `run` and a node without export keyword', () => {\n60\t    const src = `const node = { output: { v: 'number' } };\\nconst run = async (ctx, inputs) => ({ v: 1 });\\nexport { node, run };`;\n61\t    const { node, hasRun } = extractCodeNodeMeta(src, '/x/01-a.ts');\n62\t    expect(hasRun).toBe(true);\n63\t    expect(node).toEqual({ output: { v: 'number' } });\n64\t  });\n65\t\n66\t  it('reports hasRun=false when no run function is exported', () => {\n67\t    const { hasRun } = extractCodeNodeMeta(`export const node = {};`, '/x/01-a.ts');\n68\t    expect(hasRun).toBe(false);\n69\t  });\n70\t\n71\t  it('throws when a metadata value is not a static literal', () => {\n72\t    const src = `export const node = { output: someComputedThing() };\\nexport function run() {}`;\n73\t    expect(() => extractCodeNodeMeta(src, '/x/01-a.ts')).toThrow(/static literals/);\n74\t  });\n75\t});\n76\t\n77\tdescribe('loadTasklist with code nodes', () => {\n78\t  it('loads a mixed md + ts DAG: md node is kind:agent, ts node is kind:code with an absolute codeModulePath', async () => {\n79\t    const dir = await makeTasklistSpace({\n80\t      '01-fetch.md': `---\\nid: fetch\\noutput:\\n  items: array\\n---\\n\\nFETCH_T: gather items.`,\n81\t      '02-reduce.ts': `export const node = {\\n  dependsOn: ['fetch'],\\n  output: { total: 'number' },\\n};\\nexport async function run(ctx, inputs) {\\n  return { total: inputs.fetch.items.length };\\n}\\n`,\n82\t    });\n83\t    const tl = join(dir, 'tasklists', 'flow');\n84\t    const tasks = await loadTasklist(tl, [join(tl, '01-fetch.md'), join(tl, '02-reduce.ts')]);\n85\t\n86\t    expect(tasks['fetch']!.kind).toBe('agent');\n87\t    expect(tasks['fetch']!.codeModulePath).toBeUndefined();\n88\t\n89\t    const reduce = tasks['reduce']!;\n90\t    expect(reduce.kind).toBe('code');\n91\t    // id derived from filename (numeric prefix stripped) exactly like md nodes.\n92\t    expect(reduce.id).toBe('reduce');\n93\t    expect(reduce.dependsOn).toEqual(['fetch']);\n94\t    expect(reduce.output).toEqual({ total: 'number' });\n95\t    expect(reduce.instruction).toBe('');\n96\t    expect(reduce.codeModulePath).toBe(resolve(join(tl, '02-reduce.ts')));\n97\t  });\n98\t\n99\t  it('honours an explicit `id` in the node metadata (overriding the filename)', async () => {\n100\t    const dir = await makeTasklistSpace({\n101\t      '01-x.ts': `export const node = { id: 'custom', output: { v: 'number' } };\\nexport async function run() { return { v: 1 }; }`,\n102\t    });\n103\t    const tl = join(dir, 'tasklists', 'flow');\n104\t    const tasks = await loadTasklist(tl, [join(tl, '01-x.ts')]);\n105\t    expect(Object.keys(tasks)).toEqual(['custom']);\n106\t    expect(tasks['custom']!.kind).toBe('code');\n107\t  });\n108\t\n109\t  it('parses a per-node `capabilities:` subset off an md node', async () => {\n110\t    const dir = await makeTasklistSpace({\n111\t      '01-store.md': `---\\nid: store\\noutput:\\n  ok: boolean\\ncapabilities:\\n  - knowledge:write\\n---\\n\\nSTORE_T: persist.`,\n112\t    });\n113\t    const tl = join(dir, 'tasklists', 'flow');\n114\t    const tasks = await loadTasklist(tl, [join(tl, '01-store.md')]);\n115\t    expect(tasks['store']!.capabilities).toEqual(['knowledge:write']);\n116\t  });\n117\t\n118\t  it('throws on an unknown capability id in a node `capabilities:` list', async () => {\n119\t    const dir = await makeTasklistSpace({\n120\t      '01-x.md': `---\\nid: x\\noutput:\\n  v: number\\ncapabilities:\\n  - db:destroy\\n---\\n\\nX_T: work.`,\n121\t    });\n122\t    const tl = join(dir, 'tasklists', 'flow');\n123\t    await expect(loadTasklist(tl, [join(tl, '01-x.md')])).rejects.toThrow(/unknown capability id\\(s\\)/);\n124\t  });\n125\t\n126\t  it('throws when a .ts node has no run export', async () => {\n127\t    const dir = await makeTasklistSpace({\n128\t      '01-broken.ts': `export const node = { output: { v: 'number' } };`,\n129\t    });\n130\t    const tl = join(dir, 'tasklists', 'flow');\n131\t    await expect(loadTasklist(tl, [join(tl, '01-broken.ts')])).rejects.toThrow(/must export an async `run/);\n132\t  });\n133\t\n134\t  it('discovers .ts nodes (and their connections gate) through loadSpace → tasklists', async () => {\n135\t    const dir = await makeTasklistSpace({\n136\t      'index.md': `---\\ninput:\\n  topic: string\\nconnections:\\n  - slack\\n---\\n\\nThe flow.`,\n137\t      '01-a.md': `---\\nid: a\\noutput:\\n  v: number\\n---\\n\\nA_T: work.`,\n138\t      '02-b.ts': `export const node = { dependsOn: ['a'], output: { v: 'number' } };\\nexport async function run() { return { v: 2 }; }`,\n139\t    });\n140\t    const space = await loadSpace(dir);\n141\t    const flow = space.tasklists['flow']!;\n142\t    // Both node files are present, sorted by NN prefix (md + ts interleaved).\n143\t    expect(flow.files.map((f) => f.split('/').pop())).toEqual(['01-a.md', '02-b.ts']);\n144\t    // Tasklist-level connections gate parsed as typed data (no enforcement in core).\n145\t    expect(flow.connections).toEqual(['slack']);\n146\t  });\n147\t});\n148\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"ebf332f3-1c91-4535-b6db-c7be6d6b30ac","timestamp":"2026-07-16T06:19:13.273Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
