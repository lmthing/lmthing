ms`. `writeProjectApi` returns `{ ok, error? }`\nand validates the module at write time; rewrite and retry if `w.ok` is false. Emit one statement:\n\n```typescript\nconst ep = item;\nconst name = ep.name;\nconst table = Array.isArray(ep.tables) && ep.tables[0] ? ep.tables[0] : (plan_tables.tables[0] ? plan_tables.tables[0].name : 'items');\nconst src = [\n  \"export const name = '\" + name + \"';\",\n  \"export const description = '\" + String(ep.purpose).replace(/'/g, '') + \"';\",\n  \"export interface Input {}\",\n  \"export interface Output { items: any[] }\",\n  \"export default async function handler(_input: Input, ctx: { db: any }): Promise<Output> {\",\n  \"  const items = await ctx.db.query('\" + table + \"');\",\n  \"  return { items };\",\n  \"}\",\n].join(\"\\n\");\nconst w = writeProjectApi(ep.route, src);\ncurrentTask.resolve({ route: ep.route, name, ok: w.ok });\n```\n","newString":"export const node = {\n  id: 'implement_endpoints',\n  output: { route: 'string', name: 'string', ok: 'boolean' },\n  dependsOn: ['plan_endpoints', 'plan_tables', 'implement_tables'],\n  forEach: 'plan_endpoints.endpoints',\n};\n\ntype Endpoint = { name?: unknown; route?: unknown; purpose?: unknown; tables?: unknown };\ntype TablePlan = { name?: unknown };\n\nexport async function run(ctx: { project: { writeProjectApi(route: string, src: string): Promise<{ ok: boolean }> } }, inputs: { item?: Endpoint; plan_tables?: { tables?: TablePlan[] } }) {\n  const endpoint = inputs.item ?? {};\n  const name = typeof endpoint.name === 'string' ? endpoint.name : '';\n  const route = typeof endpoint.route === 'string' ? endpoint.route : '';\n  const tables = Array.isArray(endpoint.tables) ? endpoint.tables : [];\n  const plannedTables = Array.isArray(inputs.plan_tables?.tables) ? inputs.plan_tables.tables : [];\n  const table = typeof tables[0] === 'string'\n    ? tables[0]\n    : typeof plannedTables[0]?.name === 'string'\n      ? plannedTables[0].name\n      : 'items';\n  const descr