{
  "name": "lmthing-monorepo",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm --filter ./studio dev",
    "build": "pnpm --filter ./studio build",
    "build:pages": "pnpm --filter ./studio build:pages",
    "lint": "pnpm --filter ./studio lint",
    "preview": "pnpm --filter ./studio preview"
  },
  "devDependencies": {
    "vite-plus": "latest"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "protobufjs",
      "supabase"
    ]
  }
}