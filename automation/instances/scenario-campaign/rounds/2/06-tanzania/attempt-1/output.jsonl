{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Il254lG6wwDsn8wZe3wxJLcy","type":"tool_result","content":"1\timport { serialize } from './serialize.js';\n2\timport type { YieldRequest } from '../eval/yield.js';\n3\t\n4\texport interface InspectQuery {\n5\t  path?: string;\n6\t  slice?: [number, number];\n7\t  depth?: number;\n8\t  filter?: string;\n9\t  sample?: number;\n10\t  keys?: boolean;\n11\t  count?: boolean;\n12\t  search?: string;\n13\t}\n14\t\n15\t/**\n16\t * Create the `inspect` global function that pushes a yield request and\n17\t * returns a Promise. The turn loop resolves it and emits VARIABLES.\n18\t */\n19\texport function createInspectGlobal(\n20\t  pushYield: (req: YieldRequest) => void,\n21\t): (...args: unknown[]) => Promise<void> {\n22\t  return function inspect(...args: unknown[]): Promise<void> {\n23\t    return new Promise<void>((resolve, reject) => {\n24\t      // Process args: each arg is either a plain value or [value, query]\n25\t      const processed = args.map((arg) => {\n26\t        if (Array.isArray(arg) && arg.length === 2 && isInspectQuery(arg[1])) {\n27\t          const [value, query] = arg as [unknown, InspectQuery];\n28\t          return { value: applyQuery(value, query), query };\n29\t        }\n30\t        return { value: arg, query: undefined };\n31\t      });\n32\t\n33\t      pushYield({\n34\t        kind: 'inspect',\n35\t        args: processed,\n36\t        deferred: {\n37\t          resolve: () => resolve(),\n38\t          reject,\n39\t        },\n40\t        vmPromiseHandle: undefined,\n41\t      });\n42\t    });\n43\t  };\n44\t}\n45\t\n46\tfunction isInspectQuery(val: unknown): val is InspectQuery {\n47\t  return typeof val === 'object' && val !== null && !Array.isArray(val);\n48\t}\n49\t\n50\t/**\n51\t * Apply an InspectQuery to a value, transforming it according to the query.\n52\t */\n53\texport function applyQuery(value: unknown, query: InspectQuery): unknown {\n54\t  let result = value;\n55\t\n56\t  // path: dotted path access\n57\t  if (query.path) {\n58\t    result = getPath(result, query.path);\n59\t  }\n60\t\n61\t  // keys: return object keys\n62\t  if (query.keys && typeof result === 'object' && result !== null) {\n63\t    return Object.keys(result as object);\n64\t  }\n65\t\n66\t  // count: return length\n67\t  if (query.count) {\n68\t    if (Array.isArray(result)) return result.length;\n69\t    if (typeof result === 'string') return result.length;\n70\t    if (typeof result === 'object' && result !== null) return Object.keys(result as object).length;\n71\t    return 0;\n72\t  }\n73\t\n74\t  // search: filter array by string match\n75\t  if (query.search !== undefined && Array.isArray(result)) {\n76\t    const term = query.search.toLowerCase();\n77\t    result = (result as unknown[]).filter((item) =>\n78\t      JSON.stringify(item).toLowerCase().includes(term),\n79\t    );\n80\t  }\n81\t\n82\t  // filter: predicate expression over array items\n83\t  if (query.filter && Array.isArray(result)) {\n84\t    result = applyFilter(result as unknown[], query.filter);\n85\t  }\n86\t\n87\t  // slice: [start, end]\n88\t  if (query.slice && Array.isArray(result)) {\n89\t    result = (result as unknown[]).slice(query.slice[0], query.slice[1]);\n90\t  }\n91\t\n92\t  // sample: random sample of n items\n93\t  if (query.sample !== undefined && Array.isArray(result)) {\n94\t    const arr = result as unknown[];\n95\t    if (query.sample >= arr.length) return arr;\n96\t    const sampled: unknown[] = [];\n97\t    const indices = new Set<number>();\n98\t    while (indices.size < query.sample) {\n99\t      indices.add(Math.floor(Math.random() * arr.length));\n100\t    }\n101\t    for (const i of indices) sampled.push(arr[i]);\n102\t    result = sampled;\n103\t  }\n104\t\n105\t  return result;\n106\t}\n107\t\n108\tfunction getPath(value: unknown, path: string): unknown {\n109\t  const parts = path.split('.');\n110\t  let current = value;\n111\t  for (const part of parts) {\n112\t    if (current === null || current === undefined) return undefined;\n113\t    if (Array.isArray(current)) {\n114\t      const idx = parseInt(part, 10);\n115\t      current = (current as unknown[])[idx];\n116\t    } else if (typeof current === 'object') {\n117\t      current = (current as Record<string, unknown>)[part];\n118\t    } else {\n119\t      return undefined;\n120\t    }\n121\t  }\n122\t  return current;\n123\t}\n124\t\n125\t/**\n126\t * Very restricted predicate evaluator over array items.\n127\t * Supports: `<dotted.path> <op> <literal>` joined by AND/OR.\n128\t * Ops: == != > < >= <=\n129\t */\n130\tfunction applyFilter(arr: unknown[], filterExpr: string): unknown[] {\n131\t  return arr.filter((item) => evalPredicate(item, filterExpr));\n132\t}\n133\t\n134\tfunction evalPredicate(item: unknown, expr: string): boolean {\n135\t  // Split by OR first (lower precedence)\n136\t  const orParts = expr.split(/\\bOR\\b/);\n137\t  return orParts.some((orPart) => evalAndPredicate(item, orPart.trim()));\n138\t}\n139\t\n140\tfunction evalAndPredicate(item: unknown, expr: string): boolean {\n141\t  const andParts = expr.split(/\\bAND\\b/);\n142\t  return andParts.every((part) => evalComparison(item, part.trim()));\n143\t}\n144\t\n145\tfunction evalComparison(item: unknown, expr: string): boolean {\n146\t  const match = expr.match(/^(.+?)\\s*(==|!=|>=|<=|>|<)\\s*(.+)$/);\n147\t  if (!match) return false;\n148\t\n149\t  const [, pathStr, op, literalStr] = match as [string, string, string, string, string];\n150\t  const lhs = getPath(item, pathStr.trim());\n151\t  const rhs = parseLiteral(literalStr.trim());\n152\t\n153\t  switch (op) {\n154\t    case '==': return lhs == rhs; // eslint-disable-line eqeqeq\n155\t    case '!=': return lhs != rhs; // eslint-disable-line eqeqeq\n156\t    case '>': return (lhs as number) > (rhs as number);\n157\t    case '<': return (lhs as number) < (rhs as number);\n158\t    case '>=': return (lhs as number) >= (rhs as number);\n159\t    case '<=': return (lhs as number) <= (rhs as number);\n160\t    default: return false;\n161\t  }\n162\t}\n163\t\n164\tfunction parseLiteral(s: string): unknown {\n165\t  if (s === 'true') return true;\n166\t  if (s === 'false') return false;\n167\t  if (s === 'null') return null;\n168\t  if (/^-?\\d+(\\.\\d+)?$/.test(s)) return parseFloat(s);\n169\t  // String literal\n170\t  if ((s.startsWith('\"') && s.endsWith('\"')) || (s.startsWith(\"'\") && s.endsWith(\"'\"))) {\n171\t    return s.slice(1, -1);\n172\t  }\n173\t  return s;\n174\t}\n175\t\n176\t/**\n177\t * Format inspect results as a VARIABLES block string.\n178\t */\n179\texport function formatInspectResult(args: Array<{ value: unknown; query?: InspectQuery }>): string {\n180\t  const lines: string[] = ['VARIABLES'];\n181\t  for (let i = 0; i < args.length; i++) {\n182\t    const { value, query } = args[i]!;\n183\t    const key = query?.path ? `inspected[${i}].${query.path}` : `inspected[${i}]`;\n184\t    lines.push(`${key}: ${serialize(value)}`);\n185\t  }\n186\t  return lines.join('\\n');\n187\t}\n188\t"}]},"parent_tool_use_id":"call_0lb5WCKZ0OPAnEXw8oFAxUMW","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"99b809bd-e1c9-4f82-8a75-93210ec1074e","timestamp":"2026-07-16T22:48:23.815Z","subagent_type":"Explore","task_description":"Trace source-data loss"}
