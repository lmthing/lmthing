{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_dZL32ubM91aQC7GHfqiW8dfJ","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Harness smoke test — proves the whole chain works before any scenario burns an hour on it:\n4\t * register → pod → env → THING session → a real LLM turn → trace assertions.\n5\t *\n6\t *   node smoke.mjs [label]\n7\t *\n8\t * If this fails, no scenario can pass; fix the harness first.\n9\t */\n10\timport { Pod } from './lib/pod.mjs';\n11\timport { ThingSession, approveAllConsent } from './lib/thing.mjs';\n12\timport { Report } from './lib/report.mjs';\n13\timport { getUser } from './provision.mjs';\n14\timport { budget } from './lib/gateway.mjs';\n15\t\n16\tconst label = process.argv[2] ?? 'smoke';\n17\tconst r = new Report('smoke', 'Harness smoke test');\n18\t\n19\tr.step('provision', 'a fresh prod user with a ready pod and Azure keys loaded');\n20\tconst user = await getUser(label);\n21\tr.check('user registered', !!user.userId, user.userId);\n22\tr.check('pod reachable', !!user.pod, user.pod);\n23\t\n24\tconst pod = new Pod({ base: user.pod, token: user.token });\n25\t\n26\tr.step('pod API', 'projects + store catalog answer over the Envoy-routed origin');\n27\tconst projects = await pod.listProjects();\n28\tr.check('GET /api/projects', Array.isArray(projects.projects ?? projects), JSON.stringify(projects).slice(0, 200));\n29\tconst store = await pod.storeSpaces();\n30\tconst spaces = store.spaces ?? [];\n31\tr.check('store catalog non-empty', spaces.length > 0, `${spaces.length} spaces`);\n32\tr.note(`catalog: ${spaces.map((s) => s.id).join(', ')}`);\n33\t\n34\tr.step('THING turn', 'a real LLM turn completes and the trace shows llm calls + a display');\n35\tconst thing = new ThingSession(pod, { verbose: true, onAsk: approveAllConsent });\n36\tawait thing.start();\n37\tconst turn = await thing.send('In one sentence: what can you help me build?', { timeoutMs: 240_000 });\n38\tr.check('turn completed', true, `${(turn.durationMs / 1000).toFixed(1)}s`);\n39\tr.check('LLM was called', turn.llmCalls > 0, `${turn.llmCalls} calls`);\n40\tr.check('THING replied', turn.text.length > 0, turn.text.slice(0, 200));\n41\tr.check('no eval errors', turn.errors.length === 0, JSON.stringify(turn.errors).slice(0, 300));\n42\tr.metric('first turn', (turn.durationMs / 1000).toFixed(1), 's');\n43\tr.metric('tokens', `${turn.tokens.in} in / ${turn.tokens.out} out`);\n44\t\n45\tconst b = await budget(user.token).catch((e) => ({ error: String(e) }));\n46\tr.note(`budget: ${JSON.stringify(b)}`);\n47\t\n48\tr.save(`${new URL('.', import.meta.url).pathname}.state/smoke-report.md`);\n49\tprocess.exit(r.passed ? 0 : 1);\n50\t"}]},"parent_tool_use_id":null,"session_id":"0dcb5bd3-991a-418a-bd79-b78383bf23a4","uuid":"a5a95774-8b90-421c-99a1-fcd23684a12a","timestamp":"2026-07-14T16:41:52.974Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/smoke.mjs","content":"#!/usr/bin/env node\n/**\n * Harness smoke test — proves the whole chain works before any scenario burns an hour on it:\n * register → pod → env → THING session → a real LLM turn → trace assertions.\n *\n *   node smoke.mjs [label]\n *\n * If this fails, no scenario can pass; fix the harness first.\n */\nimport { Pod } from './lib/pod.mjs';\nimport { ThingSession, approveAllConsent } from './lib/thing.mjs';\nimport { Report } from './lib/report.mjs';\nimport { getUser } from './provision.mjs';\nimport { budget } from './lib/gateway.mjs';\n\nconst label = process.argv[2] ?? 'smoke';\nconst r = new Report('smoke', 'Harness smoke test');\n\nr.step('provision', 'a fresh prod user with a ready pod and Azure keys loaded');\nconst user = await getUser(label);\nr.check('user registered', !!user.userId, user.userId);\nr.check('pod reachable', !!user.pod, user.pod);\n\nconst pod = new Pod({ base: user.pod, token: user.token });\n\nr.step('pod API', 'projects + store catalog answer over the Envoy-routed origin');\nconst projects = await pod.listProjects();\nr.check('GET /api/projects', Array.isArray(projects.projects ?? projects), JSON.stringify(projects).slice(0, 200));\nconst store = await pod.storeSpaces();\nconst spaces = store.spaces ?? [];\nr.check('store catalog non-empty', spaces.length > 0, `${spaces.length} spaces`);\nr.note(`catalog: ${spaces.map((s) => s.id).join(', ')}`);\n\nr.step('THING turn', 'a real LLM turn completes and the trace shows llm calls + a display');\nconst thing = new ThingSession(pod, { verbose: true, onAsk: approveAllConsent });\nawait thing.start();\nconst turn = await thing.send('In one sentence: what can you help me build?', { timeoutMs: 240_000 });\nr.check('turn completed', true, `${(turn.durationMs / 1000).toFixed(1)}s`);\nr.check('LLM was called', turn.llmCalls > 0, `${turn.llmCalls} calls`);\nr.check('THING replied', turn.text.length > 0, turn.text.slice(0, 200));\nr.check('no eval errors', turn.errors.length === 0, JSON.stringify(turn.errors).slice(0, 300));\nr.metric('first turn', (turn.durationMs / 1000).toFixed(1), 's');\nr.metric('tokens', `${turn.tokens.in} in / ${turn.tokens.out} out`);\n\nconst b = await budget(user.token).catch((e) => ({ error: String(e) }));\nr.note(`budget: ${JSON.stringify(b)}`);\n\nr.save(`${new URL('.', import.meta.url).pathname}.state/smoke-report.md`);\nprocess.exit(r.passed ? 0 : 1);\n","numLines":50,"startLine":1,"totalLines":50}}}
