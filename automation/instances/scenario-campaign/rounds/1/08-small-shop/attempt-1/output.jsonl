nager = new SessionManager({\n172\t      streamFn: mockStreamFn,\n173\t      lmthingRoot: root,\n174\t      snapshotsDir: join(root, 'snapshots'),\n175\t      // Keyless build that still wires the REAL connection resolver (as\n176\t      // defaultBuildSession does) so callConnection resolves the space's descriptor.\n177\t      buildSession: (args: BuildSessionArgs) =>\n178\t        new Session(\n179\t          {\n180\t            spaceDir: args.spaceDir,\n181\t            agentSlug: args.agentSlug,\n182\t            modelAlias: 'mock',\n183\t            renderHost: args.renderHost,\n184\t            systemSpaceDirs: [],\n185\t            projectSpacesDir: args.projectSpacesDir,\n186\t            projectId: args.projectId,\n187\t            projectRoot: args.projectRoot,\n188\t            appGlobals: { callConnection: createConnectionResolver(args.projectRoot) },\n189\t            appDts: args.appDts,\n190\t          },\n191\t          { streamFn: mockStreamFn },\n192\t        ),\n193\t    });\n194\t\n195\t    const handler = createInboundHandler(manager, root);\n196\t    const { res, get } = fakeRes();\n197\t\n198\t    // A valid demo message: the emitter drops any payload without a non-bot `from.id`.\n199\t    const body = JSON.stringify({ message: { message_id: 1, chat: { id: 'c1' }, from: { id: 'u1', username: 'ada' }, text: 'hello there' } });\n200\t    const sig = 'sha256=' + createHmac('sha256', DEMO_WEBHOOK_SECRET).update(body, 'utf8').digest('hex');\n201\t\n202\t    await handler(\n203\t      fakeReq(body, { 'content-type': 'application/json', 'x-demo-signature': sig }),\n204\t      res,\n205\t      { path: 'demo' },\n206\t    );\n207\t\n208\t    // Inbound verified + the emitter produced exactly one event (fast 200 ack).\n209\t    expect(get().status).toBe(200);\n210\t\n211\t    // The dispatch to the event hook + the agent run are fire-and-forget — wait them out.\n212\t    await waitFor(() => received.length >= 1);\n213\t\n214\t    // The message payload reached the delegated handler agent (event trigger seed).\n215\t    expect(capturedPrompt).toContain('hello there');\n216\t    expect(capturedPrompt).toContain('message.received');\n217\t\n218\t    // The OUTBOUND callConnection landed on the mock provider, host-pinned to\n219\t    // DEMO_BASE_URL, Bearer DEMO_API_TOKEN attached, with the agent's reply body.\n220\t    expect(received).toHaveLength(1);\n221\t    const out = received[0]!;\n222\t    expect(out.method).toBe('POST');\n223\t    expect(out.url).toBe('/messages');\n224\t    expect(out.auth).toBe(`Bearer ${DEMO_BASE_TOKEN}`);\n225\t    expect(out.body).toEqual({ chat_id: 'c1', text: 'pong from agent' });\n226\t  });\n227\t\n228\t  it('rejects a wrongly-signed inbound (401) and never calls the provider', async () => {\n229\t    const root = await makeRootWithDemoSpace();\n230\t    process.env['INTEGRATION_DEMO_BASE_URL'] = providerBase;\n231\t    process.env['INTEGRATION_DEMO_API_TOKEN'] = DEMO_BASE_TOKEN;\n232\t    process.env['INTEGRATION_DEMO_WEBHOOK_SECRET'] = DEMO_WEBHOOK_SECRET;\n233\t    received.length = 0;\n234\t\n235\t    const manager = new SessionManager({\n236\t      streamFn: createMockStreamFn(() => ''),\n237\t      lmthingRoot: root,\n238\t      snapshotsDir: join(root, 'snapshots'),\n239\t      buildSession: (args: BuildSessionArgs) =>\n240\t        new Session(\n241\t          { spaceDir: args.spaceDir, agentSlug: args.agentSlug, modelAlias: 'mock', renderHost: args.renderHost, systemSpaceDirs: [] },\n242\t          { streamFn: createMockStreamFn(() => '') },\n243\t        ),\n244\t    });\n245\t\n246\t    const handler = createInboundHandler(manager, root);\n247\t    const { res, get } = fakeRes();\n248\t    const body = JSON.stringify({ message: { chat: { id: 'c1' }, text: 'hi' } });\n249\t    const badSig = 'sha256=' + createHmac('sha256', 'the-wrong-secret').update(body, 'utf8').digest('hex');\n250\t\n251\t    await handler(fakeReq(body, { 'x-demo-signature': badSig }), res, { path: 'demo' });\n252\t\n253\t    expect(get().status).toBe(401);\n254\t    expect(received).toHaveLength(0);\n255\t  });\n256\t});\n257\t"}]},"parent_tool_use_id":null,"session_id":"f21d2fda-94ab-442d-8f32-017580283d3b","uuid":"08cfc94c-e4cf-45a4-8f42-e0bd0650028c","timestamp":"2026-07-14T16:55:03.727Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/integration-demo-e2e.test.ts","content":"      status = s;\n    },\n    end() {},\n  } as unknown as ServerResponse;\n  return { res, get: () => ({ status }) };\n}\n\ndescribe('integration-demo — full contained loop against a mock provider (keyless)', () => {\n  it('verifies a signed inbound, emits message.received, runs the delegated handler agent, and posts the reply outbound via callConnection', async () => {\n    // The events-pipeline path: inbound → HMAC verify → the space's webhook EMITTER\n    // def `emit()` → `integration-demo/message.received` → a PROJECT event hook whose\n    // `trigger` delegates to the handler agent → demoSendMessage → callConnection → out.\n    const root = await makeRootWithDemoSpace({ withReplyHook: true });\n    process.env['INTEGRATION_DEMO_BASE_URL'] = providerBase;\n    process.env['INTEGRATION_DEMO_API_TOKEN'] = DEMO_BASE_TOKEN;\n    process.env['INTEGRATION_DEMO_WEBHOOK_SECRET'] = DEMO_WEBHOOK_SECRET;\n\n    // The mock model: on the handler's first turn, reply into the same chat via the\n    // space's own wrapper (which calls callConnection('demo', …)); then stop. Also\n    // capture the prompt to prove the raw inbound payload reached the agent.\n    let capturedPrompt = '';\n    const mockStreamFn = createMockStreamFn((opts: StreamOpts) => {\n      const hasAssistant = opts.messages.some((m) => m.role === 'assistant');\n      if (hasAssistant) return '';\n      capturedPrompt = opts.messages\n        .filter((m) => m.role === 'user')\n        .map((m) => (typeof m.content === 'string' ? m.content : JSON.stringify(m.content)))\n        .join('\\n');\n      return `const r = await demoSendMessage('c1', 'pong from agent'); display('sent ' + (r && r.ok));`;\n    });\n\n    const manager = new SessionManager({\n      streamFn: mockStreamFn,\n      lmthingRoot: root,\n      snapshotsDir: join(root, 'snapshots'),\n      // Keyless build that still wires the REAL connection resolver (as\n      // defaultBuildSession does) so callConnection resolves the space's descriptor.\n      buildSession: (args: BuildSessionArgs) =>\n        new Session(\n          {\n            spaceDir: args.spaceDir,\n            agentSlug: args.agentSlug,\n            modelAlias: 'mock',\n            renderHost: args.renderHost,\n            systemSpaceDirs: [],\n            projectSpacesDir: args.projectSpacesDir,\n            projectId: args.projectId,\n            projectRoot: args.projectRoot,\n            appGlobals: { callConnection: createConnectionResolver(args.projectRoot) },\n            appDts: args.appDts,\n          },\n          { streamFn: mockStreamFn },\n        ),\n    });\n\n    const handler = createInboundHandler(manager, root);\n    const { res, get } = fakeRes();\n\n    // A valid demo message: the emitter drops any payload without a non-bot `from.id`.\n    const body = JSON.stringify({ message: { message_id: 1, chat: { id: 'c1' }, from: { id: 'u1', username: 'ada' }, text: 'hello there' } });\n    const sig = 'sha256=' + createHmac('sha256', DEMO_WEBHOOK_SECRET).update(body, 'utf8').digest('hex');\n\n    await handler(\n      fakeReq(body, { 'content-type': 'application/json', 'x-demo-signature': sig }),\n      res,\n      { path: 'demo' },\n    );\n\n    // Inbound verified + the emitter produced exactly one event (fast 200 ack).\n    expect(get().status).toBe(200);\n\n    // The dispatch to the event hook + the agent run are fire-and-forget — wait them out.\n    await waitFor(() => received.length >= 1);\n\n    // The message payload reached the delegated handler agent (event trigger seed).\n    expect(capturedPrompt).toContain('hello there');\n    expect(capturedPrompt).toContain('message.received');\n\n    // The OUTBOUND callConnection landed on the mock provider, host-pinned to\n    // DEMO_BASE_URL, Bearer DEMO_API_TOKEN attached, with the agent's reply body.\n    expect(received).toHaveLength(1);\n    const out = received[0]!;\n    expect(out.method).toBe('POST');\n    expect(out.url).toBe('/messages');\n    expect(out.auth).toBe(`Bearer ${DEMO_BASE_TOKEN}`);\n    expect(out.body).toEqual({ chat_id: 'c1', text: 'pong from agent' });\n  });\n\n  it('rejects a wrongly-signed inbound (401) and never calls the provider', async () => {\n    const root = await makeRootWithDemoSpace();\n    process.env['INTEGRATION_DEMO_BASE_URL'] = providerBase;\n    process.env['INTEGRATION_DEMO_API_TOKEN'] = DEMO_BASE_TOKEN;\n    process.env['INTEGRATION_DEMO_WEBHOOK_SECRET'] = DEMO_WEBHOOK_SECRET;\n    received.length = 0;\n\n    const manager = new SessionManager({\n      streamFn: createMockStreamFn(() => ''),\n      lmthingRoot: root,\n      snapshotsDir: join(root, 'snapshots'),\n      buildSession: (args: BuildSessionArgs) =>\n        new Session(\n          { spaceDir: args.spaceDir, agentSlug: args.agentSlug, modelAlias: 'mock', renderHost: args.renderHost, systemSpaceDirs: [] },\n          { streamFn: createMockStreamFn(() => '') },\n        ),\n    });\n\n    const handler = createInboundHandler(manager, root);\n    const { res, get } = fakeRes();\n    const body = JSON.stringify({ message: { chat: { id: 'c1' }, text: 'hi' } });\n    const badSig = 'sha256=' + createHmac('sha256', 'the-wrong-secret').update(body, 'utf8').digest('hex');\n\n    await handler(fakeReq(body, { 'x-demo-signature': badSig }), res, { path: 'demo' });\n\n    expect(get().status).toBe(401);\n    expect(received).toHaveLength(0);\n  });\n});\n","numLines":118,"startLine":140,"totalLines":257}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_JdIpEAeFfh4OqpdpCy7Ogpcc","type":"tool_result","content":"1\timport type { ConnectionResolver, ConnectionRequest, ConnectionResponse } from '@lmthing/core';\n2\timport { createHmac, randomBytes } from 'node:crypto';\n3\timport { isIP } from 'node:net';\n4\timport { lookup } from 'node:dns/promises';\n5\timport { lookup as dnsLookupCb } from 'node:dns';\n6\timport type { AuthStyle, ProviderConfig } from './providers/types.js';\n7\timport { scanIntegrationDescriptors } from './integration-manifests.js';\n8\t\n9\t/**\n10\t * Pod-side resolver for the agent/space `callConnection(provider, req)` global.\n11\t *\n12\t * BRING-YOUR-OWN-TOKEN model: the user configures their OWN provider token in\n13\t * the pod env (Settings → Integrations) — lmthing does NOT broker OAuth or store\n14\t * refresh tokens. This resolver looks the token up in `process.env` by the\n15\t * provider's `tokenEnv`, host-pins the request to the provider `apiBase`, applies\n16\t * the provider's auth style, and makes the REST call DIRECTLY. No gateway round-trip.\n17\t *\n18\t * SELF-CONTAINED PROVIDERS: only the three built-ins (slack/github/google) are\n19\t * hard-coded here. Every messaging integration declares its own provider config\n20\t * (`apiBase`, `tokenEnv`, `auth`) in its SPACE's `package.json` `lmthing.connection`\n21\t * block — the resolver discovers it by scanning the session's installed spaces\n22\t * ({@link scanIntegrationDescriptors}). Adding a platform is a new space folder,\n23\t * no edit here.\n24\t *\n25\t * Errors are thrown (never silently binding undefined) so the yield router\n26\t * surfaces them to the agent: an unknown provider, or a provider whose token env\n27\t * var is unset (\"not configured — set <TOKEN_ENV> in Settings → Integrations\").\n28\t *\n29\t * Uses non-blocking `fetch` with an AbortSignal timeout so a slow provider can't\n30\t * stall the session server's event loop / trip the idle watchdog.\n31\t */\n32\t\n33\tconst CALL_TIMEOUT_MS = 25_000;\n34\t\n35\t/**\n36\t * Built-in providers (Bearer, constant base). `apiBase` mirrors the old gateway\n37\t * connections-registry so existing `integration-*` spaces (relative paths like\n38\t * `/chat.postMessage`) keep working unchanged. All OTHER providers come from\n39\t * installed integration spaces' `lmthing.connection` descriptors.\n40\t */\n41\tconst BUILTIN_PROVIDERS: Record<string, ProviderConfig> = {\n42\t  slack: { apiBase: 'https://slack.com/api', tokenEnv: 'SLACK_BOT_TOKEN', auth: { kind: 'bearer' } },\n43\t  github: { apiBase: 'https://api.github.com', tokenEnv: 'GITHUB_TOKEN', auth: { kind: 'bearer' } },\n44\t  google: { apiBase: 'https://www.googleapis.com', tokenEnv: 'GOOGLE_ACCESS_TOKEN', auth: { kind: 'bearer' } },\n45\t};\n46\t\n47\t/** The always-available built-in providers. Installed integration spaces add\n48\t *  more per-project (discovered dynamically), so this is not the full set for a\n49\t *  given session — see {@link createConnectionResolver}'s per-project support list. */\n50\texport const SUPPORTED_CONNECTION_PROVIDERS = Object.keys(BUILTIN_PROVIDERS);\n51\t\n52\t/** Thrown for a misconfigured provider (unset token / base / basic-username env). */\n53\tclass NotConfiguredError extends Error {}\n54\t\n55\t/**\n56\t * Resolve a provider id to its config: a built-in, else an installed space's\n57\t * `lmthing.connection` descriptor scanned from `<projectRoot>/spaces/`. Returns\n58\t * undefined for an unknown provider (the caller throws with the supported list).\n59\t */\n60\tfunction resolveProviderConfig(provider: string, projectRoot: string | undefined): ProviderConfig | undefined {\n61\t  const builtin = BUILTIN_PROVIDERS[provider];\n62\t  if (builtin) return builtin;\n63\t  if (projectRoot) {\n64\t    const fromSpace = scanIntegrationDescriptors(projectRoot).connections[provider];\n65\t    if (fromSpace) return fromSpace;\n66\t  }\n67\t  return undefined;\n68\t}\n69\t\n70\t/** The providers callable in this project context (built-ins + installed spaces). */\n71\tfunction supportedProviders(projectRoot: string | undefined): string[] {\n72\t  const ids = new Set(Object.keys(BUILTIN_PROVIDERS));\n73\t  if (projectRoot) for (const id of Object.keys(scanIntegrationDescriptors(projectRoot).connections)) ids.add(id);\n74\t  return [...ids].sort();\n75\t}\n76\t\n77\t/** Read a required env var or throw the standard \"not configured\" guidance. */\n78\tfunction requireEnv(name: string): string {\n79\t  const v = process.env[name];\n80\t  if (!v) throw new NotConfiguredError(`not configured — set ${name} in Settings → Integrations`);\n81\t  return v;\n82\t}\n83\t\n84\t/** Thrown when a resolved provider base URL points at an internal/loopback host\n85\t *  — an SSRF guard so a space's `apiBase` can't turn the pod into a proxy for\n86\t *  cloud-metadata / cluster-internal services (litellm, gateway, 169.254.169.254…). */\n87\tclass BlockedHostError extends Error {}\n88\t\n89\t/** Is `ip` in a private / loopback / link-local range (IPv4 or IPv6)? Malformed\n90\t *  input is treated as blocked (fail-closed). */\n91\tfunction isPrivateIp(ip: string): boolean {\n92\t  const fam = isIP(ip);\n93\t  if (fam === 4) {\n94\t    const p = ip.split('.').map((n) => Number(n));\n95\t    if (p.length !== 4 || p.some((n) => !Number.isInteger(n) || n < 0 || n > 255)) return true;\n96\t    const [a, b] = p as [number, number, number, number];\n97\t    if (a === 0 || a === 10 || a === 127) return true; // this-host / private / loopback\n98\t    if (a === 169 && b === 254) return true; // link-local incl. 169.254.169.254 metadata\n99\t    if (a === 172 && b >= 16 && b <= 31) return true; // private\n100\t    if (a === 192 && b === 168) return true; // private\n101\t    if (a === 100 && b >= 64 && b <= 127) return true; // CGNAT 100.64/10\n102\t    return false;\n103\t  }\n104\t  if (fam === 6) {\n105\t    const h = ip.toLowerCase();\n106\t    if (h === '::1' || h === '::') return true; // loopback / unspecified\n107\t    if (h.startsWith('fe80')) return true; // link-local\n108\t    if (h.startsWith('fc') || h.startsWith('fd')) return true; // unique-local fc00::/7\n109\t    if (h.startsWith('::ffff:')) return isPrivateIp(h.slice(7)); // IPv4-mapped\n110\t    return false;\n111\t  }\n112\t  return false; // not an IP literal — handled by the hostname checks in isBlockedHost\n113\t}\n114\t\n115\t/** Reject internal hosts: loopback/private/link-local IPs, single-label names\n116\t *  (cluster services like `litellm`/`gateway`), and internal TLDs. */\n117\tfunction isBlockedHost(host: string): boolean {\n118\t  const h = host.toLowerCase().replace(/^\\[|\\]$/g, ''); // strip IPv6 brackets\n119\t  if (h === 'localhost' || h.endsWith('.localhost')) return true;\n120\t  if (h.endsWith('.local') || h.endsWith('.internal') || h.endsWith('.svc') || h.endsWith('.cluster.local')) return true;\n121\t  const isIpLiteral = isIP(h) !== 0;\n122\t  if (!isIpLiteral && !h.includes('.')) return true; // bare hostname ⇒ cluster-internal\n123\t  return isPrivateIp(h);\n124\t}\n125\t\n126\t/** Guard a resolved base URL before any request: http(s) only, no internal host. */\n127\tfunction assertSafeBaseUrl(base: string): void {\n128\t  let u: URL;\n129\t  try {\n130\t    u = new URL(base);\n131\t  } catch {\n132\t    throw new BlockedHostError('provider base URL is not a valid absolute URL');\n133\t  }\n134\t  if (u.protocol !== 'https:' && u.protocol !== 'http:') {\n135\t    throw new BlockedHostError(`provider base URL scheme \"${u.protocol}\" is not allowed`);\n136\t  }\n137\t  // Per-pod opt-out for local dev / a self-hosted provider on a private network\n138\t  // the pod can legitimately reach. Only ever weakens the pod whose OWN env sets\n139\t  // it (never cross-user), so it's a safe escape hatch.\n140\t  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return;\n141\t  if (isBlockedHost(u.hostname)) {\n142\t    throw new BlockedHostError(`provider base host \"${u.hostname}\" is internal/blocked`);\n143\t  }\n144\t}\n145\t\n146\t/** DNS-rebinding guard: resolve the hostname and reject if ANY resolved address\n147\t *  is internal — the static host check in {@link assertSafeBaseUrl} can't see a\n148\t *  PUBLIC name that resolves to a private IP. (Residual: a TOCTOU race with a\n149\t *  fast-rebinding TTL between this lookup and fetch's own; full closure needs\n150\t *  connection-time IP pinning.) IP literals are already covered statically. */\n151\tasync function assertResolvedHostSafe(hostname: string): Promise<void> {\n152\t  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return;\n153\t  const h = hostname.replace(/^\\[|\\]$/g, '');\n154\t  if (isIP(h) !== 0) return; // IP literal — already checked in assertSafeBaseUrl\n155\t  let addrs: Array<{ address: string }>;\n156\t  try {\n157\t    addrs = await lookup(h, { all: true });\n158\t  } catch {\n159\t    return; // DNS failure — let fetch surface the network error\n160\t  }\n161\t  for (const a of addrs) {\n162\t    if (isPrivateIp(a.address)) {\n163\t      throw new BlockedHostError(`provider host \"${hostname}\" resolves to internal address ${a.address}`);\n164\t    }\n165\t  }\n166\t}\n167\t\n168\t/**\n169\t * A DNS `lookup` that rejects any resolved internal IP — used as the undici\n170\t * dispatcher's connect lookup so the address we VALIDATE is the exact address the\n171\t * socket CONNECTS to (closing the resolve-vs-connect TOCTOU that a plain pre-check\n172\t * can't). Mirrors `net.LookupFunction`; supports both `all` shapes.\n173\t */\n174\tfunction pinnedLookup(\n175\t  hostname: string,\n176\t  options: unknown,\n177\t  cb: (err: Error | null, address?: unknown, family?: number) => void,\n178\t): void {\n179\t  dnsLookupCb(hostname, (options ?? {}) as never, (err, address, family) => {\n180\t    if (err) return cb(err, address as unknown, family);\n181\t    const list = Array.isArray(address) ? address : [{ address: address as string, family }];\n182\t    for (const item of list) {\n183\t      if (isPrivateIp((item as { address: string }).address)) {\n184\t        return cb(new BlockedHostError(`host \"${hostname}\" resolves to internal address ${(item as { address: string }).address}`));\n185\t      }\n186\t    }\n187\t    cb(null, address as unknown, family);\n188\t  });\n189\t}\n190\t\n191\t/** Lazily build an undici dispatcher that pins connections to a validated public\n192\t *  IP. If undici isn't resolvable (or the opt-out is set) returns undefined and\n193\t *  the caller falls back to plain `fetch` — the pinning is a hardening ENHANCEMENT\n194\t *  that can never break a normal call. Memoized (attempted once). */\n195\tlet dispatcherResolved = false;\n196\tlet pinnedDispatcher: unknown;\n197\tasync function getPinnedDispatcher(): Promise<unknown> {\n198\t  if (dispatcherResolved) return pinnedDispatcher;\n199\t  dispatcherResolved = true;\n200\t  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return undefined;\n201\t  try {\n202\t    const undici = (await import('undici')) as { Agent: new (opts: unknown) => unknown };\n203\t    pinnedDispatcher = new undici.Agent({ connect: { lookup: pinnedLookup } });\n204\t  } catch {\n205\t    pinnedDispatcher = undefined; // undici not available → plain fetch + the resolve pre-check\n206\t  }\n207\t  return pinnedDispatcher;\n208\t}\n209\t\n210\t/** Redact a secret's literal value from an error string before surfacing it to\n211\t *  the agent/logs — token-in-path providers (e.g. Telegram `…/bot<token>/…`) can\n212\t *  otherwise leak the token via a fetch error message that echoes the URL. */\n213\tfunction redactSecret(message: string, secret: string | undefined): string {\n214\t  if (!secret || secret.length < 4) return message;\n215\t  return message.split(secret).join('***');\n216\t}\n217\t\n218\t/**\n219\t * Resolve `cfg.apiBase` to a concrete base URL:\n220\t * - `{ env, suffix }` → `process.env[env]` (required) + suffix (self-hosted servers).\n221\t * - a string, with `{token}` → the token value and `{env:VAR}` → `process.env[VAR]` (required).\n222\t * Trailing slashes are stripped.\n223\t */\n224\tfunction resolveApiBase(cfg: ProviderConfig, token: string): string {\n225\t  let base: string;\n226\t  if (typeof cfg.apiBase === 'object') {\n227\t    base = requireEnv(cfg.apiBase.env) + (cfg.apiBase.suffix ?? '');\n228\t  } else {\n229\t    base = cfg.apiBase\n230\t      .replace('{token}', token)\n231\t      .replace(/\\{env:([A-Z0-9_]+)\\}/g, (_m, name: string) => requireEnv(name));\n232\t  }\n233\t  base = base.replace(/\\/+$/, '');\n234\t  assertSafeBaseUrl(base);\n235\t  return base;\n236\t}\n237\t\n238\t/** Attach the provider's auth to `headers`/`query`, given the raw serialized body. */\n239\tfunction applyAuth(\n240\t  auth: AuthStyle,\n241\t  token: string,\n242\t  headers: Record<string, string>,\n243\t  query: Record<string, string>,\n244\t  body: string | undefined,\n245\t): void {\n246\t  switch (auth.kind) {\n247\t    case 'bearer':\n248\t      headers['Authorization'] = `Bearer ${token}`;\n249\t      break;\n250\t    case 'bot':\n251\t      headers['Authorization'] = `Bot ${token}`;\n252\t      break;\n253\t    case 'basic': {\n254\t      const user = requireEnv(auth.userEnv);\n255\t      headers['Authorization'] = `Basic ${Buffer.from(`${user}:${token}`).toString('base64')}`;\n256\t      break;\n257\t    }\n258\t    case 'query-token':\n259\t      query[auth.param] = token;\n260\t      break;\n261\t    case 'nextcloud-bot': {\n262\t      // Nextcloud Talk bot requests are HMAC-signed over `random + signedContent`,\n263\t      // where signedContent is the message/reaction the bot is posting (Nextcloud\n264\t      // signs the content, not the whole envelope). Fall back to the raw body.\n265\t      const random = randomBytes(32).toString('hex');\n266\t      let signed = body ?? '';\n267\t      try {\n268\t        const parsed = body ? (JSON.parse(body) as Record<string, unknown>) : {};\n269\t        if (typeof parsed['message'] === 'string') signed = parsed['message'];\n270\t        else if (typeof parsed['reaction'] === 'string') signed = parsed['reaction'];\n271\t      } catch {\n272\t        /* non-JSON body — sign it verbatim */\n273\t      }\n274\t      headers['X-Nextcloud-Talk-Bot-Random'] = random;\n275\t      headers['X-Nextcloud-Talk-Bot-Signature'] = createHmac('sha256', token)\n276\t        .update(random + signed)\n277\t        .digest('hex');\n278\t      break;\n279\t    }\n280\t    case 'none':\n281\t      break;\n282\t  }\n283\t}\n284\t\n285\tasync function callProvider(cfg: ProviderConfig, token: string, req: ConnectionRequest): Promise<Response> {\n286\t  const path = req.path ?? '';\n287\t  // Host-pinning: `path` is sandbox-supplied, so it MUST be relative to the\n288\t  // provider apiBase — reject absolute URLs / scheme / protocol-relative so an\n289\t  // agent can't redirect the credential to an attacker-controlled host.\n290\t  if (/^https?:\\/\\//i.test(path) || path.includes('://') || path.startsWith('//')) {\n291\t    throw new Error('callConnection: path must be relative to the provider apiBase');\n292\t  }\n293\t  const base = resolveApiBase(cfg, token);\n294\t  const rel = path.startsWith('/') ? path : `/${path}`;\n295\t\n296\t  const headers: Record<string, string> = { Accept: 'application/json', 'User-Agent': 'lmthing-pod' };\n297\t  if (req.headers) {\n298\t    for (const [k, v] of Object.entries(req.headers)) {\n299\t      const lk = k.toLowerCase();\n300\t      if (lk === 'authorization' || lk === 'host') continue;\n301\t      headers[k] = v;\n302\t    }\n303\t  }\n304\t\n305\t  const method = (req.method || 'GET').toUpperCase();\n306\t  let body: string | undefined;\n307\t  if (req.body !== undefined && method !== 'GET' && method !== 'HEAD') {\n308\t    body = typeof req.body === 'string' ? req.body : JSON.stringify(req.body);\n309\t    if (!Object.keys(headers).some((h) => h.toLowerCase() === 'content-type')) {\n310\t      headers['Content-Type'] = 'application/json';\n311\t    }\n312\t  }\n313\t\n314\t  // Auth may add a query param (query-token) — merge with the caller's query.\n315\t  const query: Record<string, string> = { ...(req.query ?? {}) };\n316\t  applyAuth(cfg.auth ?? { kind: 'bearer' }, token, headers, query, body);\n317\t\n318\t  let url = `${base}${rel}`;\n319\t  if (Object.keys(query).length > 0) {\n320\t    url += (url.includes('?') ? '&' : '?') + new URLSearchParams(query).toString();\n321\t  }\n322\t\n323\t  await assertResolvedHostSafe(new URL(base).hostname);\n324\t  const dispatcher = await getPinnedDispatcher();\n325\t  const init: RequestInit & { dispatcher?: unknown } = {\n326\t    method,\n327\t    headers,\n328\t    body,\n329\t    signal: AbortSignal.timeout(CALL_TIMEOUT_MS),\n330\t  };\n331\t  if (dispatcher) init.dispatcher = dispatcher; // pin to the validated IP when undici is available\n332\t  return fetch(url, init);\n333\t}\n334\t\n335\t/**\n336\t * Build a `callConnection` resolver bound to `projectRoot` (the session's\n337\t * project on disk). Built-in providers work everywhere; installed integration\n338\t * spaces under `<projectRoot>/spaces/` contribute their own providers. Pass no\n339\t * `projectRoot` (legacy/project-less sessions) to expose only the built-ins.\n340\t */\n341\texport function createConnectionResolver(projectRoot?: string): ConnectionResolver {\n342\t  return async (provider: string, req: ConnectionRequest): Promise<ConnectionResponse> => {\n343\t    const cfg = resolveProviderConfig(provider, projectRoot);\n344\t    if (!cfg) {\n345\t      throw new Error(\n346\t        `callConnection(\"${provider}\"): unknown provider (supported: ${supportedProviders(projectRoot).join(', ')})`,\n347\t      );\n348\t    }\n349\t    const token = process.env[cfg.tokenEnv];\n350\t    if (!token) {\n351\t      throw new Error(\n352\t        `callConnection(\"${provider}\"): not configured — set ${cfg.tokenEnv} in Settings → Integrations`,\n353\t      );\n354\t    }\n355\t\n356\t    let res: Response;\n357\t    try {\n358\t      res = await callProvider(cfg, token, req);\n359\t    } catch (err) {\n360\t      if (err instanceof NotConfiguredError) {\n361\t        throw new Error(`callConnection(\"${provider}\"): ${err.message}`);\n362\t      }\n363\t      if (err instanceof BlockedHostError) {\n364\t        throw new Error(`callConnection(\"${provider}\"): blocked — ${err.message}`);\n365\t      }\n366\t      const msg = redactSecret(String((err as Error)?.message ?? err), token);\n367\t      throw new Error(`callConnection(\"${provider}\"): request failed: ${msg}`);\n368\t    }\n369\t\n370\t    const text = await res.text().catch(() => '');\n371\t    let data: unknown = null;\n372\t    if (text) {\n373\t      try {\n374\t        data = JSON.parse(text);\n375\t      } catch {\n376\t        data = text;\n377\t      }\n378\t    }\n379\t    return { ok: res.ok, status: res.status, data };\n380\t  };\n381\t}\n382\t"}]},"parent_tool_use_id":null,"session_id":"f21d2fda-94ab-442d-8f32-017580283d3b","uuid":"e558574d-52c4-4ce2-9aff-3cabb584cd7b","timestamp":"2026-07-14T16:55:03.729Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/connections.ts","content":"import type { ConnectionResolver, ConnectionRequest, ConnectionResponse } from '@lmthing/core';\nimport { createHmac, randomBytes } from 'node:crypto';\nimport { isIP } from 'node:net';\nimport { lookup } from 'node:dns/promises';\nimport { lookup as dnsLookupCb } from 'node:dns';\nimport type { AuthStyle, ProviderConfig } from './providers/types.js';\nimport { scanIntegrationDescriptors } from './integration-manifests.js';\n\n/**\n * Pod-side resolver for the agent/space `callConnection(provider, req)` global.\n *\n * BRING-YOUR-OWN-TOKEN model: the user configures their OWN provider token in\n * the pod env (Settings → Integrations) — lmthing does NOT broker OAuth or store\n * refresh tokens. This resolver looks the token up in `process.env` by the\n * provider's `tokenEnv`, host-pins the request to the provider `apiBase`, applies\n * the provider's auth style, and makes the REST call DIRECTLY. No gateway round-trip.\n *\n * SELF-CONTAINED PROVIDERS: only the three built-ins (slack/github/google) are\n * hard-coded here. Every messaging integration declares its own provider config\n * (`apiBase`, `tokenEnv`, `auth`) in its SPACE's `package.json` `lmthing.connection`\n * block — the resolver discovers it by scanning the session's installed spaces\n * ({@link scanIntegrationDescriptors}). Adding a platform is a new space folder,\n * no edit here.\n *\n * Errors are thrown (never silently binding undefined) so the yield router\n * surfaces them to the agent: an unknown provider, or a provider whose token env\n * var is unset (\"not configured — set <TOKEN_ENV> in Settings → Integrations\").\n *\n * Uses non-blocking `fetch` with an AbortSignal timeout so a slow provider can't\n * stall the session server's event loop / trip the idle watchdog.\n */\n\nconst CALL_TIMEOUT_MS = 25_000;\n\n/**\n * Built-in providers (Bearer, constant base). `apiBase` mirrors the old gateway\n * connections-registry so existing `integration-*` spaces (relative paths like\n * `/chat.postMessage`) keep working unchanged. All OTHER providers come from\n * installed integration spaces' `lmthing.connection` descriptors.\n */\nconst BUILTIN_PROVIDERS: Record<string, ProviderConfig> = {\n  slack: { apiBase: 'https://slack.com/api', tokenEnv: 'SLACK_BOT_TOKEN', auth: { kind: 'bearer' } },\n  github: { apiBase: 'https://api.github.com', tokenEnv: 'GITHUB_TOKEN', auth: { kind: 'bearer' } },\n  google: { apiBase: 'https://www.googleapis.com', tokenEnv: 'GOOGLE_ACCESS_TOKEN', auth: { kind: 'bearer' } },\n};\n\n/** The always-available built-in providers. Installed integration spaces add\n *  more per-project (discovered dynamically), so this is not the full set for a\n *  given session — see {@link createConnectionResolver}'s per-project support list. */\nexport const SUPPORTED_CONNECTION_PROVIDERS = Object.keys(BUILTIN_PROVIDERS);\n\n/** Thrown for a misconfigured provider (unset token / base / basic-username env). */\nclass NotConfiguredError extends Error {}\n\n/**\n * Resolve a provider id to its config: a built-in, else an installed space's\n * `lmthing.connection` descriptor scanned from `<projectRoot>/spaces/`. Returns\n * undefined for an unknown provider (the caller throws with the supported list).\n */\nfunction resolveProviderConfig(provider: string, projectRoot: string | undefined): ProviderConfig | undefined {\n  const builtin = BUILTIN_PROVIDERS[provider];\n  if (builtin) return builtin;\n  if (projectRoot) {\n    const fromSpace = scanIntegrationDescriptors(projectRoot).connections[provider];\n    if (fromSpace) return fromSpace;\n  }\n  return undefined;\n}\n\n/** The providers callable in this project context (built-ins + installed spaces). */\nfunction supportedProviders(projectRoot: string | undefined): string[] {\n  const ids = new Set(Object.keys(BUILTIN_PROVIDERS));\n  if (projectRoot) for (const id of Object.keys(scanIntegrationDescriptors(projectRoot).connections)) ids.add(id);\n  return [...ids].sort();\n}\n\n/** Read a required env var or throw the standard \"not configured\" guidance. */\nfunction requireEnv(name: string): string {\n  const v = process.env[name];\n  if (!v) throw new NotConfiguredError(`not configured — set ${name} in Settings → Integrations`);\n  return v;\n}\n\n/** Thrown when a resolved provider base URL points at an internal/loopback host\n *  — an SSRF guard so a space's `apiBase` can't turn the pod into a proxy for\n *  cloud-metadata / cluster-internal services (litellm, gateway, 169.254.169.254…). */\nclass BlockedHostError extends Error {}\n\n/** Is `ip` in a private / loopback / link-local range (IPv4 or IPv6)? Malformed\n *  input is treated as blocked (fail-closed). */\nfunction isPrivateIp(ip: string): boolean {\n  const fam = isIP(ip);\n  if (fam === 4) {\n    const p = ip.split('.').map((n) => Number(n));\n    if (p.length !== 4 || p.some((n) => !Number.isInteger(n) || n < 0 || n > 255)) return true;\n    const [a, b] = p as [number, number, number, number];\n    if (a === 0 || a === 10 || a === 127) return true; // this-host / private / loopback\n    if (a === 169 && b === 254) return true; // link-local incl. 169.254.169.254 metadata\n    if (a === 172 && b >= 16 && b <= 31) return true; // private\n    if (a === 192 && b === 168) return true; // private\n    if (a === 100 && b >= 64 && b <= 127) return true; // CGNAT 100.64/10\n    return false;\n  }\n  if (fam === 6) {\n    const h = ip.toLowerCase();\n    if (h === '::1' || h === '::') return true; // loopback / unspecified\n    if (h.startsWith('fe80')) return true; // link-local\n    if (h.startsWith('fc') || h.startsWith('fd')) return true; // unique-local fc00::/7\n    if (h.startsWith('::ffff:')) return isPrivateIp(h.slice(7)); // IPv4-mapped\n    return false;\n  }\n  return false; // not an IP literal — handled by the hostname checks in isBlockedHost\n}\n\n/** Reject internal hosts: loopback/private/link-local IPs, single-label names\n *  (cluster services like `litellm`/`gateway`), and internal TLDs. */\nfunction isBlockedHost(host: string): boolean {\n  const h = host.toLowerCase().replace(/^\\[|\\]$/g, ''); // strip IPv6 brackets\n  if (h === 'localhost' || h.endsWith('.localhost')) return true;\n  if (h.endsWith('.local') || h.endsWith('.internal') || h.endsWith('.svc') || h.endsWith('.cluster.local')) return true;\n  const isIpLiteral = isIP(h) !== 0;\n  if (!isIpLiteral && !h.includes('.')) return true; // bare hostname ⇒ cluster-internal\n  return isPrivateIp(h);\n}\n\n/** Guard a resolved base URL before any request: http(s) only, no internal host. */\nfunction assertSafeBaseUrl(base: string): void {\n  let u: URL;\n  try {\n    u = new URL(base);\n  } catch {\n    throw new BlockedHostError('provider base URL is not a valid absolute URL');\n  }\n  if (u.protocol !== 'https:' && u.protocol !== 'http:') {\n    throw new BlockedHostError(`provider base URL scheme \"${u.protocol}\" is not allowed`);\n  }\n  // Per-pod opt-out for local dev / a self-hosted provider on a private network\n  // the pod can legitimately reach. Only ever weakens the pod whose OWN env sets\n  // it (never cross-user), so it's a safe escape hatch.\n  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return;\n  if (isBlockedHost(u.hostname)) {\n    throw new BlockedHostError(`provider base host \"${u.hostname}\" is internal/blocked`);\n  }\n}\n\n/** DNS-rebinding guard: resolve the hostname and reject if ANY resolved address\n *  is internal — the static host check in {@link assertSafeBaseUrl} can't see a\n *  PUBLIC name that resolves to a private IP. (Residual: a TOCTOU race with a\n *  fast-rebinding TTL between this lookup and fetch's own; full closure needs\n *  connection-time IP pinning.) IP literals are already covered statically. */\nasync function assertResolvedHostSafe(hostname: string): Promise<void> {\n  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return;\n  const h = hostname.replace(/^\\[|\\]$/g, '');\n  if (isIP(h) !== 0) return; // IP literal — already checked in assertSafeBaseUrl\n  let addrs: Array<{ address: string }>;\n  try {\n    addrs = await lookup(h, { all: true });\n  } catch {\n    return; // DNS failure — let fetch surface the network error\n  }\n  for (const a of addrs) {\n    if (isPrivateIp(a.address)) {\n      throw new BlockedHostError(`provider host \"${hostname}\" resolves to internal address ${a.address}`);\n    }\n  }\n}\n\n/**\n * A DNS `lookup` that rejects any resolved internal IP — used as the undici\n * dispatcher's connect lookup so the address we VALIDATE is the exact address the\n * socket CONNECTS to (closing the resolve-vs-connect TOCTOU that a plain pre-check\n * can't). Mirrors `net.LookupFunction`; supports both `all` shapes.\n */\nfunction pinnedLookup(\n  hostname: string,\n  options: unknown,\n  cb: (err: Error | null, address?: unknown, family?: number) => void,\n): void {\n  dnsLookupCb(hostname, (options ?? {}) as never, (err, address, family) => {\n    if (err) return cb(err, address as unknown, family);\n    const list = Array.isArray(address) ? address : [{ address: address as string, family }];\n    for (const item of list) {\n      if (isPrivateIp((item as { address: string }).address)) {\n        return cb(new BlockedHostError(`host \"${hostname}\" resolves to internal address ${(item as { address: string }).address}`));\n      }\n    }\n    cb(null, address as unknown, family);\n  });\n}\n\n/** Lazily build an undici dispatcher that pins connections to a validated public\n *  IP. If undici isn't resolvable (or the opt-out is set) returns undefined and\n *  the caller falls back to plain `fetch` — the pinning is a hardening ENHANCEMENT\n *  that can never break a normal call. Memoized (attempted once). */\nlet dispatcherResolved = false;\nlet pinnedDispatcher: unknown;\nasync function getPinnedDispatcher(): Promise<unknown> {\n  if (dispatcherResolved) return pinnedDispatcher;\n  dispatcherResolved = true;\n  if (process.env['LMTHING_ALLOW_INTERNAL_CONNECTIONS'] === '1') return undefined;\n  try {\n    const undici = (await import('undici')) as { Agent: new (opts: unknown) => unknown };\n    pinnedDispatcher = new undici.Agent({ connect: { lookup: pinnedLookup } });\n  } catch {\n    pinnedDispatcher = undefined; // undici not available → plain fetch + the resolve pre-check\n  }\n  return pinnedDispatcher;\n}\n\n/** Redact a secret's literal value from an error string before surfacing it to\n *  the agent/logs — token-in-path providers (e.g. Telegram `…/bot<token>/…`) can\n *  otherwise leak the token via a fetch error message that echoes the URL. */\nfunction redactSecret(message: string, secret: string | undefined): string {\n  if (!secret || secret.length < 4) return message;\n  return message.split(secret).join('***');\n}\n\n/**\n * Resolve `cfg.apiBase` to a concrete base URL:\n * - `{ env, suffix }` → `process.env[env]` (required) + suffix (self-hosted servers).\n * - a string, with `{token}` → the token value and `{env:VAR}` → `process.env[VAR]` (required).\n * Trailing slashes are stripped.\n */\nfunction resolveApiBase(cfg: ProviderConfig, token: string): string {\n  let base: string;\n  if (typeof cfg.apiBase === 'object') {\n    base = requireEnv(cfg.apiBase.env) + (cfg.apiBase.suffix ?? '');\n  } else {\n    base = cfg.apiBase\n      .replace('{token}', token)\n      .replace(/\\{env:([A-Z0-9_]+)\\}/g, (_m, name: string) => requireEnv(name));\n  }\n  base = base.replace(/\\/+$/, '');\n  assertSafeBaseUrl(base);\n  return base;\n}\n\n/** Attach the provider's auth to `headers`/`query`, given the raw serialized body. */\nfunction applyAuth(\n  auth: AuthStyle,\n  token: string,\n  headers: Record<string, string>,\n  query: Record<string, string>,\n  body: string | undefined,\n): void {\n  switch (auth.kind) {\n    case 'bearer':\n      headers['Authorization'] = `Bearer ${token}`;\n      break;\n    case 'bot':\n      headers['Authorization'] = `Bot ${token}`;\n      break;\n    case 'basic': {\n      const user = requireEnv(auth.userEnv);\n      headers['Authorization'] = `Basic ${Buffer.from(`${user}:${token}`).toString('base64')}`;\n      break;\n    }\n    case 'query-token':\n      query[auth.param] = token;\n      break;\n    case 'nextcloud-bot': {\n      // Nextcloud Talk bot requests are HMAC-signed over `random + signedContent`,\n      // where signedContent is the message/reaction the bot is posting (Nextcloud\n      // signs the content, not the whole envelope). Fall back to the raw body.\n      const random = randomBytes(32).toString('hex');\n      let signed = body ?? '';\n      try {\n        const parsed = body ? (JSON.parse(body) as Record<string, unknown>) : {};\n        if (typeof parsed['message'] === 'string') signed = parsed['message'];\n        else if (typeof parsed['reaction'] === 'string') signed = parsed['reaction'];\n      } catch {\n        /* non-JSON body — sign it verbatim */\n      }\n      headers['X-Nextcloud-Talk-Bot-Random'] = random;\n      headers['X-Nextcloud-Talk-Bot-Signature'] = createHmac('sha256', token)\n        .update(random + signed)\n        .digest('hex');\n      break;\n    }\n    case 'none':\n      break;\n  }\n}\n\nasync function callProvider(cfg: ProviderConfig, token: string, req: ConnectionRequest): Promise<Response> {\n  const path = req.path ?? '';\n  // Host-pinning: `path` is sandbox-supplied, so it MUST be relative to the\n  // provider apiBase — reject absolute URLs / scheme / protocol-relative so an\n  // agent can't redirect the credential to an attacker-controlled host.\n  if (/^https?:\\/\\//i.test(path) || path.includes('://') || path.startsWith('//')) {\n    throw new Error('callConnection: path must be relative to the provider apiBase');\n  }\n  const base = resolveApiBase(cfg, token);\n  const rel = path.startsWith('/') ? path : `/${path}`;\n\n  const headers: Record<string, string> = { Accept: 'application/json', 'User-Agent': 'lmthing-pod' };\n  if (req.headers) {\n    for (const [k, v] of Object.entries(req.headers)) {\n      const lk = k.toLowerCase();\n      if (lk === 'authorization' || lk === 'host') continue;\n      headers[k] = v;\n    }\n  }\n\n  const method = (req.method || 'GET').toUpperCase();\n  let body: string | undefined;\n  if (req.body !== undefined && method !== 'GET' && method !== 'HEAD') {\n    body = typeof req.body === 'string' ? req.body : JSON.stringify(req.body);\n    if (!Object.keys(headers).some((h) => h.toLowerCase() === 'content-type')) {\n      headers['Content-Type'] = 'application/json';\n    }\n  }\n\n  // Auth may add a query param (query-token) — merge with the caller's query.\n  const query: Record<string, string> = { ...(req.query ?? {}) };\n  applyAuth(cfg.auth ?? { kind: 'bearer' }, token, headers, query, body);\n\n  let url = `${base}${rel}`;\n  if (Object.keys(query).length > 0) {\n    url += (url.includes('?') ? '&' : '?') + new URLSearchParams(query).toString();\n  }\n\n  await assertResolvedHostSafe(new URL(base).hostname);\n  const dispatcher = await getPinnedDispatcher();\n  const init: RequestInit & { dispatcher?: unknown } = {\n    method,\n    headers,\n    body,\n    signal: AbortSignal.timeout(CALL_TIMEOUT_MS),\n  };\n  if (dispatcher) init.dispatcher = dispatcher; // pin to the validated IP when undici is available\n  return fetch(url, init);\n}\n\n/**\n * Build a `callConnection` resolver bound to `projectRoot` (the session's\n * project on disk). Built-in providers work everywhere; installed integration\n * spaces under `<projectRoot>/spaces/` contribute their own providers. Pass no\n * `projectRoot` (legacy/project-less sessions) to expose only the built-ins.\n */\nexport function createConnectionResolver(projectRoot?: string): ConnectionResolver {\n  return async (provider: string, req: ConnectionRequest): Promise<ConnectionResponse> => {\n    const cfg = resolveProviderConfig(provider, projectRoot);\n    if (!cfg) {\n      throw new Error(\n        `callConnection(\"${provider}\"): unknown provider (supported: ${supportedProviders(projectRoot).join(', ')})`,\n      );\n    }\n    const token = process.env[cfg.tokenEnv];\n    if (!token) {\n      throw new Error(\n        `callConnection(\"${provider}\"): not configured — set ${cfg.tokenEnv} in Settings → Integrations`,\n      );\n    }\n\n    let res: Response;\n    try {\n      res = await callProvider(cfg, token, req);\n    } catch (err) {\n      if (err instanceof NotConfiguredError) {\n        throw new Error(`callConnection(\"${provider}\"): ${err.message}`);\n      }\n      if (err instanceof BlockedHostError) {\n        throw new Error(`callConnection(\"${provider}\"): blocked — ${err.message}`);\n      }\n      const msg = redactSecret(String((err as Error)?.message ?? err), token);\n      throw new Error(`callConnection(\"${provider}\"): request failed: ${msg}`);\n    }\n\n    const text = await res.text().catch(() => '');\n    let data: unknown = null;\n    if (text) {\n      try {\n        data = JSON.parse(text);\n      } catch {\n        data = text;\n      }\n    }\n    return { ok: res.ok, status: res.status, data };\n  };\n}\n","numLines":382,"startLine":1,"totalLines":382}}}
