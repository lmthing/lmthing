nt = (actions?.items ?? []).filter(a => a.status === 'open').length;\n\n  const daysUntilTrip = (() => {\n    if (!upcomingLegs.length) return '—';\n    const first = new Date(upcomingLegs[0].start_date);\n    const now = new Date();\n    const diff = Math.ceil((first.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));\n    return diff > 0 ? String(diff) : 'Today!';\n  })();\n\n  return (\n    <main className=\"max-w-4xl mx-auto space-y-6 p-4\">\n      {/* Hero header */}\n      <header className=\"space-y-2\">\n        <h1 className=\"text-2xl font-bold text-foreground\">Tanzania 2026</h1>\n        <p className=\"text-muted\">Vasilis &amp; Athina Mari — Cairo · Arusha · Ngorongoro · Zanzibar</p>\n      </header>\n\n      {/* Stat tiles row */}\n      <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n        <StatTile icon=\"dollarSign\" value={summary ? `$${summary.total_usd.toLocaleString()}` : '—'} label=\"Total USD\" />\n        <StatTile icon=\"banknote\" value={summary ? `TZS ${summary.total_tzs.toLocaleString()}` : '—'} label=\"Total TZS\" />\n        <StatTile icon=\"calendar\" value={daysUntilTrip} label=\"Days until trip\" />\n        <StatTile icon=\"users\" value=\"2\" label=\"Travelers\" />\n      </div>\n\n      {/* Badge row: flagged costs + open actions */}\n      <div className=\"flex flex-wrap gap-2\">\n        {flaggedCount > 0 && (\n          <Link href=\"/costs-tracker\" className=\"inline-flex items-center gap-1\">\n            <Badge text={`${flaggedCount} flagged cost${flaggedCount !== 1 ? 's' : ''}`} variant=\"warning\" size=\"md\" />\n          </Link>\n        )}\n        {openActionCount > 0 && (\n          <Link href=\"/notes-memories\" className=\"inline-flex items-center gap-1\">\n            <Badge text={`${openActionCount} open action item${openActionCount !== 1 ? 's' : ''}`} variant=\"danger\" size=\"md\" />\n          </Link>\n        )}\n        {flaggedCount === 0 && openActionCount === 0 && (\n          <Badge text=\"All clear\" variant=\"success\" size=\"md\" />\n        )}\n      </div>\n\n      {/* Quick-summary safari balance */}\n      {summary?.pending_balance_usd != null && summary.pending_balance_usd > 0 && (\n        <PageSection title=\"Safari Balance\">\n          <CostRow\n            item={{\n              id: 'safari-balance',\n              label: 'Pending safari balance',\n              amount: summary.pending_balance_usd,\n              currency: 'USD',\n              status: 'pending',\n              flagged: true,\n            }}\n          />\n          {summary.pending_balance_tzs != null && summary.pending_balance_tzs > 0 && (\n            <CostRow\n              item={{\n                id: 'safari-balance-tzs',\n                label: 'Pending safari balance (TZS)',\n                amount: summary.pending_balance_tzs,\n                currency: 'TZS',\n                status: 'pending',\n                flagged: false,\n              }}\n            />\n          )}\n        </PageSection>\n      )}\n\n      {/* Upcoming legs */}\n      <PageSection\n        title=\"Up Next\"\n        action={{ label: 'Full itinerary →', href: '/itinerary' }}\n      >\n        {upcomingLegs.length > 0 ? (\n          <div className=\"space-y-3\">\n            {upcomingLegs.slice(0, 2).map((leg) => (\n              <LegCard key={leg.id} leg={leg} compact={false} />\n            ))}\n          </div>\n        ) : (\n          <EmptyState icon=\"calendarOff\" title=\"No upcoming legs\" description=\"The itinerary starts soon. Check the full plan.\" />\n        )}\n      </PageSection>\n\n      {/* Flagged costs preview */}\n      <PageSection\n        title=\"Costs to Watch\"\n        action={flaggedCount > 0 ? { label: 'All costs →', href: '/costs-tracker' } : undefined}\n      >\n        {flaggedCount > 0 ? (\n          <div className=\"space-y-2\">\n            {(flagged?.items ?? []).slice(0, 5).map((item) => (\n              <CostRow key={item.id} item={item} showLeg={true} />\n            ))}\n          </div>\n        ) : (\n          <EmptyState icon=\"checkCircle\" title=\"No flagged costs\" description=\"All expenses look fine.\" />\n        )}\n      </PageSection>\n\n      {/* Open action items preview */}\n      <PageSection\n        title=\"Action Items\"\n        action={openActionCount > 0 ? { label: 'All actions →', href: '/notes-memories' } : undefined}\n      >\n        {openActionCount > 0 ? (\n          <div className=\"space-y-1\">\n            {(actions?.items ?? [])\n              .filter(a => a.status === 'open' || a.status === 'in-progress')\n              .slice(0, 3)\n              .map((item) => (\n                <ActionItemCheckbox\n                  key={item.id}\n                  item={item}\n                  onToggle={(id: string, newStatus: string) => {\n                    toggleMutation.mutate({ id, status: newStatus });\n                  }}\n                />\n              ))}\n          </div>\n        ) : (\n          <EmptyState icon=\"checkSquare\" title=\"No open actions\" description=\"Everything is taken care of.\" />\n        )}\n      </PageSection>\n    </main>\n  );\n}","numLines":156,"startLine":1,"totalLines":156}}}
