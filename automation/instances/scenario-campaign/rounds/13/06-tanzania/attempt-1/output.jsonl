{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_PJTw4bp8jbjUHEtnjBWyWK7q","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { createVM } from '../sandbox/quickjs.js';\n3\timport { runTurnLoop, formatReadDocuments } from './turn-loop.js';\n4\timport { MessageHistory } from '../context/history.js';\n5\timport { LIBRARY_DTS } from '../typecheck/library-dts.js';\n6\timport type { RenderHost } from '../session/types.js';\n7\timport type { StreamSession, StreamOpts } from './stream-types.js';\n8\timport type { YieldRequest } from './yield.js';\n9\t\n10\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n11\t\n12\tdescribe('formatReadDocuments', () => {\n13\t  const ydoc = (): YieldRequest =>\n14\t    ({ kind: 'readDocument', args: ['id', undefined], deferred: { resolve() {}, reject() {} }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n15\t  const yother = (): YieldRequest =>\n16\t    ({ kind: 'fetch', args: [], deferred: { resolve() {}, reject() {} }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n17\t\n18\t  it('surfaces the FULL text of a read document (bypassing the 200-char preview cap)', () => {\n19\t    const longText = 'A'.repeat(5000) + ' END';\n20\t    const out = formatReadDocuments(\n21\t      [ydoc()],\n22\t      [{ ok: true, attachmentId: 'abc', mediaType: 'application/pdf', filename: 'report.pdf', kind: 'text', text: longText }],\n23\t    );\n24\t    expect(out).toContain('DOCUMENT CONTENTS');\n25\t    expect(out).toContain('report.pdf (application/pdf)');\n26\t    expect(out).toContain(longText); // whole text present, not truncated to 200 chars\n27\t    expect(out).not.toContain('chars total');\n28\t  });\n29\t\n30\t  it('flags a host-truncated document and aligns yields with resolved values by index', () => {\n31\t    const out = formatReadDocuments(\n32\t      [yother(), ydoc()],\n33\t      [{ some: 'other yield' }, { ok: true, attachmentId: 'x', mediaType: 'text/plain', kind: 'text', text: 'hi', truncated: true }],\n34\t    );\n35\t    expect(out).toContain('truncated');\n36\t    expect(out).toContain('x (text/plain)'); // no filename → falls back to attachmentId\n37\t    expect(out).toContain('hi');\n38\t  });\n39\t\n40\t  it('returns empty string for no documents, failed reads, and unsupported results', () => {\n41\t    expect(formatReadDocuments([], [])).toBe('');\n42\t    expect(formatReadDocuments([ydoc()], [{ ok: false, attachmentId: 'x', mediaType: '', kind: 'unsupported', error: 'nope' }])).toBe('');\n43\t    expect(formatReadDocuments([yother()], [{ ok: true, kind: 'text', text: 'not a doc yield' }])).toBe('');\n44\t  });\n45\t});\n46\t\n47\tdescribe('turn loop — beforeTurn soft reminder', () => {\n48\t  it('appends the beforeTurn reminder to the request messages without persisting it', async () => {\n49\t    const vm = await createVM();\n50\t    const history = new MessageHistory();\n51\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n52\t\n53\t    const seenMessages: Array<Array<{ role: string; content: string }>> = [];\n54\t    let calls = 0;\n55\t    const streamFn = async (o: StreamOpts): Promise<StreamSession> => {\n56\t      seenMessages.push(o.messages);\n57\t      const text = calls++ === 0 ? 'const x = 1;' : '';\n58\t      let aborted = false;\n59\t      async function* gen() { if (!aborted && text) yield text; }\n60\t      return { textStream: gen(), abort() { aborted = true; } } as StreamSession;\n61\t    };\n62\t\n63\t    await runTurnLoop({\n64\t      vm, history, systemBlock: 'test', ambientDts: LIBRARY_DTS,\n65\t      renderHost: silentHost, streamFn,\n66\t      processYield: async () => undefined,\n67\t      beforeTurn: () => '## Open todos\\n- [ ] finish the thing',\n68\t    });\n69\t\n70\t    // The reminder rode along on the request as a trailing user message...\n71\t    const firstReq = seenMessages[0]!;\n72\t    expect(firstReq[firstReq.length - 1]!.content).toContain('Open todos');\n73\t    // ...but was NOT written to history (so it re-injects fresh, never duplicating).\n74\t    expect(history.messages.some((m) => m.content.includes('Open todos'))).toBe(false);\n75\t    vm.dispose();\n76\t  });\n77\t});\n78\t\n79\tdescribe('turn loop — idle watchdog', () => {\n80\t  it('retries a stream that stalls with no tokens (treats the stall as transient)', async () => {\n81\t    const vm = await createVM();\n82\t    const history = new MessageHistory();\n83\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n84\t\n85\t    let calls = 0;\n86\t    const streamFn = async (): Promise<StreamSession> => {\n87\t      const turn = calls++;\n88\t      const stall = turn === 0; // first turn emits no tokens and never ends → idle timeout\n89\t      let aborted = false;\n90\t      async function* gen() {\n91\t        if (stall) { await new Promise<void>(() => {}); }      // hangs forever\n92\t        else if (!aborted) yield 'const recovered = true;';    // binds → globalThis via the loop\n93\t      }\n94\t      return { textStream: gen(), abort() { aborted = true; } } as StreamSession;\n95\t    };\n96\t\n97\t    const result = await runTurnLoop({\n98\t      vm, history, systemBlock: 'test', ambientDts: LIBRARY_DTS,\n99\t      renderHost: silentHost, streamFn,\n100\t      processYield: async () => undefined,\n101\t      maxRetries: 3,\n102\t      streamIdleMs: 40, // tiny so the stalled turn trips the watchdog fast\n103\t    });\n104\t\n105\t    expect(result).toBe('done');\n106\t    expect(calls).toBeGreaterThanOrEqual(2); // the stalled turn was retried\n107\t    const h = vm.ctx.getProp(vm.ctx.global, 'recovered');\n108\t    try { expect(vm.ctx.dump(h)).toBe(true); } finally { h.dispose(); }\n109\t    vm.dispose();\n110\t  });\n111\t});\n112\t"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"93d21be6-6c64-4b