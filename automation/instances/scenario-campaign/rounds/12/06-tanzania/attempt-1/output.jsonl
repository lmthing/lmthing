',\n28\t  cwd: REPO_ROOT,\n29\t\n30\t  // Each task is a scenario id under sdk/org/scenarios/. Round 1 baselines + adds the first new\n31\t  // Acts; later rounds add more. Append new scenario ids here to fold them in (they start at round 1).\n32\t  // One scenario at a time (human-gated, serial). Keep only the ACTIVE scenario here; when it goes\n33\t  // fully green, replace it with the next one (06-tanzania → 07-life-admin → …).\n34\t  tasks: [\n35\t    '06-tanzania',\n36\t  ],\n37\t\n38\t  // Every round runs the judge; it decides internally whether to FIX the first failure (and verify)\n39\t  // or, if the scenario is fully green, author ONE extension. (create.md is a separate manual\n40\t  // entrypoint for authoring a brand-new scenario.yaml — not part of the round loop.)\n41\t  firstRoundTemplate: 'judge.md',\n42\t  nextRoundTemplate: 'judge.md',\n43\t  // Resume wrapper honoring the never-commit rule (the built-in one says \"commit early & often\").\n44\t  continueTemplate: 'prompt.continue.md',\n45\t  roundMode: (round) => `judge pass ${round} — fix one failure & verify, or extend if green`,\n46\t\n47\t  // A scenario is now a single declarative sdk/org/scenarios/<id>/scenario.yaml (+ fixtures/) played\n48\t  // by the generic YAML runner — no per-scenario run.mjs, no results/ dir. The judge's report goes\n49\t  // beside its progress log in the engine's round-artifact tree ({{progressFile}}'s dir), which the\n50\t  // engine commits with the ledger.\n51\t  vars: (ctx) => ({\n52\t    SCENARIO_ID: ctx.task,\n53\t    SCENARIO_DIR: `sdk/org/scenarios/${ctx.task}`,\n54\t    SCENARIO_YAML: `sdk/org/scenarios/${ctx.task}/scenario.yaml`,\n55\t  }),\n56\t\n57\t  // The judge is ONE coherent session: it drives the live run, plays the persona, judges, and fixes.\n58\t  // No parallel subagents — its work is sequential and its context must stay clean (the whole point\n59\t  // of one-failure-per-invocation is to bound context rot).\n60\t  subagents: (ctx) => [],\n61\t