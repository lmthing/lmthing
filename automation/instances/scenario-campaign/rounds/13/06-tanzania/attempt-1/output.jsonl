{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_XgDzjgwe087UByI8aLEsL6wP","type":"tool_result","content":"220\t        return { ok: true }; // mirrors Session.handleYield's return\n221\t      },\n222\t      maxRetries: 2,\n223\t    });\n224\t\n225\t    expect(seen).toEqual({ title: 'Pasta night', slug: 'pasta-night' });\n226\t    expect(readGlobal(vm, 'r')).toEqual({ ok: true });\n227\t    vm.dispose();\n228\t  });\n229\t});\n230\t\n231\tdescribe('turn loop — nested yield binding (yield inside an awaited async wrapper)', () => {\n232\t  it(\"binds the bound name to the outer async function's return value, not the inner yield's raw resolved value\", async () => {\n233\t    const vm = await createVM();\n234\t    // A yielding global `y(tag)`, same shape as sleep/ask/etc.\n235\t    const y = (tag: string) =>\n236\t      new Promise((resolve, reject) => {\n237\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n238\t      });\n239\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n240\t\n241\t    // A plain async function (mirrors webSearch/webFetch awaiting fetch() internally)\n242\t    // that awaits the yielding global and post-processes its result before returning.\n243\t    const def = vm.evalScript(\n244\t      'globalThis.wrapper = async function wrapper() { const inner = await y(\"tag\"); return { processed: inner, marker: \"real\" }; };',\n245\t    );\n246\t    expect(def.ok).toBe(true);\n247\t\n248\t    const history = new MessageHistory();\n249\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n250\t\n251\t    const result = await runTurnLoop({\n252\t      vm,\n253\t      history,\n254\t      systemBlock: 'test',\n255\t      ambientDts: 'declare function wrapper(): Promise<any>; declare function y(tag: string): Promise<any>;',\n256\t      renderHost: silentHost,\n257\t      streamFn: scriptedStream('const out = await wrapper();'),\n258\t      // The INNER yield resolves to a raw sentinel, distinct from wrapper's real return —\n259\t      // proves the bound value isn't just this raw value passed through.\n260\t      processYield: async () => 'RAW_INNER_VALUE',\n261\t      maxRetries: 2,\n262\t    });\n263\t\n264\t    expect(result).toBe('done');\n265\t    expect(readGlobal(vm, 'out')).toEqual({ processed: 'RAW_INNER_VALUE', marker: 'real' });\n266\t    vm.dispose();\n267\t  });\n268\t\n269\t  it('services SEQUENTIAL internal yields to completion (webFetch plain→render), not just the first', async () => {\n270\t    const vm = await createVM();\n271\t    // A yielding global `y(tag)`, same shape as fetch — each call is one host yield.\n272\t    const y = (tag: string) =>\n273\t      new Promise((resolve, reject) => {\n274\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n275\t      });\n276\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n277\t\n278\t    // A wrapper that awaits the yielding global TWICE in sequence (mirrors webFetch's\n279\t    // auto-dynamic path: a plain fetch, then — based on its result — a second fetch to\n280\t    // the render service). The second await only becomes a pending yield after the\n281\t    // first resumes, so the turn loop must loop-service both before binding.\n282\t    const def = vm.evalScript(\n283\t      'globalThis.wrapper = async function wrapper() { const first = await y(\"a\"); const second = await y(\"b\"); return { first, second, marker: \"real\" }; };',\n284\t    );\n285\t    expect(def.ok).toBe(true);\n286\t\n287\t    const history = new MessageHistory();\n288\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n289\t\n290\t    let call = 0;\n291\t    const result = await runTurnLoop({\n292\t      vm,\n293\t      history,\n294\t      systemBlock: 'test',\n295\t      ambientDts: 'declare function wrapper(): Promise<any>; declare function y(tag: string): Promise<any>;',\n296\t      renderHost: silentHost,\n297\t      streamFn: scriptedStream('const out = await wrapper();'),\n298\t      // Distinct value per sequential yield — proves BOTH ran (not just the first).\n299\t      processYield: async () => `R${call++}`,\n300\t      maxRetries: 2,\n301\t    });\n302\t\n303\t    expect(result).toBe('done');\n304\t    // Before the sequential-yield fix, `out` bound the raw first Response (\"R0\");\n305\t    // now it is the wrapper's real return after BOTH internal awaits completed.\n306\t    expect(readGlobal(vm, 'out')).toEqual({ first: 'R0', second: 'R1', marker: 'real' });\n307\t    vm.dispose();\n308\t  });\n309\t});\n310\t\n311\tdescribe('turn loop — inspect() surfaces values to the model', () => {\n312\t  // Regression: a BARE (unbound) inspect(x) must still surface x into the\n313\t  // VARIABLES block the model reads. Before this was wired, bare inspect\n314\t  // resolved to an empty VARIABLES block, so the model saw nothing and would\n315\t  // re-type values from memory (hallucinating the truncated tail).\n316\t  it('emits the inspected value even when the call is unbound', async () => {\n317\t    const vm = await createVM();\n318\t    // inspect(v) pushes a yield whose args mirror globals/inspect.ts: [{ value, query }].\n319\t    const inspect = (v: unknown) =>\n320\t      new Promise((resolve, reject) => {\n321\t        vm.pendingYields.push({\n322\t          kind: 'inspect',\n323\t          args: [{ value: v, query: undefined }],\n324\t          deferred: { resolve, reject },\n325\t          vmPromiseHandle: undefined,\n326\t        } as unknown as YieldRequest);\n327\t      });\n328\t    injectGlobal(vm.ctx, 'inspect', inspect as (...a: unknown[]) => unknown);\n329\t\n330\t    const history = new MessageHistory();\n331\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"0a00aa33-4a5b-4346-be27-a3aa2d866085","timestamp":"2026-07-16T02:09:39.522Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
