1\t        ...(deps.model ? { model: deps.model } : {}),\n572\t        ...(inputTokens !== undefined ? { inputTokens } : {}),\n573\t        ...(outputTokens !== undefined ? { outputTokens } : {}),\n574\t      });\n575\t      history.append({ role: 'assistant', content: historyContent, blockType: 'normal' });\n576\t    }\n577\t\n578\t    if (turnError && failingStatement) {\n579\t      // process.exit() is intentional termination, not a recoverable error. The model\n580\t      // uses it as control flow (e.g. `if (!ok) process.exit(1)`); retrying re-runs the\n581\t      // exact same code and burns LLM calls in a loop. Treat it as a clean stop.\n582\t      if (/\\bprocess\\.exit\\(/.test(turnError)) {\n583\t        renderHost.log(`[process.exit] intentional termination — not retrying`);\n584\t        return 'done';\n585\t      }\n586\t      // Do NOT roll back accumulatedContext: statements that succeeded earlier in\n587\t      // this turn already bound their variables in the VM (globalThis) and persist\n588\t      // into the retry. Keeping them in the typecheck context matches VM reality —\n589\t      // rolling back would make tsc reject valid references with \"Cannot find name\".\n590\t      // The failing statement was never appended (it errors before accumulation), so\n591\t      // there is nothing partial to discard.\n592\t      renderHost.log(`[error] ${turnError}`);\n593\t      history.append({ role: 'user', content: buildErrorBlock(failingStatement, turnError, attempt, maxRetries, accumulatedContext), blockType: 'error' });\n594\t      if (attempt >= maxRetries) return 'error';\n595\t      continue;\n596\t    }\n597\t\n598\t    if (pendingYield && yieldingStatement) {\n599\t      // Binding pattern of the yielding statement (kind + names).\n600\t      const pattern = extractBindingPattern(yieldingStatement);\n601\t\n602\t      // Resolve the statement's yields to completion. Most statements yield once, or a\n603\t      // single CONCURRENT batch — `await Promise.all([fork(...), fork(...)])`. But a\n604\t      // model-awaited helper can also await host calls SEQUENTIALLY: e.g. `webFetch`\n605\t      // does a plain fetch and THEN, if the page is JS-rendered, a second fetch to the\n606\t      // render service; `webSearch`'s `auto` chain likewise falls Tavily→Bing→DuckDuckGo.\n607\t      // Each later await only surfaces as a pending yield AFTER `drivePendingJobs()`\n608\t      // resumes the prior one, so we loop until the VM has no pending yields left (the\n609\t      // statement has fully returned). Servicing only the first batch would bind an\n610\t      // incomplete value — the raw first Response — instead of the helper's real return.\n611\t      // The QuickJS module continuation after `await` does NOT re-run in this sync eval\n612\t      // model, so the host binds the final value itself (see bindYieldResults, below).\n613\t      // Bounded by MAX_SEQUENTIAL_YIELDS (a runaway is also bounded by the tool-call budget).\n614\t      const yields: YieldRequest[] = [];\n615\t      const resolvedValues: unknown[] = [];\n616\t      const yieldErrors: Array<{ kind: string; message: string }> = [];\n617\t      let batch = vm.pendingYields.splice(0);\n618\t      for (let guard = 0; batch.length > 0 && guard < MAX_SEQUENTIAL_YIELDS; guard++) {\n619\t        const base = resolvedValues.length;\n620\t        for (const y of batch) { yields.push(y); resolvedValues.push(undefined); }\n621\t        // Budget: count each resolved yield as a tool call. Throws (and the caller\n622\t        // disposes the VM) if over the tool-call or wall-clock cap.\n623\t        deps.budget?.tickToolCalls(batch.length);\n624\t        await Promise.all(batch.map(async (yieldReq, i) => {\n625\t          const yieldId = `${nodeId ?? ctx}_y${++yieldCounter}`;\n626\t          tracer.write({ ts: Date.now(), type: 'yield', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, args: yieldReq.args, yieldId });\n627\t          try {\n628\t            const resolved = await processYield(yieldReq);\n629\t            tracer.write({ ts: Date.now(), type: 'yield_resolved', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, value: resolved, yieldId });\n630\t            yieldReq.deferred.resolve(resolved);\n631\t            resolvedValues[base + i] = resolved;\n632\t          } catch (err) {\n633\t            // A budget breach inside a yield (e.g. a fork rejected by the fork-depth\n634\t            // cap, or an over-budget fork) is a HARD stop, not a recoverable\n635\t            // tool error. Propagate it so it surfaces exactly like the episode and\n636\t            // tool-call caps (clean non-zero exit + VM disposal by the caller) —\n637\t            // instead of being swallowed into an undefined binding that lets the run\n638\t            // continue past its ceiling.\n639\t            if (err instanceof BudgetExceededError) throw err;\n640\t            yieldReq.deferred.reject(err);\n641\t            resolvedValues[base + i] = undefined;\n642\t            yieldErrors.push({ kind: yieldReq.kind, message: err instanceof Error ? err.message : String(err) });\n643\t          }\n644\t        }));\n645\t        vm.drivePendingJobs();\n646\t        // A yield that errored can't cleanly resume the VM continuation, so stop\n647\t        // servicing further sequential yields and let the error path below surface it\n648\t        // (and retry the turn). `fetch` never rejects — it resolves `{ok:false}` — so\n649\t        // webFetch/webSearch's sequential fetches always run to completion here.\n650\t        if (yieldErrors.length > 0) break;\n651\t        batch = vm.pendingYields.splice(0);\n652\t      }\n653\t\n654\t      // A yield that threw (e.g. delegate() to a hallucinated space key, a function\n655\t      // that errored) used to bind `undefined` silently — the model never learned why\n656\t      // and could not self-correct. Surface it as a normal turn error so the actionable\n657\t      // message (e.g. the list of real space keys) reaches the model and it retries.\n658\t      // Hard caps already short-circuited above; forks/tasklists salvage rather than\n659\t      // throw, so this primarily catches recoverable model mistakes. On the final attempt\n660\t      // we fall through and bind the undefined values so the run can still limp forward.\n661\t      if (yieldErrors.length > 0 && attempt < maxRetries) {\n662\t        turnError = yieldErrors.map((e) => `${e.kind}() failed: ${e.message}`).join('; ');\n663\t        failingStatement = yieldingStatement;\n664\t        renderHost.log(`[yield error] ${turnError}`);\n665\t        // Preserve the failed statement's bound names so a retry that references them\n666\t        // (or re-emits the binding) typechecks instead of dying with \"Cannot find name\".\n667\t        // Declared ambient (any) + seeded undefined in the VM so eval can't ReferenceError.\n668\t        for (const name of pattern.names) {\n669\t          yieldErrorNames.add(name);\n670\t          vm.setVar(name, undefined);\n671\t        }\n672\t        history.append({ role: 'user', content: buildErrorBlock(failingStatement, turnError, attempt, maxRetries, accumulatedContext), blockType: 'error' });\n673\t        continue;\n674\t      }\n675\t\n676\t      // Map resolved values onto the bound names, preferring the VM's own computed\n677\t      // value for each name over the raw resolved-yield value where they diverge\n678\t      // (see bindYieldResults' doc comment — the webSearch()-awaiting-fetch() case).\n679\t      const variables = bindYieldResults(vm, pattern, yields.length, resolvedValues);\n680\t      for (const [name, value] of Object.entries(variables)) {\n681\t        vm.setVar(name, value); // inject into VM scope + host scope for the next turn\n682\t      }\n683\t\n684\t      // Emit a serialized variables snapshot for the observability tree\n685\t      if (Object.keys(variables).length > 0) {\n686\t        const serialized: Record<string, unknown> = {};\n687\t        for (const [k, v] of Object.entries(variables)) {\n688\t          serialized[k] = serialize(v);\n689\t        }\n690\t        tracer.write({ ts: Date.now(), type: 'variables', context: ctx, ...(nodeId ? { nodeId } : {}), vars: serialized });\n691\t      }\n692\t\n693\t      // Add the yielding statement to accumulated context for future typecheck\n694\t      appendContext(yieldingStatement);\n695\t\n696\t      // inspect() is a read-only probe: its whole purpose is to surface a value\n697\t      // (or a queried slice/path/keys view of it) to the MODEL. Unlike other yields\n698\t      // it is normally called WITHOUT a binding (`inspect(x)` / `inspect([x, q])`),\n699\t      // so the generic name-binding above captures nothing. Surface the inspected\n700\t      // values explicitly via formatInspectResult, independent of any binding —\n701\t      // otherwise a bare inspect() resolves to an empty VARIABLES block and the\n702\t      // model sees nothing (the exact failure that lets it re-type/​hallucinate\n703\t      // values instead of reading them).\n704\t      const inspectArgs = yields\n705\t        .filter((y) => y.kind === 'inspect')\n706\t        .flatMap((y) => (y.args as Array<{ value: unknown; query?: InspectQuery }>));\n707\t\n708\t      // Always emit a continuation message so the model knows the yield resolved and\n709\t      // what's already in scope — even for yields with no variable bindings (e.g. sleep).\n710\t      if (Object.keys(variables).length > 0) {\n711\t        renderHost.log(`[variables] ${Object.keys(variables).join(', ')}`);\n712\t      } else if (inspectArgs.length > 0) {\n713\t        renderHost.log(`[inspect] ${inspectArgs.length} value(s)`);\n714\t      } else {\n715\t        renderHost.log(`[resumed]`);\n716\t      }\n717\t\n718\t      let varContent = emitVariables(variables, accumulatedContext);\n719\t      if (inspectArgs.length > 0) {\n720\t        // Fold the inspected lines into the VARIABLES section the model already reads.\n721\t        // formatInspectResult returns \"VARIABLES\\ninspected[i]: …\" — drop its header\n722\t        // and splice its lines in right after the existing VARIABLES header.\n723\t        const inspectLines = formatInspectResult(inspectArgs).split('\\n').slice(1);\n724\t        varContent = varContent.replace(/^VARIABLES\\n?/, (m) => m + inspectLines.join('\\n') + '\\n');\n725\t      }\n726\t      // readDocument results are meant to be READ IN FULL. The VARIABLES preview\n727\t      // serializes the bound `doc` with a 200-char string cap, so the model would\n728\t      // otherwise see only the opening of any real document (and mistake the preview\n729\t      // marker for real truncation). Surface each successfully-read document's whole\n730\t      // text as its own block, exactly as it came back from readDocument (already\n731\t      // capped host-side at READ_DOCUMENT_MAX_CHARS).\n732\t      const documentBlock = formatReadDocuments(yields, resolvedValues);\n733\t      if (documentBlock) varContent += `\\n\\n${documentBlock}`;\n734\t      const budgetWarning = deps.budget?.nearLimitWarning();\n735\t      if (budgetWarning) varContent += `\\n\\n${budgetWarning}`;\n736\t      history.append({ role: 'user', content: varContent, blockType: 'variables' });\n737\t\n738\t      attempt = 0;\n739\t      continue;\n740\t    }\n741\t\n742\t    if (!hadStatements) {\n743\t      renderHost.log(`[turn ${attempt}] model produced no statements — done`);\n744\t      tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'no_statements' });\n745\t      return 'done';\n746\t    }\n747\t\n748\t    // The model ended its response with no pending yield. If its last clean\n749\t    // statement was a non-yielding `await`-binding, it most likely stopped to\n750\t    // \"see\" a result the runtime never surfaces (e.g. writeTaskFile) — which\n751\t    // would strand a multi-step program. Re-prompt it to continue, bounded so a\n752\t    // genuinely-finished model (which emits no further statements → no_statements\n753\t    // → done) and a model that keeps binding without progressing both terminate.\n754\t    if (lastStmtNonYieldBinding && continueNudges < maxContinueNudges) {\n755\t      continueNudges++;\n756\t      renderHost.log(`[turn ${attempt}] ended on a non-yielding binding — nudging to continue (${continueNudges}/${maxContinueNudges})`);\n757\t      tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'continue' });\n758\t      history.append({ role: 'user', content: CONTINUATION_NUDGE, blockType: 'normal' });\n759\t      attempt = 0;\n760\t      continue;\n761\t    }\n762\t\n763\t    renderHost.log(`[turn ${attempt}] done`);\n764\t    tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'done' });\n765\t    return 'done';\n766\t  }\n767\t\n768\t  tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'max_retries' });\n769\t  return 'error';\n770\t}\n771\t"}]},"parent_tool_use_id":"call_FFJKMOVjsfKJlWJZsycaWrdj","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"cf8a810b-cdf8-4b94-a3bf-03a3db4d1034","timestamp":"2026-07-16T06:24:05.715Z","subagent_type":"general-purpose","task_description":"Review live-build tasklist"}
