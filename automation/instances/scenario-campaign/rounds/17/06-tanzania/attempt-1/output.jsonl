{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Fq5UrXhj7yCd6owVR3SqsDkZ","type":"tool_result","content":"1\timport type { StreamOpts, StreamSession } from '../eval/stream-types.js';\n2\timport type { BudgetLimits } from '../eval/budget.js';\n3\timport type { RoleModelConfig } from '../fork/roles.js';\n4\timport type { AppGlobalImpls } from '../exec/app-globals.js';\n5\timport type { DocumentResolver } from '../globals/read-document.js';\n6\timport type { IntegrationStatusResolver } from '../globals/integration-status.js';\n7\timport type { ConsentPrompter } from '../globals/consent.js';\n8\timport type { CodeNodeCtxFactory } from '../tasklist/orchestrator.js';\n9\t\n10\texport interface RenderHost {\n11\t  display(descriptor: unknown): void;\n12\t  ask(id: string, descriptor: unknown): Promise<unknown>;\n13\t  log(message: string): void;\n14\t}\n15\t\n16\texport interface Clock {\n17\t  setTimeout(fn: () => void, ms: number): void;\n18\t  clearTimeout(id: unknown): void;\n19\t}\n20\t\n21\texport interface SessionOpts {\n22\t  spaceDir: string;\n23\t  agentSlug: string;\n24\t  modelAlias: string;\n25\t  renderHost: RenderHost;\n26\t  maxRetries?: number;\n27\t  maxConcurrentForks?: number;\n28\t  /** Inactivity watchdog for the model stream (ms). A turn whose stream emits no token\n29\t   *  for this long is retried as a transient failure. Default 60000. */\n30\t  streamIdleMs?: number;\n31\t  clock?: Clock;\n32\t  traceFile?: string;\n33\t  /** Override the always-loaded system space directories. Defaults to the\n34\t   *  bundled fs/web/memory/todo/agents spaces. Pass [] to disable. */\n35\t  systemSpaceDirs?: string[];\n36\t  /** When set, collapse history to a summary once it exceeds maxHistoryTurns*2\n37\t   *  messages (keeping the last few verbatim). Used by long REPL sessions. */\n38\t  maxHistoryTurns?: number;\n39\t  /** When true, bypass an agent's `defaultAction` routing so the first turn runs\n40\t   *  the model-driven turn loop