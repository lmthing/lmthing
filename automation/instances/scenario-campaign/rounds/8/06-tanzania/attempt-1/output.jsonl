       },\n              \"lodging\": {\n                \"type\": \"string\",\n                \"description\": \"Lodging name\"\n              },\n              \"cost_usd\": {\n                \"type\": \"number\",\n                \"description\": \"Cost in USD\"\n              },\n              \"notes\": {\n                \"type\": \"string\",\n                \"description\": \"Additional notes about this leg\"\n              },\n              \"sort_order\": {\n                \"type\": \"number\",\n                \"description\": \"Display order\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"park_fees\",\n          \"schema\": {\n            \"title\": \"NCA Park Fees\",\n            \"description\": \"Official Ngorongoro Conservation Area tariff schedule — seeded from the NCA PDF.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\",\n                \"description\": \"Primary key\"\n              },\n              \"category\": {\n                \"type\": \"string\",\n                \"description\": \"Fee category (e.g. Entry Permit, Crater Service, Camping, Vehicle)\"\n              },\n              \"subcategory\": {\n                \"type\": \"string\",\n                \"description\": \"Specific fee type\"\n              },\n              \"age_group\": {\n                \"type\": \"string\",\n                \"description\": \"Age group or weight class\"\n              },\n              \"non_ea_usd\": {\n                \"type\": \"number\",\n                \"description\": \"Non-East African citizen rate in USD\"\n              },\n              \"ea_tzs\": {\n                \"type\": \"number\",\n                \"description\": \"East African citizen rate in TZS\"\n              },\n              \"expat_usd\": {\n                \"type\": \"number\",\n                \"description\": \"Expatriate/resident rate in USD\"\n              },\n              \"notes\": {\n                \"type\": \"string\",\n                \"description\": \"Additional tariff notes\"\n              },\n              \"sort_order\": {\n                \"type\": \"number\",\n                \"description\": \"Display order\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"photos\",\n          \"schema\": {\n            \"title\": \"Photos\",\n            \"description\": \"Photo gallery entries for the Tanzania trip — reference images with descriptions.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\",\n                \"description\": \"Primary key\"\n              },\n              \"title\": {\n                \"type\": \"string\",\n                \"description\": \"Photo title or caption\"\n              },\n              \"description\": {\n                \"type\": \"string\",\n                \"description\": \"What the photo shows or the story behind it\"\n              },\n              \"location\": {\n                \"type\": \"string\",\n                \"description\": \"Where it was taken\"\n              },\n              \"date_taken\": {\n                \"type\": \"string\",\n                \"description\": \"Approximate date\"\n              },\n              \"sort_order\": {\n                \"type\": \"number\",\n                \"description\": \"Display order\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"questions\",\n          \"schema\": {\n            \"title\": \"Open Questions\",\n            \"description\": \"Open questions, loose ends, and things to confirm before or during the trip.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"primaryKey\"