{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Ip4dxpBIdj8jt64LTmc5WWxa","type":"tool_result","content":"1\t/**\n2\t * Write-time lint for generated app artifacts.\n3\t *\n4\t * The typed writers (`writeProjectApi/Page/Hook/Component/Table` and the catalog twins) validate\n5\t * parse + slug + column names today, but NOT the real loader/compiler CONTRACT — so a file the app\n6\t * loader will later reject (an API endpoint with no `export const name`, a page with no default\n7\t * export, a hook of the wrong shape, a schema with a dangling relation) is accepted at write time and\n8\t * only fails downstream at compile/serve, with a confusing error far from the cause.\n9\t *\n10\t * These validators mirror the ACTUAL loader contracts by reusing the loaders' own functions\n11\t * (`apiEndpointContractError`, `validateHook`, `validateSchemaSet`), so the lint can never drift from\n12\t * what the app requires. Each returns a human message (the first violation) or null. The writer\n13\t * throws a {@link LintError} on a non-null result, which the model sees as a retryable error and\n14\t * fixes in place — like a typecheck failure. (Lives in `libs/cli` because it reuses the CLI loaders;\n15\t * `@lmthing/core` must never import it.)\n16\t */\n17\timport { existsSync, readdirSync, readFileSync } from 'node:fs';\n18\timport { join } from 'node:path';\n19\timport { apiEndpointContractError, parseExportedString } from '../api/loader.js';\n20\timport { evalHookDefaultFromSource } from '../hooks/loader.js';\n21\t\n22\t/**\n23\t * A write-time CONTRACT violation in generated content (not an fs/host failure). Writers re-throw\n24\t * this past their catch-to-`{ok:false}`, so it surfaces to the model as a retryable error rather\n25\t * than a swallowed `{ ok:false }` a node might ignore.\n26\t */\n27\texport class LintError extends Error {\n28\t  constructor(message: string) {\n29\t    super(message);\n30\t    this.name = 'LintError';\n31\t  }\n32\t}\n33\t\n34\tconst HTTP_METHOD_FILE_RE = /^(GET|POST|PUT|PATCH|DELETE)\\.ts$/;\n35\t\n36\t/** True when the source has a default export in any form the bundler/loader accepts. */\n37\tfunction hasDefaultExport(src: string): boolean {\n38\t  return /export\\s+default\\b/.test(src) || /export\\s*\\{[^}]*\\bas\\s+default\\b[^}]*\\}/.test(src);\n39\t}\n40\t\n41\t/**\n42\t * The API-endpoint contract at write time: the loader's own `export const name` check\n43\t * ({@link apiEndpointContractError}), a default/`handler` export (the runtime handler-module\n44\t * contract, `api/handler-module.ts#loadHandlerFromCode`), and a project-unique name.\n45\t */\n46\texport function lintApiHandler(src: string, opts: { existingNames?: Map<string, string> } = {}): string | null {\n47\t  const contractErr = apiEndpointContractError(src);\n48\t  if (contractErr) {\n49\t    return `api endpoint rejected (not saved): ${contractErr}. Add e.g. \\`export const name = 'itemsList'\\` and re-write.`;\n50\t  }\n51\t  const hasHandler =\n52\t    hasDefaultExport(src) ||\n53\t    /export\\s+(?:async\\s+)?function\\s+handler\\b/.test(src) ||\n54\t    /export\\s+const\\s+handler\\b/.test(src);\n55\t  if (!hasHandler) {\n56\t    return (\n57\t      'api endpoint rejected (not saved): no request handler — an endpoint must `export default` a ' +\n58\t      'handler function (or `export function handler`). Add `export default async (req, ctx) => { … }` and re-write.'\n59\t    );\n60\t  }\n61\t  const name = parseExportedString(src, 'name');\n62\t  if (name && opts.existingNames) {\n63\t    const owner = opts.existingNames.get(name);\n64\t    if (owner) {\n65\t      return (\n66\t        `api endpoint rejected (not saved): the name \"${name}\" is already used by ${owner} — endpoint ` +\n67\t        'names are unique per project. Pick a different `export const name` (or edit that file).'\n68\t      );\n69\t    }\n70\t  }\n71\t  return null;\n72\t}\n73\t\n74\t/** A page must default-export a component (else the page bundle has nothing to render). */\n75\texport function lintPageSource(src: string): string | null {\n76\t  if (!hasDefaultExport(src)) {\n77\t    return (\n78\t      'page rejected (not saved): no default export — a page must `export default` a React component. ' +\n79\t      'Add `export default function Page() { … }` and re-write.'\n80\t    );\n81\t  }\n82\t  return null;\n83\t}\n84\t\n85\t/** A shared component must default-export the component an importing page renders. */\n86\texport function lintComponentSource(src: string): string | null {\n87\t  if (!hasDefaultExport(src)) {\n88\t    return (\n89\t      'component rejected (not saved): no default export — a component must `export default` its ' +\n90\t      'React component. Add `export default function <Name>() { … }` and re-write.'\n91\t    );\n92\t  }\n93\t  return null;\n94\t}\n95\t\n96\tconst HOOK_TYPES = new Set(['cron', 'event', 'webhook']);\n97\t\n98\t/**\n99\t * A hook's GROSS shape: `export default` must be a hook OBJECT with a known `type`. Evaluated with\n100\t * the loader's OWN eval (so write-time sees exactly what load-time will), then a light shape check.\n101\t *\n102\t * Deliberately NOT the full `validateHook` (every/daily/on.event/trigger/handler): the hook LOADER\n103\t * is fail-soft — a hook that fails those finer checks is skipped-with-warn at load, not fatal — so\n104\t * making the finer shape a hard write-time throw would invert that design and could stall a build on\n105\t * a detail the app tolerates. This catches the errors that are unambiguously broken (default is a\n106\t * function/value, or an unknown/missing `type`) and leaves the fine shape to the fail-soft loader.\n107\t */\n108\texport function lintHookSource(src: string, _slug: string, file: string): string | null {\n109\t  let raw: unknown;\n110\t  try {\n111\t    raw = evalHookDefaultFromSource(src, file);\n112\t  } catch (e) {\n113\t    const first = (e instanceof Error ? e.message : String(e)).split('\\n')[0];\n114\t    return `hook rejected (not saved): the module failed to evaluate — ${first}. A hook must \\`export default\\` a plain object.`;\n115\t  }\n116\t  if (raw === null || typeof raw !== 'object' || Array.isArray(raw)) {\n117\t    return (\n118\t      'hook rejected (not saved): `export default` must be a hook OBJECT ' +\n119\t      \"(`{ type: 'cron' | 'event' | 'webhook', … }`), not a function or bare value. Re-write it as an object.\"\n120\t    );\n121\t  }\n122\t  const type = (raw as { type?: unknown }).type;\n123\t  if (typeof type !== 'string' || !HOOK_TYPES.has(type)) {\n124\t    return (\n125\t      `hook rejected (not saved): the hook \\`type\\` must be one of ${[...HOOK_TYPES].map((t) => `'${t}'`).join(' | ')} ` +\n126\t      `(got ${JSON.stringify(type)}). Set e.g. \\`type: 'cron'\\` and re-write.`\n127\t    );\n128\t  }\n129\t  return null;\n130\t}\n131\t\n132\t/** Scan `api/**` for the endpoint names already claimed → `Map<name, project-relative file>`. */\n133\texport function existingApiNames(projectRoot: string, excludeFile: string): Map<string, string> {\n134\t  const out = new Map<string, string>();\n135\t  const apiDir = join(projectRoot, 'api');\n136\t  if (!existsSync(apiDir)) return out;\n137\t  const walk = (dir: string): void => {\n138\t    for (const entry of readdirSync(dir, { withFileTypes: true })) {\n139\t      const abs = join(dir, entry.name);\n140\t      if (entry.isDirectory()) {\n141\t        walk(abs);\n142\t        continue;\n143\t      }\n144\t      if (!entry.isFile() || !HTTP_METHOD_FILE_RE.test(entry.name) || abs === excludeFile) continue;\n145\t      try {\n146\t        const nm = parseExportedString(readFileSync(abs, 'utf8'), 'name');\n147\t        if (nm) out.set(nm, abs.slice(projectRoot.length + 1));\n148\t      } catch {\n149\t        /* unreadable sibling — skip */\n150\t      }\n151\t    }\n152\t  };\n153\t  try {\n154\t    walk(apiDir);\n155\t  } catch {\n156\t    /* no api dir */\n157\t  }\n158\t  return out;\n159\t}\n160\t"}]},"parent_tool_use_id":null,"session_id":"4abecf79-4263-4bbb-a5c4-a77231683cc7","uuid":"5e8b4a69-42a6-46f3-a8a1-2ea836483bc6","timestamp":"2026-07-16T15:16:14.571Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/app/authoring/lint.ts","content":"/**\n * Write-time lint for generated app artifacts.\n *\n * The typed writers (`writeProjectApi/Page/Hook/Component/Table` and the catalog twins) validate\n * parse + slug + column names today, but NOT the real loader/compiler CONTRACT — so a file the app\n * loader will later reject (an API endpoint with no `export const name`, a page with no default\n * export, a hook of the wrong shape, a schema with a dangling relation) is accepted at write time and\n * only fails downstream at compile/serve, with a confusing error far from the cause.\n *\n * These validators mirror the ACTUAL loader contracts by reusing the loaders' own functions\n * (`apiEndpointContractError`, `validateHook`, `validateSchemaSet`), so the lint can never drift from\n * what the app requires. Each returns a human message (the first violation) or null. The writer\n * throws a {@link LintError} on a non-null result, which the model sees as a retryable error and\n * fixes in place — like a typecheck failure. (Lives in `libs/cli` because it reuses the CLI loaders;\n * `@lmthing/core` must never import it.)\n */\nimport { existsSync, readdirSync, readFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { apiEndpointContractError, parseExportedString } from '../api/loader.js';\nimport { evalHookDefaultFromSource } from '../hooks/loader.js';\n\n/**\n * A write-time CONTRACT violation in generated content (not an fs/host failure). Writers re-throw\n * this past their catch-to-`{ok:false}`, so it surfaces to the model as a retryable error rather\n * than a swallowed `{ ok:false }` a node might ignore.\n */\nexport class LintError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'LintError';\n  }\n}\n\nconst HTTP_METHOD_FILE_RE = /^(GET|POST|PUT|PATCH|DELETE)\\.ts$/;\n\n/** True when the source has a default export in any form the bundler/loader accepts. */\nfunction hasDefaultExport(src: string): boolean {\n  return /export\\s+default\\b/.test(src) || /export\\s*\\{[^}]*\\bas\\s+default\\b[^}]*\\}/.test(src);\n}\n\n/**\n * The API-endpoint contract at write time: the loader's own `export const name` check\n * ({@link apiEndpointContractError}), a default/`handler` export (the runtime handler-module\n * contract, `api/handler-module.ts#loadHandlerFromCode`), and a project-unique name.\n */\nexport function lintApiHandler(src: string, opts: { existingNames?: Map<string, string> } = {}): string | null {\n  const contractErr = apiEndpointContractError(src);\n  if (contractErr) {\n    return `api endpoint rejected (not saved): ${contractErr}. Add e.g. \\`export const name = 'itemsList'\\` and re-write.`;\n  }\n  const hasHandler =\n    hasDefaultExport(src) ||\n    /export\\s+(?:async\\s+)?function\\s+handler\\b/.test(src) ||\n    /export\\s+const\\s+handler\\b/.test(src);\n  if (!hasHandler) {\n    return (\n      'api endpoint rejected (not saved): no request handler — an endpoint must `export default` a ' +\n      'handler function (or `export function handler`). Add `export default async (req, ctx) => { … }` and re-write.'\n    );\n  }\n  const name = parseExportedString(src, 'name');\n  if (name && opts.existingNames) {\n    const owner = opts.existingNames.get(name);\n    if (owner) {\n      return (\n        `api endpoint rejected (not saved): the name \"${name}\" is already used by ${owner} — endpoint ` +\n        'names are unique per project. Pick a different `export const name` (or edit that file).'\n      );\n    }\n  }\n  return null;\n}\n\n/** A page must default-export a component (else the page bundle has nothing to render). */\nexport function lintPageSource(src: string): string | null {\n  if (!hasDefaultExport(src)) {\n    return (\n      'page rejected (not saved): no default export — a page must `export default` a React component. ' +\n      'Add `export default function Page() { … }` and re-write.'\n    );\n  }\n  return null;\n}\n\n/** A shared component must default-export the component an importing page renders. */\nexport function lintComponentSource(src: string): string | null {\n  if (!hasDefaultExport(src)) {\n    return (\n      'component rejected (not saved): no default export — a component must `export default` its ' +\n      'React component. Add `export default function <Name>() { … }` and re-write.'\n    );\n  }\n  return null;\n}\n\nconst HOOK_TYPES = new Set(['cron', 'event', 'webhook']);\n\n/**\n * A hook's GROSS shape: `export default` must be a hook OBJECT with a known `type`. Evaluated with\n * the loader's OWN eval (so write-time sees exactly what load-time will), then a light shape check.\n *\n * Deliberately NOT the full `validateHook` (every/daily/on.event/trigger/handler): the hook LOADER\n * is fail-soft — a hook that fails those finer checks is skipped-with-warn at load, not fatal — so\n * making the finer shape a hard write-time throw would invert that design and could stall a build on\n * a detail the app tolerates. This catches the errors that are unambiguously broken (default is a\n * function/value, or an unknown/missing `type`) and leaves the fine shape to the fail-soft loader.\n */\nexport function lintHookSource(src: string, _slug: string, file: string): string | null {\n  let raw: unknown;\n  try {\n    raw = evalHookDefaultFromSource(src, file);\n  } catch (e) {\n    const first = (e instanceof Error ? e.message : String(e)).split('\\n')[0];\n    return `hook rejected (not saved): the module failed to evaluate — ${first}. A hook must \\`export default\\` a plain object.`;\n  }\n  if (raw === null || typeof raw !== 'object' || Array.isArray(raw)) {\n    return (\n      'hook rejected (not saved): `export default` must be a hook OBJECT ' +\n      \"(`{ type: 'cron' | 'event' | 'webhook', … }`), not a function or bare value. Re-write it as an object.\"\n    );\n  }\n  const type = (raw as { type?: unknown }).type;\n  if (typeof type !== 'string' || !HOOK_TYPES.has(type)) {\n    return (\n      `hook rejected (not saved): the hook \\`type\\` must be one of ${[...HOOK_TYPES].map((t) => `'${t}'`).join(' | ')} ` +\n      `(got ${JSON.stringify(type)}). Set e.g. \\`type: 'cron'\\` and re-write.`\n    );\n  }\n  return null;\n}\n\n/** Scan `api/**` for the endpoint names already claimed → `Map<name, project-relative file>`. */\nexport function existingApiNames(projectRoot: string, excludeFile: string): Map<string, string> {\n  const out = new Map<string, string>();\n  const apiDir = join(projectRoot, 'api');\n  if (!existsSync(apiDir)) return out;\n  const walk = (dir: string): void => {\n    for (const entry of readdirSync(dir, { withFileTypes: true })) {\n      const abs = join(dir, entry.name);\n      if (entry.isDirectory()) {\n        walk(abs);\n        continue;\n      }\n      if (!entry.isFile() || !HTTP_METHOD_FILE_RE.test(entry.name) || abs === excludeFile) continue;\n      try {\n        const nm = parseExportedString(readFileSync(abs, 'utf8'), 'name');\n        if (nm) out.set(nm, abs.slice(projectRoot.length + 1));\n      } catch {\n        /* unreadable sibling — skip */\n      }\n    }\n  };\n  try {\n    walk(apiDir);\n  } catch {\n    /* no api dir */\n  }\n  return out;\n}\n","numLines":160,"startLine":1,"totalLines":160}}}
