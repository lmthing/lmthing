{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_bthoq7sMqWKdkeoIBtwtUXnj","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { runTasklist } from './orchestrator.js';\n6\timport { ForkEngine } from '../fork/fork.js';\n7\timport { loadSpace } from '../spaces/load.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamOpts } from '../eval/stream-types.js';\n11\t\n12\t/**\n13\t * Coverage for the host-driven `forEach` map node and per-task `role`/`functions`\n14\t * scoping (the new authoring primitives). Drives the REAL runTasklist + ForkEngine\n15\t * with the scripted mock provider — no API keys.\n16\t */\n17\t\n18\tconst tmpDirs: string[] = [];\n19\tafterAll(async () => {\n20\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n21\t});\n22\t\n23\tasync function makeTasklistSpace(files: Record<string, string>): Promise<string> {\n24\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-foreach-'));\n25\t  tmpDirs.push(dir);\n26\t  await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n27\t  await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'You are a runner.\\n', 'utf8');\n28\t  const tl = join(dir, 'tasklists', 'flow');\n29\t  await mkdir(tl, { recursive: true });\n30\t  for (const [name, contents] of Object.entries(files)) {\n31\t    await writeFile(join(tl, name), contents, 'utf8');\n32\t  }\n33\t  return dir;\n34\t}\n35\t\n36\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n37\t\n38\tdescribe('forEach map node', () => {\n39\t  it('fans a task out once per element and collects the results into an array', async () => {\n40\t    const dir = await makeTasklistSpace({\n41\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n42\t      '02-square.md': `---\\nid: square\\ndependsOn: [list]\\nforEach: list.items\\noutput:\\n  n: number\\n---\\n\\nSQUARE_T: square the item.`,\n43\t      '03-done.md': `---\\nid: done\\ndependsOn: [square]\\ngoal: true\\noutput:\\n  total: number\\n---\\n\\nDONE_T: sum the squares.`,\n44\t    });\n45\t    const space = await loadSpace(dir);\n46\t    const seen: string[] = [];\n47\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n48\t      const user = o.messages.map((m) => m.content).join('\\n');\n49\t      if (user.includes('LIST_T')) { seen.push('list'); return `currentTask.resolve({ items: [2, 3, 4] });`; }\n50\t      // Each per-element fork sees its element bound as `item`.\n51\t      if (user.includes('SQUARE_T')) { seen.push('square'); return `currentTask.resolve({ n: item * item });`; }\n52\t      // The dependent task receives `square` as the collected ARRAY of element outputs.\n53\t      if (user.includes('DONE_T')) { seen.push('done'); return `currentTask.resolve({ total: square.reduce((s: number, e: { n: number }) => s + e.n, 0) });`; }\n54\t      return '';\n55\t    });\n56\t    const engine = new ForkEngine({\n57\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n58\t      renderHost: silentHost, streamFn,\n59\t    });\n60\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n61\t    // 2²+3²+4² = 29\n62\t    expect(goal.data).toEqual({ total: 29 });\n63\t    expect(goal.ok).toBe(true);\n64\t    expect(goal.degraded).toBe(false);\n65\t    // square ran three times (one per element).\n66\t    expect(seen.filter((s) => s === 'square')).toHaveLength(3);\n67\t  });\n68\t\n69\t  it('runs zero element forks when the source array is empty', async () => {\n70\t    const dir = await makeTasklistSpace({\n71\t      '01-list.md': `---\\nid: list\\noutput:\\n  items: array\\n---\\n\\nLIST_T: produce the list.`,\n72\t      '02-each.md': `---\\nid: each\\ndependsOn: [list]\\nforEach: list.items\\ngoal: true\\noutput:\\n  n: number\\n---\\n\\nEACH_T: per item.`,\n73\t    });\n74\t    const space = await loadSpace(dir);\n75\t    const seen: string[] = [];\n76\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n77\t      const user = o.messages.map((m) => m.content).join('\\n');\n78\t      if (user.includes('LIST_T')) return `currentTask.resolve({ items: [] });`;\n79\t      if (user.includes('EACH_T')) { seen.push('each'); return `currentTask.resolve({ n: 1 });`; }\n80\t      return '';\n81\t    });\n82\t    const engine = new ForkEngine({\n83\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n84\t      renderHost: silentHost, streamFn,\n85\t    });\n86\t    const goal = await runTasklist({ name: 'flow', space, forkEngine: engine });\n87\t    expect(goal.data).toEqual([]); // empty source → empty collected array\n88\t    expect(seen).toHaveLength(0); // no element forks dispatched\n89\t  });\n90\t});\n91\t\n92\tdescribe('charter + tasklist goal injection into task forks', () => {\n93\t  it('injects the parent charter and the tasklist goal, but never raw instruct.md', async () => {\n94\t    const dir = await mkdtemp(join(tmpdir(), 'lmthing-foreach-'));\n95\t    tmpDirs.push(dir);\n96\t    await mkdir(join(dir, 'agents', 'main'), { recursive: true });\n97\t    await writeFile(join(dir, 'agents', 'main', 'instruct.md'), 'SECRET_INSTRUCT_BODY: route via delegate and ask the user.\\n', 'utf8');\n98\t    await writeFile(join(dir, 'agents', 'main', 'charter.md'), 'CHARTER_IDENTITY: you are a precise widget expert.\\n', 'utf8');\n99\t    const tl = join(dir, 'tasklists', 'flow');\n100\t    await mkdir(tl, { recursive: true });\n101\t    await writeFile(join(tl, 'index.md'), `---\\n---\\n\\nTASKLIST_GOAL: assemble the widget end to end.`, 'utf8');\n102\t    await writeFile(join(tl, '01-only.md'), `---\\nid: only\\ngoal: true\\noutput:\\n  v: number\\n---\\n\\nONLY_T: do the step.`, 'utf8');\n103\t    const space = await loadSpace(dir);\n104\t    let systemSeen = '';\n105\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n106\t      systemSeen = o.system ?? '';\n107\t      const user = o.messages.map((m) => m.content).join('\\n');\n108\t      if (user.includes('ONLY_T')) return `currentTask.resolve({ v: 1 });`;\n109\t      return '';\n110\t    });\n111\t    const engine = new ForkEngine({\n112\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n113\t      parentAgentCharter: space.agents['main']!.charterBody,\n114\t      renderHost: silentHost, streamFn,\n115\t    });\n116\t    await runTasklist({ name: 'flow', space, forkEngine: engine });\n117\t    expect(systemSeen).toContain('CHARTER_IDENTITY'); // charter injected\n118\t    expect(systemSeen).toContain('TASKLIST_GOAL'); // tasklist index.md goal injected\n119\t    expect(systemSeen).not.toContain('SECRET_INSTRUCT_BODY'); // instruct.md NOT injected into forks\n120\t  });\n121\t});\n122\t\n123\tdescribe('per-task role + functions scoping', () => {\n124\t  it('withholds all generic-fs prompt lines from a non-scratch task (fs is off every fork)', async () => {\n125\t    const dir = await makeTasklistSpace({\n126\t      '01-probe.md': `---\\nid: probe\\nrole: explore\\ngoal: true\\noutput:\\n  ok: boolean\\n---\\n\\nPROBE_T: read-only probe.`,\n127\t    });\n128\t    const space = await loadSpace(dir);\n129\t    let systemSeen = '';\n130\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n131\t      systemSeen = o.system ?? '';\n132\t      const user = o.messages.map((m) => m.content).join('\\n');\n133\t      if (user.includes('PROBE_T')) {\n134\t        // A read-only task must NOT reference writeFileRaw — it is now stripped from\n135\t        // the ambient DTS (allowWrite:false), so a stray call would fail typecheck.\n136\t        // The capability/DTS gate itself is pinned by bootstrap.test.ts + roles.test.ts;\n137\t        // this test owns the PROMPT gate below.\n138\t        return `currentTask.resolve({ ok: true });`;\n139\t      }\n140\t      return '';\n141\t    });\n142\t    const engine = new ForkEngine({\n143\t      maxConcurrentForks: 4, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n144\t      renderHost: silentHost, streamFn,\n145\t    });\n146\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { ok: boolean };\n147\t    expect(goal.ok).toBe(true);\n148\t    // Prompt gate: a non-scratch fork's system prompt does NOT advertise the write\n149\t    // primitives (writeFileRaw/readFileRaw are gone entirely) and explicitly tells the\n150\t    // fork there is no filesystem and execShell is unavailable."}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"26345acf-d362-457e-9a96-f32a9b6edcc8","timestamp":"2026-07-16T02:07:45.821Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
