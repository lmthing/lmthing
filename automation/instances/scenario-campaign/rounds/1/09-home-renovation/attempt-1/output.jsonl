ing(error) }));\n    const raw = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);\n    const ok = response.status === 200 && !/^\\s*<!doctype/i.test(raw) && raw.length > 20;\n    API_OK += ok ? 1 : 0;\n    report.check(`app API ${route} returns real JSON`, ok, `status ${response.status}: ${raw.slice(0, 140)}`);\n  }\n  report.check('at least one app-own API route exposes data', API_OK > 0, `${API_OK}/${apiFiles.length}`);\n  const target = { appUrl: `${pod.appOrigin(PROJECT)}/`, projectId: PROJECT, accessToken: user.token, local: !user.token };\n  writeFileSync(`${RESULTS}/browser-target.json`, JSON.stringify(target, null, 2));\n  report.note(`Browser verification target recorded in results/browser-target.json; app built=${build.built}.`);\n  cp.acts.II = { passed: report.stepPassed, appUrl: target.appUrl };\n  saveCheckpoint(cp);\n}\n\n// ═══ Act III — automatic invisible research ═════════════════════════════════════\nif (ACTS.includes(3)) {\n  report.step('Act III — Automatic invisible research', 'a plain worry uses live research, persists a finding, and routes a later question into the new topic');\n  const before = await allState(pod);\n  const turn = acc(await thing.send(\"quick one — do we actually need paperwork for the wetroom? and Niko keeps going back and forth on underfloor heating for the bathroom, is it even worth it for a small room like ours?\", { timeoutMs: 900_000 }));\n  ceiling(report, 'Act III research', turn.durationMs, 8);\n  const web = turn.yields.filter((yielded) => /^(webSearch|webFetch|fetch)$/.test(yielded.kind));\n  report.check('delegated research without user jargon', turn.delegates.some((delegate) => delegate.startsWith('system-research')), turn.delegates.join(', '));\n  report.check('live web research ran', web.length > 0, web.map((yielded) => yielded.kind).join(', ') || 'none');\n  const after = await allState(pod);\n  report.check('research created persisted information beyond the seed files', after.blob.length > before.blob.length && /(permit|wetroom|underfloor|heating)/.test(after.blob), `state bytes ${before.blob.length} to ${after.blob.length}`);\n  const spaces = await projectSpaces(pod);\n  report.check('a permit or heating topic space exists', spaces.own.some((id) => /permit|wetroom|heating|bathroom/.test(id)), spaces.own.join(', '));\n  const follow = acc(await thing.send('So what should we actually line up first for that wetroom paperwork?', { timeoutMs: 900_000 }));\n  report.check('later plain question routes into the retained topic', follow.delegates.some((delegate) => /permit|bathroom|heating/.test(delegate)), follow.delegates.join(', '));\n  cp.acts.III = { passed: report.stepPassed };\n  saveCheckpoint(cp);\n}\n\n// ═══ Acts IV and V — custom form and cancelled ask ═══════════════════════════════\nif (ACTS.includes(4) || ACTS.includes(5)) {\n  if (ACTS.includes(4)) {\n    report.step('Act IV — Space-authored form and view', 'a project space owns a custom quote form and budget view, and the in-app conversation opens them');\n    const spaces = await projectSpaces(pod);\n    let budgetSpace = spaces.own.find((id) => /budget|cost|finance/.test(id));\n    if (!budgetSpace) budgetSpace = spaces.own[0];\n    const fileData = await pod.req('GET', `/api/projects/${PROJECT}/spaces/${budgetSpace}/files`).catch(() => ({ files: {} }));\n    const files = Object.keys(fileData.files ?? {});\n    report.check('a space has the custom LogQuote component', files.some((file) => /components\\/form\\/LogQuote\\.tsx$/.test(file)), files.join(', ') || 'none');\n    report.check('a space has the custom BudgetBurndown component', files.some((file) => /components\\/view\\/BudgetBurndown\\.tsx$/.test(file)), files.join(', ') || 'none');\n    const inApp = new ThingSession(pod, { projectId: PROJECT, onAsk: scriptedOnAsk(true), verbose: true });\n    await inApp.start();\n    inApp.onAsk = (descriptor) => descriptor?.type === 'ConsentCard' ? true : undefined;\n    const turn = await inApp.send(\"can you log the second quote Kostas sent over for the tiling, and let me see how we're doing against the ceiling so far\", { timeoutMs: 900_000 });\n    metrics.in += turn.tokens.in; metrics.out += turn.tokens.out;\n    const asks = await inApp.openAsks();\n    const customAsk = asks.find((ask) => ask.descriptor?.type === 'LogQuote');\n    const customView = turn.events.some((event) => event.type === 'display' && event.descriptor?.type === 'BudgetBurndown');\n    report.check('the open form descriptor is LogQuote', !!customAsk, JSON.stringify(asks.map((ask) => ask.descriptor?.type)));\n    report.check('the displayed view descriptor is BudgetBurndown', customView, JSON.stringify(turn.events.filter((event) => event.type === 'display').map((event) => event.descriptor?.type)));\n    cp.quoteAsk = customAsk ? { sessionId: inApp.sessionId, askId: customAsk.id } : null;\n    cp.acts.IV = { passed: report.stepPassed, budgetSpace, quoteAsk: cp.quoteAsk };\n    saveCheckpoint(cp);\n  }\n  if (ACTS.includes(5)) {\n    report.step('Act V — Dismissed form settles safely', 'cancelling the custom form resolves null, writes no guessed quote, and leaves the session usable');\n    const quoteAsk = cp.quoteAsk;\n    report.check('Act IV left a quote form to dismiss', !!quoteAsk, JSON.stringify(quoteAsk));\n    const before = await allState(pod);\n    if (quoteAsk) {\n      await pod.req('DELETE', `/api/sessions/${quoteAsk.sessionId}/ask/${quoteAsk.askId}`, undefined).catch((error) => report.note(`ask cancellation failed: ${error}`));\n      await sleep(5_000);\n    }\n    const after = await allState(pod);\n    report.check('dismissal did not create a guessed second-quote row', !/kostas|second quote/.test(after.blob) || before.blob === after.blob, `state bytes ${before.blob.length} to ${after.blob.length}`);\n    const fresh = new ThingSession(pod, { projectId: PROJECT, onAsk: scriptedOnAsk(true), verbose: true });\n    await fresh.start();\n    const next = await fresh.send('Are we still keeping an eye on the kitchen budget?', { timeoutMs: 600_000 });\n    report.check('a following ordinary turn completes', (next.lastText ?? '').length > 0, (next.lastText ?? '').slice(0, 180));\n    cp.acts.V = { passed: report.stepPassed };\n    saveCheckpoint(cp);\n  }\n}\n\n// ═══ Act VI — inspect large estimate ════════════════════════════════════════════\nif (ACTS.includes(6)) {\n  report.step('Act VI — Inspect the large estimate without dumping it', 'the estimate analysis uses inspect and the final reply remains a concise summary');\n  const turn = acc(await thing.send('quick one — out of that big contractor estimate PDF, roughly how much is labour versus materials, and is there anything crazy over five hundred euros hiding in there?', { timeoutMs: 900_000 }));\n  ceiling(report, 'Act VI inspect', turn.durationMs, 2);\n  const inspect = turn.yields.filter((yielded) => yielded.kind === 'inspect');\n  report.check('trace contains an inspect yield', inspect.length > 0, JSON.stringify(inspect).slice(0, 240));\n  report.check('inspect uses a narrowing operator', inspect.some((yielded) => /count|filter|search|slice/.test(JSON.stringify(yielded.args))), JSON.stringify(inspect.map((yielded) => yielded.args)).slice(0, 240));\n  report.check('final reply is a summary rather than the full estimate', (turn.lastText ?? '').length < 5000, `${(turn.lastText ?? '').length} chars`);\n  cp.acts.VI = { passed: report.stepPassed };\n  saveCheckpoint(cp);\n}\n","structuredPatch":[{"oldStart":271,"oldLines":3,"newStart":271,"newLines":85,"lines":["   cp.acts.VI = { passed: report.stepPassed };","   saveCheckpoint(cp);"," }","+","+// ═══ Acts VII and VIII — app form, emitter, and budget alert ════════════════════","+if (ACTS.includes(7)) {","+  report.step('Act VII — App cost form causes a real budget update', 'posting to the app route rather than chat writes an expense with the new overage token');","+  const state = await allState(pod);","+  const routeFiles = (await pod.fsTree().catch(() => ({ files: [] }))).files?.filter((file) => new RegExp(`^${PROJECT}/api/.*/POST\\\\.tsx?$`).test(file)) ?? [];","+  const costRoute = routeFiles.find((file) => /expense|cost/i.test(file));","+  report.check('app has a cost-posting route', !!costRoute, routeFiles.join(', ') || 'none');","+  const before = state.blob;","+  if (costRoute) {","+    const route = costRoute.replace(new RegExp(`^${PROJECT}/api/`), '').replace(/\\/POST\\.tsx?$/, '');","+    const response = await pod.appApi(PROJECT, route, { description: 'Hallway upstand extra tiling', contractor: 'Hansson Tiling', amount: 1500, reference: 'UPSTAND-1500' }, 'POST').catch((error) => ({ status: 0, body: String(error) }));","+    report.check('the app form API accepts the cost', response.status >= 200 && response.status < 300, `status ${response.status}: ${JSON.stringify(response.body).slice(0, 180)}`);","+  }","+  await sleep(10_000);","+  const after = await allState(pod);","+  report.check('the app-form cost became a real persisted row', /upstand-1500|hallway upstand/.test(after.blob) && !/upstand-1500|hallway upstand/.test(before), 'UPSTAND-1500 in persisted state');","+  cp.acts.VII = { passed: report.stepPassed };","+  saveCheckpoint(cp);","+}","+if (ACTS.includes(8)) {","+  report.step('Act VIII — Budget alert names the trade and does nothing destructive', 'the expenses write triggers an alert containing the trade name without a send/payment action');","+  const state = await allState(pod);","+  report.check('an alert naming Hansson Tiling landed', /hansson tiling/.test(state.blob) && /alert|over budget|threshold/.test(state.blob), 'searched persisted rows and space files');","+  const destructive = thing.events.filter((event) => event.type === 'yield' && /send|pay|callConnection|charge/i.test(event.kind));","+  report.check('no destructive send/payment yield appeared', destructive.length === 0, destructive.map((event) => event.kind).join(', ') || 'none');","+  c