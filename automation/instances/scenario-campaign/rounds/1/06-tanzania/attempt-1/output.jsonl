method = 'POST') =>\n177\t    this.reqAbs(method, `${this.appOrigin(projectId)}/api/${String(route).replace(/^\\//, '')}`, body);\n178\t  /** The one authoritative hook-run path (crond, boot catch-up and Studio all use it).\n179\t   *  The slug is a single path segment and may contain `:`/`@` (space hooks are\n180\t   *  `<spaceId>:<base>`; emitters are `@emitter:<scope>:<name>`) — encode it. */\n181\t  runHook = (projectId, slug) =>\n182\t    this.req('POST', `/api/projects/${projectId}/hooks/${encodeURIComponent(slug)}/run`, {});\n183\t  /** Run a cron emitter def by its pseudo-slug (`@emitter:<scope>:<name>`). */\n184\t  runEmitter = (projectId, scope, name) => this.runHook(projectId, `@emitter:${scope}:${name}`);\n185\t\n186\t  /**\n187\t   * Deliver an inbound webhook exactly as an external provider would.\n188\t   * `headers` carries the provider's signature headers — the pod verifies BEFORE emit.\n189\t   *\n190\t   * NOTE the bearer token: in prod the pod is reached through Envoy, which routes on the\n191\t   * gateway JWT's `sub` claim — without it the edge answers `401 Jwt is missing` and the\n192\t   * request never reaches the pod. The real public path (gateway `/api/inbound/<token>/<path>`)\n193\t   * is a 202 fire-and-forget broker that hides the pod's own status code, so a scenario that\n194\t   * needs to assert 200/401/404 + `{events:n}` must deliver to the pod directly. The pod\n195\t   * itself does no auth: verification is the provider signature, exactly as in production.\n196\t   */\n197\t  async inbound(path, body, headers = {}) {\n198\t    const payload = typeof body === 'string' ? body : JSON.stringify(body);\n199\t    // A scaled-to-zero pod answers the FIRST hit with `504 {waking:true}` (the Envoy\n200\t    // instant-wake activator) while it boots — that is not the def's real verdict. Retry\n201\t    // the exact same signed bytes until the woken pod actually runs verify→emit. The body\n202\t    // is byte-identical, but inbound dedupe only kicks in AFTER a successful verify, so a\n203\t    // retry of a request the pod never processed is not deduped.\n204\t    for (let attempt = 0; ; attempt++) {\n205\t      const res = await fetchResilient(`${this.base}/api/inbound/${path}`, {\n206\t        method: 'POST',\n207\t        headers: {\n208\t          'content-type': 'application/json',\n209\t          ...(this.token ? { authorization: `Bearer ${this.token}` } : {}),\n210\t          ...headers,\n211\t        },\n212\t        body: payload,\n213\t      });\n214\t      const text = await res.text();\n215\t      let parsed = text;\n216\t      try {\n217\t        parsed = JSON.parse(text);\n218\t      } catch {\n219\t        /* raw */\n220\t      }\n221\t      const waking = res.status === 504 || (parsed && typeof parsed === 'object' && parsed.waking === true);\n222\t      if (!waking || attempt >= 100) return { status: res.status, body: parsed };\n223\t      await new Promise((r) => setTimeout(r, 3000));\n224\t    }\n225\t  }\n226\t\n227\t  // ── uploads (chat attachments) ──────────────────────────────────────────\n228\t  /**\n229\t   * The mediaType decides the pod's ROUTE, not just a label: `image/*` goes to system-vision,\n230\t   * `audio/*` is transcribed at ingest, everything else goes to system-files. So a `.mp3` sent as\n231\t   * `application/octet-stream` is never transcribed, and a scenario asserting \"a spoken-only fact\n232\t   * reached a row\" fails for a reason that has nothing to do with the product. Every fixture type the\n233\t   * scenarios actually upload must be in this table.\n234\t   */\n235\t  static MEDIA_TYPES = {\n236\t    '.md': 'text/markdown',\n237\t    '.txt': 'text/plain',\n238\t    '.csv': 'text/csv',\n239\t    '.json': 'application/json',\n240\t    '.pdf': 'application/pdf',\n241\t    '.jpg': 'image/jpeg',\n242\t    '.jpeg': 'image/jpeg',\n243\t    '.png': 'image/png',\n244\t    '.webp': 'image/webp',\n245\t    '.gif': 'image/gif',\n246\t    '.mp3': 'audio/mpeg',\n247\t    '.m4a': 'audio/mp4',\n248\t    '.wav': 'audio/wav',\n249\t    '.ogg': 'audio/ogg',\n250\t    '.webm': 'audio/webm',\n251\t    '.xlsx': 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',\n252\t    '.xls': 'application/vnd.ms-excel',\n253\t    '.docx': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',\n254\t  };\n255\t\n256\t  /**\n257\t   * Upload a local file as a chat attachment (the UI's \"load a file\" action).\n258\t   * `POST /api/uploads` takes base64 + mediaType and returns an AttachmentRef\n259\t   * (`{id, kind, mediaType, filename?, url}`) that a message then references by id.\n260\t   * Pair with `ThingSession.sendWithAttachments()` (WS path — HTTP /message drops attachments).\n261\t   *\n262\t   * Throws on an unknown extension rather than silently sending `application/octet-stream` — a\n263\t   * misrouted attachment turns a real product failure into a green test (see MEDIA_TYPES).\n264\t   */\n265\t  async upload(filePath, { mediaType, filename } = {}) {\n266\t    const { readFileSync } = await import('node:fs');\n267\t    const { basename, extname } = await import('node:path');\n268\t    const bytes = readFileSync(filePath);\n269\t    const ext = extname(filePath).toLowerCase();\n270\t    const mt = mediaType ?? Pod.MEDIA_TYPES[ext];\n271\t    if (!mt) {\n272\t      throw new Error(\n273\t        `upload(${basename(filePath)}): no mediaType known for \"${ext}\" — pass { mediaType } explicitly ` +\n274\t          `or add it to Pod.MEDIA_TYPES. Guessing octet-stream would misroute it (no vision, no transcription).`,\n275\t      );\n276\t    }\n277\t    const ref = await this.req('POST', '/api/uploads', {\n278\t      filename: filename ?? basename(filePath),\n279\t      mediaType: mt,\n280\t      data: bytes.toString('base64'),\n281\t    });\n282\t    return ref;\n283\t  }\n284\t\n285\t  // ── accounting ──────────────────────────────────────────────────────────\n286\t  /** Pod-global token/cost ledger — includes the DELEGATE tree, not just top-level turns. */\n287\t  sessionLedger = () => this.req('GET', '/api/session-ledger');\n288\t  /** The gateway's spend-window report, as the pod sees it. */\n289\t  budget = () => this.req('GET', '/api/budget');\n290\t\n291\t  // ── env / lifecycle ─────────────────────────────────────────────────────\n292\t  getEnv = () => this.req('GET', '/api/env');\n293\t  /**\n294\t   * Restart the pod process (used by the auto-resume scenario). The pod exits ~100ms later.\n295\t   *\n296\t   * In prod, Kubernetes brings it straight back. LOCALLY, NOTHING DOES — `POST /api/restart` just\n297\t   * kills the one shared `lmthing serve` and leaves it dead, hanging this lane AND every sibling\n298\t   * lane on the same server (found the hard way: S06's Act XIII took the whole local pod down\n299\t   * mid-run). So on the local target we must bring it back up ourselves — which is also the truer\n300\t   * reproduction of the edge this Act exists to test: the process really does die and really does\n301\t   * come back, and the session must survive it.\n302\t   */\n303\t  restart = async () => {\n304\t    if (!LOCAL) return this.req('POST', '/api/restart', {}).catch(() => ({ ok: true }));\n305\t    await this.req('POST', '/api/restart', {}).catch(() => ({ ok: true }));\n306\t    await restartLocalServer();\n307\t    return { ok: true, local: true };\n308\t  };\n309\t}\n310\t"}]},"parent_tool_use_id":null,"session_id":"4bfa69d9-de98-4976-b4ad-12c5314f8543","uuid":"9f69b39d-e4f7-410d-ba4d-d0454db3d0d2","timestamp":"2026-07-14T16:48:17.639Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/lib/pod.mjs","content":"/**\n * Pod HTTP client — the compute pod IS the app (see sdk/org/libs/cli/src/server/serve.ts).\n *\n * The pod itself does no auth: Envoy validates the gateway JWT at the edge and routes on the\n * `sub` claim to `lmthing.user-<id>.svc`. So every call here just carries the bearer token and\n * talks to the chat origin. Locally (`lmthing serve`) pass base=http://localhost:8080 and no token.\n */\nimport { LOCAL, restartLocalServer } from './local.mjs';\n\n/**\n * A pod that is scaling from zero, rolling a new image, or sitting behind a blipping gateway does\n * not always answer with a *response* — the connection itself fails (undici's 10s\n * `ConnectTimeoutError`, `ECONNRESET`, `socket hang up`, a DNS `EAI_AGAIN`). Those surface as a\n * bare `TypeError: fetch failed`, which is NOT an HTTP status and so slipped past every\n * `{waking:true}`/504 retry below — one connect timeout to lmthing.chat killed a multi-hour run\n * with an uncaught exception. Treat a transient transport fault exactly like a `waking` answer:\n * back off and retry. A non-transient error (a bad URL, an aborted body) still throws at once.\n */\nconst TRANSIENT = /fetch failed|ConnectTimeout|UND_ERR|ECONNRESET|ECONNREFUSED|EAI_AGAIN|socket hang up|network|terminated|other side closed/i;\n\nexport async function fetchResilient(url, init, { tries = 40, waitMs = 3000 } = {}) {\n  for (let attempt = 0; ; attempt++) {\n    try {\n      return await fetch(url, init);\n    } catch (e) {\n      const msg = `${e?.message ?? e} ${e?.cause?.code ?? ''} ${e?.cause?.message ?? ''}`;\n      if (!TRANSIENT.test(msg) || attempt >= tries) throw e;\n      await new Promise((r) => setTimeout(r, waitMs));\n    }\n  }\n}\n\nexport class Pod {\n  /**\n   * @param {object} o\n   * @param {string} o.base      the pod/API origin (prod: https://lmthing.chat)\n   * @param {string} [o.token]   gateway JWT (Envoy routes on its `sub` claim)\n   * @param {string} [o.appBase] the SERVED-APP origin. In prod the app is NOT reachable under\n   *   `<chat>/app/<id>/` — Envoy hands `/app/*` on the chat host to the static web SPA (nginx),\n   *   which answers a GET with the SPA *shell* (a 200 `<!doctype>` that is not the app at all —\n   *   a scenario asserting only \"200 + <!doctype\" false-passes) and a POST with **405**. The app\n   *   is root-mounted on lmthing.app (`/<project>/`, `/<project>/api/<route>` — serve.ts's\n   *   \"Project-app ROOT mount\"). Locally there is no split host, so apps stay under `/app/<id>/`.\n   */\n  constructor({ base, token, appBase }) {\n    this.base = base;\n    this.token = token;\n    this.appBase = appBase ?? process.env.LM_APP_BASE ?? (/lmthing\\.chat/.test(base) ? 'https://lmthing.app' : base);\n    /** true when the app has its own host → root mount (no `/app` prefix). */\n    this.appRootMounted = this.appBase !== this.base;\n  }\n\n  /** The origin+prefix the SERVED app actually lives at (see `appBase`). */\n  appOrigin(projectId) {\n    return this.appRootMounted\n      ? `${this.appBase}/${projectId}`\n      : `${this.base}/app/${projectId}`;\n  }\n\n  /** Absolute-URL variant of `req` (the served app is on a different origin than /api/*). */\n  async reqAbs(method, url, body) {\n    for (let attempt = 0; ; attempt++) {\n      const res = await fetchResilient(url, {\n        method,\n        headers: {\n          ...(body !== undefined ? { 'content-type': 'application/json' } : {}),\n          ...(this.token ? { authorization: `Bearer ${this.token}` } : {}),\n        },\n        ...(body !== undefined ? { body: JSON.stringify(body) } : {}),\n      });\n      const text = await res.text();\n      let parsed = text;\n      try {\n        parsed = JSON.parse(text);\n      } catch {\n        /* html / raw */\n      }\n      // The activator MARKS its own response (`{waking:true}`) whatever status it uses (503/504),\n      // so key on that marker — never on a bare 503, which for an app route is a real verdict.\n      const waking =\n        res.status === 504 || (parsed && typeof parsed === 'object' && parsed.waking === true);\n      if (waking && attempt < 100) {\n        await new Promise((r) => setTimeout(r, 3000));\n        continue;\n      }\n      return { status: res.status, body: parsed };\n    }\n  }\n\n  async req