ct shipped node_modules. Absent for\n68\t   *  legacy/non-project sessions — that scoping is what keeps them project-only. A name\n69\t   *  already provided by the system toolkit or the agent's selected space functions WINS\n70\t   *  (the colliding project function is dropped + a shadow warning is logged), so the\n71\t   *  DTS overlay never double-declares. */\n72\t  projectFunctions?: Record<string, string>;\n73\t  projectFunctionsBundled?: Record<string, string>;\n74\t  /** Project-generated typed `apiCall` overloads (Phase 4) — appended to the agent's ambient\n75\t   *  DTS when it holds `api:call`, so `apiCall('markRead', …)` is strictly typed. Built by\n76\t   *  libs/cli from the project's `api/` endpoint contracts. */\n77\t  appDts?: string;\n78\t  /** Host-provided app-global engine impls (the project's db store, etc.). Wrapped in the\n79\t   *  capability-scope check and injected into the session VM + its forks/delegates when the\n80\t   *  agent holds the matching grants AND projectRoot is set (see exec/app-globals.ts). The\n81\t   *  db impl is built by libs/cli (better-sqlite3) per project. */\n82\t  appGlobals?: AppGlobalImpls;\n83\t  /** Host resolver for the universal `readDocument` global — extracts a stored\n84\t   *  upload's text (unpdf/utf8/transcript) Node-side. Supplied by libs/cli (where\n85\t   *  the uploads dir is known) and threaded into the session, its delegates and\n86\t   *  forks. Project-independent (NOT an app-global): absent ⇒ a readDocument yield\n87\t   *  rejects with a clear \"no document resolver configured\" error. */\n88\t  documentResolver?: DocumentResolver;\n89\t  /** Host resolver for the `integrationStatus` global — reports presence-only config\n90\t   *  status (names of missing required env vars, never their values) for an installed\n91\t   *  integration space in this project. Supplied by libs/cli (knows the project root +\n92\t   *  `process.env`); threaded into the project-rooted session. Absent ⇒ an\n93\t   *  `integrationStatus` yield rejects with a clear \"no project scope\" error. */\n94\t  integrationStatusResolver?: IntegrationStatusResolver;\n95\t  /** Consent prompter for consent-marked invocations (plan S10) — built on the\n96\t   *  `renderHost.ask` plumbing (see `createAskConsentPrompter`) and supplied ONLY\n97\t   *  for INTERACTIVE sessions: headless runs/forks/delegates/hooks leave it unset\n98\t   *  so a consent-marked call FAILS CLOSED (\"requires user consent — run\n99\t   *  interactively\") instead of hanging on an ask nobody will answer. Threaded\n100\t   *  into the yield router as `requestConsent`. */\n101\t  consentPrompter?: ConsentPrompter;\n102\t  /** Host-built factory for `kind:'code'` tasklist nodes (plan S9). Threaded into\n103\t   *  the session's yield-router context so a `tasklist()` yield whose SPACE tasklist\n104\t   *  contains code nodes can run them: for each node the CLI/pod loads its\n105\t   *  `run(ctx, inputs)` module in a Node worker with a ctx (db + delegate +\n106\t   *  callConnection locked to the space/tasklist `connections:`) serviced\n107\t   *  main-side. Absent for legacy/non-project sessions (and bare unit tests) — a\n108\t   *  code node then fails with a clear required-task error (core never executes\n109\t   *  the node module itself). Built by libs/cli's `createCodeNodeCtxFactory`. */\n110\t  codeNodeCtxFactory?: CodeNodeCtxFactory;"}]},"parent_tool_use_id":null,"session_id":"ddf06e51-7358-4abc-8049-dd6b1803b5d8","uuid":"82f9a803-104b-45ca-81a8-e667765f4819","timestamp":"2026-07-16T06:51:41.826Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/session/types.ts","content":"import type { StreamOpts, StreamSession } from '../eval/stream-types.js';\nimport type { BudgetLimits } from '../eval/budget.js';\nimport type { RoleModelConfig } from '../fork/roles.js';\nimport type { AppGlobalImpls } from '../exec/app-globals.js';\nimport type { DocumentResolver } from '../globals/read-document.js';\nimport type { IntegrationStatusResolver } from '../globals/integration-status.js';\nimport type { ConsentPrompter } from '../globals/consent.js';\nimport type { CodeNodeCtxFactory } from '../tasklist/orchestrator.js';\n\nexport interface RenderHost {\n  display(descriptor: unknown): void;\n  ask(id: string, descriptor: unknown): Promise<unknown>;\n  log(message: string): void;\n}\n\nexport interface Clock {\n  setTimeout(fn: () => void, ms: number): void;\n  clearTimeout(id: unknown): void;\n}\n\nexport interface SessionOpts {\n  spaceDir: string;\n  agentSlug: string;\n  modelAlias: string;\n  renderHost: RenderHost;\n  maxRetries?: number;\n  maxConcurrentForks?: number;\n  /** Inactivity watchdog for the model stream (ms). A turn whose stream emits no token\n   *  for this long is retried as a transient failure. Default 60000. */\n  streamIdleMs?: number;\n  clock?: Clock;\n  traceFile?: string;\n  /** Override the always-loaded system space directories. Defaults to the\n   *  bundled fs/web/memory/todo/agents spaces. Pass [] to disable. */\n  systemSpaceDirs?: string[];\n  /** When set, collapse history to a summary once it exceeds maxHistoryTurns*2\n   *  messages (keeping the last few verbatim). Used by long REPL sessions. */\n  maxHistoryTurns?: number;\n  /** When true, bypass an agent's `defaultAction` routing so the first turn runs\n   *  the model-driven turn loop instead of the action's tasklist. */\n  noDefaultAction?: boolean;\n  /** Host-enforced budget caps (episodes / tool calls / fork depth / wall clock).\n   *  Reset per start()/continue() invocation. Cannot be disabled from inside the VM. */\n  budget?: BudgetLimits;\n  /** Optional per-role model assignment for forks (e.g. explore/plan → cheap model). */\n  roleModels?: RoleModelConfig;\n  /** Absolute space dirs to load into dynamicSpaces at session.start(), making them\n   *  delegatable immediately (e.g. existing project spaces). Each dir is loaded via\n   *  loadSpace and keyed by its dir path. Failures are logged but do not block startup. */\n  preloadSpaceDirs?: string[];\n  /** Absolute path to the project's spaces/ dir. Exposed to ALL VMs (session, forks,\n   *  delegates) as process.env.LMTHING_PROJECT_SPACES_DIR so the architect can write\n   *  synthesized spaces there instead of stripping LMTHING_SPACE_DIR. */\n  projectSpacesDir?: string;\n  /** Absolute project root `<root>/<projectId>` — the app layer (database/pages/api/hooks)\n   *  root, distinct from spaceDir (per-agent) and projectSpacesDir (the spaces/ dir).\n   *  Threaded into every child VM (session/fork/delegate) and exposed as\n   *  LMTHING_PROJECT_DIR; gates app-capability global injection. A top-level THING\n   *  session with no projectRoot gets no app globals. */\n  projectRoot?: string;\n  /** The project id (basename of projectRoot); exposed as LMTHING_PROJECT_ID. */\n  projectId?: string;\n  /** The PROJECT's functions (`<projectRoot>/functions/*.ts`) — the THIRD function\n   *  scope, loaded by libs/cli (loadProjectFunctions) and injected into project-rooted\n   *  sessions (and their forks, via the shared agentFunctions map) alongside the\n   *  system + space functions. Original TS source keyed by name; `projectFunctionsBundled`\n   *  carries esbuild output when the project shipped node_modules. Absent for\n   *  legacy/non-project sessions — that scoping is what keeps them project-only. A name\n   *  already provided by the system toolkit or the agent's selected space functions WINS\n   *  (the colliding project function is dropped + a shadow warning is logged), so the\n   *  DTS overlay never double-declares. */\n  projectFunctions?: Record<string, string>;\n  projectFunctionsBundled?: Record<string, string>;\n  /** Project-generated typed `apiCall` overloads (Phase 4) — appended to the agent's ambient\n   *  DTS when it holds `api:call`, so `apiCall('markRead', …)` is strictly typed. Built by\n   *  libs/cli from the project's `api/` endpoint contracts. */\n  appDts?: string;\n  /** Host-provided app-global engine impls (the project's db store, etc.). Wrapped in the\n   *  capability-scope check and injected into the session VM + its forks/delegates when the\n   *  agent holds the matching grants AND projectRoot is set (see exec/app-globals.ts). The\n   *  db impl is built by libs/cli (better-sqlite3) per project. */\n  appGlobals?: AppGlobalImpls;\n  /** Host resolver for the universal `readDocument` global — extracts a stored\n   *  upload's text (unpdf/utf8/transcript) Node-side. Supplied by libs/cli (where\n   *  the uploads dir is known) and threaded into the session, its delegates and\n   *  forks. Project-independent (NOT an app-global): absent ⇒ a readDocument yield\n   *  rejects with a clear \"no document resolver configured\" error. */\n  documentResolver?: DocumentResolver;\n  /** Host resolver for the `integrationStatus` global — reports presence-only config\n   *  status (names of missing required env vars, never their values) for an installed\n   *  integration space in this project. Supplied by libs/cli (knows the project root +\n   *  `process.env`); threaded into the project-rooted session. Absent ⇒ an\n   *  `integrationStatus` yield rejects with a clear \"no project scope\" error. */\n  integrationStatusResolver?: IntegrationStatusResolver;\n  /** Consent prompter for consent-marked invocations (plan S10) — built on the\n   *  `renderHost.ask` plumbing (see `createAskConsentPrompter`) and supplied ONLY\n   *  for INTERACTIVE sessions: headless runs/forks/delegates/hooks leave it unset\n   *  so a consent-marked call FAILS CLOSED (\"requires user consent — run\n   *  interactively\") instead of hanging on an ask nobody will answer. Threaded\n   *  into the yield router as `requestConsent`. */\n  consentPrompter?: ConsentPrompter;\n  /** Host-built factory for `kind:'code'` tasklist nodes (plan S9). Threaded into\n   *  the session's yield-router context so a `tasklist()` yield whose SPACE tasklist\n   *  contains code nodes can run them: for each node the CLI/pod loads its\n   *  `run(ctx, inputs)` module in a Node worker with a ctx (db + delegate +\n   *  callConnection locked to the space/tasklist `connections:`) serviced\n   *  main-side. Absent for legacy/non-project sessions (and bare unit tests) — a\n   *  code node then fails with a clear required-task error (core never executes\n   *  the node module itself). Built by libs/cli's `createCodeNodeCtxFactory`. */\n  codeNodeCtxFactory?: CodeNodeCtxFactory;","numLines":110,"startLine":1,"totalLines":116}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_kxXGsdlVARlK7D7efhqXa3r9","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join, dirname } from 'node:path';\n4\timport { fileURLToPath } from 'node:url';\n5\timport { tmpdir } from 'node:os';\n6\timport { Session } from '../session/session.js';\n7\timport { createMockStreamFn, mockMatch } from './mock-provider.js';\n8\timport type { StreamOpts } from '../eval/stream-types.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { DocumentResolver } from '../globals/read-document.js';\n11\t\n12\t/** The real system-files space (dispatch/reader/sheet), for the delegation test. */\n13\tconst SYSTEM_FILES_DIR = fileURLToPath(new URL('../../system-spaces/system-files', import.meta.url));\n14\t\n15\tconst tmpDirs: string[] = [];\n16\tafterAll(async () => {\n17\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n18\t});\n19\t\n20\tasync function makeSpace(): Promise<string> {\n21\t  const dir = await mkdtemp(join(tmpdir(), 'lmthing-attach-core-'));\n22\t  tmpDirs.push(dir);\n23\t  const file = join(dir, 'agents', 'main', 'instruct.md');\n24\t  await mkdir(dirname(file), { recursive: true });\n25\t  await writeFile(file, 'You are a test agent.\\n', 'utf8');\n26\t  return dir;\n27\t}\n28\t\n29\tdescribe('Session multimodal input threading', () => {\n30\t  it('exposes an image to a text agent as a delegatable note (NOT raw parts)', async () => {\n31\t    const captured: StreamOpts[] = [];\n32\t    const streamFn = createMockStreamFn((opts: StreamOpts) => {\n33\t      captured.push(opts);\n34\t      return ''; // no statements → turn ends\n35\t    });\n36\t    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n37\t    const session = new Session(\n38\t      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [] },\n39\t      { streamFn },\n40\t    );\n41\t\n42\t    await session.start({\n43\t      text: 'what is in this picture?',\n44\t      attachments: [\n45\t        { id: 'up1', kind: 'image', mediaType: 'image/png', filename: 'p.png', part: { type: 'image', image: 'data:image/png;base64,AAAA', mediaType: 'image/png' } },\n46\t      ],\n47\t    });\n48\t\n49\t    expect(captured.length).toBeGreaterThan(0);\n50\t    const userMsg = [...captured[0]!.messages].reverse().find((m) => m.role === 'user');\n51\t    expect(userMsg).toBeTruthy();\n52\t    // The user's text is framed as usual…\n53\t    expect(userMsg!.content).toContain('what is in this picture?');\n54\t    // …the attachment is surfaced as a note (id + kind) so a text model can delegate…\n55\t    expect(userMsg!.content).toContain('up1');\n56\t    expect(userMsg!.content).toMatch(/image/i);\n57\t    expect(userMsg!.content).toContain('system-vision');\n58\t    // …and the raw image bytes are NOT sent to the (text) THING model.\n59\t    expect(userMsg!.attachments).toBeUndefined();\n60\t\n61\t    await session.dispose();\n62\t  });\n63\t\n64\t  it('a plain string message carries no attachments', async () => {\n65\t    const captured: StreamOpts[] = [];\n66\t    const streamFn = createMockStreamFn((opts: StreamOpts) => {\n67\t      captured.push(opts);\n68\t      return '';\n69\t    });\n70\t    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n71\t    const session = new Session(\n72\t      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [] },\n73\t      { streamFn },\n74\t    );\n75\t\n76\t    await session.start('just text');\n77\t    const userMsg = [...captured[0]!.messages].reverse().find((m) => m.role === 'user');\n78\t    expect(userMsg!.attachments).toBeUndefined();\n79\t\n80\t    await session.dispose();\n81\t  });\n82\t\n83\t  it('hands a delegated files agent an id-anchored readDocument note (no bytes/text)', async () => {\n84\t    // Drive the full session→delegate path: the top-level agent delegates the file\n85\t    // to system-files/reader; the session resolves the attachment id into an\n86\t    // id-anchored note telling the specialist to call readDocument(id). No bytes or\n87\t    // inlined text ever ride on the message — the whole point of the new design.\n88\t    let topLevelMsg = '';\n89\t    let readerMsg = '';\n90\t    let delegated = false;\n91\t    const streamFn = mockMatch(\n92\t      [\n93\t        // The reader delegate's turn (its charter \"document reader\" is in the system\n94\t        // block): capture its first user message, then resolve.\n95\t        {\n96\t          when: /document reader/,\n97\t          respond: (opts: StreamOpts) => {\n98\t            const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n99\t            readerMsg = u?.content ?? '';\n100\t            return 'currentTask.resolve(\"done\");';\n101\t          },\n102\t        },\n103\t      ],\n104\t      // Fallback = the top-level agent's turn: delegate the file once, then stop.\n105\t      (opts: StreamOpts) => {\n106\t        const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n107\t        topLevelMsg = u?.content ?? '';\n108\t        if (delegated) return '';\n109\t        delegated = true;\n110\t        return `await delegate('system-files', 'reader', { query: 'summarize', attachmentIds: ['up1'] });`;\n111\t      },\n112\t    );\n113\t\n114\t    // A document resolver need not be exercised here (the reader is mocked), but the\n115\t    // session threads it — assert it is not required to build the note.\n116\t    const documentResolver: DocumentResolver = async (id) => ({ ok: true, attachmentId: id, mediaType: 'application/pdf', kind: 'text', text: 'x' });\n117\t\n118\t    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n119\t    const session = new Session(\n120\t      {\n121\t        spaceDir: await makeSpace(),\n122\t        agentSlug: 'default',\n123\t        modelAlias: 'mock',\n124\t        renderHost: host,\n125\t        systemSpaceDirs: [SYSTEM_FILES_DIR],\n126\t        documentResolver,\n127\t      },\n128\t      { streamFn },\n129\t    );\n130\t\n131\t    await session.start({\n132\t      text: 'summarize this file',\n133\t      attachments: [\n134\t        // A FILE attachment: no image part, no inlined text — id + metadata only.\n135\t        { id: 'up1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf' },\n136\t      ],\n137\t    });\n138\t\n139\t    // The top-level note routes files to system-files (by id), NOT raw bytes.\n140\t    expect(topLevelMsg).toContain('up1');\n141\t    expect(topLevelMsg).toContain('system-files');\n142\t    // The delegated reader is told to fetch the file itself via readDocument(id).\n143\t    expect(readerMsg).toContain('readDocument');\n144\t    expect(readerMsg).toContain('up1');\n145\t    expect(readerMsg).toContain('doc.pdf');\n146\t\n147\t    await session.dispose();\n148\t  });\n149\t\n150\t  it('resolves a PRIOR turn\\'s attachment id when a LATER turn delegates it (propose→consent→build)', async () => {\n151\t    // THING's flow: turn 1 the user dumps a file and THING only OFFERS (no build);\n152\t    // turn 2 a bare \"yes please\" and THING delegates the SAME file to the automator to\n153\t    // seed the app. The attachment arrived in turn 1 but is delegated in turn 2. If\n154\t    // `pendingAttachments` is cleared each turn, turn 2's delegate can't resolve the\n155\t    // turn-1 id → the automator reads nothing → empty tables. This asserts the id still\n156\t    // resolves across turns (the reader gets an id-anchored readDocument note).\n157\t    let readerMsg = '';\n158\t    let sawSecondTurn = false;\n159\t    let delegated = false;\n160\t    const streamFn = mockMatch(\n161\t      [\n162\t        {\n163\t          when: /document reader/,\n164\t          respond: (opts: StreamOpts) => {\n165\t            const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n166\t            readerMsg = u?.content ?? '';\n167\t            return 'currentTask.resolve(\"done\");';\n168\t          },\n169\t        },\n170\t      ],\n171\t      // Top-level agent: turn 1 just \"offers\" (no statements); turn 2 delegates the\n172\t      // turn-1 attachment id ONCE, then stops.\n173\t      (opts: StreamOpts) => {\n174\t        const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n175\t        if (/yes please/.test(u?.content ?? '')) sawSecondTurn = true;\n176\t        if (!sawSecondTurn || delegated) return ''; // turn 1: offer only; post-delegate: stop\n177\t        delegated = true;\n178\t        return `await delegate('system-files', 'reader', { query: 'seed the app', attachmentIds: ['up1'] });`;\n179\t      },\n180\t    );\n181\t    const documentResolver: DocumentResolver = async (id) => ({ ok: true, attachmentId: id, mediaType: 'application/pdf', kind: 'text', text: 'x' });\n182\t    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n183\t    const session = new Session(\n184\t      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [SYSTEM_FILES_DIR], documentResolver },\n185\t      { streamFn },\n186\t    );\n187\t\n188\t    // Turn 1: the file arrives; THING only offers.\n189\t    await session.start({\n190\t      text: 'here is my budget spreadsheet, I keep losing track',\n191\t      attachments: [{ id: 'up1', kind: 'file', mediaType: 'application/pdf', filename: 'budget.pdf' }],\n192\t    });\n193\t    expect(readerMsg).toBe(''); // nothing delegated yet\n194\t\n195\t    // Turn 2: a bare \"yes please\" — THING delegates the SAME (turn-1) attachment.\n196\t    await session.continue('yes please, build it');\n197\t    expect(readerMsg).toContain('readDocument');\n198\t    expect(readerMsg).toContain('up1');\n199\t    expect(readerMsg).toContain('budget.pdf');\n200\t\n201\t    await session.dispose();\n202\t  });\n203\t});\n204\t"}]},"parent_tool_use_id":null,"session_id":"ddf06e51-7358-4abc-8049-dd6b1803b5d8","uuid":"2a7f9100-aefc-477b-8c19-16a6ca3f2959","timestamp":"2026-07-16T06:51:41.827Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/testing/attachments-core.test.ts","content":"import { describe, it, expect, afterAll } from 'vitest';\nimport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\nimport { join, dirname } from 'node:path';\nimport { fileURLToPath } from 'node:url';\nimport { tmpdir } from 'node:os';\nimport { Session } from '../session/session.js';\nimport { createMockStreamFn, mockMatch } from './mock-provider.js';\nimport type { StreamOpts } from '../eval/stream-types.js';\nimport type { RenderHost } from '../session/types.js';\nimport type { DocumentResolver } from '../globals/read-document.js';\n\n/** The real system-files space (dispatch/reader/sheet), for the delegation test. */\nconst SYSTEM_FILES_DIR = fileURLToPath(new URL('../../system-spaces/system-files', import.meta.url));\n\nconst tmpDirs: string[] = [];\nafterAll(async () => {\n  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n});\n\nasync function makeSpace(): Promise<string> {\n  const dir = await mkdtemp(join(tmpdir(), 'lmthing-attach-core-'));\n  tmpDirs.push(dir);\n  const file = join(dir, 'agents', 'main', 'instruct.md');\n  await mkdir(dirname(file), { recursive: true });\n  await writeFile(file, 'You are a test agent.\\n', 'utf8');\n  return dir;\n}\n\ndescribe('Session multimodal input threading', () => {\n  it('exposes an image to a text agent as a delegatable note (NOT raw parts)', async () => {\n    const captured: StreamOpts[] = [];\n    const streamFn = createMockStreamFn((opts: StreamOpts) => {\n      captured.push(opts);\n      return ''; // no statements → turn ends\n    });\n    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n    const session = new Session(\n      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [] },\n      { streamFn },\n    );\n\n    await session.start({\n      text: 'what is in this picture?',\n      attachments: [\n        { id: 'up1', kind: 'image', mediaType: 'image/png', filename: 'p.png', part: { type: 'image', image: 'data:image/png;base64,AAAA', mediaType: 'image/png' } },\n      ],\n    });\n\n    expect(captured.length).toBeGreaterThan(0);\n    const userMsg = [...captured[0]!.messages].reverse().find((m) => m.role === 'user');\n    expect(userMsg).toBeTruthy();\n    // The user's text is framed as usual…\n    expect(userMsg!.content).toContain('what is in this picture?');\n    // …the attachment is surfaced as a note (id + kind) so a text model can delegate…\n    expect(userMsg!.content).toContain('up1');\n    expect(userMsg!.content).toMatch(/image/i);\n    expect(userMsg!.content).toContain('system-vision');\n    // …and the raw image bytes are NOT sent to the (text) THING model.\n    expect(userMsg!.attachments).toBeUndefined();\n\n    await session.dispose();\n  });\n\n  it('a plain string message carries no attachments', async () => {\n    const captured: StreamOpts[] = [];\n    const streamFn = createMockStreamFn((opts: StreamOpts) => {\n      captured.push(opts);\n      return '';\n    });\n    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n    const session = new Session(\n      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [] },\n      { streamFn },\n    );\n\n    await session.start('just text');\n    const userMsg = [...captured[0]!.messages].reverse().find((m) => m.role === 'user');\n    expect(userMsg!.attachments).toBeUndefined();\n\n    await session.dispose();\n  });\n\n  it('hands a delegated files agent an id-anchored readDocument note (no bytes/text)', async () => {\n    // Drive the full session→delegate path: the top-level agent delegates the file\n    // to system-files/reader; the session resolves the attachment id into an\n    // id-anchored note telling the specialist to call readDocument(id). No bytes or\n    // inlined text ever ride on the message — the whole point of the new design.\n    let topLevelMsg = '';\n    let readerMsg = '';\n    let delegated = false;\n    const streamFn = mockMatch(\n      [\n        // The reader delegate's turn (its charter \"document reader\" is in the system\n        // block): capture its first user message, then resolve.\n        {\n          when: /document reader/,\n          respond: (opts: StreamOpts) => {\n            const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n            readerMsg = u?.content ?? '';\n            return 'currentTask.resolve(\"done\");';\n          },\n        },\n      ],\n      // Fallback = the top-level agent's turn: delegate the file once, then stop.\n      (opts: StreamOpts) => {\n        const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n        topLevelMsg = u?.content ?? '';\n        if (delegated) return '';\n        delegated = true;\n        return `await delegate('system-files', 'reader', { query: 'summarize', attachmentIds: ['up1'] });`;\n      },\n    );\n\n    // A document resolver need not be exercised here (the reader is mocked), but the\n    // session threads it — assert it is not required to build the note.\n    const documentResolver: DocumentResolver = async (id) => ({ ok: true, attachmentId: id, mediaType: 'application/pdf', kind: 'text', text: 'x' });\n\n    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n    const session = new Session(\n      {\n        spaceDir: await makeSpace(),\n        agentSlug: 'default',\n        modelAlias: 'mock',\n        renderHost: host,\n        systemSpaceDirs: [SYSTEM_FILES_DIR],\n        documentResolver,\n      },\n      { streamFn },\n    );\n\n    await session.start({\n      text: 'summarize this file',\n      attachments: [\n        // A FILE attachment: no image part, no inlined text — id + metadata only.\n        { id: 'up1', kind: 'file', mediaType: 'application/pdf', filename: 'doc.pdf' },\n      ],\n    });\n\n    // The top-level note routes files to system-files (by id), NOT raw bytes.\n    expect(topLevelMsg).toContain('up1');\n    expect(topLevelMsg).toContain('system-files');\n    // The delegated reader is told to fetch the file itself via readDocument(id).\n    expect(readerMsg).toContain('readDocument');\n    expect(readerMsg).toContain('up1');\n    expect(readerMsg).toContain('doc.pdf');\n\n    await session.dispose();\n  });\n\n  it('resolves a PRIOR turn\\'s attachment id when a LATER turn delegates it (propose→consent→build)', async () => {\n    // THING's flow: turn 1 the user dumps a file and THING only OFFERS (no build);\n    // turn 2 a bare \"yes please\" and THING delegates the SAME file to the automator to\n    // seed the app. The attachment arrived in turn 1 but is delegated in turn 2. If\n    // `pendingAttachments` is cleared each turn, turn 2's delegate can't resolve the\n    // turn-1 id → the automator reads nothing → empty tables. This asserts the id still\n    // resolves across turns (the reader gets an id-anchored readDocument note).\n    let readerMsg = '';\n    let sawSecondTurn = false;\n    let delegated = false;\n    const streamFn = mockMatch(\n      [\n        {\n          when: /document reader/,\n          respond: (opts: StreamOpts) => {\n            const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n            readerMsg = u?.content ?? '';\n            return 'currentTask.resolve(\"done\");';\n          },\n        },\n      ],\n      // Top-level agent: turn 1 just \"offers\" (no statements); turn 2 delegates the\n      // turn-1 attachment id ONCE, then stops.\n      (opts: StreamOpts) => {\n        const u = [...opts.messages].reverse().find((m) => m.role === 'user');\n        if (/yes please/.test(u?.content ?? '')) sawSecondTurn = true;\n        if (!sawSecondTurn || delegated) return ''; // turn 1: offer only; post-delegate: stop\n        delegated = true;\n        return `await delegate('system-files', 'reader', { query: 'seed the app', attachmentIds: ['up1'] });`;\n      },\n    );\n    const documentResolver: DocumentResolver = async (id) => ({ ok: true, attachmentId: id, mediaType: 'application/pdf', kind: 'text', text: 'x' });\n    const host: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n    const session = new Session(\n      { spaceDir: await makeSpace(), agentSlug: 'default', modelAlias: 'mock', renderHost: host, systemSpaceDirs: [SYSTEM_FILES_DIR], documentResolver },\n      { streamFn },\n    );\n\n    // Turn 1: the file arrives; THING only offers.\n    await session.start({\n      text: 'here is my budget spreadsheet, I keep losing track',\n      attachments: [{ id: 'up1', kind: 'file', mediaType: 'application/pdf', filename: 'budget.pdf' }],\n    });\n    expect(readerMsg).toBe(''); // nothing delegated yet\n\n    // Turn 2: a bare \"yes please\" — THING delegates the SAME (turn-1) attachment.\n    await session.continue('yes please, build it');\n    expect(readerMsg).toContain('readDocument');\n    expect(readerMsg).toContain('up1');\n    expect(readerMsg).toContain('budget.pdf');\n\n    await session.dispose();\n  });\n});\n","numLines":204,"startLine":1,"totalLines":204}}}
