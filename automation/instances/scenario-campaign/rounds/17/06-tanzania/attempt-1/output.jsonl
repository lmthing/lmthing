ing; location: string; description: string; category: string; booking_ref: string; contact: string; }\nexport default function Home() {\n  const { data, isLoading } = useApi<{ stops: Stop[] }>('itinerary-list');\n  if (isLoading) return <p className=\"text-muted p-4\">Loading itinerary…</p>;\n  const stops = data?.stops ?? [];\n  return (\n    <div className=\"p-4 space-y-3\">\n      <h1 className=\"text-foreground text-xl font-bold\">Tanzania Trip · Aug 3–20 2026</h1>\n      <div className=\"divide-y divide-border rounded-lg border border-border\">\n        {stops.map((s) => (\n          <div key={s.id} className=\"p-3 flex justify-between items-start\">\n            <div>\n              <p className=\"text-foreground font-medium\">{s.location}</p>\n              <p className=\"text-muted text-sm\">{s.date} · {s.category}</p>\n              {s.description ? <p className=\"text-foreground text-sm mt-1\">{s.description}</p> : null}\n              {s.contact ? <p className=\"text-muted text-xs\">{s.contact}</p> : null}\n            </div>\n            {s.booking_ref ? <span className=\"text-xs bg-primary/10 text-primary px-2 py-0.5 rounded\">{s.booking_ref}</span> : null}\n          </div>\n        ))}\n      </div>\n    </div>\n  );\n}","numLines":25,"startLine":1,"totalLines":25}}}
