7\t      continue;\n518\t    }\n519\t\n520\t    // Flush remaining buffer. Unlike the streaming loop above, this never emits\n521\t    // statement/progress/error tracer events or renderHost logs, and never touches\n522\t    // `stream`/`aborted` (the stream has already ended) — that asymmetry is intentional\n523\t    // and predates this refactor; processStatement only supplies the shared pipeline.\n524\t    if (!aborted) {\n525\t      // Release the fence filter's held partial line first — it may complete one\n526\t      // or more statements in the detector — then flush the detector's own tail.\n527\t      const released = fenceFilter.flush();\n528\t      const flushedStatements = released ? detector.feed(released) : [];\n529\t      const trailing = detector.flush().trim();\n530\t      for (const stmt of [...flushedStatements, ...(trailing ? [trailing] : [])]) {\n531\t        const outcome = processStatement(stmt);\n532\t        if (outcome.kind !== 'dropped') hadStatements = true;\n533\t        // Mirror the streaming loop: stop at the first error or yield.\n534\t        if (outcome.kind !== 'ok' && outcome.kind !== 'dropped') break;\n535\t      }\n536\t    }\n537\t\n538\t    // Await token usage from the stream (best-effort; available after stream is consumed).\n539\t    // Skip when the stream was aborted mid-way (yield/error): the usage event arrives\n540\t    // only in the final API chunk, which never comes after abort, so the promise hangs.\n541\t    // Even on a \"normal\" end the promise can stay pending forever (provider ended the\n542\t    // stream without the final usage chunk — live E6 hang: one fork stalled here with\n543\t    // no timer left, the DAG deadlocked, and Node exited silently once every other\n544\t    // promise drained). Usage is telemetry, never worth blocking on: bound the wait.\n545\t    let inputTokens: number | undefined;\n546\t    let outputTokens: number | undefined;\n547\t    if (stream.usage && !aborted && !streamErrored) {\n548\t      let usageTimer: ReturnType<typeof setTimeout> | undefined;\n549\t      try {\n550\t        const u = await Promise.race([\n551\t          stream.usage,\n552\t          new Promise<undefined>((res) => { usageTimer = setTimeout(() => res(undefined), 10_000); }),\n553\t        ]);\n554\t        if (u && (u.promptTokens > 0 || u.completionTokens > 0)) {\n555\t          inputTokens = u.promptTokens;\n556\t          outputTokens = u.completionTokens;\n557\t        }\n558\t      } catch { /* usage unavailable */ } finally {\n559\t        if (usageTimer) clearTimeout(usageTimer);\n560\t      }\n561\t    }\n562\t\n563\t    // Use parsed statements for history so incomplete trailing stream text is excluded.\n564\t    const historyContent = parsedStatements.length > 0 ? parsedStatements.join('\\n') : assistantContent.trim();\n565\t    if (historyContent) {\n566\t      renderHost.log(`[model response]\\n${historyContent}\\n[/model response]`);\n567\t      tracer.write({\n568\t        ts: Date.now(), type: 'llm_response', context: ctx,\n569\t        ...(nodeId ? { nodeId } : {}),\n570\t        attempt, text: historyContent,\n571\t        ...(deps.model ? { model: deps.model } : {}),\n572\t        ...(inputTokens !== undefined ? { inputTokens } : {}),\n573\t        ...(outputTokens !== undefined ? { outputTokens } : {}),\n574\t      });\n575\t      history.append({ role: 'assistant', content: historyContent, blockType: 'normal' });\n576\t    }\n577\t\n578\t    if (turnError && failingStatement) {\n579\t      // process.exit() is intentional termination, not a recoverable error. The model"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"ade2557c-b424-420e-8f71-af2a1c0b3a01","timestamp":"2026-07-15T23:59:05.709Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_KuqIyRBjm9fS7NgYYIq1J1eU","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { createVM, type VM } from '../sandbox/quickjs.js';\n3\timport { injectGlobal } from '../sandbox/host-bridge.js';\n4\timport { injectHostTools } from '../globals/host-tools.js';\n5\timport { createSetSessionMetaGlobal } from '../globals/set-session-meta.js';\n6\timport { runTurnLoop } from './turn-loop.js';\n7\timport { MessageHistory } from '../context/history.js';\n8\timport { LIBRARY_DTS } from '../typecheck/library-dts.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamSession, StreamOpts } from './stream-types.js';\n11\timport type { YieldRequest } from './yield.js';\n12\t\n13\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n14\t\n15\t/** A streamFn that emits `statements` on the first turn, then nothing (so the loop ends). */\n16\tfunction scriptedStream(statements: string): (opts: StreamOpts) => Promise<StreamSession> {\n17\t  let calls = 0;\n18\t  return async () => {\n19\t    const text = calls++ === 0 ? statements : '';\n20\t    let aborted = false;\n21\t    async function* gen() {\n22\t      if (!aborted && text) yield text;\n23\t    }\n24\t    return { textStream: gen(), abort() { aborted = true; } } as StreamSession;\n25\t  };\n26\t}\n27\t\n28\tfunction readGlobal(vm: VM, name: string): unknown {\n29\t  const h = vm.ctx.getProp(vm.ctx.global, name);\n30\t  try { return vm.ctx.dump(h); } finally { h.dispose(); }\n31\t}\n32\t\n33\t/** A streamFn whose first N turns throw a transient stream error, then emits `statements`. */\n34\tfunction flakyThenStream(failTurns: number, statements: string): (opts: StreamOpts) => Promise<StreamSession> {\n35\t  let calls = 0;\n36\t  return async () => {\n37\t    const turn = calls++;\n38\t    const fail = turn < failTurns;\n39\t    const emitted = turn === failTurns; // emit code exactly once, after the failures\n40\t    let aborted = false;\n41\t    async function* gen() {\n42\t      if (fail) throw new Error('terminated');\n43\t      if (!aborted && emitted) yield statements;\n44\t    }\n45\t    return { textStream: gen(), abort() { aborted = true; } } as StreamSession;\n46\t  };\n47\t}\n48\t\n49\tdescribe('turn loop — transient stream error recovery', () => {\n50\t  it('retries a dropped/terminated stream instead of finishing as done', async () => {\n51\t    const vm = await createVM();\n52\t    const history = new MessageHistory();\n53\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n54\t\n55\t    const result = await runTurnLoop({\n56\t      vm,\n57\t      history,\n58\t      systemBlock: 'test',\n59\t      ambientDts: LIBRARY_DTS,\n60\t      renderHost: silentHost,\n61\t      // First turn's stream throws \"terminated\"; the retry succeeds and binds x.\n62\t      streamFn: flakyThenStream(1, 'const x = 7;'),\n63\t      processYield: async () => undefined,\n64\t      maxRetries: 3,\n65\t    });\n66\t\n67\t    expect(result).toBe('done');\n68\t    expect(readGlobal(vm, 'x')).toBe(7);\n69\t    vm.dispose();\n70\t  });\n71\t\n72\t  it('gives up with error (not a false done) when every attempt drops', async () => {\n73\t    const vm = await createVM();\n74\t    const history = new MessageHistory();\n75\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n76\t\n77\t    const result = await runTurnLoop({\n78\t      vm,\n79\t      history,\n80\t      systemBlock: 'test',\n81\t      ambientDts: LIBRARY_DTS,\n82\t      renderHost: silentHost,\n83\t      streamFn: flakyThenStream(5, 'const x = 7;'), // always fails within maxRetries\n84\t      processYield: async () => undefined,\n85\t      maxRetries: 3,\n86\t    });\n87\t\n88\t    expect(result).toBe('error');\n89\t    vm.dispose();\n90\t  });\n91\t});\n92\t\n93\tdescribe('turn loop — parallel yields (Promise.all of forks)', () => {\n94\t  it('binds each parallel yield to its OWN result (no collision)', async () => {\n95\t    const vm = await createVM();\n96\t    // A yielding global `y(tag)` that pushes a yield carrying its tag.\n97\t    const y = (tag: string) =>\n98\t      new Promise((resolve, reject) => {\n99\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n100\t      });\n101\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n102\t\n103\t    const history = new MessageHistory();\n104\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n105\t\n106\t    const result = await runTurnLoop({\n107\t      vm,\n108\t      history,\n109\t      systemBlock: 'test',\n110\t      ambientDts: 'declare function y(tag: string): Promise<any>;',\n111\t      renderHost: silentHost,\n112\t      streamFn: scriptedStream('const [a, b] = await Promise.all([y(\"X\"), y(\"Y\")]);'),\n113\t      // Each yield resolves to a distinct value keyed by its tag.\n114\t      processYield: async (req) => ({ from: req.args[0] }),\n115\t      maxRetries: 2,\n116\t    });\n117\t\n118\t    expect(result).toBe('done');\n119\t    // The VM must have bound a→X's result and b→Y's result — not both to the last one.\n120\t    expect(readGlobal(vm, 'a')).toEqual({ from: 'X' });\n121\t    expect(readGlobal(vm, 'b')).toEqual({ from: 'Y' });\n122\t\n123\t    // And the emitted VARIABLES block reflects the distinct values.\n124\t    const varsMsg = history.messages.find((m) => m.blockType === 'variables');\n125\t    expect(varsMsg?.content).toContain('\"from\": \"X\"');\n126\t    expect(varsMsg?.content).toContain('\"from\": \"Y\"');\n127\t    vm.dispose();\n128\t  });\n129\t\n130\t  it('resolves parallel yields concurrently, not sequentially', async () => {\n131\t    const vm = await createVM();\n132\t    const startTimes: Record<string, number> = {};\n133\t    const endTimes: Record<string, number> = {};\n134\t    const y = (tag: string) =>\n135\t      new Promise((resolve, reject) => {\n136\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n137\t      });\n138\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n139\t\n140\t    const history = new MessageHistory();\n141\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n142\t\n143\t    await runTurnLoop({\n144\t      vm,\n145\t      history,\n146\t      systemBlock: 'test',\n147\t      ambientDts: 'declare function y(tag: string): Promise<any>;',\n148\t      renderHost: silentHost,\n149\t      streamFn: scriptedStream('const [a, b] = await Promise.all([y(\"X\"), y(\"Y\")]);'),\n150\t      processYield: async (req) => {\n151\t        const tag = req.args[0] as string;\n152\t        startTimes[tag] = Date.now();\n153\t        await new Promise((r) => setTimeout(r, 80));\n154\t        endTimes[tag] = Date.now();\n155\t        return { tag };\n156\t      },\n157\t      maxRetries: 2,\n158\t    });\n159\t\n160\t    // Both must have started (both yields were dispatched)\n161\t    expect(startTimes['X']).toBeDefined();\n162\t    expect(startTimes['Y']).toBeDefined();\n163\t    // Y must have started before X finished — proving concurrent execution.\n164\t    expect(startTimes['Y']).toBeLessThan(endTimes['X']!);\n165\t    expect(readGlobal(vm, 'a')).toEqual({ tag: 'X' });\n166\t    expect(readGlobal(vm, 'b')).toEqual({ tag: 'Y' });\n167\t    vm.dispose();\n168\t  });\n169\t\n170\t  it('binds a destructured single-yield object result to each name', async () => {\n171\t    const vm = await createVM();\n172\t    const ask2 = () =>\n173\t      new Promise((resolve, reject) => {\n174\t        vm.pendingYields.push({ kind: 'ask', args: [], deferred: { resolve, reject }, vmPromiseHandle: undefined } as YieldRequest);\n175\t      });\n176\t    injectGlobal(vm.ctx, 'ask2', ask2 as (...a: unknown[]) => unknown);\n177\t\n178\t    const history = new MessageHistory();\n179\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n180\t\n181\t    await runTurnLoop({\n182\t      vm,\n183\t      history,\n184\t      systemBlock: 'test',\n185\t      ambientDts: 'declare function ask2(): Promise<any>;',\n186\t      renderHost: silentHost,\n187\t      streamFn: scriptedStream('const { name, age } = await ask2();'),\n188\t      processYield: async () => ({ name: 'Ada', age: 36 }),\n189\t      maxRetries: 2,\n190\t    });\n191\t\n192\t    expect(readGlobal(vm, 'name')).toBe('Ada');\n193\t    expect(readGlobal(vm, 'age')).toBe(36);\n194\t    vm.dispose();\n195\t  });\n196\t});\n197\t\n198\tdescribe('turn loop — setSessionMeta() runs end-to-end in a real VM', () => {\n199\t  it('injects the real global, typechecks against LIBRARY_DTS, and binds {ok:true}', async () => {\n200\t    const vm = await createVM();\n201\t    // The genuine global factory pushes a 'setSessionMeta' yield.\n202\t    const setSessionMeta = createSetSessionMetaGlobal((req) => vm.pendingYields.push(req));\n203\t    injectGlobal(vm.ctx, 'setSessionMeta', setSessionMeta as (...a: unknown[]) => unknown);\n204\t\n205\t    const history = new MessageHistory();\n206\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n207\t\n208\t    let seen: unknown;\n209\t    await runTurnLoop({\n210\t      vm,\n211\t      history,\n212\t      systemBlock: 'test',\n213\t      // LIBRARY_DTS is the real session DTS — proves setSessionMeta typechecks there.\n214\t      ambientDts: LIBRARY_DTS,\n215\t      renderHost: silentHost,\n216\t      streamFn: scriptedStream('const r = await setSessionMeta({ title: \"Pasta night\", slug: \"pasta-night\" });'),\n217\t      processYield: async (req) => {\n218\t        seen = req.args[0];\n219\t        expect(req.kind).toBe('setSessionMeta');\n220\t        return { ok: true }; // mirrors Session.handleYield's return\n221\t      },\n222\t      maxRetries: 2,\n223\t    });\n224\t\n225\t    expect(seen).toEqual({ title: 'Pasta night', slug: 'pasta-night' });\n226\t    expect(readGlobal(vm, 'r')).toEqual({ ok: true });\n227\t    vm.dispose();\n228\t  });\n229\t});\n230\t\n231\tdescribe('turn loop — nested yield binding (yield inside an awaited async wrapper)', () => {\n232\t  it(\"binds the bound name to the outer async function's return value, not the inner yield's raw resolved value\", async () => {\n233\t    const vm = await createVM();\n234\t    // A yielding global `y(tag)`, same shape as sleep/ask/etc.\n235\t    const y = (tag: string) =>\n236\t      new Promise((resolve, reject) => {\n237\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n238\t      });\n239\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n240\t\n241\t    // A plain async function (mirrors webSearch/webFetch awaiting fetch() internally)\n242\t    // that awaits the yielding global and post-processes its result before returning.\n243\t    const def = vm.evalScript(\n244\t      'globalThis.wrapper = async function wrapper() { const inner = await y(\"tag\"); return { processed: inner, marker: \"real\" }; };',\n245\t    );\n246\t    expect(def.ok).toBe(true);\n247\t\n248\t    const history = new MessageHistory();\n249\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n250\t\n251\t    const result = await runTurnLoop({\n252\t      vm,\n253\t      history,\n254\t      systemBlock: 'test',\n255\t      ambientDts: 'declare function wrapper(): Promise<any>; declare function y(tag: string): Promise<any>;',\n256\t      renderHost: silentHost,\n257\t      streamFn: scriptedStream('const out = await wrapper();'),\n258\t      // The INNER yield resolves to a raw sentinel, distinct from wrapper's real return —\n259\t      // proves the bound value isn't just this raw value passed through.\n260\t      processYield: async () => 'RAW_INNER_VALUE',\n261\t      maxRetries: 2,\n262\t    });\n263\t\n264\t    expect(result).toBe('done');\n265\t    expect(readGlobal(vm, 'out')).toEqual({ processed: 'RAW_INNER_VALUE', marker: 'real' });\n266\t    vm.dispose();\n267\t  });\n268\t\n269\t  it('services SEQUENTIAL internal yields to completion (webFetch plain→render), not just the first', async () => {\n270\t    const vm = await createVM();\n271\t    // A yielding global `y(tag)`, same shape as fetch — each call is one host yield.\n272\t    const y = (tag: string) =>\n273\t      new Promise((resolve, reject) => {\n274\t        vm.pendingYields.push({ kind: 'y', args: [tag], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n275\t      });\n276\t    injectGlobal(vm.ctx, 'y', y as (...a: unknown[]) => unknown);\n277\t\n278\t    // A wrapper that awaits the yielding global TWICE in sequence (mirrors webFetch's\n279\t    // auto-dynamic path: a plain fetch, then — based on its result — a second fetch to\n280\t    // the render service). The second await only becomes a pending yield after the\n281\t    // first resumes, so the turn loop must loop-service both before binding.\n282\t    const def = vm.evalScript(\n283\t      'globalThis.wrapper = async function wrapper() { const first = await y(\"a\"); const second = await y(\"b\"); return { first, second, marker: \"real\" }; };',\n284\t    );\n285\t    expect(def.ok).toBe(true);\n286\t\n287\t    const history = new MessageHistory();\n288\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n289\t\n290\t    let call = 0;\n291\t    const result = await runTurnLoop({\n292\t      vm,\n293\t      history,\n294\t      systemBlock: 'test',\n295\t      ambientDts: 'declare function wrapper(): Promise<any>; declare function y(tag: string): Promise<any>;',\n296\t      renderHost: silentHost,\n297\t      streamFn: scriptedStream('const out = await wrapper();'),\n298\t      // Distinct value per sequential yield — proves BOTH ran (not just the first).\n299\t      processYield: async () => `R${call++}`,\n300\t      maxRetries: 2,\n301\t    });\n302\t\n303\t    expect(result).toBe('done');\n304\t    // Before the sequential-yield fix, `out` bound the raw first Response (\"R0\");\n305\t    // now it is the wrapper's real return after BOTH internal awaits completed.\n306\t    expect(readGlobal(vm, 'out')).toEqual({ first: 'R0', second: 'R1', marker: 'real' });\n307\t    vm.dispose();\n308\t  });\n309\t});\n310\t\n311\tdescribe('turn loop — inspect() surfaces values to the model', () => {\n312\t  // Regression: a BARE (unbound) inspect(x) must still surface x into the\n313\t  // VARIABLES block the model reads. Before this was wired, bare inspect\n314\t  // resolved to an empty VARIABLES block, so the model saw nothing and would\n315\t  // re-type values from memory (hallucinating the truncated tail).\n316\t  it('emits the inspected value even when the call is unbound', async () => {\n317\t    const vm = await createVM();\n318\t    // inspect(v) pushes a yield whose args mirror globals/inspect.ts: [{ value, query }].\n319\t    const inspect = (v: unknown) =>\n320\t      new Promise((resolve, reject) => {\n321\t        vm.pendingYields.push({\n322\t          kind: 'inspect',\n323\t          args: [{ value: v, query: undefined }],\n324\t          deferred: { resolve, reject },\n325\t          vmPromiseHandle: undefined,\n326\t        } as unknown as YieldRequest);\n327\t      });\n328\t    injectGlobal(vm.ctx, 'inspect', inspect as (...a: unknown[]) => unknown);\n329\t\n330\t    const history = new MessageHistory();\n331\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n332\t\n333\t    await runTurnLoop({\n334\t      vm,\n335\t      history,\n336\t      systemBlock: 'test',\n337\t      ambientDts: 'declare function inspect(...v: any[]): Promise<void>;',\n338\t      renderHost: silentHost,\n339\t      // No binding — the model just probes the value.\n340\t      streamFn: scriptedStream('inspect({ marketSize: \"$0.9B\", units: 12000 });'),\n341\t      // Mirrors session.ts: the inspect resolved value is args[0].\n342\t      processYield: async (req) => (req.args[0] as { value: unknown }).value,\n343\t      maxRetries: 2,\n344\t    });\n345\t\n346\t    const varsMsg = history.messages.find((m) => m.blockType === 'variables');\n347\t    expect(varsMsg?.content).toContain('inspected[0]');\n348\t    expect(varsMsg?.content).toContain('$0.9B');\n349\t    expect(varsMsg?.content).toContain('12000');\n350\t    vm.dispose();\n351\t  });\n352\t});\n353\t\n354\tdescribe('turn loop — process.exit() is not retried', () => {\n355\t  it('treats process.exit() as a clean stop instead of looping retries', async () => {\n356\t    const vm = await createVM();\n357\t    injectHostTools(vm, { renderHost: silentHost, spaceDir: '/tmp' });\n358\t\n359\t    const history = new MessageHistory();\n360\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n361\t\n362\t    let calls = 0;\n363\t    const streamFn = async (): Promise<StreamSession> => {\n364\t      calls++;\n365\t      let aborted = false;\n366\t      async function* gen() { if (!aborted) yield 'process.exit(1);'; }\n367\t      return { textStream: gen(), abort() { aborted = true; } };\n368\t    };\n369\t\n370\t    const result = await runTurnLoop({\n371\t      vm,\n372\t      history,\n373\t      systemBlock: 'test',\n374\t      ambientDts: LIBRARY_DTS,\n375\t      renderHost: silentHost,\n376\t      streamFn,\n377\t      processYield: async () => undefined,\n378\t      maxRetries: 3,\n379\t    });\n380\t\n381\t    expect(result).toBe('done'); // intentional termination, not 'error'\n382\t    expect(calls).toBe(1); // NOT retried 3× on the same process.exit() code\n383\t    vm.dispose();\n384\t  });\n385\t});\n386\t\n387\t/** Helper: a streamFn that emits one entry of `turns` per call, then '' forever. */\n388\tfunction turnsStream(turns: string[]): { fn: (o: StreamOpts) => Promise<StreamSession>; calls: () => number } {\n389\t  let i = 0;\n390\t  const fn = async () => {\n391\t    const text = turns[i++] ?? '';\n392\t    let aborted = false;\n393\t    async function* gen() { if (!aborted && text) yield text; }\n394\t    return { textStream: gen(), abort() { aborted = true; } } as StreamSession;\n395\t  };\n396\t  return { fn, calls: () => i };\n397\t}\n398\t\n399\tdescribe('turn loop — continuation nudge (stalled mid-program after a non-yielding await-binding)', () => {\n400\t  it('re-prompts the model when it stops right after `const x = await <space fn>()`, so the run continues', async () => {\n401\t    const vm = await createVM();\n402\t    // prep(): a non-yielding host fn (returns a value, pushes no yield) — like a space fn.\n403\t    injectGlobal(vm.ctx, 'prep', (() => 42) as (...a: unknown[]) => unknown);\n404\t    // fin(): a yielding global, proves the run advanced past the stall.\n405\t    const fin = () => new Promise((resolve, reject) => {\n406\t      vm.pendingYields.push({ kind: 'fin', args: [], deferred: { resolve, reject }, vmPromiseHandle: undefined } as unknown as YieldRequest);\n407\t    });\n408\t    injectGlobal(vm.ctx, 'fin', fin as (...a: unknown[]) => unknown);\n409\t\n410\t    const history = new MessageHistory();\n411\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n412\t    // Turn 1 stops right after a non-yielding await-binding (the bug signature).\n413\t    // After the nudge, turn 2 does a real yielding call; turn 3 is empty → done.\n414\t    const s = turnsStream(['const r = await prep();', 'const finRes = await fin();', '']);\n415\t\n416\t    const result = await runTurnLoop({\n417\t      vm, history, systemBlock: 'test',\n418\t      ambientDts: 'declare function prep(): Promise<number>;\\ndeclare function fin(): Promise<any>;',\n419\t      renderHost: silentHost, streamFn: s.fn,\n420\t      processYield: async () => ({ ok: true }),\n421\t      maxRetries: 2,\n422\t    });\n423\t\n424\t    expect(result).toBe('done');\n425\t    expect(s.calls()).toBeGreaterThanOrEqual(3); // turn1 stall + NUDGE→turn2 + turn3 empty\n426\t    expect(readGlobal(vm, 'finRes')).toEqual({ ok: true }); // continued past the stall\n427\t    vm.dispose();\n428\t  });\n429\t\n430\t  it('does NOT nudge when the last statement is a literal binding (no call → no spurious extra turn)', async () => {\n431\t    const vm = await createVM();\n432\t    const history = new MessageHistory();\n433\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n434\t    // Plain literal binding, no call → not the stranded-mid-program signature → loop ends.\n435\t    const s = turnsStream(['const x = 5;', '']);\n436\t\n437\t    const result = await runTurnLoop({\n438\t      vm, history, systemBlock: 'test', ambientDts: LIBRARY_DTS,\n439\t      renderHost: silentHost, streamFn: s.fn,\n440\t      processYield: async () => undefined, maxRetries: 2,\n441\t    });\n442\t\n443\t    expect(result).toBe('done');\n444\t    expect(s.calls()).toBe(1); // no nudge → streamFn called exactly once\n445\t    vm.dispose();\n446\t  });\n447\t\n448\t  it('DOES nudge when the last statement binds from a SYNC non-yielding call (e.g. writeTaskFile)', async () => {\n449\t    const vm = await createVM();\n450\t    // writeTaskFile(): a SYNC non-yielding host fn (returns a value, pushes no yield).\n451\t    injectGlobal(vm.ctx, 'writeTaskFile', (() => ({ ok: true })) as (...a: unknown[]) => unknown);\n452\t    injectGlobal(vm.ctx, 'finish', (() => true) as (...a: unknown[]) => unknown);\n453\t    const history = new MessageHistory();\n454\t    history.append({ role: 'user', content: 'go', blockType: 'normal' });\n455\t    // Sync space-function call bound to a var, then the model stops — the runtime never\n456\t    // surfaces the result, so the model is stranded mid-program. Must be nudged to continue.\n457\t    const s = turnsStream(['const r = writeTaskFile(\"d\", \"tl\", {});', 'const done = finish();', '']);\n458\t\n459\t    const result = await runTurnLoop({\n460\t      vm, history, systemBlock: 'test',"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"45cc6484-0473-4373-aef3-6725c74c1ce2","timestamp":"2026-07-15T23:59:05.710Z","subagent_type":"Explore","task_description":"Trace parallel specialist persistence"}
