/deep-research-flow.test.ts:91:    // A local server records each request's arrival time (to also prove the forEach\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/deep-research-flow.test.ts:122:          // `item` is the forEach element (one planned question). `fetcher` is a\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/deep-research-flow.test.ts:170:      // The 3 forEach forks' fetches reached the server within a tight window of\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:18: * node: dependsOn wiring, forEach fan-out (as a body AND as the array source),\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:98:  it('fans a code node out over an upstream array (code node AS a forEach body)', async () => {\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:101:      '02-each.ts': `export const node = { dependsOn: ['list'], forEach: 'list.items', goal: true, output: { n: 'number' } };\\nexport async function run() { return {}; }`,\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:107:    // forEach collects each element's output into an array, in order.\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:112:  it('lets a code node PRODUCE the array that a downstream forEach code node fans over', async () => {\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:113:    // Covers \"a code node's array output can drive forEach\" with no agent nodes at all.\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/orchestrator.codenode.test.ts:116:      '02-each.ts': `export const node = { dependsOn: ['gen'], forEach: 'gen.items', goal: true, output: { v: 'number' } };\\nexport async function run() { return {}; }`,\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/tasklist/foreach.test.ts:1