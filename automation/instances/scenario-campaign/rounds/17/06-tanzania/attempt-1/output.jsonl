{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_qfBvoqAuAi54HwPJaHbgLEUK","type":"tool_result","content":"1\timport type { YieldRequest } from './yield.js';\n2\timport type { ApiCallFn, ConnectionResolver } from '../db/types.js';\n3\timport type { DocumentResolver } from '../globals/read-document.js';\n4\timport type { IntegrationStatusResolver } from '../globals/integration-status.js';\n5\timport type { StoreResolver, InstallSpaceResult } from '../globals/store.js';\n6\timport type { EmitEventResolver } from '../globals/emit-event.js';\n7\timport {\n8\t  CONSENT_MARKED_YIELD_KINDS,\n9\t  enforceConsent,\n10\t  summarizeConsentArgs,\n11\t  type ConsentCard,\n12\t  type ConsentPrompter,\n13\t} from '../globals/consent.js';\n14\timport type { Clock } from '../session/types.js';\n15\timport type { Space } from '../spaces/load.js';\n16\timport type { ForkEngine, ForkTask } from '../fork/fork.js';\n17\timport type { DelegateOpts } from '../globals/delegate.js';\n18\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n19\t\n20\t/**\n21\t * Dependencies the shared yield router needs to resolve the yield kinds common\n22\t * to the full (session) VM, the delegate VM and fork leaf VMs: sleep, fork,\n23\t * tasklist, delegate, fetch — plus, for fork leaves (which have no session-side\n24\t * handler to fall back to), loadKnowledge and registerSpace.\n25\t *\n26\t * The genuine per-caller differences are parameterized:\n27\t *  - `runDelegate` — the session builds a fresh registry from its spaces; a\n28\t *    delegate recurses with depth+1; a fork leaf gates on the task's\n29\t *    `canDelegateTo` and routes to the engine's delegateRunner. The caller\n30\t *    supplies the right behaviour.\n31\t *  - `onTasklistResult` — delegate uses it to auto-capture the action's tasklist\n32\t *    result; the session leaves it undefined.\n33\t *  - `getForkEngine` — absent for fork leaves (no fork/tasklist there): those\n34\t *    kinds fall through as unhandled, preserving the old leaf behaviour.\n35\t */\n36\texport interface YieldRouterContext {\n37\t  /** Space for tasklist resolution. Absent in fork-leaf contexts (no tasklist there). */\n38\t  space?: Space;\n39\t  clock?: Clock;\n40\t  /** Lazily-resolved, shared ForkEngine (one per session/delegate scope) so the\n41\t   *  maxConcurrentForks semaphore is enforced across all fork/tasklist yields.\n42\t   *  Absent for fork leaves — fork/tasklist yields are then unhandled. */\n43\t  getForkEngine?: () => ForkEngine | Promise<ForkEngine>;\n44\t  /** Resolve a delegate() yield. May throw (e.g. a fork task's canDelegateTo\n45\t   *  gate) — the error surfaces to the model as a retryable yield error. */\n46\t  runDelegate: (\n47\t    packageName: string,\n48\t    agentName: string,\n49\t    action: string | undefined,\n50\t    delegateOpts: DelegateOpts | undefined,\n51\t  ) => Promise<unknown>;\n52\t  /** Fired after a tasklist resolves (delegate uses it for auto-capture). */\n53\t  onTasklistResult?: (name: string, result: unknown) => void;\n54\t  /** Run a shell command host-side (cwd = space dir). */\n55\t  execCommand?: (cmd: string) => { ok: boolean; output: string };\n56\t  /** Tracer for minting child scopes in tasklist. */\n57\t  tracer?: Tracer;\n58\t  /** Current execution scope — becomes parentScope on spawned forks/delegates. */\n59\t  scope?: TraceScope;\n60\t  /** When set, loadKnowledge yields are resolved HERE by reading the file under\n61\t   *  `<knowledgeSpaceDir>/knowledge/…` and returning its content (fork leaves,\n62\t   *  which must win the race against the global's own concurrent resolve —\n63\t   *  otherwise undefined is bound before the file read completes). The session\n64\t   *  handles loadKnowledge itself; leave unset there. */\n65\t  knowledgeSpaceDir?: string;\n66\t  /** When true, registerSpace yields are resolved HERE (fork leaves): the space\n67\t   *  is loaded and inserted into `dynamicSpaces` when provided. The map is the\n68\t   *  SAME reference the parent Session hands to delegate(), so a space\n69\t   *  registered inside a fork is reachable by the parent's later delegate(). */\n70\t  resolveRegisterSpace?: boolean;\n71\t  dynamicSpaces?: Map<string, Space>;\n72\t  /** Resolve an `apiCall()` yield — enter the project's api runtime by endpoint\n73\t   *  `name` (host-supplied via the project's app globals). Absent outside a\n74\t   *  project-app context; an `apiCall` yield then rejects with a clear error. */\n75\t  apiCallResolver?: ApiCallFn;\n76\t  /** The running agent's `api:call: { allow: [...] }` grant — the endpoints it may\n77\t   *  enter. Enforced in the `apiCall` yield (a name outside the list is refused with a\n78\t   *  retryable error naming what IS allowed). `['*']` = any endpoint this project\n79\t   *  declares. Absent ⇒ unenforced (a non-agent context, e.g. a bare unit test). */\n80\t  apiCallAllow?: string[];\n81\t  /** Resolve a `callConnection()` yield — forward the request to the gateway's\n82\t   *  egress proxy for the named connected service (host-supplied via the pod's\n83\t   *  scoped connections JWT). Absent outside a pod with a configured connections\n84\t   *  gateway; a `callConnection` yield then rejects with a clear error. */\n85\t  connectionResolver?: ConnectionResolver;\n86\t  /** Build a per-node execution context for a `kind:'code'` tasklist node\n87\t   *  (db + callConnection locked to the space/tasklist `connections:` + delegate).\n88\t   *  Threaded into `runTasklist`. Absent until the CLI/pod wires a runner (plan\n89\t   *  step S9); a code node then fails with a clear required-task error. Core\n90\t   *  never imports/executes the node module. */\n91\t  codeNodeCtxFactory?: import('../tasklist/orchestrator.js').CodeNodeCtxFactory;\n92\t  /** Resolve a `readDocument()` yield — extract a stored upload's text host-side\n93\t   *  (host-supplied by libs/cli, where the uploads dir is known). Absent outside a\n94\t   *  pod/CLI with an uploads dir; a `readDocument` yield then rejects with a clear\n95\t   *  error. Not an app-global (project-independent) — threaded from SessionOpts. */\n96\t  documentResolver?: DocumentResolver;\n97\t  /** Resolve an `integrationStatus()` yield — report presence-only config status\n98\t   *  (names of missing required env vars, never their values) for an installed\n99\t   *  integration space in the current project. Host-supplied by libs/cli (knows the\n100\t   *  project root + `process.env`). Absent outside a project-rooted session; an\n101\t   *  `integrationStatus` yield then rejects with a clear error. */\n102\t  integrationStatusResolver?: IntegrationStatusResolver;\n103\t  /** Consent prompter for consent-marked invocations (plan S10) — supplied ONLY\n104\t   *  by interactive session contexts (the cli builds it on `renderHost.ask`).\n105\t   *  Absent (headless runs, forks, delegates, hooks) ⇒ a consent-marked yield\n106\t   *  FAILS CLOSED with a clear \"requires user consent\" error. */\n107\t  requestConsent?: ConsentPrompter;\n108\t  /** Resolve the store-global yields (`storeSearch`/`storeInspect`/`installSpace`)\n109\t   *  — host-supplied by libs/cli on `AppGlobalImpls.store` (mirrors\n110\t   *  `connectionResolver`). Absent ⇒ a store yield rejects with a clear error. */\n111\t  storeResolver?: StoreResolver;\n112\t  /** Resolve an `emitEvent()` yield — validate against the caller scope's\n113\t   *  declared events and dispatch to subscribing hooks (host-supplied by\n114\t   *  libs/cli on `AppGlobalImpls.emitEvent`). Absent ⇒ a clear error. */\n115\t  emitEventResolver?: EmitEventResolver;\n116\t}\n117\t\n118\texport type RouteResult =\n119\t  | { handled: true; value: unknown }\n120\t  | { handled: false };\n121\t\n122\t/**\n123\t * Single resolver for the yield kinds shared by the session, delegate and fork\n124\t * leaf VMs. Returns `{ handled: false }` for kinds the caller must handle itself\n125\t * (ask/inspect are session-only; the session also resolves its own\n126\t * loadKnowledge/registerSpace before consulting the router).\n127\t *\n128\t * `fetch` is real, non-blocking Node I/O — see `eval/fetch-yield.ts`. A future\n129\t * `execShell`/`tool` yield kind would follow the same shape.\n130\t */\n131\texport async function routeCommonYield(\n132\t  req: YieldRequest,\n133\t  ctx: YieldRouterContext,\n134\t): Promise<RouteResult> {\n135\t  // Generic HOST-ENFORCED consent (plan S10): a consent-marked yield kind (the\n136\t  // registry in globals/consent.ts — `installSpace` today) must be approved by\n137\t  // the USER before its resolver runs. No prompter (headless/fork/delegate/hook\n138\t  // contexts) ⇒ FAIL CLOSED; denial ⇒ a structured refusal the agent sees. This\n139\t  // runs BEFORE the switch so no resolver below can execute unapproved.\n140\t  if (CONSENT_MARKED_YIELD_KINDS.has(req.kind)) {\n141\t    await enforceConsent(ctx.requestConsent, {\n142\t      function: req.kind,\n143\t      argsSummary: summarizeConsentArgs(req.args),\n144\t    });\n145\t  }\n146\t  switch (req.kind) {\n147\t    case 'sleep': {\n148\t      const ms = req.args[1] as number;\n149\t      await new Promise<void>((resolve) => {\n150\t        if (ctx.clock) ctx.clock.setTimeout(resolve, ms);\n151\t        else setTimeout(resolve, ms);\n152\t      });\n153\t      return { handled: true, value: undefined };\n154\t    }\n155\t    case 'fork': {\n156\t      if (!ctx.getForkEngine) return { handled: false }; // fork leaves have no fork()\n157\t      const engine = await ctx.getForkEngine();\n158\t      const task = req.args[0] as ForkTask;\n159\t      // Attach the current scope as parent so the fork's node is correctly nested\n160\t      if (ctx.scope && !task.parentScope) task.parentScope = ctx.scope;\n161\t      const value = await engine.fork(task);\n162\t      return { handled: true, value };\n163\t    }\n164\t    case 'tasklist': {\n165\t      if (!ctx.getForkEngine || !ctx.space) return { handled: false }; // fork leaves have no tasklist()\n166\t      const name = req.args[0] as string;\n167\t      const seed = req.args[1] as Record<string, unknown> | undefined;\n168\t      const engine = await ctx.getForkEngine();\n169\t      const { runTasklist } = await import('../tasklist/orchestrator.js');\n170\t      const result = await runTasklist({ name, space: ctx.space, forkEngine: engine, seed, tracer: ctx.tracer, parentScope: ctx.scope, codeNodeCtxFactory: ctx.codeNodeCtxFactory });\n171\t      ctx.onTasklistResult?.(name, result);\n172\t      return { handled: true, value: result };\n173\t    }\n174\t    case 'delegate': {\n175\t      const [packageName, agentName, action, delegateOpts] = req.args as [\n176\t        string,\n177\t        string,\n178\t        string | undefined,\n179\t        DelegateOpts | undefined,\n180\t      ];\n181\t      const value = await ctx.runDelegate(packageName, agentName, action, delegateOpts);\n182\t      return { handled: true, value };\n183\t    }\n184\t    case 'fetch': {\n185\t      const [url, fetchOpts] = req.args as [string, import('../globals/fetch.js').FetchOpts | undefined];\n186\t      const { resolveFetchYield } = await import('./fetch-yield.js');\n187\t      const value = await resolveFetchYield(url, fetchOpts);\n188\t      return { handled: true, value };\n189\t    }\n190\t    case 'apiCall': {\n191\t      // Enter the project's own api endpoint by name (agent-facing `apiCall`).\n192\t      // A missing resolver means this context has no project api runtime — throw\n193\t      // an actionable, retryable error rather than binding undefined.\n194\t      if (!ctx.apiCallResolver) {\n195\t        throw new Error('apiCall is not available here: this session has no project api runtime');\n196\t      }\n197\t      const [name, input] = req.args as [string, unknown];\n198\t      // ENFORCE the `api:call: { allow: [...] }` grant. Holding the capability is what\n199\t      // injects the global; the allowlist is what says WHICH endpoints it may enter, and\n200\t      // until now it was parsed, validated — and never checked, so any holder could call\n201\t      // anything. `'*'` is the one wildcard (any endpoint THIS project declares).\n202\t      const allow = ctx.apiCallAllow;\n203\t      if (allow && !allow.includes('*') && !allow.includes(name)) {\n204\t        throw new Error(\n205\t          `apiCall(\"${name}\") is not permitted: this agent's api:call allowlist is [${allow.join(', ')}]`,\n206\t        );\n207\t      }\n208\t      const value = await ctx.apiCallResolver(name, input);\n209\t      return { handled: true, value };\n210\t    }\n211\t    case 'callConnection': {\n212\t      // Forward an authenticated request to an external service; the pod resolver\n213\t      // attaches the user's own token (bring-your-own-token, Settings →\n214\t      // Integrations) and calls the provider directly. A missing resolver means\n215\t      // this context has no connection support wired (e.g. a bare unit test) —\n216\t      // throw an actionable, retryable error rather than binding undefined.\n217\t      if (!ctx.connectionResolver) {\n218\t        throw new Error('callConnection is not available here: no connection resolver configured');\n219\t      }\n220\t      const [provider, request] = req.args as [string, import('../db/types.js').ConnectionRequest];\n221\t      const value = await ctx.connectionResolver(provider, request);\n222\t      return { handled: true, value };\n223\t    }\n224\t    case 'readDocument': {\n225\t      // Extract a stored upload's content host-side (unpdf for PDF, utf8 for text,\n226\t      // transcript for audio). A missing resolver means this context has no uploads\n227\t      // dir (e.g. a bare in-memory session) — throw an actionable, retryable error\n228\t      // rather than binding undefined.\n229\t      if (!ctx.documentResolver) {\n230\t        throw new Error('readDocument is not available here: no document resolver configured');\n231\t      }\n232\t      const [attachmentId, opts] = req.args as [string, { maxChars?: number } | undefined];\n233\t      const value = await ctx.documentResolver(attachmentId, opts);\n234\t      return { handled: true, value };\n235\t    }\n236\t    case 'integrationStatus': {\n237\t      // Presence-only config status of an installed integration in the current\n238\t      // project (missing REQUIRED env-var names — never their values). A missing\n239\t      // resolver means this context has no project scope (e.g. a fork leaf / bare\n240\t      // unit test) — throw an actionable, retryable error rather than binding\n241\t      // undefined.\n242\t      if (!ctx.integrationStatusResolver) {\n243\t        throw new Error('integrationStatus is not available here: no project scope configured');\n244\t      }\n245\t      const [spaceId] = req.args as [string];\n246\t      const value = await ctx.integrationStatusResolver(spaceId);\n247\t      return { handled: true, value };\n248\t    }\n249\t    case 'consent': {\n250\t      // The consent gate for a consent-marked SPACE FUNCTION: its injection-time\n251\t      // wrapper (sandbox/inject-functions.ts) awaits `__requestConsent`, which\n252\t      // pushes this yield with the HOST-built card. Same enforcement primitive\n253\t      // as the pre-switch gate: no prompter ⇒ fail closed; deny ⇒ refusal.\n254\t      const card = req.args[0] as ConsentCard;\n255\t      await enforceConsent(ctx.requestConsent, card);\n256\t      return { handled: true, value: { granted: true } };\n257\t    }\n258\t    case 'storeSearch': {\n259\t      // Catalog search (agent-facing `storeSearch`, gated on `store:read`). A\n260\t      // missing resolver means this context has no store wiring (e.g. a bare\n261\t      // unit test / no project) — throw an actionable, retryable error.\n262\t      if (!ctx.storeResolver) {\n263\t        throw new Error('storeSearch is not available here: no store resolver configured');\n264\t      }\n265\t      const [query] = req.args as [string | undefined];\n266\t      const value = await ctx.storeResolver.search(query);\n267\t      return { handled: true, value };\n268\t    }\n269\t    case 'storeInspect': {\n270\t      // One catalog entry (agent-facing `storeInspect`, gated on `store:read`).\n271\t      if (!ctx.storeResolver) {\n272\t        throw new Error('storeInspect is not available here: no store resolver configured');\n273\t      }\n274\t      const [spaceId] = req.args as [string];\n275\t      const value = await ctx.storeResolver.inspect(spaceId);\n276\t      return { handled: true, value };\n277\t    }\n278\t    case 'installSpace': {\n279\t      // Consent-marked store install (the pre-switch gate already ran): pure\n280\t      // install via the pod resolver, then LIVE-REGISTER the installed dir into\n281\t      // the shared dynamicSpaces map (same mechanism as registerSpace, so\n282\t      // delegate() reaches the space in THIS session), then republish the pod's\n283\t      // runtime artifacts. Order: consent → install → register → republish.\n284\t      if (!ctx.storeResolver) {\n285\t        throw new Error('installSpace is not available here: no store resolver configured');\n286\t      }\n287\t      const [spaceId] = req.args as [string];\n288\t      const outcome = await ctx.storeResolver.install(spaceId);\n289\t      if (!outcome.ok || !outcome.installedDir) {\n290\t        // Divergence guard / install failure — surfaced as a value (not a throw)\n291\t        // so the agent can relay the \"local edits held back\" message verbatim.\n292\t        const value: InstallSpaceResult = {\n293\t          ok: false,\n294\t          spaceId: outcome.spaceId ?? spaceId,\n295\t          ...(outcome.projectId !== undefined ? { projectId: outcome.projectId } : {}),\n296\t          ...(outcome.diverged ? { diverged: true } : {}),\n297\t          ...(outcome.message !== undefined ? { message: outcome.message } : {}),\n298\t          ...(outcome.error !== undefined ? { error: outcome.error } : {}),\n299\t        };\n300\t        return { handled: true, value };\n301\t      }\n302\t      let spaceKey: string | undefined;\n303\t      let agentSlug: string | undefined;\n304\t      let registerError: string | undefined;\n305\t      try {\n306\t        const { loadSpace } = await import('../spaces/load.js');\n307\t        const space = await loadSpace(outcome.installedDir);\n308\t        ctx.dynamicSpaces?.set(outcome.installedDir, space);\n309\t        spaceKey = outcome.installedDir;\n310\t        agentSlug = Object.keys(space.agents)[0] ?? '';"}]},"parent_tool_use_id":"call_FFJKMOVjsfKJlWJZsycaWrdj","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"8f5f3e5a-de24-442b-a356-e73927fca8a6","timestamp":"2026-07-16T06:23:28.212Z","subagent_type":"general-purpose","task_description":"Review live-build tasklist"}
