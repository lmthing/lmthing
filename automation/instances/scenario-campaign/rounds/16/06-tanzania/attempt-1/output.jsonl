{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_PjxUzmRO5R3fhJIMQ0UPPru5","type":"tool_result","content":"1\timport type { TaskNode } from '../spaces/tasklist-load.js';\n2\timport { evaluateCondition } from './condition-dsl.js';\n3\t\n4\texport function validateDag(tasks: Record<string, TaskNode>): void {\n5\t  const ids = Object.keys(tasks);\n6\t\n7\t  // At most one explicit goal. 0 is valid — the effective goal then falls\n8\t  // back to the last task in file order (see resolveGoalTask below).\n9\t  const goalTasks = ids.filter((id) => tasks[id]!.goal);\n10\t  if (goalTasks.length > 1) {\n11\t    throw new Error(`Tasklist has multiple goal tasks: ${goalTasks.join(', ')}`);\n12\t  }\n13\t\n14\t  // Check all dependsOn references are valid\n15\t  for (const id of ids) {\n16\t    const task = tasks[id]!;\n17\t    if (task.dependsOn) {\n18\t      for (const dep of task.dependsOn) {\n19\t        if (!(dep in tasks)) {\n20\t          throw new Error(`Task \"${id}\" depends on unknown task \"${dep}\"`);\n21\t        }\n22\t      }\n23\t    }\n24\t    // forEach must name an upstream task (the head segment) that this task depends on, so\n25\t    // its output array is available by the time the host fans this task out.\n26\t    if (task.forEach) {\n27\t      const head = task.forEach.split('.')[0]!;\n28\t      if (!(head in tasks)) {\n29\t        throw new Error(`Task \"${id}\" forEach references unknown task \"${head}\"`);\n30\t      }\n31\t      if (!(task.dependsOn ?? []).includes(head)) {\n32\t        throw new Error(`Task \"${id}\" forEach \"${task.forEach}\" must also be listed in dependsOn (add \"${head}\")`);\n33\t      }\n34\t    }\n35\t  }\n36\t\n37\t  // Check no cycles using DFS\n38\t  const WHITE = 0, GRAY = 1, BLACK = 2;\n39\t  const color: Record<string, number> = {};\n40\t  for (const id of ids) color[id] = WHITE;\n41\t\n42\t  function dfs(id: string): void {\n43\t    color[id] = GRAY;\n44\t    const task = tasks[id]!;\n45\t    for (const dep of task.dependsOn ?? []) {\n46\t      if (color[dep] === GRAY) {\n47\t        throw new Error(`Cycle detected in tasklist: \"${id}\" -> \"${dep}\"`);\n48\t      }\n49\t      if (color[dep] === WHITE) {\n50\t        dfs(dep);\n51\t      }\n52\t    }\n53\t    color[id] = BLACK;\n54\t  }\n55\t\n56\t  for (const id of ids) {\n57\t    if (color[id] === WHITE) dfs(id);\n58\t  }\n59\t}\n60\t\n61\t/**\n62\t * Resolve the tasklist's effective goal task: the explicit `goal: true` task\n63\t * when present, else the last task in file order (tasks are inserted into\n64\t * `tasks` in file/NN-prefix order by `loadTasklist`, which JS object\n65\t * insertion order preserves for string keys).\n66\t */\n67\texport function resolveGoalTask(tasks: Record<string, TaskNode>): TaskNode | undefined {\n68\t  const values = Object.values(tasks);\n69\t  const explicit = values.find((t) => t.goal);\n70\t  if (explicit) return explicit;\n71\t  return values[values.length - 1];\n72\t}\n73\t\n74\texport function topoSort(tasks: Record<string, TaskNode>): TaskNode[] {\n75\t  const ids = Object.keys(tasks);\n76\t  const visited = new Set<string>();\n77\t  const result: TaskNode[] = [];\n78\t\n79\t  function visit(id: string): void {\n80\t    if (visited.has(id)) return;\n81\t    visited.add(id);\n82\t    const task = tasks[id]!;\n83\t    for (const dep of task.dependsOn ?? []) {\n84\t      visit(dep);\n85\t    }\n86\t    result.push(task);\n87\t  }\n88\t\n89\t  for (const id of ids) visit(id);\n90\t  return result;\n91\t}\n92\t\n93\texport function findReadyTasks(\n94\t  tasks: Record<string, TaskNode>,\n95\t  done: Set<string>,\n96\t  skipped: Set<string>,\n97\t  outputs: Record<string, unknown>,\n98\t): TaskNode[] {\n99\t  const ready: TaskNode[] = [];\n100\t\n101\t  for (const [id, task] of Object.entries(tasks)) {\n102\t    // Skip already done/skipped tasks\n103\t    if (done.has(id) || skipped.has(id)) continue;\n104\t\n105\t    // Check all dependencies are satisfied\n106\t    const deps = task.dependsOn ?? [];\n107\t    const depsOk = deps.every((dep) => done.has(dep) || skipped.has(dep));\n108\t    if (!depsOk) continue;\n109\t\n110\t    // Check condition if present\n111\t    if (task.condition) {\n112\t      try {\n113\t        const condOk = evaluateCondition(task.condition, outputs);\n114\t        if (!condOk) {\n115\t          // Condition not met — skip this task\n116\t          continue;\n117\t        }\n118\t      } catch {\n119\t        continue;\n120\t      }\n121\t    }\n122\t\n123\t    ready.push(task);\n124\t  }\n125\t\n126\t  return ready;\n127\t}\n128\t"}]},"parent_tool_use_id":"call_uxqb06RglxS9Y92kx5H5jMqM","session_id":"08b44427-7432-4e2d-a9c3-d9296f1761a5","uuid":"a5e89d49-6e67-4af9-aa42-560adae1997e","timestamp":"2026-07-16T04:44:38.279Z","subagent_type":"Explore","task_description":"Design lowest rung partition fix"}
