{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_6IkdL28YDe0BE1S3sgjm9UgV","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * run-yaml.mjs — the GENERIC scenario runner.\n4\t *\n5\t * Plays a declarative `scenario.yaml` (persona · promise · invariants · steps) against a LOCAL\n6\t * `lmthing serve`, driving the pod through the harness exactly as the /chat SPA would, and writes\n7\t * per-step EVIDENCE (the execution trace + the real spaces/DB/app state after each step) for the\n8\t * JUDGE to read. It does NOT judge — the judge (see automation/instances/scenario-campaign/judge.md)\n9\t * reads this output, decides pass/fail per step, and fixes at the right rung.\n10\t *\n11\t * Local only: SCENARIO_TARGET defaults to 'local' here (getUser → http://localhost:8080, no auth).\n12\t *\n13\t *   node scenarios/run-yaml.mjs 06-tanzania                 # play the whole scenario, fresh project\n14\t *   node scenarios/run-yaml.mjs 06-tanzania --through 5     # play steps 1..5 (the judge's verify rerun)\n15\t *   node scenarios/run-yaml.mjs 06-tanzania --out <dir>     # where to write evidence (default <sc>/.run)\n16\t *\n17\t * Step verbs (see scenario-spec.md): attach[] · say · then_say · open_app · in_app_chat ·\n18\t * fresh_session · restart_pod · if_asked{} · expect[] (expect is passed through, never executed).\n19\t */\n20\timport { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync } from 'node:fs';\n21\timport { join, resolve, dirname, basename } from 'node:path';\n22\timport { fileURLToPath } from 'node:url';\n23\timport { parseYaml } from './lib/yaml.mjs';\n24\timport { getUser } from './harness/provision.mjs';\n25\timport { Pod } from './harness/lib/pod.mjs';\n26\timport { ThingSession, approveAllConsent, denyAllConsent } from './harness/lib/thing.mjs';\n27\timport { restartLocalServer, freshLocalServer, serverUp } from './harness/lib/local.mjs';\n28\t\n29\tprocess.env.SCENARIO_TARGET ??= 'local'; // this runner is local-only by design\n30\t\n31\tconst HERE = dirname(fileURLToPath(import.meta.url));\n32\tconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n33\t\n34\t// ── args ─────────────────────────────────────────────────────────────────────\n35\tconst argv = process.argv.slice(2);\n36\tconst flag = (name, def) => {\n37\t  const i = argv.indexOf(name);\n38\t  return i >= 0 && argv[i + 1] ? argv[i + 1] : def;\n39\t};\n40\tconst idOrPath = argv.find((a) => !a.startsWith('--')) ?? '06-tanzania';\n41\tconst verbose = argv.includes('--verbose');\n42\tconst keepProject = argv.includes('--keep-project');\n43\tconst planOnly = argv.includes('--plan'); // parse + print the plan, never connect to a pod\n44\tconst freshServer = argv.includes('--fresh-server'); // WIPE the pod data dir (0 projects) + start clean first\n45\t\n46\t// Resolve scenario dir + yaml.\n47\tconst scenarioDir = idOrPath.endsWith('.yaml')\n48\t  ? dirname(resolve(idOrPath))\n49\t  : resolve(HERE, idOrPath);\n50\tconst yamlPath = idOrPath.endsWith('.yaml') ? resolve(idOrPath) : join(scenarioDir, 'scenario.yaml');\n51\tif (!existsSync(yamlPath)) fail(`no scenario.yaml at ${yamlPath}`);\n52\tconst fixturesDir = join(scenarioDir, 'fixtures');\n53\t\n54\tconst scenario = parseYaml(readFileSync(yamlPath, 'utf8'));\n55\tconst steps = scenario.steps ?? [];\n56\tconst through = Number(flag('--through', String(steps.length)));\n57\tconst outDir = resolve(flag('--out', join(scenarioDir, '.run')));\n58\t// A fresh server means an empty runtime root, so the stable scenario project id is collision-free\n59\t// and keeps evidence readable. Without --fresh-server (dev re-runs on a dirty root) a unique suffix\n60\t// avoids clobbering an existing project.\n61\tconst projectId = flag('--project', freshServer ? (scenario.project ?? scenario.id) : `${scenario.project ?? scenario.id}-${Date.now().toString(36)}`);\n62\t\n63\tmkdirSync(outDir, { recursive: true });\n64\tconst traceMd = [];\n65\tfunction log(...a) {\n66\t  if (verbose) console.log('[run-yaml]', ...a);\n67\t}\n68\tfunction fail(msg) {\n69\t  console.error(`run-yaml: ${msg}`);\n70\t  process.exit(1);\n71\t}\n72\tfunction readdirSyncSafe(dir) {\n73\t  try {\n74\t    return readdirSync(dir);\n75\t  } catch {\n76\t    return [];\n77\t  }\n78\t}\n79\t\n80\t// ── ask handling: the driver answers in-persona; the JUDGE later scores the ask ────────────────\n81\t// A step's `if_asked` map + the scenario `knows` list ground the load-bearing answers. Consent is\n82\t// approved by default (a step may set `deny_consent: true`). Every ask + how it was answered is\n83\t// recorded so the judge can score whether asking was correct (and whether the answer was right).\n84\tlet currentStep = {};\n85\tconst asksThisStep = [];\n86\tfunction onAsk(descriptor) {\n87\t  const text = JSON.stringify(descriptor ?? {});\n88\t  // Consent cards: approve unless the step opts into denial.\n89\t  if (descriptor?.type === 'ConsentCard') {\n90\t    const answer = currentStep.deny_consent ? false : true;\n91\t    asksThisStep.push({ kind: 'consent', answer, descriptor });\n92\t    return answer;\n93\t  }\n94\t  // Clarifying question / form: match the step's if_asked, else best-effort from its single entry.\n95\t  const ifAsked = currentStep.if_asked ?? {};\n96\t  const keys = Object.keys(ifAsked);\n97\t  let matched =\n98\t    keys.find((k) => text.toLowerCase().includes(k.toLowerCase().slice(0, 24))) ??\n99\t    (keys.length === 1 ? keys[0] : undefined);\n100\t  const answer = matched ? ifAsked[matched] : '';\n101\t  asksThisStep.push({ kind: 'question', matched: matched ?? null, answer, descriptor });\n102\t  // Return the string answer; unmatched → '' (recorded prominently so the judge sees an unhandled ask).\n103\t  return answer;\n104\t}\n105\t\n106\t// ── state capture: what the judge verifies token-in-state against ──────────────────────────────\n107\tasync function snapshot(pod) {\n108\t  const snap = { spaces: [], appTables: {}, appManifest: null, error: null };\n109\t  try {\n110\t    const sp = await pod.listSpaces(projectId).catch(() => null);\n111\t    snap.spaces = (sp?.spaces ?? sp ?? []).map((s) => s.slug ?? s.name ?? s.id ?? s);\n112\t  } catch (e) {\n113\t    snap.error = String(e?.message ?? e);\n114\t  }\n115\t  try {\n116\t    const man = await pod.appManifest(projectId).catch(() => null);\n117\t    if (man) {\n118\t      snap.appManifest = { tables: man.tables ?? man.database ?? [], pages: man.pages ?? [], built: man.build?.built ?? null };\n119\t      const tableNames = (snap.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean);\n120\t      for (const t of tableNames) {\n121\t        const rows = await pod.appData(projectId, t).catch(() => null);\n122\t        if (rows) snap.appTables[t] = rows.rows ?? rows.data ?? rows;\n123\t      }\n124\t    }\n125\t  } catch (e) {\n126\t    snap.appError = String(e?.message ?? e);\n127\t  }\n128\t  return snap;\n129\t}\n130\t\n131\t// ── dry plan: parse + print the step plan, never touch a pod ───────────────────────────────────\n132\tif (planOnly) {\n133\t  console.log(`scenario ${scenario.id} — \"${scenario.title}\"  (project ${scenario.project})`);\n134\t  console.log(`persona: ${String(scenario.persona).slice(0, 90)}…`);\n135\t  console.log(`invariants: ${scenario.invariants?.length}  ·  knows: ${scenario.knows?.length}  ·  steps: ${steps.length}\\n`);\n136\t  const allFixtures = new Set();\n137\t  steps.forEach((s, i) => {\n138\t    const verbs = Object.keys(s).filter((k) => k !== 'expect');\n139\t    (s.attach ?? []).forEach((f) => allFixtures.add(f));\n140\t    const msg = (s.say ?? s.then_say ?? s.in_app_chat ?? '').toString().replace(/\\n/g, ' ').slice(0, 64);\n141\t    console.log(`  ${String(i + 1).padStart(2)}. [${verbs.join(', ')}]  ${msg}${msg.length >= 64 ? '…' : ''}`);\n142\t    if (s.attach) console.log(`       attach: ${s.attach.join(', ')}`);\n143\t    console.log(`       expect: ${s.expect?.length ?? 0}${s.if_asked ? '  if_asked: ' + Object.keys(s.if_asked).length : ''}`);\n144\t  });\n145\t  // Fixture coverage: does every file in fixtures/ get used, and does every attach exist?\n146\t  const used = [...allFixtures];\n147\t  console.log(`\\nfixtures attached across the scenario (${used.length}): ${used.join(', ')}`);\n148\t  const missing = used.filter((f) => !existsSync(join(fixturesDir, f)));\n149\t  if (missing.length) console.log(`⚠️  attached but NOT on disk: ${missing.join(', ')}`);\n150\t  try {\n151\t    const onDisk = readdirSyncSafe(fixturesDir).filter((f) => !/^(links\\.md|.*\\.txt)$/.test(f));\n152\t    const unused = onDisk.filter((f) => !allFixtures.has(f));\n153\t    if (unused.length) console.log(`⚠️  on disk but NEVER attached: ${unused.join(', ')}`);\n154\t    else console.log(`✅ every uploadable fixture on disk is attached by some step`);\n155\t  } catch { /* fixtures dir may be absent */ }\n156\t  process.exit(0);\n157\t}\n158\t\n159\t// ── main ─────────────────────────────────────────────────────────────────────────────────────\n160\t(async () => {\n161\t  log(`scenario ${scenario.id} · project ${projectId} · steps 1..${through}/${steps.length}`);\n162\t  if (freshServer) {\n163\t    log('--fresh-server: wiping the pod data dir (0 projects) and starting clean…');\n164\t    await freshLocalServer();\n165\t  }\n166\t  if (!(await serverUp())) fail('local server not up — run: node harness/local-server.mjs up (or pass --fresh-server)');\n167\t\n168\t  const user = await getUser(scenario.id);\n169\t  const pod = new Pod({ base: user.pod, token: user.token });\n170\t  // Fresh project (unique id per run unless --project pins one).\n171\t  try {\n172\t    await pod.createProject(projectId);\n173\t  } catch (e) {\n174\t    log(`createProject(${projectId}) — ${String(e?.message ?? e)} (continuing; may already exist)`);\n175\t  }\n176\t\n177\t  let thing = new ThingSession(pod, { projectId, onAsk, verbose });\n178\t  await thing.start();\n179\t\n180\t  const results = [];\n181\t  for (let n = 0; n < Math.min(through, steps.length); n++) {\n182\t    const step = steps[n];\n183\t    currentStep = step;\n184\t    asksThisStep.length = 0;\n185\t    const num = n + 1;\n186\t    const rec = { step: num, verbs: Object.keys(step).filter((k) => k !== 'expect'), expect: step.expect ?? [], turns: [], asks: [], notes: [] };\n187\t    log(`── step ${num}: ${rec.verbs.join(', ')}`);\n188\t\n189\t    try {\n190\t      if (step.fresh_session) {\n191\t        thing = new ThingSession(pod, { projectId, onAsk, verbose });\n192\t        await thing.start();\n193\t        await thing.syncToTail();\n194\t        rec.notes.push('started a fresh session (zero history)');\n195\t      }\n196\t      if (step.restart_pod) {\n197\t        rec.notes.push('restarting local server…');\n198\t        await restartLocalServer();\n199\t        for (let i = 0; i < 40 && !(await serverUp()); i++) await sleep(500);\n200\t        rec.notes.push((await serverUp()) ? 'server back up' : 'server did NOT come back up');\n201\t      }\n202\t\n203\t      // The message(s) for this step, with attachments if any.\n204\t      if (step.say != null) {\n205\t        let turn;\n206\t        if (Array.isArray(step.attach) && step.attach.length) {\n207\t          const refs = [];\n208\t          for (const f of step.attach) {\n209\t            const p = join(fixturesDir, f);\n210\t            if (!existsSync(p)) {\n211\t              rec.notes.push(`MISSING FIXTURE: ${f}`);\n212\t              continue;\n213\t            }\n214\t            refs.push(await pod.upload(p));\n215\t          }\n216\t          rec.attached = step.attach;\n217\t          turn = await thing.sendWithAttachments(step.say, refs);\n218\t        } else {\n219\t          turn = await thing.send(step.say);\n220\t        }\n221\t        rec.turns.push(summarizeTurn(turn, step.say));\n222\t      }\n223\t      if (step.then_say != null) {\n224\t        const t = await thing.send(step.then_say);\n225\t        rec.turns.push(summarizeTurn(t, step.then_say));\n226\t      }\n227\t      if (step.in_app_chat != null) {\n228\t        // The in-app chat is a project-scoped THING session with authoring caps — same project.\n229\t        const t = await thing.send(step.in_app_chat);\n230\t        rec.turns.push(summarizeTurn(t, `[in-app] ${step.in_app_chat}`));\n231\t      }\n232\t      if (step.open_app) {\n233\t        const build = await pod.appBuild(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n234\t        rec.appBuild = { built: build?.built ?? build?.build?.built ?? null, routes: build?.routes ?? null, error: build?.error ?? null };\n235\t        const page = await pod.appPage(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n236\t        rec.appPageStatus = page?.status ?? (page?.error ? `error: ${page.error}` : 'ok');\n237\t        rec.notes.push('opened app (built + fetched root page; browser render is the judge\\'s job)');\n238\t      }\n239\t    } catch (e) {\n240\t      rec.error = String(e?.stack ?? e?.message ?? e);"}]},"parent_tool_use_id":null,"session_id":"2142c1ae-f65f-4763-943d-8eaf39a5f62b","uuid":"90cf6ae3-1253-4a13-aa48-ee0560055a7a","timestamp":"2026-07-15T18:22:08.988Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/run-yaml.mjs","content":"#!/usr/bin/env node\n/**\n * run-yaml.mjs — the GENERIC scenario runner.\n *\n * Plays a declarative `scenario.yaml` (persona · promise · invariants · steps) against a LOCAL\n * `lmthing serve`, driving the pod through the harness exactly as the /chat SPA would, and writes\n * per-step EVIDENCE (the execution trace + the real spaces/DB/app state after each step) for the\n * JUDGE to read. It does NOT judge — the judge (see automation/instances/scenario-campaign/judge.md)\n * reads this output, decides pass/fail per step, and fixes at the right rung.\n *\n * Local only: SCENARIO_TARGET defaults to 'local' here (getUser → http://localhost:8080, no auth).\n *\n *   node scenarios/run-yaml.mjs 06-tanzania                 # play the whole scenario, fresh project\n *   node scenarios/run-yaml.mjs 06-tanzania --through 5     # play steps 1..5 (the judge's verify rerun)\n *   node scenarios/run-yaml.mjs 06-tanzania --out <dir>     # where to write evidence (default <sc>/.run)\n *\n * Step verbs (see scenario-spec.md): attach[] · say · then_say · open_app · in_app_chat ·\n * fresh_session · restart_pod · if_asked{} · expect[] (expect is passed through, never executed).\n */\nimport { readFileSync, writeFileSync, mkdirSync, existsSync, readdirSync } from 'node:fs';\nimport { join, resolve, dirname, basename } from 'node:path';\nimport { fileURLToPath } from 'node:url';\nimport { parseYaml } from './lib/yaml.mjs';\nimport { getUser } from './harness/provision.mjs';\nimport { Pod } from './harness/lib/pod.mjs';\nimport { ThingSession, approveAllConsent, denyAllConsent } from './harness/lib/thing.mjs';\nimport { restartLocalServer, freshLocalServer, serverUp } from './harness/lib/local.mjs';\n\nprocess.env.SCENARIO_TARGET ??= 'local'; // this runner is local-only by design\n\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n\n// ── args ─────────────────────────────────────────────────────────────────────\nconst argv = process.argv.slice(2);\nconst flag = (name, def) => {\n  const i = argv.indexOf(name);\n  return i >= 0 && argv[i + 1] ? argv[i + 1] : def;\n};\nconst idOrPath = argv.find((a) => !a.startsWith('--')) ?? '06-tanzania';\nconst verbose = argv.includes('--verbose');\nconst keepProject = argv.includes('--keep-project');\nconst planOnly = argv.includes('--plan'); // parse + print the plan, never connect to a pod\nconst freshServer = argv.includes('--fresh-server'); // WIPE the pod data dir (0 projects) + start clean first\n\n// Resolve scenario dir + yaml.\nconst scenarioDir = idOrPath.endsWith('.yaml')\n  ? dirname(resolve(idOrPath))\n  : resolve(HERE, idOrPath);\nconst yamlPath = idOrPath.endsWith('.yaml') ? resolve(idOrPath) : join(scenarioDir, 'scenario.yaml');\nif (!existsSync(yamlPath)) fail(`no scenario.yaml at ${yamlPath}`);\nconst fixturesDir = join(scenarioDir, 'fixtures');\n\nconst scenario = parseYaml(readFileSync(yamlPath, 'utf8'));\nconst steps = scenario.steps ?? [];\nconst through = Number(flag('--through', String(steps.length)));\nconst outDir = resolve(flag('--out', join(scenarioDir, '.run')));\n// A fresh server means an empty runtime root, so the stable scenario project id is collision-free\n// and keeps evidence readable. Without --fresh-server (dev re-runs on a dirty root) a unique suffix\n// avoids clobbering an existing project.\nconst projectId = flag('--project', freshServer ? (scenario.project ?? scenario.id) : `${scenario.project ?? scenario.id}-${Date.now().toString(36)}`);\n\nmkdirSync(outDir, { recursive: true });\nconst traceMd = [];\nfunction log(...a) {\n  if (verbose) console.log('[run-yaml]', ...a);\n}\nfunction fail(msg) {\n  console.error(`run-yaml: ${msg}`);\n  process.exit(1);\n}\nfunction readdirSyncSafe(dir) {\n  try {\n    return readdirSync(dir);\n  } catch {\n    return [];\n  }\n}\n\n// ── ask handling: the driver answers in-persona; the JUDGE later scores the ask ────────────────\n// A step's `if_asked` map + the scenario `knows` list ground the load-bearing answers. Consent is\n// approved by default (a step may set `deny_consent: true`). Every ask + how it was answered is\n// recorded so the judge can score whether asking was correct (and whether the answer was right).\nlet currentStep = {};\nconst asksThisStep = [];\nfunction onAsk(descriptor) {\n  const text = JSON.stringify(descriptor ?? {});\n  // Consent cards: approve unless the step opts into denial.\n  if (descriptor?.type === 'ConsentCard') {\n    const answer = currentStep.deny_consent ? false : true;\n    asksThisStep.push({ kind: 'consent', answer, descriptor });\n    return answer;\n  }\n  // Clarifying question / form: match the step's if_asked, else best-effort from its single entry.\n  const ifAsked = currentStep.if_asked ?? {};\n  const keys = Object.keys(ifAsked);\n  let matched =\n    keys.find((k) => text.toLowerCase().includes(k.toLowerCase().slice(0, 24))) ??\n    (keys.length === 1 ? keys[0] : undefined);\n  const answer = matched ? ifAsked[matched] : '';\n  asksThisStep.push({ kind: 'question', matched: matched ?? null, answer, descriptor });\n  // Return the string answer; unmatched → '' (recorded prominently so the judge sees an unhandled ask).\n  return answer;\n}\n\n// ── state capture: what the judge verifies token-in-state against ──────────────────────────────\nasync function snapshot(pod) {\n  const snap = { spaces: [], appTables: {}, appManifest: null, error: null };\n  try {\n    const sp = await pod.listSpaces(projectId).catch(() => null);\n    snap.spaces = (sp?.spaces ?? sp ?? []).map((s) => s.slug ?? s.name ?? s.id ?? s);\n  } catch (e) {\n    snap.error = String(e?.message ?? e);\n  }\n  try {\n    const man = await pod.appManifest(projectId).catch(() => null);\n    if (man) {\n      snap.appManifest = { tables: man.tables ?? man.database ?? [], pages: man.pages ?? [], built: man.build?.built ?? null };\n      const tableNames = (snap.appManifest.tables ?? []).map((t) => t.name ?? t.slug ?? t).filter(Boolean);\n      for (const t of tableNames) {\n        const rows = await pod.appData(projectId, t).catch(() => null);\n        if (rows) snap.appTables[t] = rows.rows ?? rows.data ?? rows;\n      }\n    }\n  } catch (e) {\n    snap.appError = String(e?.message ?? e);\n  }\n  return snap;\n}\n\n// ── dry plan: parse + print the step plan, never touch a pod ───────────────────────────────────\nif (planOnly) {\n  console.log(`scenario ${scenario.id} — \"${scenario.title}\"  (project ${scenario.project})`);\n  console.log(`persona: ${String(scenario.persona).slice(0, 90)}…`);\n  console.log(`invariants: ${scenario.invariants?.length}  ·  knows: ${scenario.knows?.length}  ·  steps: ${steps.length}\\n`);\n  const allFixtures = new Set();\n  steps.forEach((s, i) => {\n    const verbs = Object.keys(s).filter((k) => k !== 'expect');\n    (s.attach ?? []).forEach((f) => allFixtures.add(f));\n    const msg = (s.say ?? s.then_say ?? s.in_app_chat ?? '').toString().replace(/\\n/g, ' ').slice(0, 64);\n    console.log(`  ${String(i + 1).padStart(2)}. [${verbs.join(', ')}]  ${msg}${msg.length >= 64 ? '…' : ''}`);\n    if (s.attach) console.log(`       attach: ${s.attach.join(', ')}`);\n    console.log(`       expect: ${s.expect?.length ?? 0}${s.if_asked ? '  if_asked: ' + Object.keys(s.if_asked).length : ''}`);\n  });\n  // Fixture coverage: does every file in fixtures/ get used, and does every attach exist?\n  const used = [...allFixtures];\n  console.log(`\\nfixtures attached across the scenario (${used.length}): ${used.join(', ')}`);\n  const missing = used.filter((f) => !existsSync(join(fixturesDir, f)));\n  if (missing.length) console.log(`⚠️  attached but NOT on disk: ${missing.join(', ')}`);\n  try {\n    const onDisk = readdirSyncSafe(fixturesDir).filter((f) => !/^(links\\.md|.*\\.txt)$/.test(f));\n    const unused = onDisk.filter((f) => !allFixtures.has(f));\n    if (unused.length) console.log(`⚠️  on disk but NEVER attached: ${unused.join(', ')}`);\n    else console.log(`✅ every uploadable fixture on disk is attached by some step`);\n  } catch { /* fixtures dir may be absent */ }\n  process.exit(0);\n}\n\n// ── main ─────────────────────────────────────────────────────────────────────────────────────\n(async () => {\n  log(`scenario ${scenario.id} · project ${projectId} · steps 1..${through}/${steps.length}`);\n  if (freshServer) {\n    log('--fresh-server: wiping the pod data dir (0 projects) and starting clean…');\n    await freshLocalServer();\n  }\n  if (!(await serverUp())) fail('local server not up — run: node harness/local-server.mjs up (or pass --fresh-server)');\n\n  const user = await getUser(scenario.id);\n  const pod = new Pod({ base: user.pod, token: user.token });\n  // Fresh project (unique id per run unless --project pins one).\n  try {\n    await pod.createProject(projectId);\n  } catch (e) {\n    log(`createProject(${projectId}) — ${String(e?.message ?? e)} (continuing; may already exist)`);\n  }\n\n  let thing = new ThingSession(pod, { projectId, onAsk, verbose });\n  await thing.start();\n\n  const results = [];\n  for (let n = 0; n < Math.min(through, steps.length); n++) {\n    const step = steps[n];\n    currentStep = step;\n    asksThisStep.length = 0;\n    const num = n + 1;\n    const rec = { step: num, verbs: Object.keys(step).filter((k) => k !== 'expect'), expect: step.expect ?? [], turns: [], asks: [], notes: [] };\n    log(`── step ${num}: ${rec.verbs.join(', ')}`);\n\n    try {\n      if (step.fresh_session) {\n        thing = new ThingSession(pod, { projectId, onAsk, verbose });\n        await thing.start();\n        await thing.syncToTail();\n        rec.notes.push('started a fresh session (zero history)');\n      }\n      if (step.restart_pod) {\n        rec.notes.push('restarting local server…');\n        await restartLocalServer();\n        for (let i = 0; i < 40 && !(await serverUp()); i++) await sleep(500);\n        rec.notes.push((await serverUp()) ? 'server back up' : 'server did NOT come back up');\n      }\n\n      // The message(s) for this step, with attachments if any.\n      if (step.say != null) {\n        let turn;\n        if (Array.isArray(step.attach) && step.attach.length) {\n          const refs = [];\n          for (const f of step.attach) {\n            const p = join(fixturesDir, f);\n            if (!existsSync(p)) {\n              rec.notes.push(`MISSING FIXTURE: ${f}`);\n              continue;\n            }\n            refs.push(await pod.upload(p));\n          }\n          rec.attached = step.attach;\n          turn = await thing.sendWithAttachments(step.say, refs);\n        } else {\n          turn = await thing.send(step.say);\n        }\n        rec.turns.push(summarizeTurn(turn, step.say));\n      }\n      if (step.then_say != null) {\n        const t = await thing.send(step.then_say);\n        rec.turns.push(summarizeTurn(t, step.then_say));\n      }\n      if (step.in_app_chat != null) {\n        // The in-app chat is a project-scoped THING session with authoring caps — same project.\n        const t = await thing.send(step.in_app_chat);\n        rec.turns.push(summarizeTurn(t, `[in-app] ${step.in_app_chat}`));\n      }\n      if (step.open_app) {\n        const build = await pod.appBuild(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n        rec.appBuild = { built: build?.built ?? build?.build?.built ?? null, routes: build?.routes ?? null, error: build?.error ?? null };\n        const page = await pod.appPage(projectId).catch((e) => ({ error: String(e?.message ?? e) }));\n        rec.appPageStatus = page?.status ?? (page?.error ? `error: ${page.error}` : 'ok');\n        rec.notes.push('opened app (built + fetched root page; browser render is the judge\\'s job)');\n      }\n    } catch (e) {\n      rec.error = String(e?.stack ?? e?.message ?? e);","numLines":240,"startLine":1,"totalLines":314}}}
