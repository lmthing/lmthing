Key,\n  agentSlug: register.agentSlug,\n  actionId: design.actionId,\n  query: topic,\n  ok,\n  errors: ok ? \"\" : (validate.ok ? (register.error || \"registration failed\") : validate.errors),\n});\n","numLines":28,"startLine":1,"totalLines":28}}}
