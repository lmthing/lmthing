: undefined });\n34\t  });\n35\t  it('denies a target not in the allowlist', () => {\n36\t    expect(resolveTaskDelegate(['sp/ag#x'], 'other', 'ag')).toBeNull();\n37\t    expect(resolveTaskDelegate(['sp/ag#x'], 'sp', 'nope')).toBeNull();\n38\t  });\n39\t});\n40\t\n41\tdescribe('delegate inside a task (canDelegateTo)', () => {\n42\t  it('routes an allowed delegate through the engine delegateRunner and returns its result', async () => {\n43\t    const dir = await makeTasklistSpace({\n44\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nCALL_T: delegate then resolve.`,\n45\t    });\n46\t    const space = await loadSpace(dir);\n47\t    const calls: Array<{ pkg: string; agent: string; action?: string; allowed?: string[] }> = [];\n48\t    // Turn 1: emit the delegate binding (it yields). Turn 2 (after `r` is bound from the resolved\n49\t    // delegate): emit the resolve. (A single mock that re-emits both each turn would re-delegate.)\n50\t    let turn = 0;\n51\t    const streamFn = createMockStreamFn(() => {\n52\t      turn++;\n53\t      if (turn === 1) return `const r = await delegate('helper', 'agent', 'act', { query: 'hi' });`;\n54\t      return `currentTask.resolve({ v: r.n });`;\n55\t    });\n56\t    const engine = new ForkEngine({\n57\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n58\t      renderHost: silentHost, streamFn,\n59\t      delegateRunner: async (pkg, agent, action, _opts, allowed) => {\n60\t        calls.push({ pkg, agent, action, allowed });\n61\t        return { n: 42 };\n62\t      },\n63\t    });\n64\t    const goal = (await runTasklist({ name: 'flow', space, forkEngine: engine })).data as { v: number };\n65\t    expect(goal).toEqual({ v: 42 });\n66\t    expect(calls).toEqual([{ pkg: 'helper', agent: 'agent', action: 'act', allowed: ['act'] }]);\n67\t  });\n68\t\n69\t  it('blocks a delegate to a non-allowlisted target (runner never called; fork salvages)', async () => {\n70\t    const dir = await makeTasklistSpace({\n71\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - helper/agent#act\\noutput:\\n  v: number\\n---\\n\\nBAD_T: delegate to a forbidden target.`,\n72\t    });\n73\t    const space = await loadSpace(dir);\n74\t    let runnerCalls = 0;\n75\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n76\t      const u = o.messages.map((m) => m.content).join('\\n');\n77\t      // 'evil/agent' is NOT in canDelegateTo → the delegate yield throws, fork never resolves → salvage.\n78\t      if (u.includes('BAD_T')) return `const r = await delegate('evil', 'agent', 'act', { query: 'x' }) as { n: number };\\ncurrentTask.resolve({ v: r.n });`;\n79\t      return '';\n80\t    });\n81\t    const engine = new ForkEngine({\n82\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n83\t      renderHost: silentHost, streamFn,\n84\t      delegateRunner: async () => { runnerCalls++; return { n: 1 }; },\n85\t    });\n86\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n87\t    expect(runnerCalls).toBe(0);            // forbidden target never reached the runner\n88\t    expect(env.data).toEqual({ v: 0 });     // fork salvaged a NEUTRAL schema-valid placeholder\n89\t    expect(env.ok).toBe(false);             // …and the envelope signals the degradation\n90\t    expect(env.degraded).toBe(true);\n91\t  });\n92\t\n93\t  it('canDelegateTo: [\"*\"] gives the task an UNSCOPED delegate (any target routes to the runner)', async () => {\n94\t    const dir = await makeTasklistSpace({\n95\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"*\"\\noutput:\\n  v: number\\n---\\n\\nSTAR_T: delegate anywhere then resolve.`,\n96\t    });\n97\t    const space = await loadSpace(dir);\n98\t    const calls: Array<{ pkg: string; agent: string; allowed?: string[] }> = [];\n99\t    let turn = 0;\n100\t    const streamFn = createMockStreamFn(() => {\n101\t      turn++;\n102\t      if (turn === 1) return `const r = await delegate('any-space-at-all', 'whoever', 'act', { query: 'hi' });`;\n103\t      return `currentTask.resolve({ v: r.n });`;\n104\t    });\n105\t    const engine = new ForkEngine({\n106\t      maxConcurrentForks: 2, parentHistory: [], parentSpaceDir: dir, parentAgentSlug: 'main',\n107\t      renderHost: silentHost, streamFn,\n108\t      delegateRunner: async (pkg, agent, _action, _opts, allowed) => {\n109\t        calls.push({ pkg, agent, allowed });\n110\t        return { n: 7 };\n111\t      },\n112\t    });\n113\t    const env = await runTasklist({ name: 'flow', space, forkEngine: engine });\n114\t    expect(env.ok).toBe(true);\n115\t    expect(env.data).toEqual({ v: 7 });\n116\t    // Unrestricted: no target gate, no action narrowing.\n117\t    expect(calls).toEqual([{ pkg: 'any-space-at-all', agent: 'whoever', allowed: undefined }]);\n118\t  });\n119\t\n120\t  it('canDelegateTo: [\"registered:*\"] admits a dynamicSpaces-registered target and blocks others', async () => {\n121\t    const dir = await makeTasklistSpace({\n122\t      '01-call.md': `---\\nid: call\\ngoal: true\\nrole: general\\ncanDelegateTo:\\n  - \"registered:*\"\\noutput:\\n  v: number\\n---\\n\\nREG_T: delegate to the registered space.`,\n123\t    });\n124\t    const space = await loadSpace(dir);\n125\t    const regDir = '/dyn/built-space';\n126\t    const dynamicSpaces = new Map([[regDir, space]]); // any Space value; the gate matches keys/dirs\n127\t    const calls: string[] = [];\n128\t    let turn = 0;\n129\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n130\t      turn++;\n131\t      // Turn 1: an UNREGISTERED target — the gate throws (retryable error).\n132\t      if (turn === 1) return `const r = await delegate('never-registered', 'agent', 'act', { query: 'x' });`;\n133\t      // Turn 2 (retry with the ERROR block)