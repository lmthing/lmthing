{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_P78RLt5XHXWelhqbdmXqmEVF","type":"tool_result","content":"1\timport { useApi, useApiMutation, Link } from '@app/runtime';\n2\timport LegCard from '../components/LegCard';\n3\timport StatTile from '../components/StatTile';\n4\timport Badge from '../components/Badge';\n5\timport CostRow from '../components/CostRow';\n6\timport ActionItemCheckbox from '../components/ActionItemCheckbox';\n7\timport PageSection from '../components/PageSection';\n8\timport EmptyState from '../components/EmptyState';\n9\t\n10\ttype Leg = { id: string; slug: string; leg_number: number; title: string; location: string; lodging?: string; start_date: string; end_date: string; notes?: string; cost_summary?: string };\n11\ttype CostSummary = { total_usd: number; total_tzs: number; pending_balance_usd?: number; pending_balance_tzs?: number; paid_count: number; pending_count: number; estimated_count: number };\n12\ttype FlaggedItem = { id: string; label: string; amount: number; currency: string; status: string; flagged: boolean; leg_label?: string };\n13\ttype ActionItem = { id: string; label: string; status: string; sort_order: number };\n14\t\n15\texport default function DashboardPage() {\n16\t  const { data: legs, isLoading: legsLoading } = useApi<{ items: Leg[] }>('itinerary-legs-next');\n17\t  const { data: summary, isLoading: summaryLoading } = useApi<CostSummary>('cost-summary');\n18\t  const { data: flagged, isLoading: flaggedLoading } = useApi<{ items: FlaggedItem[] }>('cost-line-items-flagged');\n19\t  const { data: actions, isLoading: actionsLoading } = useApi<{ items: ActionItem[] }>('action-items-list');\n20\t  const toggleMutation = useApiMutation('action-item');\n21\t\n22\t  const isLoading = legsLoading || summaryLoading || flaggedLoading || actionsLoading;\n23\t  if (isLoading) return <p className=\"p-4 text-muted\">Loading dashboard…</p>;\n24\t\n25\t  const upcomingLegs = legs?.items ?? [];\n26\t  const flaggedCount = flagged?.items?.length ?? 0;\n27\t  const openActionCount = (actions?.items ?? []).filter(a => a.status === 'open').length;\n28\t\n29\t  const daysUntilTrip = (() => {\n30\t    if (!upcomingLegs.length) return '—';\n31\t    const first = new Date(upcomingLegs[0].start_date);\n32\t    const now = new Date();\n33\t    const diff = Math.ceil((first.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));\n34\t    return diff > 0 ? String(diff) : 'Today!';\n35\t  })();\n36\t\n37\t  return (\n38\t    <main className=\"max-w-4xl mx-auto space-y-6 p-4\">\n39\t      {/* Hero header */}\n40\t      <header className=\"space-y-2\">\n41\t        <h1 className=\"text-2xl font-bold text-foreground\">Tanzania 2026</h1>\n42\t        <p className=\"text-muted\">Vasilis &amp; Athina Mari — Cairo · Arusha · Ngorongoro · Zanzibar</p>\n43\t      </header>\n44\t\n45\t      {/* Stat tiles row */}\n46\t      <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n47\t        <StatTile icon=\"dollarSign\" value={summary ? `$${summary.total_usd.toLocaleString()}` : '—'} label=\"Total USD\" />\n48\t        <StatTile icon=\"banknote\" value={summary ? `TZS ${summary.total_tzs.toLocaleString()}` : '—'} label=\"Total TZS\" />\n49\t        <StatTile icon=\"calendar\" value={daysUntilTrip} label=\"Days until trip\" />\n50\t        <StatTile icon=\"users\" value=\"2\" label=\"Travelers\" />\n51\t      </div>\n52\t\n53\t      {/* Badge row: flagged costs + open actions */}\n54\t      <div className=\"flex flex-wrap gap-2\">\n55\t        {flaggedCount > 0 && (\n56\t          <Link href=\"/costs-tracker\" className=\"inline-flex items-center gap-1\">\n57\t            <Badge text={`${flaggedCount} flagged cost${flaggedCount !== 1 ? 's' : ''}`} variant=\"warning\" size=\"md\" />\n58\t          </Link>\n59\t        )}\n60\t        {openActionCount > 0 && (\n61\t          <Link href=\"/notes-memories\" className=\"inline-flex items-center gap-1\">\n62\t            <Badge text={`${openActionCount}