n33\timport { generateProjectContracts, type ProjectContracts } from '../app/build/contracts.js';\n34\timport { loadAllHooks } from '../app/hooks/index.js';\n35\timport { ProjectHookRuntime } from '../app/hooks/runtime.js';\n36\timport { scanEmitterDefs } from './emitter-manifests.js';\n37\timport { WebRenderHost } from '../rpc/server.js';\n38\timport { TraceHub } from '../rpc/trace-hub.js';\n39\timport {\n40\t  DEFAULT_PROJECT_ID,\n41\t  SYSTEM_PROJECT_ID,\n42\t  safeProjectId,\n43\t  slugify,\n44\t  scaffoldProject,\n45\t  readProjectMeta,\n46\t  listProjects,\n47\t  deleteProject,\n48\t  getInstructions,\n49\t  setInstructions,\n50\t  listDocuments,\n51\t  addDocument,\n52\t  listSystemSpaceDirs,\n53\t  listProjectSpaceDirs,\n54\t  ensureDefaultProject,\n55\t  safeDocumentName,\n56\t  sessionsDir,\n57\t  listProjectSessions,\n58\t  spaceSessionsDir,\n59\t  listSpaceSessions,\n60\t  projectSpaceDir,\n61\t  readSpaceFiles,\n62\t  writeSpaceFiles,\n63\t  writeProjectSpaceFile as writeSpaceFile,\n64\t  deleteProjectSpaceFile as deleteSpaceFile,\n65\t} from './projects.js';\n66\timport type { ProjectMeta, PersistedSessionMeta } from './projects.js';\n67\t\n68\texport type SessionStatus = 'idle' | 'running' | 'error';\n69\t\n70\t/** Lightweight descriptor for a space created under a project, surfaced in the\n71\t *  web UI. Derived from the space's package.json + agent instruct frontmatter. */\n72\texport interface SpaceMeta {\n73\t  /** Dir basename — the stable id within the project's spaces/ tree. */\n74\t  id: string;\n75\t  /** Display name: first agent's title, else package name, else id. */\n76\t  name: string;\n77\t  /** One-line description (first non-heading line of the first agent's instruct body). */\n78\t  description: string;\n79\t  agents: { slug: string; title: string; actions: { id: string; label: string }[] }[];\n80\t  functionCount: number;\n81\t  componentCount: number;\n82\t  hasKnowledge: boolean;\n83\t}\n84\t\n85\t/** One live multi-session entry