wn };\ntype EndpointPlan = { name?: unknown };\ntype ComponentPlan = { name?: unknown };\n\nexport async function run(ctx: { project: { writeProjectPage(route: string, src: string): Promise<{ ok: boolean }> } }, inputs: { item?: PagePlan; plan_endpoints?: { endpoints?: EndpointPlan[] }; plan_components?: { components?: ComponentPlan[] } }) {\n  const page = inputs.item ?? {};\n  const route = typeof page.route === 'string' ? page.route : '';\n  const pageEndpoints = Array.isArray(page.endpoints) ? page.endpoints : [];\n  const pageComponents = Array.isArray(page.components) ? page.components : [];\n  const endpoints = Array.isArray(inputs.plan_endpoints?.endpoints) ? inputs.plan_endpoints.endpoints : [];\n  const components = Array.isArray(inputs.plan_components?.components) ? inputs.plan_components.components : [];\n  const endpoint = typeof pageEndpoints[0] === 'string'\n    ? pageEndpoints[0]\n    : typeof endpoints[0]?.name === 'string'\n      ? endpoints[0].name\n      : 'items-list';\n  const component = typeof pageComponents[0] === 'string'\n    ? pageComponents[0]\n    : typeof components[0]?.name === 'string'\n      ? components[0].name\n      : '';\n  const up = '../'.repeat(route.split('/').length);\n  const src = [\n    \"import { useApi } from '@app/runtime';\",\n    ...(component ? [\"import \" + component + \" from '\" + up + 'components/' + component + \"';\"] : []),\n    '',\n    'export default function Page() {',\n    \"  const { data, isLoading, error } = useApi<{ items: { id: string; title?: string }[] }>('\" + endpoint + \"');\",\n    '  if (isLoading) return <p className=\"p-4 text-muted\">Loading…</p>;',\n    '  if (error) return <p className=\"p-4 text-destructive\">Could not load data.</p>;',\n    '  return (',\n    '    <main className=\"space-y-2 p-4\">',\n    '      {(data?.items ?? []).map((it) => (',\n    component\n      ? '        <' + component + ' key={it.id} title={it.title ?? it.id} />'\n      : '        <div key={it.id} classNam