ion mergePodEnv(token, vars) {\n  const current = await req('GET', '/api/compute/env', { token }).catch(() => ({ vars: {} }));\n  const existing = current.vars ?? {};\n  const merged = { ...existing, ...vars };","numLines":70,"startLine":45,"totalLines":209}}}
