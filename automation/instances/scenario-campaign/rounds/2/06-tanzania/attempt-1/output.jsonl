{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_GeQJoa4aI89ZN8FB2D3dmU9x","type":"tool_result","content":"1\t/**\n2\t * Budget guardrails for autonomous runs.\n3\t *\n4\t * A `Budget` is a host-side counter that caps how much work a turn loop (or a\n5\t * fork's turn loop) may do before it is forcibly stopped. It is set by the\n6\t * CALLER (session / fork engine) — never by the worker code running inside the\n7\t * VM — so a model cannot lift its own ceiling. Exceeding any limit throws a\n8\t * structured `BudgetExceededError`, which the caller turns into a clean stop and\n9\t * VM disposal.\n10\t *\n11\t * The limits are deliberately coarse and few: episodes (LLM turns), tool calls\n12\t * (yields), fork depth, and wall-clock. They are insurance against runaway cost\n13\t * in unattended sessions, not a fine-grained scheduler.\n14\t */\n15\t\n16\texport interface BudgetLimits {\n17\t  /** Max number of LLM turns (episodes) in a single turn-loop invocation. */\n18\t  maxEpisodes?: number;\n19\t  /** Max number of value-yielding calls (ask/fork/delegate/…) resolved. */\n20\t  maxToolCalls?: number;\n21\t  /** Max fork nesting depth. A top-level session fork is depth 1. */\n22\t  maxForkDepth?: number;\n23\t  /** Max wall-clock time for the run, in milliseconds. */\n24\t  maxWallClockMs?: number;\n25\t}\n26\t\n27\texport type BudgetKind = 'episodes' | 'toolCalls' | 'forkDepth' | 'wallClock';\n28\t\n29\texport class BudgetExceededError extends Error {\n30\t  constructor(\n31\t    public readonly kind: BudgetKind,\n32\t    public readonly limit: number,\n33\t    public readonly used: number,\n34\t  ) {\n35\t    super(`Budget exceeded: ${kind} limit of ${limit} (used ${used})`);\n36\t    this.name = 'BudgetExceededError';\n37\t  }\n38\t}\n39\t\n40\texport interface BudgetSnapshot {\n41\t  episodes: number;\n42\t  toolCalls: number;\n43\t  elapsedMs: number;\n44\t}\n45\t\n46\texport class Budget {\n47\t  private _episodes = 0;\n48\t  private _toolCalls = 0;\n49\t  private readonly startedAt: number;\n50\t\n51\t  constructor(\n52\t    private readonly limits: BudgetLimits = {},\n53\t    private readonly now: () => number = Date.now,\n54\t  ) {\n55\t    this.startedAt = now();\n56\t  }\n57\t\n58\t  get episodes(): number {\n59\t    return this._episodes;\n60\t  }\n61\t\n62\t  get toolCalls(): number {\n63\t    return this._toolCalls;\n64\t  }\n65\t\n66\t  elapsedMs(): number {\n67\t    return this.now() - this.startedAt;\n68\t  }\n69\t\n70\t  /** Count one LLM turn. Throws if over the episode (or wall-clock) limit. */\n71\t  tickEpisode(): void {\n72\t    this._episodes++;\n73\t    this.assertWallClock();\n74\t    if (this.limits.maxEpisodes !== undefined && this._episodes > this.limits.maxEpisodes) {\n75\t      throw new BudgetExceededError('episodes', this.limits.maxEpisodes, this._episodes);\n76\t    }\n77\t  }\n78\t\n79\t  /** Count resolved tool calls (yields). Throws if over the tool-call (or wall-clock) limit. */\n80\t  tickToolCalls(n = 1): void {\n81\t    this._toolCalls += n;\n82\t    this.assertWallClock();\n83\t    if (this.limits.maxToolCalls !== undefined && this._toolCalls > this.limits.maxToolCalls) {\n84\t      throw new BudgetExceededError('toolCalls', this.limits.maxToolCalls, this._toolCalls);\n85\t    }\n86\t  }\n87\t\n88\t  /** Assert a fork at the given depth is within the depth limit. */\n89\t  assertForkDepth(depth: number): void {\n90\t    if (this.limits.maxForkDepth !== undefined && depth > this.limits.maxForkDepth) {\n91\t      throw new BudgetExceededError('forkDepth', this.limits.maxForkDepth, depth);\n92\t    }\n93\t  }\n94\t\n95\t  /** Assert the run has not exceeded its wall-clock limit. */\n96\t  assertWallClock(): void {\n97\t    if (this.limits.maxWallClockMs !== undefined && this.elapsedMs() > this.limits.maxWallClockMs) {\n98\t      throw new BudgetExceededError('wallClock', this.limits.maxWallClockMs, this.elapsedMs());\n99\t    }\n100\t  }\n101\t\n102\t  /**\n103\t   * Returns a human-readable warning string when any limit is within 2 steps\n104\t   * (episodes/toolCalls) or 80% consumed (wallClock). Returns null when well\n105\t   * within budget. Injected into the VARIABLES block so the model knows to wrap\n106\t   * up and call resolve() before the hard stop hits.\n107\t   */\n108\t  nearLimitWarning(): string | null {\n109\t    const warnings: string[] = [];\n110\t    if (this.limits.maxEpisodes !== undefined) {\n111\t      const remaining = this.limits.maxEpisodes - this._episodes;\n112\t      if (remaining <= 2) {\n113\t        warnings.push(`LLM turns: ${this._episodes}/${this.limits.maxEpisodes} used (${remaining} remaining)`);\n114\t      }\n115\t    }\n116\t    if (this.limits.maxToolCalls !== undefined) {\n117\t      const remaining = this.limits.maxToolCalls - this._toolCalls;\n118\t      if (this._toolCalls / this.limits.maxToolCalls >= 0.8) {\n119\t        warnings.push(`tool calls: ${this._toolCalls}/${this.limits.maxToolCalls} used (${remaining} remaining)`);\n120\t      }\n121\t    }\n122\t    if (this.limits.maxWallClockMs !== undefined) {\n123\t      const elapsed = this.elapsedMs();\n124\t      if (elapsed / this.limits.maxWallClockMs >= 0.8) {\n125\t        const remainingSec = Math.round((this.limits.maxWallClockMs - elapsed) / 1000);\n126\t        warnings.push(`wall clock: ${Math.round(elapsed / 1000)}s/${Math.round(this.limits.maxWallClockMs / 1000)}s (${remainingSec}s remaining)`);\n127\t      }\n128\t    }\n129\t    if (warnings.length === 0) return null;\n130\t    return `BUDGET WARNING — approaching limit(s): ${warnings.join('; ')}. Wrap up immediately and call currentTask.resolve() now.`;\n131\t  }\n132\t\n133\t  /** Read-only progress snapshot, surfaced to the VM via the `progress` global. */\n134\t  snapshot(): BudgetSnapshot {\n135\t    return { episodes: this._episodes, toolCalls: this._toolCalls, elapsedMs: this.elapsedMs() };\n136\t  }\n137\t}\n138\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"59842fb0-5312-4496-a1a3-94fa008f623e","timestamp":"2026-07-16T22:24:26.895Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_FbVeS86b0m8wGTm7T4imtZax","type":"tool_result","content":"1\timport type { VM } from '../sandbox/quickjs.js';\n2\timport type { MessageHistory } from '../context/history.js';\n3\timport type { RenderHost } from '../session/types.js';\n4\timport type { YieldRequest } from './yield.js';\n5\timport type { StreamOpts, StreamSession } from './stream-types.js';\n6\timport { NULL_TRACER } from '../sandbox/trace.js';\n7\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n8\timport { BoundaryDetector } from '../sandbox/boundary.js';\n9\timport { runTsc } from '../typecheck/tsc.js';\n10\timport { transpileStatement } from '../typecheck/transpile.js';\n11\timport { buildErrorBlock } from './error-rewind.js';\n12\timport { emitVariables, extractBindingNames, extractBindingPattern, type BindingKind } from '../context/variables.js';\n13\timport { formatInspectResult, type InspectQuery } from '../globals/inspect.js';\n14\timport { serialize } from '../globals/serialize.js';\n15\timport type { ReadDocumentResult } from '../globals/read-document.js';\n16\timport { BudgetExceededError, type Budget } from './budget.js';\n17\t\n18\texport type { StreamOpts, StreamSession };\n19\t\n20\t/** Known markdown fence language tags. */\n21\tconst FENCE_LANGS = ['typescript', 'javascript', 'tsx', 'jsx', 'json', 'ts', 'js'];\n22\t\n23\t/** Max sequential yield batches serviced for one statement (see the servicing loop in\n24\t *  runTurnLoop). A statement normally yields once or one concurrent batch; helpers that\n25\t *  await host calls back-to-back (webFetch's plain→render, webSearch's provider chain)\n26\t *  need a few more. Generous cap purely to bound a pathological await-in-loop; the\n27\t *  tool-call budget is the real limiter. */\n28\tconst MAX_SEQUENTIAL_YIELDS = 64;\n29\t\n30\t/** Duck-typed check for a successful text {@link ReadDocumentResult}. */\n31\tfunction isReadableDocument(v: unknown): v is ReadDocumentResult & { text: string } {\n32\t  return (\n33\t    typeof v === 'object' &&\n34\t    v !== null &&\n35\t    (v as ReadDocumentResult).ok === true &&\n36\t    (v as ReadDocumentResult).kind === 'text' &&\n37\t    typeof (v as ReadDocumentResult).text === 'string'\n38\t  );\n39\t}\n40\t\n41\t/**\n42\t * Build a DOCUMENT CONTENTS block from any `readDocument` yields that returned\n43\t * text, so the model reads the FULL document rather than the 200-char VARIABLES\n44\t * preview of the bound result. Returns '' when no document was read. `yields[i]`\n45\t * aligns with `resolvedValues[i]`.\n46\t */\n47\texport function formatReadDocuments(yields: YieldRequest[], resolvedValues: unknown[]): string {\n48\t  const docs: Array<ReadDocumentResult & { text: string }> = [];\n49\t  for (let i = 0; i < yields.length; i++) {\n50\t    if (yields[i]?.kind !== 'readDocument') continue;\n51\t    const v = resolvedValues[i];\n52\t    if (isReadableDocument(v)) docs.push(v);\n53\t  }\n54\t  if (docs.length === 0) return '';\n55\t  const blocks = docs.map((d) => {\n56\t    const label = d.filename ?? d.attachmentId;\n57\t    const trunc = d.truncated ? ' — truncated (capped); later content was not included' : '';\n58\t    return `--- ${label} (${d.mediaType})${trunc} ---\\n${d.text}`;\n59\t  });\n60\t  return (\n61\t    'DOCUMENT CONTENTS (full text of the file(s) you just read — answer from THIS, ' +\n62\t    'not from the truncated `doc` preview in VARIABLES above):\\n\\n' +\n63\t    blocks.join('\\n\\n')\n64\t  );\n65\t}\n66\t\n67\t/** Every suffix (length ≥ 2) of a fence language tag. A bare fence tag is left\n68\t *  behind when the stream splits the opening ``` from its language across chunks,\n69\t *  so the per-chunk fence filter strips the ``` but not the tag. The split can land\n70\t *  ANYWHERE in the word — `` ```typ `` in one chunk (stripped) + `escript` in the\n71\t *  next, or `` ```types `` + `cript` — leaking a partial-tag fragment as a bogus\n72\t *  statement (the \"Cannot find name 'cript'\" failure). A standalone line that is any\n73\t *  suffix of a fence tag is never valid TS, so dropping it is safe. Single-character\n74\t *  suffixes are excluded so a legitimate one-letter probe (e.g. a bare `x`) survives. */\n75\tconst FENCE_LANG_SUFFIXES: ReadonlySet<string> = new Set(\n76\t  FENCE_LANGS.flatMap((lang) => {\n77\t    const suffixes: string[] = [];\n78\t    for (let i = 0; i <= lang.length - 2; i++) suffixes.push(lang.slice(i));\n79\t    return suffixes;\n80\t  }),\n81\t);\n82\t\n83\t/** Strip markdown code fence lines (and stray/partial fence language tags) from a\n84\t *  chunk before feeding to the boundary detector. Exported for direct testing.\n85\t *\n86\t *  NOTE: only safe on text whose newlines are FINAL (a complete response, or the\n87\t *  end-of-stream flush). For live streaming chunks use {@link FenceLineFilter} —\n88\t *  applying this per chunk swallowed mid-statement tokens that happened to arrive\n89\t *  as their own chunk and equal a fence-lang suffix (live E5 failure:\n90\t *  `JSON.stringify` streamed as […, \"JSON\", \".stringify…\"] became `.stringify`,\n91\t *  corrupting the architect's statement; a lone \" on\" chunk dies the same way). */\n92\texport function stripMarkdownFences(chunk: string): string {\n93\t  return chunk\n94\t    .split('\\n')\n95\t    .filter((line) => !/^\\s*```/.test(line) && !FENCE_LANG_SUFFIXES.has(line.trim().toLowerCase()))\n96\t    .join('\\n');\n97\t}\n98\t\n99\t/** Streaming-safe fence stripper: drop decisions are only ever made on COMPLETE\n100\t *  lines (chunk boundaries are token boundaries, not line boundaries), so a\n101\t *  mid-statement token that streams as its own chunk and equals a fence-lang\n102\t *  suffix (`JSON`, ` on`, `ts`, …) is never swallowed. A partial line is held\n103\t *  back ONLY while it could still grow into a droppable line — a short\n104\t *  all-letter run (potential bare fence tag) or a backtick opening; anything\n105\t *  else is released immediately so ordinary statements keep flowing through the\n106\t *  live streaming pipeline (with its tracer events) instead of piling into the\n107\t *  end-of-stream flush. Once a line's head has been released, its remainder is\n108\t *  exempt from drop checks (it is provably part of a real code line). A fence\n109\t *  tag split across chunks (```typ + escript) reassembles here and drops via\n110\t *  the ^``` rule. */\n111\texport class FenceLineFilter {\n112\t  private buf = '';\n113\t  /** Part of the current (still-open) line was already released downstream. */\n114\t  private headEmitted = false;\n115\t\n116\t  private static droppable(line: string): boolean {\n117\t    return /^\\s*```/.test(line) || FENCE_LANG_SUFFIXES.has(line.trim().toLowerCase());\n118\t  }\n119\t\n120\t  /** Could this partial line still become droppable with more text appended? */\n121\t  private static ambiguous(tail: string): boolean {\n122\t    return /^\\s*(?:`{1,3}.*|[A-Za-z]{0,10})$/.test(tail);\n123\t  }\n124\t\n125\t  feed(chunk: string): string {\n126\t    this.buf += chunk;\n127\t    let out = '';\n128\t    const lines = this.buf.split('\\n');\n129\t    this.buf = lines.pop()!;\n130\t    for (const line of lines) {\n131\t      const exempt = this.headEmitted; // remainder of a line whose head already shipped\n132\t      this.headEmitted = false;\n133\t      if (exempt || !FenceLineFilter.droppable(line)) out += line + '\\n';\n134\t    }\n135\t    if (this.buf && (this.headEmitted || !FenceLineFilter.ambiguous(this.buf))) {\n136\t      out += this.buf;\n137\t      this.buf = '';\n138\t      this.headEmitted = true;\n139\t    }\n140\t    return out;\n141\t  }\n142\t\n143\t  flush(): string {\n144\t    const tail = this.buf;\n145\t    this.buf = '';\n146\t    const exempt = this.headEmitted;\n147\t    this.headEmitted = false;\n148\t    return tail && (exempt || !FenceLineFilter.droppable(tail)) ? tail : '';\n149\t  }\n150\t}\n151\t\n152\t/** Statements that begin with one of these never parse as the start of a prose\n153\t *  sentence — they are real TS, so they are never treated as droppable prose. */\n154\tconst TS_KEYWORD_START =\n155\t  /^(const|let|var|await|async|return|if|else|for|while|do|switch|case|break|continue|function|class|import|export|default|throw|new|typeof|delete|void|yield|try|catch|finally|this|super|null|true|false|undefined|debugger)\\b/;\n156\t\n157\t/** Lowercase English function words. A bare one of these as a standalone token is a\n158\t *  strong signal the \"statement\" is natural-language prose, not code. */\n159\tconst ENGLISH_FUNCTION_WORDS = new Set([\n160\t  'the', 'on', 'a', 'an', 'to', 'from', 'with', 'and', 'or', 'but', 'here', 'this',\n161\t  'that', 'these', 'those', 'we', 'now', 'then', 'of', 'for', 'in', 'as', 'it', 'its',\n162\t  'your', 'you', 'based', 'will', 'because', 'since', 'so', 'about', 'into', 'after',\n163\t  'by', 'at', 'let', 'sure', 'first', 'next', 'please', 'using', 'i', 'my', 'me',\n164\t]);\n165\t\n166\t/** Detect when a model \"statement\" is actually a natural-language sentence (e.g. the\n167\t *  model narrated \"Based on the query, I will search…\" instead of emitting code). Such\n168\t *  text never parses as TS, so — like a stray fence tag — dropping it is safe and avoids\n169\t *  burning a retry on a guaranteed typecheck error. Conservative by design: requires a\n170\t *  sentence shape AND an English function word, and bails on anything with code syntax.\n171\t *  Exported for direct testing. */\n172\texport function looksLikeProse(stmt: string): boolean {\n173\t  const s = stmt.trim();\n174\t  if (!s) return false;\n175\t  // Any code punctuation → treat as code, keep it.\n176\t  if (/[=(){}\\[\\];`<>]/.test(s)) return false;\n177\t  if (/=>|\\.\\w|\\bawait\\b/.test(s)) return false;\n178\t  // Real statement keywords are never prose.\n179\t  if (TS_KEYWORD_START.test(s)) return false;\n180\t  const words = s.split(/\\s+/);\n181\t  if (words.length < 3) return false; // single identifiers are valid probes (e.g. `inspect`)\n182\t  if (!/^[A-Za-z]/.test(s)) return false;\n183\t  // An apostrophe contraction (I'll, don't, let's, we're, it's) in text that already\n184\t  // cleared the code-punctuation guards above is unambiguously prose — real code with an\n185\t  // apostrophe is a string literal, which carries a quote and a code operator and is gone.\n186\t  if (/^[A-Za-z][\\w]*'[A-Za-z]/.test(s) || /\\b[A-Za-z]+'[a-z]{1,3}\\b/.test(s)) return true;\n187\t  // Every token must be word-like (letters/digits/underscore + sentence punctuation) — prose\n188\t  // can reference identifiers like `search_broad`. The code-punctuation guard above plus the\n189\t  // required English function word below keep this from matching real statements.\n190\t  const allWordLike = words.every((w) => /^[A-Za-z][\\w,'\".:!?-]*$/.test(w));\n191\t  if (!allWordLike) return false;\n192\t  return words.some((w) => ENGLISH_FUNCTION_WORDS.has(w.toLowerCase().replace(/[,'\".:!?_-]+$/, '')));\n193\t}\n194\t\n195\texport interface TurnLoopDeps {\n196\t  vm: VM;\n197\t  history: MessageHistory;\n198\t  systemBlock: string;\n199\t  ambientDts: string;\n200\t  renderHost: RenderHost;\n201\t  streamFn: (opts: StreamOpts) => Promise<StreamSession>;\n202\t  processYield: (req: YieldRequest) => Promise<unknown>;\n203\t  maxRetries?: number;\n204\t  tracer?: Tracer;\n205\t  /** Label for trace events — e.g. 'session', 'fork:analyze_dish', 'delegate:pairing' */\n206\t  traceContext?: string;\n207\t  /** Structured execution scope (superset of traceContext). When present, every\n208\t   *  trace event carries nodeId for full observability. */\n209\t  scope?: TraceScope;\n210\t  /** Host-set budget. tickEpisode() per turn, tickToolCalls() per resolved yield.\n211\t   *  Exceeding a limit throws BudgetExceededError, which the caller disposes the VM on. */\n212\t  budget?: Budget;\n213\t  /** Optional model spec/alias for every request in this loop (e.g. a fork's\n214\t   *  role model). Passed through to streamFn; the provider resolves it. */\n215\t  model?: string;\n216\t  /** Seed for accumulatedContext: prior-turn statements so the typechecker knows\n217\t   *  variables bound in earlier turns (the VM still holds their values across\n218\t   *  continue()/resume()). Empty on a fresh start(); the Session carries it\n219\t   *  forward between turns via onContextSnapshot. */\n220\t  initialContext?: string;\n221\t  /** Called whenever accumulatedContext grows, with its latest value, so the\n222\t   *  Session can persist typecheck scope into the next turn. */\n223\t  onContextSnapshot?: (ctx: string) => void;\n224\t  /** Max times a single turn loop will re-prompt a model that stopped generating\n225\t   *  right after a non-yielding `await`-binding (a space-function result that the\n226\t   *  runtime does not auto-surface) — see CONTINUATION_NUDGE. Default 4. */\n227\t  maxContinueNudges?: number;\n228\t  /** Optional per-turn reminder hook (top-level session only). Returns a transient\n229\t   *  user message appended to THIS request only (never persisted) — used to re-surface\n230\t   *  open todos each turn so they are \"not forgotten\". Forks/delegates don't set it. */\n231\t  beforeTurn?: () => string | undefined;\n232\t  /** Inactivity watchdog: if the model stream emits no token for this many ms, the\n233\t   *  read is treated as a transient failure and retried (a silent no-token stall would\n234\t   *  otherwise hang the turn forever). Default 60000. */\n235\t  streamIdleMs?: number;\n236\t}\n237\t\n238\t/** Re-prompt sent when the model ends its response immediately after awaiting a\n239\t *  non-yielding space function (e.g. `const r = await writeTaskFile(...)`) and\n240\t *  binding the result. Those results are NOT surfaced to the model (only yields\n241\t *  are), so a model that stops to \"see\" one would strand the run mid-program.\n242\t *  This tells it the runtime truth and asks it to continue. */\n243\tconst CONTINUATION_NUDGE =\n244\t  'Your statements ran successfully, but the task is not finished. Your last statement bound a value from a NON-yielding call (a space function such as writeTaskFile/validateSpace/listScaffoldedSpaces) — and those results are NOT shown to you automatically (only yielding calls like ask/inspect/delegate/registerSpace surface their value). Continue the program now:\\n' +\n245\t  '- If you must SEE that result before the next step, call inspect(<var>) — it surfaces the value and resumes you.\\n' +\n246\t  '- Otherwise keep emitting the remaining statements (validate, register, delegate, display the final result, …).\\n' +\n247\t  'Only stop (reply with no code) once the whole task is complete and the final result has been displayed.';\n248\t\n249\t/** Outcome of running the shared per-statement pipeline (typecheck → transpile →\n250\t *  eval → pending-yield check). Callers own the parts that legitimately differ\n251\t *  between the streaming loop and the trailing-buffer flush (tracer/log emissions,\n252\t *  stream.abort()/aborted bookkeeping) — see the two call sites in runTurnLoop. */\n253\ttype StatementOutcome =\n254\t  | { kind: 'dropped' }\n255\t  | { kind: 'typecheck_error'; message: string }\n256\t  | { kind: 'eval_error'; message: string }\n257\t  | { kind: 'yielded'; yield: YieldRequest }\n258\t  | { kind: 'ok' };\n259\t\n260\t/** Maps yield-resolved values onto the bound names of a yielding statement's binding\n261\t *  pattern (simple/array/object), then prefers the VM's own computed value for each\n262\t *  name over the raw resolved value where they diverge. They agree whenever the\n263\t *  yielding call IS the directly-awaited expression (every yield kind today). They\n264\t *  diverge when a yield is nested inside another async function the model awaited\n265\t *  instead (e.g. `webSearch()` awaiting `fetch()` internally) — there, the raw\n266\t *  resolved value is the INNER yield's value, not the outer call's real return value,\n267\t *  while the VM's own bytecode (continued via drivePendingJobs(), including the\n268\t *  per-statement `globalThis[name] = name` propagation) has already computed the\n269\t *  correct one. Falls back to the raw value when the VM reports the global as unset.\n270\t *  Exported so a later phase (host-executed preludes) can reuse it. */\n271\texport function bindYieldResults(\n272\t  vm: VM,\n273\t  pattern: { kind: BindingKind; names: string[] },\n274\t  yieldCount: number,\n275\t  resolvedValues: unknown[],\n276\t): Record<string, unknown> {\n277\t  const variables: Record<string, unknown> = {};\n278\t  // Multiple yields ⟹ the statement awaited a combinator (Promise.all), whose result\n279\t  // is the array of resolved values in source order; a single yield ⟹ the result is\n280\t  // that one value.\n281\t  const awaited: unknown = yieldCount > 1 ? resolvedValues : resolvedValues[0];\n282\t  const asRecord = (v: unknown): Record<string, unknown> => (v && typeof v === 'object' ? (v as Record<string, unknown>) : {});\n283\t  const asArray = (v: unknown): unknown[] => (Array.isArray(v) ? v : []);\n284\t  if (pattern.kind === 'array') {\n285\t    const arr = asArray(awaited);\n286\t    pattern.names.forEach((name, i) => { variables[name] = arr[i]; });\n287\t  } else if (pattern.kind === 'object') {\n288\t    const obj = asRecord(awaited);\n289\t    pattern.names.forEach((name) => { variables[name] = obj[name]; });\n290\t  } else if (pattern.names.length === 1) {\n291\t    variables[pattern.names[0]!] = awaited;\n292\t  }\n293\t  for (const name of pattern.names) {\n294\t    const vmValue = vm.getVar(name);\n295\t    if (vmValue !== undefined) variables[name] = vmValue;\n296\t  }\n297\t  return variables;\n298\t}\n299\t\n300\texport async function runTurnLoop(deps: TurnLoopDeps): Promise<'done' | 'error'> {\n301\t  const { vm, history, systemBlock, ambientDts, renderHost, streamFn, processYield } = deps;\n302\t  const maxRetries = deps.maxRetries ?? 3;\n303\t  const tracer = deps.tracer ?? NULL_TRACER;\n304\t  const scope = deps.scope;\n305\t  const ctx = scope?.label ?? deps.traceContext ?? 'session';\n306\t  const nodeId = scope?.nodeId;\n307\t  // Mint a per-turn yieldId counter (cheap monotonic suffix)\n308\t  let yieldCounter = 0;\n309\t\n310\t  let attempt = 0;\n311\t  // Persists across yield-continuations within a turn AND across turns: seeded from\n312\t  // deps.initialContext (prior-turn scope kept by the Session, since the VM still\n313\t  // holds those variables) and reported back via onContextSnapshot as it grows.\n314\t  // Only a fresh start() resets it (Session passes no initialContext there).\n315\t  let accumulatedContext = deps.initialContext ?? '';\n316\t  const appendContext = (stmt: string) => {\n317\t    accumulatedContext += (accumulatedContext ? '\\n' : '') + stmt;\n318\t    deps.onContextSnapshot?.(accumulatedContext);\n319\t  };\n320\t\n321\t  // Names bound by a yielding statement whose yield ERRORED on a retryable attempt.\n322\t  // That statement is never committed to accumulatedContext (it gets re-tried), so\n323\t  // without help a retry that references the name fails typecheck (\"Cannot find name\n324\t  // 'top'\" — the research-fork-scope-loss bug). We declare these as ambient `any`\n325\t  // globals (NOT in session context): a forward reference resolves against them, and\n326\t  // a re-emitted `const <name> = …` simply shadows them — no redeclare conflict.\n327\t  const yieldErrorNames = new Set<string>();\n328\t  const fullAmbient = (): string =>\n329\t    yieldErrorNames.size > 0\n330\t      ? ambientDts + '\\n' + [...yieldErrorNames].map((n) => `declare const ${n}: any;`).join('\\n')\n331\t      : ambientDts;\n332\t  let continueNudges = 0;\n333\t  const maxContinueNudges = deps.maxContinueNudges ?? 4;\n334\t\n335\t  while (attempt < maxRetries) {\n336\t    attempt++;\n337\t    // Budget: count this LLM turn before issuing the request. Throws\n338\t    // BudgetExceededError (propagates out of runTurnLoop) if over the episode\n339\t    // or wall-clock cap — the caller disposes the VM. Counted outside the\n340\t    // stream try/catch so it cannot be swallowed as an abort.\n341\t    deps.budget?.tickEpisode();\n342\t\n343\t    const basePromptMessages = history.getPromptMessages();\n344\t    // Soft per-turn reminder (e.g. open todos). Transient: appended to THIS request only,\n345\t    // never written to history, so it is re-evaluated fresh every turn and never duplicates.\n346\t    const reminder = deps.beforeTurn?.();\n347\t    const promptMessages = reminder\n348\t      ? [...basePromptMessages, { role: 'user' as const, content: reminder }]\n349\t      : basePromptMessages;\n350\t    tracer.write({ ts: Date.now(), type: 'llm_request', context: ctx, ...(nodeId ? { nodeId } : {}), system: systemBlock, messages: promptMessages, model: deps.model });\n351\t    let lastProgressTs = 0;\n352\t    const stream = await streamFn({ system: systemBlock, messages: promptMessages, model: deps.model });\n353\t\n354\t    const detector = new BoundaryDetector();\n355\t    const fenceFilter = new FenceLineFilter();\n356\t    let pendingYield: YieldRequest | null = null;\n357\t    let yieldingStatement: string | null = null;\n358\t    let hadStatements = false;\n359\t    let turnError: string | null = null;\n360\t    let failingStatement: string | null = null;\n361\t    let aborted = false;\n362\t    // Set when the provider stream throws a NON-abort error (e.g. a dropped/terminated\n363\t    // connection). Distinct from `aborted` (our own intentional stream.abort() on a\n364\t    // statement boundary). A transient drop must be RETRIED, not mistaken for the model\n365\t    // finishing — otherwise the turn silently returns 'done' and strands the program.\n366\t    let streamErrored = false;\n367\t    // True when the last statement that evaluated cleanly this turn bound a value\n368\t    // from a NON-yielding call (a space-function result the runtime won't surface) —\n369\t    // whether or not it used `await`. Sync space functions like writeTaskFile/\n370\t    // validateSpace bind without `await`, and a model that stops right after one is\n371\t    // stranded mid-program (the exact failure CONTINUATION_NUDGE recovers from).\n372\t    let lastStmtNonYieldBinding = false;\n373\t    let assistantContent = '';\n374\t    const parsedStatements: string[] = [];\n375\t\n376\t    // Shared per-statement pipeline: prose-drop check → typecheck → transpile +\n377\t    // globalThis-propagation → eval → pending-yield check → accumulatedContext append.\n378\t    // Used by both the main streaming loop and the trailing-buffer flush below. Mutates\n379\t    // the per-turn loop state captured above (turnError, failingStatement, pendingYield,\n380\t    // yieldingStatement, parsedStatements, lastStmtNonYieldBinding); callers own the\n381\t    // parts that differ between the two sites (tracer/log emissions, stream.abort()).\n382\t    const processStatement = (stmt: string): StatementOutcome => {\n383\t      if (looksLikeProse(stmt)) return { kind: 'dropped' };\n384\t\n385\t      const tscResult = runTsc({ ambientDts: fullAmbient(), sessionContext: accumulatedContext, statement: stmt });\n386\t      if (!tscResult.ok) {\n387\t        const errMsg = tscResult.diagnostics.map((d) => d.message).join('; ');\n388\t        turnError = errMsg;\n389\t        failingStatement = stmt;\n390\t        return { kind: 'typecheck_error', message: errMsg };\n391\t      }\n392\t\n393\t      // Transpile TS/JSX → JS, append globalThis bindings so the next module can\n394\t      // access variables declared here (each evalStatement is an isolated module).\n395\t      const boundNames = extractBindingNames(stmt);\n396\t      let jsCode = transpileStatement(stmt);\n397\t      if (boundNames.length > 0) {\n398\t        const assigns = boundNames\n399\t          .map((n) => `try { globalThis['${n}'] = ${n}; } catch {}`)\n400\t          .join('\\n');\n401\t        jsCode += '\\n' + assigns;\n402\t      }\n403\t      const evalResult = vm.evalStatement(jsCode);\n404\t      if (!evalResult.ok) {\n405\t        turnError = evalResult.error;\n406\t        failingStatement = stmt;\n407\t        return { kind: 'eval_error', message: evalResult.error };\n408\t      }\n409\t\n410\t      if (vm.pendingYields.length > 0) {\n411\t        const yieldReq = vm.pendingYields[vm.pendingYields.length - 1]!;\n412\t        pendingYield = yieldReq;\n413\t        yieldingStatement = stmt;\n414\t        parsedStatements.push(stmt);\n415\t        return { kind: 'yielded', yield: yieldReq };\n416\t      }\n417\t\n418\t      parsedStatements.push(stmt);\n419\t      appendContext(stmt);\n420\t      lastStmtNonYieldBinding = boundNames.length > 0 && /[A-Za-z_$][\\w.$]*\\s*\\(/.test(stmt);\n421\t      return { kind: 'ok' };\n422\t    };\n423\t\n424\t    renderHost.log(`[turn ${attempt}] streaming...`);\n425\t    const idleMs = deps.streamIdleMs ?? 60_000;\n426\t    try {\n427\t      // Manual iteration so each token read can race an inactivity timeout. A silent\n428\t      // no-token stall (the architect-stall bug) is otherwise indistinguishable from a\n429\t      // slow model and hangs the turn forever; on idle we abort + mark a transient stream\n430\t      // error so the existing retry path re-issues the request.\n431\t      const iterator = stream.textStream[Symbol.asyncIterator]();\n432\t      while (true) {\n433\t        let idleTimer: ReturnType<typeof setTimeout> | undefined;\n434\t        const idle = new Promise<'idle'>((res) => { idleTimer = setTimeout(() => res('idle'), idleMs); });\n435\t        let step: IteratorResult<string> | 'idle';\n436\t        try {\n437\t          step = await Promise.race([iterator.next(), idle]);\n438\t        } finally {\n439\t          if (idleTimer) clearTimeout(idleTimer);\n440\t        }\n441\t        if (step === 'idle') {\n442\t          renderHost.log(`[turn ${attempt}] stream idle >${idleMs}ms — treating as transient error, will retry`);\n443\t          streamErrored = true;\n444\t          try { stream.abort(); } catch { /* ignore */ }\n445\t          break;\n446\t        }\n447\t        if (step.done) break;\n448\t        const chunk = step.value;\n449\t        assistantContent += chunk;\n450\t        const statements = detector.feed(fenceFilter.feed(chunk));\n451\t\n452\t        for (const stmt of statements) {\n453\t          // Drop narrated prose the model emitted instead of code (e.g. \"Based on the\n454\t          // query, I will…\"). It never parses as TS, so skipping it avoids burning a\n455\t          // retry on a guaranteed typecheck error. Same rationale as stray fence tags.\n456\t          const outcome = processStatement(stmt);\n457\t          if (outcome.kind === 'dropped') {\n458\t            renderHost.log(`[stmt] (dropped prose) ${stmt}`);\n459\t            tracer.write({ ts: Date.now(), type: 'statement', context: ctx, ...(nodeId ? { nodeId } : {}), code: `/* dropped non-code prose: ${stmt.slice(0, 80)} */` });\n460\t            continue;\n461\t          }\n462\t          hadStatements = true;\n463\t          renderHost.log(`[stmt] ${stmt}`);\n464\t          tracer.write({ ts: Date.now(), type: 'statement', context: ctx, ...(nodeId ? { nodeId } : {}), code: stmt });\n465\t\n466\t          // Throttled streaming progress (≥250ms between emissions, subscriber-only)\n467\t          const now = Date.now();\n468\t          if (now - lastProgressTs >= 250) {\n469\t            lastProgressTs = now;\n470\t            tracer.write({ ts: now, type: 'llm_progress', context: ctx, ...(nodeId ? { nodeId } : {}), chars: assistantContent.length, statements: parsedStatements.length });\n471\t          }\n472\t\n473\t          if (outcome.kind === 'typecheck_error') {\n474\t            stream.abort();\n475\t            aborted = true;\n476\t            tracer.write({ ts: Date.now(), type: 'typecheck_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: outcome.message, attempt });\n477\t            break;\n478\t          }\n479\t\n480\t          if (outcome.kind === 'eval_error') {\n481\t            stream.abort();\n482\t            aborted = true;\n483\t            tracer.write({ ts: Date.now(), type: 'eval_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: outcome.message });\n484\t            break;\n485\t          }\n486\t\n487\t          if (outcome.kind === 'yielded') {\n488\t            stream.abort();\n489\t            aborted = true;\n490\t            break;\n491\t          }\n492\t        }\n493\t\n494\t        if (aborted) break;\n495\t      }\n496\t    } catch (err) {\n497\t      const isAbort = err instanceof Error && (err.name === 'AbortError' || err.message.includes('abort'));\n498\t      if (!isAbort) {\n499\t        renderHost.log(`Stream error: ${err instanceof Error ? err.message : String(err)}`);\n500\t        streamErrored = true;\n501\t      }\n502\t    }\n503\t\n504\t    // A transient provider failure (dropped/terminated connection) that produced NO\n505\t    // usable output must be RETRIED — not silently treated as \"the model finished\".\n506\t    // Without this, one flaky stream ends the turn with 'done' and strands the whole\n507\t    // run (the exact failure that killed an optional research fork mid-pipeline).\n508\t    if (streamErrored && !hadStatements && !aborted) {\n509\t      tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'stream_error' });\n510\t      if (attempt >= maxRetries) {\n511\t        renderHost.log(`[turn ${attempt}] stream error exhausted retries — giving up this turn`);\n512\t        return 'error';\n513\t      }\n514\t      renderHost.log(`[turn ${attempt}] stream error with no output — retrying request`);\n515\t      // Brief backoff so we don't hammer a provider that just dropped us.\n516\t      await new Promise((r) => setTimeout(r, Math.min(2000, 300 * attempt)));\n517\t      continue;\n518\t    }\n519\t\n520\t    // Flush remaining buffer. Unlike the streaming loop above, this never emits\n521\t    // statement/progress/error tracer events or renderHost logs, and never touches\n522\t    // `stream`/`aborted` (the stream has already ended) — that asymmetry is intentional\n523\t    // and predates this refactor; processStatement only supplies the shared pipeline.\n524\t    if (!aborted) {\n525\t      // Release the fence filter's held partial line first — it may complete one\n526\t      // or more statements in the detector — then flush the detector's own tail.\n527\t      const released = fenceFilter.flush();\n528\t      const flushedStatements = released ? detector.feed(released) : [];\n529\t      const trailing = detector.flush().trim();\n530\t      for (const stmt of [...flushedStatements, ...(trailing ? [trailing] : [])]) {\n531\t        const outcome = processStatement(stmt);\n532\t        if (outcome.kind !== 'dropped') hadStatements = true;\n533\t        // Mirror the streaming loop: stop at the first error or yield.\n534\t        if (outcome.kind !== 'ok' && outcome.kind !== 'dropped') break;\n535\t      }\n536\t    }\n537\t\n538\t    // Await token usage from the stream (best-effort; available after stream is consumed).\n539\t    // Skip when the stream was aborted mid-way (yield/error): the usage event arrives\n540\t    // only in the final API chunk, which never comes after abort, so the promise hangs.\n541\t    // Even on a \"normal\" end the promise can stay pending forever (provider ended the\n542\t    // stream without the final usage chunk — live E6 hang: one fork stalled here with\n543\t    // no timer left, the DAG deadlocked, and Node exited silently once every other\n544\t    // promise drained). Usage is telemetry, never worth blocking on: bound the wait.\n545\t    let inputTokens: number | undefined;\n546\t    let outputTokens: number | undefined;\n547\t    if (stream.usage && !aborted && !streamErrored) {\n548\t      let usageTimer: ReturnType<typeof setTimeout> | undefined;\n549\t      try {\n550\t        const u = await Promise.race([\n551\t          stream.usage,\n552\t          new Promise<undefined>((res) => { usageTimer = setTimeout(() => res(undefined), 10_000); }),\n553\t        ]);\n554\t        if (u && (u.promptTokens > 0 || u.completionTokens > 0)) {\n555\t          inputTokens = u.promptTokens;\n556\t          outputTokens = u.completionTokens;\n557\t        }\n558\t      } catch { /* usage unavailable */ } finally {\n559\t        if (usageTimer) clearTimeout(usageTimer);\n560\t      }\n561\t    }\n562\t\n563\t    // Use parsed statements for history so incomplete trailing stream text is excluded.\n564\t    const historyContent = parsedStatements.length > 0 ? parsedStatements.join('\\n') : assistantContent.trim();\n565\t    if (historyContent) {\n566\t      renderHost.log(`[model response]\\n${historyContent}\\n[/model response]`);\n567\t      tracer.write({\n568\t        ts: Date.now(), type: 'llm_response', context: ctx,\n569\t        ...(nodeId ? { nodeId } : {}),\n570\t        attempt, text: historyContent,\n571\t        ...(deps.model ? { model: deps.model } : {}),\n572\t        ...(inputTokens !== undefined ? { inputTokens } : {}),\n573\t        ...(outputTokens !== undefined ? { outputTokens } : {}),\n574\t      });\n575\t      history.append({ role: 'assistant', content: historyContent, blockType: 'normal' });\n576\t    }\n577\t\n578\t    if (turnError && failingStatement) {\n579\t      // process.exit() is intentional termination, not a recoverable error. The model\n580\t      // uses it as control flow (e.g. `if (!ok) process.exit(1)`); retrying re-runs the\n581\t      // exact same code and burns LLM calls in a loop. Treat it as a clean stop.\n582\t      if (/\\bprocess\\.exit\\(/.test(turnError)) {\n583\t        renderHost.log(`[process.exit] intentional termination — not retrying`);\n584\t        return 'done';\n585\t      }\n586\t      // Do NOT roll back accumulatedContext: statements that succeeded earlier in\n587\t      // this turn already bound their variables in the VM (globalThis) and persist\n588\t      // into the retry. Keeping them in the typecheck context matches VM reality —\n589\t      // rolling back would make tsc reject valid references with \"Cannot find name\".\n590\t      // The failing statement was never appended (it errors before accumulation), so\n591\t      // there is nothing partial to discard.\n592\t      renderHost.log(`[error] ${turnError}`);\n593\t      history.append({ role: 'user', content: buildErrorBlock(failingStatement, turnError, attempt, maxRetries, accumulatedContext), blockType: 'error' });\n594\t      if (attempt >= maxRetries) return 'error';\n595\t      continue;\n596\t    }\n597\t\n598\t    if (pendingYield && yieldingStatement) {\n599\t      // Binding pattern of the yielding statement (kind + names).\n600\t      const pattern = extractBindingPattern(yieldingStatement);\n601\t\n602\t      // Resolve the statement's yields to completion. Most statements yield once, or a\n603\t      // single CONCURRENT batch — `await Promise.all([fork(...), fork(...)])`. But a\n604\t      // model-awaited helper can also await host calls SEQUENTIALLY: e.g. `webFetch`\n605\t      // does a plain fetch and THEN, if the page is JS-rendered, a second fetch to the\n606\t      // render service; `webSearch`'s `auto` chain likewise falls Tavily→Bing→DuckDuckGo.\n607\t      // Each later await only surfaces as a pending yield AFTER `drivePendingJobs()`\n608\t      // resumes the prior one, so we loop until the VM has no pending yields left (the\n609\t      // statement has fully returned). Servicing only the first batch would bind an\n610\t      // incomplete value — the raw first Response — instead of the helper's real return.\n611\t      // The QuickJS module continuation after `await` does NOT re-run in this sync eval\n612\t      // model, so the host binds the final value itself (see bindYieldResults, below).\n613\t      // Bounded by MAX_SEQUENTIAL_YIELDS (a runaway is also bounded by the tool-call budget).\n614\t      const yields: YieldRequest[] = [];\n615\t      const resolvedValues: unknown[] = [];\n616\t      const yieldErrors: Array<{ kind: string; message: string }> = [];\n617\t      let batch = vm.pendingYields.splice(0);\n618\t      for (let guard = 0; batch.length > 0 && guard < MAX_SEQUENTIAL_YIELDS; guard++) {\n619\t        const base = resolvedValues.length;\n620\t        for (const y of batch) { yields.push(y); resolvedValues.push(undefined); }\n621\t        // Budget: count each resolved yield as a tool call. Throws (and the caller\n622\t        // disposes the VM) if over the tool-call or wall-clock cap.\n623\t        deps.budget?.tickToolCalls(batch.length);\n624\t        await Promise.all(batch.map(async (yieldReq, i) => {\n625\t          const yieldId = `${nodeId ?? ctx}_y${++yieldCounter}`;\n626\t          tracer.write({ ts: Date.now(), type: 'yield', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, args: yieldReq.args, yieldId });\n627\t          try {\n628\t            const resolved = await processYield(yieldReq);\n629\t            tracer.write({ ts: Date.now(), type: 'yield_resolved', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, value: resolved, yieldId });\n630\t            yieldReq.deferred.resolve(resolved);\n631\t            resolvedValues[base + i] = resolved;\n632\t          } catch (err) {\n633\t            // A budget breach inside a yield (e.g. a fork rejected by the fork-depth\n634\t            // cap, or an over-budget fork) is a HARD stop, not a recoverable\n635\t            // tool error. Propagate it so it surfaces exactly like the episode and\n636\t            // tool-call caps (clean non-zero exit + VM disposal by the caller) —\n637\t            // instead of being swallowed into an undefined binding that lets the run\n638\t            // continue past its ceiling.\n639\t            if (err instanceof BudgetExceededError) throw err;\n640\t            yieldReq.deferred.reject(err);\n641\t            resolvedValues[base + i] = undefined;\n642\t            yieldErrors.push({ kind: yieldReq.kind, message: err instanceof Error ? err.message : String(err) });\n643\t          }\n644\t        }));\n645\t        vm.drivePendingJobs();\n646\t        // A yield that errored can't cleanly resume the VM continuation, so stop\n647\t        // servicing further sequential yields and let the error path below surface it\n648\t        // (and retry the turn). `fetch` never rejects — it resolves `{ok:false}` — so\n649\t        // webFetch/webSearch's sequential fetches always run to completion here.\n650\t        if (yieldErrors.length > 0) break;\n651\t        batch = vm.pendingYields.splice(0);\n652\t      }\n653\t\n654\t      // A yield that threw (e.g. delegate() to a hallucinated space key, a function\n655\t      // that errored) used to bind `undefined` silently — the model never learned why\n656\t      // and could not self-correct. Surface it as a normal turn error so the actionable\n657\t      // message (e.g. the list of real space keys) reaches the model and it retries.\n658\t      // Hard caps already short-circuited above; forks/tasklists salvage rather than\n659\t      // throw, so this primarily catches recoverable model mistakes. On the final attempt\n660\t      // we fall through and bind the undefined values so the run can still limp forward.\n661\t      if (yieldErrors.length > 0 && attempt < maxRetries) {\n662\t        turnError = yieldErrors.map((e) => `${e.kind}() failed: ${e.message}`).join('; ');\n663\t        failingStatement = yieldingStatement;\n664\t        renderHost.log(`[yield error] ${turnError}`);\n665\t        // Preserve the failed statement's bound names so a retry that references them\n666\t        // (or re-emits the binding) typechecks instead of dying with \"Cannot find name\".\n667\t        // Declared ambient (any) + seeded undefined in the VM so eval can't ReferenceError.\n668\t        for (const name of pattern.names) {\n669\t          yieldErrorNames.add(name);\n670\t          vm.setVar(name, undefined);\n671\t        }\n672\t        history.append({ role: 'user', content: buildErrorBlock(failingStatement, turnError, attempt, maxRetries, accumulatedContext), blockType: 'error' });\n673\t        continue;\n674\t      }\n675\t\n676\t      // Map resolved values onto the bound names, preferring the VM's own computed\n677\t      // value for each name over the raw resolved-yield value where they diverge\n678\t      // (see bindYieldResults' doc comment — the webSearch()-awaiting-fetch() case).\n679\t      const variables = bindYieldResults(vm, pattern, yields.length, resolvedValues);\n680\t      for (const [name, value] of Object.entries(variables)) {\n681\t        vm.setVar(name, value); // inject into VM scope + host scope for the next turn\n682\t      }\n683\t\n684\t      // Emit a serialized variables snapshot for the observability tree\n685\t      if (Object.keys(variables).length > 0) {\n686\t        const serialized: Record<string, unknown> = {};\n687\t        for (const [k, v] of Object.entries(variables)) {\n688\t          serialized[k] = serialize(v);\n689\t        }\n690\t        tracer.write({ ts: Date.now(), type: 'variables', context: ctx, ...(nodeId ? { nodeId } : {}), vars: serialized });\n691\t      }\n692\t\n693\t      // Add the yielding statement to accumulated context for future typecheck\n694\t      appendContext(yieldingStatement);\n695\t\n696\t      // inspect() is a read-only probe: its whole purpose is to surface a value\n697\t      // (or a queried slice/path/keys view of it) to the MODEL. Unlike other yields\n698\t      // it is normally called WITHOUT a binding (`inspect(x)` / `inspect([x, q])`),\n699\t      // so the generic name-binding above captures nothing. Surface the inspected\n700\t      // values explicitly via formatInspectResult, independent of any binding —\n701\t      // otherwise a bare inspect() resolves to an empty VARIABLES block and the\n702\t      // model sees nothing (the exact failure that lets it re-type/​hallucinate\n703\t      // values instead of reading them).\n704\t      const inspectArgs = yields\n705\t        .filter((y) => y.kind === 'inspect')\n706\t        .flatMap((y) => (y.args as Array<{ value: unknown; query?: InspectQuery }>));\n707\t\n708\t      // Always emit a continuation message so the model knows the yield resolved and\n709\t      // what's already in scope — even for yields with no variable bindings (e.g. sleep).\n710\t      if (Object.keys(variables).length > 0) {\n711\t        renderHost.log(`[variables] ${Object.keys(variables).join(', ')}`);\n712\t      } else if (inspectArgs.length > 0) {\n713\t        renderHost.log(`[inspect] ${inspectArgs.length} value(s)`);\n714\t      } else {\n715\t        renderHost.log(`[resumed]`);\n716\t      }\n717\t\n718\t      let varContent = emitVariables(variables, accumulatedContext);\n719\t      if (inspectArgs.length > 0) {\n720\t        // Fold the inspected lines into the VARIABLES section the model already reads.\n721\t        // formatInspectResult returns \"VARIABLES\\ninspected[i]: …\" — drop its header\n722\t        // and splice its lines in right after the existing VARIABLES header.\n723\t        const inspectLines = formatInspectResult(inspectArgs).split('\\n').slice(1);\n724\t        varContent = varContent.replace(/^VARIABLES\\n?/, (m) => m + inspectLines.join('\\n') + '\\n');\n725\t      }\n726\t      // readDocument results are meant to be READ IN FULL. The VARIABLES preview\n727\t      // serializes the bound `doc` with a 200-char string cap, so the model would\n728\t      // otherwise see only the opening of any real document (and mistake the preview\n729\t      // marker for real truncation). Surface each successfully-read document's whole\n730\t      // text as its own block, exactly as it came back from readDocument (already\n731\t      // capped host-side at READ_DOCUMENT_MAX_CHARS).\n732\t      const documentBlock = formatReadDocuments(yields, resolvedValues);\n733\t      if (documentBlock) varContent += `\\n\\n${documentBlock}`;\n734\t      const budgetWarning = deps.budget?.nearLimitWarning();\n735\t      if (budgetWarning) varContent += `\\n\\n${budgetWarning}`;\n736\t      history.append({ role: 'user', content: varContent, blockType: 'variables' });\n737\t\n738\t      // Reset the retry budget ONLY on a CLEAN resolution. If this turn's yields ERRORED and\n739\t      // we still reached here (attempt >= maxRetries → the fall-through above binds the failed\n740\t      // names to `undefined` so the run can limp forward), that is NOT progress. A model that\n741\t      // stubbornly re-emits the same failing yield (e.g. a forbidden delegate) would otherwise\n742\t      // get its retry counter zeroed every cycle and loop forever — each cycle appending another\n743\t      // error+variables block until the history string overflows V8's max length (\"Invalid\n744\t      // string length\"). Withholding the reset lets `attempt` climb past maxRetries so the loop\n745\t      // returns 'error' (forks then salvage a schema-valid placeholder; sessions stop) instead\n746\t      // of spinning.\n747\t      if (yieldErrors.length === 0) attempt = 0;\n748\t      continue;\n749\t    }\n750\t\n751\t    if (!hadStatements) {\n752\t      renderHost.log(`[turn ${attempt}] model produced no statements — done`);\n753\t      tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'no_statements' });\n754\t      return 'done';\n755\t    }\n756\t\n757\t    // The model ended its response with no pending yield. If its last clean\n758\t    // statement was a non-yielding `await`-binding, it most likely stopped to\n759\t    // \"see\" a result the runtime never surfaces (e.g. writeTaskFile) — which\n760\t    // would strand a multi-step program. Re-prompt it to continue, bounded so a\n761\t    // genuinely-finished model (which emits no further statements → no_statements\n762\t    // → done) and a model that keeps binding without progressing both terminate.\n763\t    if (lastStmtNonYieldBinding && continueNudges < maxContinueNudges) {\n764\t      continueNudges++;\n765\t      renderHost.log(`[turn ${attempt}] ended on a non-yielding binding — nudging to continue (${continueNudges}/${maxContinueNudges})`);\n766\t      tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'continue' });\n767\t      history.append({ role: 'user', content: CONTINUATION_NUDGE, blockType: 'normal' });\n768\t      attempt = 0;\n769\t      continue;\n770\t    }\n771\t\n772\t    renderHost.log(`[turn ${attempt}] done`);\n773\t    tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'done' });\n774\t    return 'done';\n775\t  }\n776\t\n777\t  tracer.write({ ts: Date.now(), type: 'turn_end', context: ctx, ...(nodeId ? { nodeId } : {}), reason: 'max_retries' });\n778\t  return 'error';\n779\t}\n780\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"a94a64c2-74d3-4d04-804c-d496582355d9","timestamp":"2026-07-16T22:24:26.910Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
