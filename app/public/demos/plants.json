      },
      "description": "Creates a personalized weekly care plan for an indoor plant",
      "tasks": [
        {
          "order": 1,
          "name": "Create Plant Snapshot",
          "frontmatter": {
            "description": "Summarize current plant context and risk signals",
            "type": "updateFlowOutput",
            "model": "claude-3-5-sonnet",
            "temperature": "0.2"
          },
          "instructions": "Create a concise status snapshot from profile and symptom inputs.",
          "outputSchema": {
            "type": "object",
            "properties": {
              "plantType": {
                "type": "string"
              },
              "growthStage": {
                "type": "string"
              },
              "riskLevel": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            },
            "required": [
              "plantType",
              "growthStage",
              "riskLevel"
            ]
          },
          "targetFieldName": "snapshot"
        },
        {
          "order": 2,
          "name": "Generate Weekly Actions",
          "frontmatter": {
            "description": "Create practical daily/weekly tasks",
            "type": "updateFlowOutput",
            "isPushable": "false",
            "model": "claude-3-5-sonnet",
            "temperature": "0.3"
          },
          "instructions": "Generate a safe, low-maintenance one-week action list.",
          "outputSchema": {
            "type": "object",
            "properties": {
              "actions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "day": {
                      "type": "string"
                    },
                    "task": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "day",
                    "task"
                  ]
                }
              }
            },
            "required": [
              "actions"
            ]
          },
          "targetFieldName": "weeklyActions"
        },
        {
          "order": 3,
          "name": "Recommend Follow-up Check",
          "frontmatter": {
            "description": "Provide a follow-up checkpoint for symptom re-evaluation",
            "type": "executeTask",
            "enabledTools": [
              "plant-care-scheduler",
              "disease-symptom-checker"
            ],
            "model": "claude-3-5-sonnet",
            "temperature": "0.2"
          },
          "instructions": "Suggest when the user should reassess and what to observe."
        }
      ]
    }
