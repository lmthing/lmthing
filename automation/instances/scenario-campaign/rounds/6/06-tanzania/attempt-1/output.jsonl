ndles a mixed batch (image + pdf + audio) preserving order', () => {\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/attachments.test.ts:87:      { meta: meta({ id: 'a', kind: 'audio', mediaType: 'audio/wav', transcript: 'spoken' }), bytes: null },\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/attachments.test.ts:94:    expect(r.transcripts).toEqual(['[Transcript of audio]:\\nspoken']);\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/attachments.test.ts:95:    expect(r.traceAttachments.map((t) => t.kind)).toEqual(['image', 'file', 'audio']);\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:123:    expect(classifyKind('audio/mpeg')).toBe('audio');\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:124:    expect(classifyKind('audio/wav')).toBe('audio');\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:161:  it('persists a transcript for audio uploads', async () => {\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:165:      mediaType: 'audio/mpeg',\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:169:    expect(meta.kind).toBe('audio');\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:332:  it('returns transcript text for an audio upload', async () => {\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.test.ts:334:    const meta = await saveUpload(dir, { bytes: new Uint8Array([9]), mediaType: 'audio/mpeg', transcript: 'hello world' });\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/serve.ts:207:  // Chat attachments (vision/audio/file upload): store + serve back for the UI.\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.ts:8: *  transcribed to text server-side; images/files are passed to vision/doc models. */\n/home/vasilis/LMTHING/lmthing/sdk/org/libs/cli/src/server/uploads.ts:9:export type AttachmentKind = 'image' | 'audio' | 'file