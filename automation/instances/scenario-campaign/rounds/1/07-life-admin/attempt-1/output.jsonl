{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_3IDZmMSVj1HljUmMsyEWv6Hh","type":"tool_result","content":"1\t/**\n2\t * Local target — run scenarios against a single `lmthing serve` on localhost instead of a\n3\t * provisioned prod pod. This is the FAST path: a product-code fix is `pnpm build` + restart this\n4\t * one server (seconds), not push → CI image build → ArgoCD rollout → re-verify (minutes).\n5\t *\n6\t * The pod does NO auth of its own (Envoy validates the gateway JWT at the edge in prod); locally\n7\t * there is no edge, so the server accepts every request token-free. So a \"user\" here is just the\n8\t * shared local base URL with `token: null` — see `provisionUser()` in gateway.mjs.\n9\t *\n10\t * ONE shared server, MANY projects: every scenario writes to its OWN projectId (latam /\n11\t * tanzania-trip / life-admin / …), so concurrent lanes never collide on the single runtime root.\n12\t * They DO share one Node event loop, so lanes are coupled (a rebuild-restart by one lane briefly\n13\t * drops the others' in-memory sessions — the harness re-resumes them from the persisted id).\n14\t *\n15\t * The server is spawned DETACHED and tracked by a pidfile so it outlives the `claude -p` agent\n16\t * process that first started it, and so a later lane (or a rebuild-restart) attaches to / cycles\n17\t * the same instance instead of racing up a second one. Startup is guarded by an exclusive lock so\n18\t * two lanes booting at once cannot both spawn.\n19\t */\n20\timport { spawn } from 'node:child_process';\n21\timport { mkdirSync, openSync, closeSync, readFileSync, writeFileSync, rmSync, statSync } from 'node:fs';\n22\timport { join } from 'node:path';\n23\timport { SDK_ORG, STATE_DIR } from './paths.mjs';\n24\t\n25\texport const LOCAL_PORT = Number(process.env.LM_LOCAL_PORT ?? 8080);\n26\texport const LOCAL_BASE = `http://localhost:${LOCAL_PORT}`;\n27\t\n28\t/** True when the whole harness should target the local server rather than a prod pod. */\n29\texport const LOCAL =\n30\t  process.env.SCENARIO_TARGET === 'local' || /localhost|127\\.0\\.0\\.1/.test(process.env.LM_POD_BASE ?? '');\n31\t\n32\t/**\n33\t * State (pidfile, log, pod-root) is keyed by PORT, so a lane that wants ISOLATION can set\n34\t * `LM_LOCAL_PORT` and get its own server instead of sharing the default one. That matters because a\n35\t * restart is not a private act: `local-server.mjs restart` kills the shared process, and every other\n36\t * lane's in-flight turn dies with it. A scenario whose authoring turns run 10+ minutes cannot\n37\t * survive on a server that its siblings rebuild every few minutes — it gets interrupted, re-sends,\n38\t * and burns the budget again. The default port keeps the original shared dir, so nothing moves for\n39\t * lanes that are happy sharing.\n40\t */\n41\tconst DIR = join(STATE_DIR, LOCAL_PORT === 8080 ? 'local-server' : `local-server-${LOCAL_PORT}`);\n42\tconst PID_FILE = join(DIR, 'pid');\n43\tconst LOCK_FILE = join(DIR, 'starting.lock');\n44\tconst LOG_FILE = join(DIR, 'serve.log');\n45\t/** Dedicated runtime root so scenario projects never touch a dev `<cwd>/.lmthing`. */\n46\tconst POD_ROOT = join(DIR, 'pod-root');\n47\tconst BIN = join(SDK_ORG, 'libs', 'cli', 'dist', 'cli', 'bin.js');\n48\t\n49\t/** Does the server answer at all? `GET /api/projects` needs no body/auth and is cheap. */\n50\texport async function serverUp(base = LOCAL_BASE, { timeoutMs = 1500 } = {}) {\n51\t  try {\n52\t    const ctl = AbortSignal.timeout(timeoutMs);\n53\t    const res = await fetch(`${base}/api/projects`, { signal: ctl });\n54\t    return res.status > 0; // any HTTP answer means it's listening\n55\t  } catch {\n56\t    return false;\n57\t  }\n58\t}\n59\t\n60\tfunction pidAlive(pid) {\n61\t  if (!pid) return false;\n62\t  try {\n63\t    process.kill(pid, 0);\n64\t    return true;\n65\t  } catch (e) {\n66\t    return e?.code === 'EPERM';\n67\t  }\n68\t}\n69\t\n70\tfunction readPid() {\n71\t  try {\n72\t    const pid = Number(readFileSync(PID_FILE, 'utf8').trim());\n73\t    return Number.isInteger(pid) && pid > 0 ? pid : null;\n74\t  } catch {\n75\t    return null;\n76\t  }\n77\t}\n78\t\n79\tconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n80\t\n81\tasync function waitUp(base, { attempts = 120, everyMs = 1000 } = {}) {\n82\t  for (let i = 0; i < attempts; i++) {\n83\t    if (await serverUp(base)) return true;\n84\t    await sleep(everyMs);\n85\t  }\n86\t  return false;\n87\t}\n88\t\n89\t/**\n90\t * Guarantee a local server is listening; return its base URL. Idempotent and race-safe across\n91\t * concurrent lanes: whoever wins the exclusive lock spawns it, everyone else waits for it to come\n92\t * up. A stale lock (holder died before writing a live pid) is broken after a grace period.\n93\t */\n94\texport async function ensureLocalServer() {\n95\t  if (await serverUp()) return LOCAL_BASE;\n96\t  mkdirSync(DIR, { recursive: true });\n97\t  mkdirSync(POD_ROOT, { recursive: true });\n98\t\n99\t  // Exclusive-create the lock. If someone else holds it, they're booting — wait for the port.\n100\t  let lockFd;\n101\t  try {\n102\t    lockFd = openSync(LOCK_FILE, 'wx');\n103\t  } catch (e) {\n104\t    if (e?.code !== 'EEXIST') throw e;\n105\t    // Break a stale lock (>90s old and no live server, no live pid) so a crashed boot can't wedge us.\n106\t    const stale = Date.now() - safeMtime(LOCK_FILE) > 90_000;\n107\t    if (stale && !(await serverUp()) && !pidAlive(readPid())) {\n108\t      rmSync(LOCK_FILE, { force: true });\n109\t      return ensureLocalServer();\n110\t    }\n111\t    if (await waitUp(LOCAL_BASE)) return LOCAL_BASE;\n112\t    throw new Error('local server never came up (another lane held the start lock)');\n113\t  }\n114\t\n115\t  try {\n116\t    // A pid may already be live even though the probe missed (mid-boot) — attach to it.\n117\t    if (pidAlive(readPid()) && (await waitUp(LOCAL_BASE, { attempts: 30 }))) return LOCAL_BASE;\n118\t\n119\t    const logFd = openSync(LOG_FILE, 'a');\n120\t    // `--adopt-system-spaces`: this pod-root is a throwaway we own, so always take the freshly\n121\t    // built system-space tree (dist/system-spaces) on restart — that's how an agent's system-space\n122\t    // prompt improvements land after `pnpm build && local-server.mjs restart`.\n123\t    // `--max-sessions`: the default (8) is sized for ONE user's chat tabs. This server is shared by\n124\t    // every scenario lane at once, and a single authoring turn adds a delegate sub-session per\n125\t    // specialist it fans out to — so a handful of concurrent lanes blow past 8 easily, and the\n126\t    // capacity gate then sheds sessions the lanes are still using.\n127\t    const child = spawn(process.execPath, [BIN, 'serve', '--port', String(LOCAL_PORT), '--adopt-system-spaces', '--max-sessions', '40'], {\n128\t      cwd: SDK_ORG, // read sdk/org/.env → Azure keys credential the agents (budget-free direct Azure)\n129\t      env: { ...process.env, LMTHING_ROOT: join(POD_ROOT, '.lmthing') },\n130\t      detached: true, // own process group → survives the agent, killable as a tree\n131\t      stdio: ['ignore', logFd, logFd],\n132\t    });\n133\t    closeSync(logFd);\n134\t    child.unref();\n135\t    writeFileSync(PID_FILE, String(child.pid));\n136\t    if (!(await waitUp(LOCAL_BASE))) throw new Error(`local server did not listen on :${LOCAL_PORT} — see ${LOG_FILE}`);\n137\t    return LOCAL_BASE;\n138\t  } finally {\n139\t    closeSync(lockFd);\n140\t    rmSync(LOCK_FILE, { force: true });\n141\t  }\n142\t}\n143\t\n144\tfunction safeMtime(p) {\n145\t  try {\n146\t    return statSync(p).mtimeMs;\n147\t  } catch {\n148\t    return 0;\n149\t  }\n150\t}\n151\t\n152\t/** Kill the local server (whole process group) and clear its pidfile. */\n153\texport function stopLocalServer() {\n154\t  const pid = readPid();\n155\t  if (pidAlive(pid)) {\n156\t    try {\n157\t      process.kill(-pid, 'SIGTERM'); // negative → the detached group\n158\t    } catch {\n159\t      try {\n160\t        process.kill(pid, 'SIGTERM');\n161\t      } catch {\n162\t        /* already gone */\n163\t      }\n164\t    }\n165\t  }\n166\t  rmSync(PID_FILE, { force: true });\n167\t}\n168\t\n169\t/** Rebuild-then-restart flow: stop, wait for the port to free, bring a fresh server up. */\n170\texport async function restartLocalServer() {\n171\t  stopLocalServer();\n172\t  for (let i = 0; i < 30 && (await serverUp()); i++) await sleep(1000);\n173\t  return ensureLocalServer();\n174\t}\n175\t\n176\texport function localStatus() {\n177\t  const pid = readPid();\n178\t  return { base: LOCAL_BASE, pid, alive: pidAlive(pid), podRoot: POD_ROOT, log: LOG_FILE };\n179\t}\n180\t"}]},"parent_tool_use_id":null,"session_id":"0dcb5bd3-991a-418a-bd79-b78383bf23a4","uuid":"9bc8abbb-2852-477e-b920-8404eb3240f4","timestamp":"2026-07-14T16:41:52.970Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/lib/local.mjs","content":"/**\n * Local target — run scenarios against a single `lmthing serve` on localhost instead of a\n * provisioned prod pod. This is the FAST path: a product-code fix is `pnpm build` + restart this\n * one server (seconds), not push → CI image build → ArgoCD rollout → re-verify (minutes).\n *\n * The pod does NO auth of its own (Envoy validates the gateway JWT at the edge in prod); locally\n * there is no edge, so the server accepts every request token-free. So a \"user\" here is just the\n * shared local base URL with `token: null` — see `provisionUser()` in gateway.mjs.\n *\n * ONE shared server, MANY projects: every scenario writes to its OWN projectId (latam /\n * tanzania-trip / life-admin / …), so concurrent lanes never collide on the single runtime root.\n * They DO share one Node event loop, so lanes are coupled (a rebuild-restart by one lane briefly\n * drops the others' in-memory sessions — the harness re-resumes them from the persisted id).\n *\n * The server is spawned DETACHED and tracked by a pidfile so it outlives the `claude -p` agent\n * process that first started it, and so a later lane (or a rebuild-restart) attaches to / cycles\n * the same instance instead of racing up a second one. Startup is guarded by an exclusive lock so\n * two lanes booting at once cannot both spawn.\n */\nimport { spawn } from 'node:child_process';\nimport { mkdirSync, openSync, closeSync, readFileSync, writeFileSync, rmSync, statSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { SDK_ORG, STATE_DIR } from './paths.mjs';\n\nexport const LOCAL_PORT = Number(process.env.LM_LOCAL_PORT ?? 8080);\nexport const LOCAL_BASE = `http://localhost:${LOCAL_PORT}`;\n\n/** True when the whole harness should target the local server rather than a prod pod. */\nexport const LOCAL =\n  process.env.SCENARIO_TARGET === 'local' || /localhost|127\\.0\\.0\\.1/.test(process.env.LM_POD_BASE ?? '');\n\n/**\n * State (pidfile, log, pod-root) is keyed by PORT, so a lane that wants ISOLATION can set\n * `LM_LOCAL_PORT` and get its own server instead of sharing the default one. That matters because a\n * restart is not a private act: `local-server.mjs restart` kills the shared process, and every other\n * lane's in-flight turn dies with it. A scenario whose authoring turns run 10+ minutes cannot\n * survive on a server that its siblings rebuild every few minutes — it gets interrupted, re-sends,\n * and burns the budget again. The default port keeps the original shared dir, so nothing moves for\n * lanes that are happy sharing.\n */\nconst DIR = join(STATE_DIR, LOCAL_PORT === 8080 ? 'local-server' : `local-server-${LOCAL_PORT}`);\nconst PID_FILE = join(DIR, 'pid');\nconst LOCK_FILE = join(DIR, 'starting.lock');\nconst LOG_FILE = join(DIR, 'serve.log');\n/** Dedicated runtime root so scenario projects never touch a dev `<cwd>/.lmthing`. */\nconst POD_ROOT = join(DIR, 'pod-root');\nconst BIN = join(SDK_ORG, 'libs', 'cli', 'dist', 'cli', 'bin.js');\n\n/** Does the server answer at all? `GET /api/projects` needs no body/auth and is cheap. */\nexport async function serverUp(base = LOCAL_BASE, { timeoutMs = 1500 } = {}) {\n  try {\n    const ctl = AbortSignal.timeout(timeoutMs);\n    const res = await fetch(`${base}/api/projects`, { signal: ctl });\n    return res.status > 0; // any HTTP answer means it's listening\n  } catch {\n    return false;\n  }\n}\n\nfunction pidAlive(pid) {\n  if (!pid) return false;\n  try {\n    process.kill(pid, 0);\n    return true;\n  } catch (e) {\n    return e?.code === 'EPERM';\n  }\n}\n\nfunction readPid() {\n  try {\n    const pid = Number(readFileSync(PID_FILE, 'utf8').trim());\n    return Number.isInteger(pid) && pid > 0 ? pid : null;\n  } catch {\n    return null;\n  }\n}\n\nconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n\nasync function waitUp(base, { attempts = 120, everyMs = 1000 } = {}) {\n  for (let i = 0; i < attempts; i++) {\n    if (await serverUp(base)) return true;\n    await sleep(everyMs);\n  }\n  return false;\n}\n\n/**\n * Guarantee a local server is listening; return its base URL. Idempotent and race-safe across\n * concurrent lanes: whoever wins the exclusive lock spawns it, everyone else waits for it to come\n * up. A stale lock (holder died before writing a live pid) is broken after a grace period.\n */\nexport async function ensureLocalServer() {\n  if (await serverUp()) return LOCAL_BASE;\n  mkdirSync(DIR, { recursive: true });\n  mkdirSync(POD_ROOT, { recursive: true });\n\n  // Exclusive-create the lock. If someone else holds it, they're booting — wait for the port.\n  let lockFd;\n  try {\n    lockFd = openSync(LOCK_FILE, 'wx');\n  } catch (e) {\n    if (e?.code !== 'EEXIST') throw e;\n    // Break a stale lock (>90s old and no live server, no live pid) so a crashed boot can't wedge us.\n    const stale = Date.now() - safeMtime(LOCK_FILE) > 90_000;\n    if (stale && !(await serverUp()) && !pidAlive(readPid())) {\n      rmSync(LOCK_FILE, { force: true });\n      return ensureLocalServer();\n    }\n    if (await waitUp(LOCAL_BASE)) return LOCAL_BASE;\n    throw new Error('local server never came up (another lane held the start lock)');\n  }\n\n  try {\n    // A pid may already be live even though the probe missed (mid-boot) — attach to it.\n    if (pidAlive(readPid()) && (await waitUp(LOCAL_BASE, { attempts: 30 }))) return LOCAL_BASE;\n\n    const logFd = openSync(LOG_FILE, 'a');\n    // `--adopt-system-spaces`: this pod-root is a throwaway we own, so always take the freshly\n    // built system-space tree (dist/system-spaces) on restart — that's how an agent's system-space\n    // prompt improvements land after `pnpm build && local-server.mjs restart`.\n    // `--max-sessions`: the default (8) is sized for ONE user's chat tabs. This server is shared by\n    // every scenario lane at once, and a single authoring turn adds a delegate sub-session per\n    // specialist it fans out to — so a handful of concurrent lanes blow past 8 easily, and the\n    // capacity gate then sheds sessions the lanes are still using.\n    const child = spawn(process.execPath, [BIN, 'serve', '--port', String(LOCAL_PORT), '--adopt-system-spaces', '--max-sessions', '40'], {\n      cwd: SDK_ORG, // read sdk/org/.env → Azure keys credential the agents (budget-free direct Azure)\n      env: { ...process.env, LMTHING_ROOT: join(POD_ROOT, '.lmthing') },\n      detached: true, // own process group → survives the agent, killable as a tree\n      stdio: ['ignore', logFd, logFd],\n    });\n    closeSync(logFd);\n    child.unref();\n    writeFileSync(PID_FILE, String(child.pid));\n    if (!(await waitUp(LOCAL_BASE))) throw new Error(`local server did not listen on :${LOCAL_PORT} — see ${LOG_FILE}`);\n    return LOCAL_BASE;\n  } finally {\n    closeSync(lockFd);\n    rmSync(LOCK_FILE, { force: true });\n  }\n}\n\nfunction safeMtime(p) {\n  try {\n    return statSync(p).mtimeMs;\n  } catch {\n    return 0;\n  }\n}\n\n/** Kill the local server (whole process group) and clear its pidfile. */\nexport function stopLocalServer() {\n  const pid = readPid();\n  if (pidAlive(pid)) {\n    try {\n      process.kill(-pid, 'SIGTERM'); // negative → the detached group\n    } catch {\n      try {\n        process.kill(pid, 'SIGTERM');\n      } catch {\n        /* already gone */\n      }\n    }\n  }\n  rmSync(PID_FILE, { force: true });\n}\n\n/** Rebuild-then-restart flow: stop, wait for the port to free, bring a fresh server up. */\nexport async function restartLocalServer() {\n  stopLocalServer();\n  for (let i = 0; i < 30 && (await serverUp()); i++) await sleep(1000);\n  return ensureLocalServer();\n}\n\nexport function localStatus() {\n  const pid = readPid();\n  return { base: LOCAL_BASE, pid, alive: pidAlive(pid), podRoot: POD_ROOT, log: LOG_FILE };\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_WydT2UNbqbaRqCoZywUYgMto","type":"tool_result","content":"1\t/**\n2\t * lmthing.cloud gateway client — everything a scenario needs to stand up a disposable prod\n3\t * test user: register, provision the compute pod, load API keys into pod env, wake it.\n4\t *\n5\t * Budget note: scenarios burn real tokens. We deliberately load the **direct Azure** keys from\n6\t * `sdk/org/.env` into the pod env (AZURE_API_KEY + AZURE_RESOURCE_NAME + the LM_MODEL_* aliases),\n7\t * so agent traffic goes straight to Azure AI Foundry and never touches the per-user LiteLLM key\n8\t * that carries the tier budget. A user therefore does not \"run out\" mid-scenario. `budget()` is\n9\t * still exposed so a scenario can assert on spend, and `provisionUser()` is cheap enough to call\n10\t * again if a pod ever does get budget-capped.\n11\t */\n12\timport { readFileSync } from 'node:fs';\n13\timport { SDK_ORG } from './paths.mjs';\n14\timport { mintSession } from './jwt.mjs';\n15\timport { fetchResilient } from './pod.mjs';\n16\timport { LOCAL, LOCAL_BASE, ensureLocalServer } from './local.mjs';\n17\t\n18\texport const GATEWAY = process.env.LM_GATEWAY ?? 'https://lmthing.cloud';\n19\t\n20\tclass HttpError extends Error {\n21\t  constructor(method, url, status, body) {\n22\t    super(`${method} ${url} → ${status}: ${typeof body === 'string' ? body : JSON.stringify(body)}`);\n23\t    this.status = status;\n24\t    this.body = body;\n25\t  }\n26\t}\n27\t\n28\tasync function req(method, path, { token, body, base = GATEWAY } = {}) {\n29\t  const res = await fetchResilient(`${base}${path}`, {\n30\t    method,\n31\t    headers: {\n32\t      ...(body ? { 'content-type': 'application/json' } : {}),\n33\t      ...(token ? { authorization: `Bearer ${token}` } : {}),\n34\t    },\n35\t    ...(body ? { body: JSON.stringify(body) } : {}),\n36\t  });\n37\t  const text = await res.text();\n38\t  let parsed = text;\n39\t  try {\n40\t    parsed = JSON.parse(text);\n41\t  } catch {\n42\t    /* keep raw text */\n43\t  }\n44\t  if (!res.ok) throw new HttpError(method, path, res.status, parsed);\n45\t  return parsed;\n46\t}\n47\t\n48\t/** Parse `sdk/org/.env` into a plain object (no dotenv dep; ignores comments + blanks). */\n49\texport function readSdkEnv() {\n50\t  const raw = readFileSync(`${SDK_ORG}/.env`, 'utf8');\n51\t  const out = {};\n52\t  for (const line of raw.split('\\n')) {\n53\t    const m = /^\\s*([A-Z0-9_]+)\\s*=\\s*(.*)\\s*$/.exec(line);\n54\t    if (!m) continue; // comment or blank\n55\t    out[m[1]] = m[2].replace(/^[\"']|[\"']$/g, '');\n56\t  }\n57\t  return out;\n58\t}\n59\t\n60\t/**\n61\t * The env vars a pod needs to run agents against Azure directly (budget-free), plus web search.\n62\t * Anything absent from sdk/org/.env is simply omitted.\n63\t */\n64\texport function agentEnvFromSdk() {\n65\t  const env = readSdkEnv();\n66\t  const keys = [\n67\t    'AZURE_API_KEY',\n68\t    'AZURE_RESOURCE_NAME',\n69\t    'TAVILY_API_KEY',\n70\t    'LM_MODEL_XS',\n71\t    'LM_MODEL_S',\n72\t    'LM_MODEL_M',\n73\t    'LM_MODEL_L',\n74\t    'LM_MODEL_M_R',\n75\t    'LM_MODEL_L_R',\n76\t    'LM_MODEL_VISION',\n77\t    'LM_TRANSCRIBE_MODEL',\n78\t  ];\n79\t  const out = {};\n80\t  for (const k of keys) if (env[k]) out[k] = env[k];\n81\t  return out;\n82\t}\n83\t\n84\t/** `POST /api/auth/register` → { user_id, api_key }. Login is broken in prod; we mint instead. */\n85\texport async function register(email, password) {\n86\t  return req('POST', '/api/auth/register', { body: { email, password } });\n87\t}\n88\t\n89\texport const ensurePod = (token) => req('POST', '/api/compute/ensure', { token });\n90\texport const podStatus = (token) => req('GET', '/api/compute/status', { token });\n91\texport const wakePod = (token) => req('POST', '/api/compute/wake', { token });\n92\t\n93\t/**\n94\t * Remaining LiteLLM budget. NOTE this lives on the POD (`routes/budget.ts` relays the caller's\n95\t * Authorization to the gateway and computes the line with the master key) — there is no\n96\t * `/api/budget` on the gateway itself. Scenarios run on direct Azure keys, so this is\n97\t * informational: it tells you whether the tier key is exhausted, not whether the run can proceed.\n98\t */\n99\texport const budget = (token) => req('GET', '/api/budget', { token, base: podBase() });\n100\t\n101\t/**\n102\t * `PUT /api/compute/env` REPLACES the whole var set, so always GET-merge-PUT — clobbering the\n103\t * gateway-injected lmthingcloud creds would break the pod.\n104\t *\n105\t * A PUT rolls the deployment, and pod sessions are IN-MEMORY: any session created against the\n106\t * old pod dies with it (`GET /api/sessions/:id/events` → 404 unknown session). So we skip the\n107\t * write entirely when nothing would change — which is the common case on a reused test user.\n108\t *\n109\t * @returns {{merged: object, changed: boolean}}\n110\t */\n111\texport async function mergePodEnv(token, vars) {\n112\t  const current = await req('GET', '/api/compute/env', { token }).catch(() => ({ vars: {} }));\n113\t  const existing = current.vars ?? {};\n114\t  const merged = { ...existing, ...vars };\n115\t  const changed = Object.entries(merged).some(([k, v]) => existing[k] !== v);\n116\t  if (!changed) return { merged, changed: false };\n117\t  await req('PUT', '/api/compute/env', { token, body: { vars: merged } });\n118\t  return { merged, changed: true };\n119\t}\n120\t\n121\t/**\n122\t * Wait until a session created NOW would survive — i.e. the env-triggered rollout is finished.\n123\t *\n124\t * There is no reliable \"which pod process am I talking to\" signal from outside, and the gateway's\n125\t * `pod.ready` (readyReplicas > 0) stays true across a rolling update because the OLD replica is\n126\t * still ready. So we test the property we actually need, directly: create a probe session, wait,\n127\t * and confirm it still exists. If the pod rolled under us, the probe vanishes and we retry.\n128\t */\n129\texport async function waitPodSettled(token, base = podBase(), { attempts = 6, settleMs = 9_000 } = {}) {\n130\t  const headers = { authorization: `Bearer ${token}`, 'content-type': 'application/json' };\n131\t  for (let i = 0; i < attempts; i++) {\n132\t    try {\n133\t      const res = await fetch(`${base}/api/sessions`, {\n134\t        method: 'POST',\n135\t        headers,\n136\t        body: JSON.stringify({ projectId: 'user' }),\n137\t      });\n138\t      if (res.ok) {\n139\t        const { sessionId } = await res.json();\n140\t        await new Promise((r) => setTimeout(r, settleMs));\n141\t        const list = await fetch(`${base}/api/sessions`, { headers }).then((r) => r.json());\n142\t        const alive = (list.sessions ?? []).some((s) => s.sessionId === sessionId);\n143\t        if (alive) {\n144\t          // Clean up the probe so it doesn't pollute the scenario's session list.\n145\t          await fetch(`${base}/api/sessions/${sessionId}`, { method: 'DELETE', headers }).catch(() => {});\n146\t          return true;\n147\t        }\n148\t      }\n149\t    } catch {\n150\t      /* pod mid-roll — retry */\n151\t    }\n152\t    await new Promise((r) => setTimeout(r, 5_000));\n153\t  }\n154\t  throw new Error('pod never settled: a freshly created session keeps disappearing');\n155\t}\n156\t\n157\t/**\n158\t * Poll until the gateway reports the pod ready (or throw).\n159\t *\n160\t * Readiness lives at `status.pod.ready` / `status.pod.stage === 'ready'` — NOT at the top level.\n161\t * Note \"ready\" here means readyReplicas>0, which precedes Envoy actually wiring the woken\n162\t * endpoint (see the pod-readiness-edge race); callers that immediately hit the pod should\n163\t * tolerate one early 503, which `Pod.req` surfaces as a normal HttpError.\n164\t */\n165\texport async function waitPodReady(token, { timeoutMs = 180_000, intervalMs = 3_000 } = {}) {\n166\t  const deadline = Date.now() + timeoutMs;\n167\t  let last;\n168\t  while (Date.now() < deadline) {\n169\t    try {\n170\t      last = await podStatus(token);\n171\t      if (last?.pod?.ready || last?.pod?.stage === 'ready') return last;\n172\t    } catch (err) {\n173\t      last = { error: String(err) };\n174\t    }\n175\t    await new Promise((r) => setTimeout(r, intervalMs));\n176\t  }\n177\t  throw new Error(`pod not ready after ${timeoutMs}ms: ${JSON.stringify(last)}`);\n178\t}\n179\t\n180\t/**\n181\t * Full disposable-test-user provision: register → mint session → ensure pod → load agent keys →\n182\t * wait ready. Returns everything a scenario needs, including a `pod` base URL.\n183\t *\n184\t * Pods are reached through the chat origin: Envoy validates the JWT and routes on the `sub` claim\n185\t * to `lmthing.user-<id>.svc`, waking a scaled-to-zero pod on the way.\n186\t */\n187\texport async function provisionUser({ label = 'scn', password = 'Test-Passw0rd!' } = {}) {\n188\t  // Local target: no register, no JWT, no pod env PUT. Bring up (or attach to) the one shared\n189\t  // `lmthing serve`, which reads sdk/org/.env for the Azure keys itself. The pod does no auth, so\n190\t  // token is null; lanes are isolated by projectId, not by user, on this single server.\n191\t  if (LOCAL) {\n192\t    await ensureLocalServer();\n193\t    return { email: `${label}@local`, password, userId: `local-${label}`, session: null, token: null, pod: LOCAL_BASE };\n194\t  }\n195\t  const email = `${label}-${Date.now().toString(36)}@lmthing.test`;\n196\t  const { user_id: userId } = await register(email, password);\n197\t  const session = mintSession(userId, email);\n198\t  await ensurePod(session.accessToken);\n199\t  // Pod env must be loaded BEFORE the first agent turn: the PUT rolls the pod, and a restart\n200\t  // mid-scenario destroys in-memory sessions (it would look like a spurious failure).\n201\t  const { changed } = await mergePodEnv(session.accessToken, agentEnvFromSdk());\n202\t  await waitPodReady(session.accessToken);\n203\t  if (changed) await waitPodSettled(session.accessToken);\n204\t  return { email, password, userId, session, token: session.accessToken, pod: podBase() };\n205\t}\n206\t\n207\t/** The origin that fronts a user's pod (Envoy routes by JWT `sub`; local → the shared serve). */\n208\texport const podBase = () => process.env.LM_POD_BASE ?? (LOCAL ? LOCAL_BASE : 'https://lmthing.chat');\n209\t"}]},"parent_tool_use_id":null,"session_id":"0dcb5bd3-991a-418a-bd79-b78383bf23a4","uuid":"e6d774cc-17e5-42b8-90db-a6002759e48b","timestamp":"2026-07-14T16:41:52.972Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/scenarios/harness/lib/gateway.mjs","content":"/**\n * lmthing.cloud gateway client — everything a scenario needs to stand up a disposable prod\n * test user: register, provision the compute pod, load API keys into pod env, wake it.\n *\n * Budget note: scenarios burn real tokens. We deliberately load the **direct Azure** keys from\n * `sdk/org/.env` into the pod env (AZURE_API_KEY + AZURE_RESOURCE_NAME + the LM_MODEL_* aliases),\n * so agent traffic goes straight to Azure AI Foundry and never touches the per-user LiteLLM key\n * that carries the tier budget. A user therefore does not \"run out\" mid-scenario. `budget()` is\n * still exposed so a scenario can assert on spend, and `provisionUser()` is cheap enough to call\n * again if a pod ever does get budget-capped.\n */\nimport { readFileSync } from 'node:fs';\nimport { SDK_ORG } from './paths.mjs';\nimport { mintSession } from './jwt.mjs';\nimport { fetchResilient } from './pod.mjs';\nimport { LOCAL, LOCAL_BASE, ensureLocalServer } from './local.mjs';\n\nexport const GATEWAY = process.env.LM_GATEWAY ?? 'https://lmthing.cloud';\n\nclass HttpError extends Error {\n  constructor(method, url, status, body) {\n    super(`${method} ${url} → ${status}: ${typeof body === 'string' ? body : JSON.stringify(body)}`);\n    this.status = status;\n    this.body = body;\n  }\n}\n\nasync function req(method, path, { token, body, base = GATEWAY } = {}) {\n  const res = await fetchResilient(`${base}${path}`, {\n    method,\n    headers: {\n      ...(body ? { 'content-type': 'application/json' } : {}),\n      ...(token ? { authorization: `Bearer ${token}` } : {}),\n    },\n    ...(body ? { body: JSON.stringify(body) } : {}),\n  });\n  const text = await res.text();\n  let parsed = text;\n  try {\n    parsed = JSON.parse(text);\n  } catch {\n    /* keep raw text */\n  }\n  if (!res.ok) throw new HttpError(method, path, res.status, parsed);\n  return parsed;\n}\n\n/** Parse `sdk/org/.env` into a plain object (no dotenv dep; ignores comments + blanks). */\nexport function readSdkEnv() {\n  const raw = readFileSync(`${SDK_ORG}/.env`, 'utf8');\n  const out = {};\n  for (const line of raw.split('\\n')) {\n    const m = /^\\s*([A-Z0-9_]+)\\s*=\\s*(.*)\\s*$/.exec(line);\n    if (!m) continue; // comment or blank\n    out[m[1]] = m[2].replace(/^[\"']|[\"']$/g, '');\n  }\n  return out;\n}\n\n/**\n * The env vars a pod needs to run agents against Azure directly (budget-free), plus web search.\n * Anything absent from sdk/org/.env is simply omitted.\n */\nexport function agentEnvFromSdk() {\n  const env = readSdkEnv();\n  const keys = [\n    'AZURE_API_KEY',\n    'AZURE_RESOURCE_NAME',\n    'TAVILY_API_KEY',\n    'LM_MODEL_XS',\n    'LM_MODEL_S',\n    'LM_MODEL_M',\n    'LM_MODEL_L',\n    'LM_MODEL_M_R',\n    'LM_MODEL_L_R',\n    'LM_MODEL_VISION',\n    'LM_TRANSCRIBE_MODEL',\n  ];\n  const out = {};\n  for (const k of keys) if (env[k]) out[k] = env[k];\n  return out;\n}\n\n/** `POST /api/auth/register` → { user_id, api_key }. Login is broken in prod; we mint instead. */\nexport async function register(email, password) {\n  return req('POST', '/api/auth/register', { body: { email, password } });\n}\n\nexport const ensurePod = (token) => req('POST', '/api/compute/ensure', { token });\nexport const podStatus = (token) => req('GET', '/api/compute/status', { token });\nexport const wakePod = (token) => req('POST', '/api/compute/wake', { token });\n\n/**\n * Remaining LiteLLM budget. NOTE this lives on the POD (`routes/budget.ts` relays the caller's\n * Authorization to the gateway and computes the line with the master key) — there is no\n * `/api/budget` on the gateway itself. Scenarios run on direct Azure keys, so this is\n * informational: it tells you whether the tier key is exhausted, not whether the run can proceed.\n */\nexport const budget = (token) => req('GET', '/api/budget', { token, base: podBase() });\n\n/**\n * `PUT /api/compute/env` REPLACES the whole var set, so always GET-merge-PUT — clobbering the\n * gateway-injected lmthingcloud creds would break the pod.\n *\n * A PUT rolls the deployment, and pod sessions are IN-MEMORY: any session created against the\n * old pod dies with it (`GET /api/sessions/:id/events` → 404 unknown session). So we skip the\n * write entirely when nothing would change — which is the common case on a reused test user.\n *\n * @returns {{merged: object, changed: boolean}}\n */\nexport async function mergePodEnv(token, vars) {\n  const current = await req('GET', '/api/compute/env', { token }).catch(() => ({ vars: {} }));\n  const existing = current.vars ?? {};\n  const merged = { ...existing, ...vars };\n  const changed = Object.entries(merged).some(([k, v]) => existing[k] !== v);\n  if (!changed) return { merged, changed: false };\n  await req('PUT', '/api/compute/env', { token, body: { vars: merged } });\n  return { merged, changed: true };\n}\n\n/**\n * Wait until a session created NOW would survive — i.e. the env-triggered rollout is finished.\n *\n * There is no reliable \"which pod process am I talking to\" signal from outside, and the gateway's\n * `pod.ready` (readyReplicas > 0) stays true across a rolling update because the OLD replica is\n * still ready. So we test the property we actually need, directly: create a probe session, wait,\n * and confirm it still exists. If the pod rolled under us, the probe vanishes and we retry.\n */\nexport async function waitPodSettled(token, base = podBase(), { attempts = 6, settleMs = 9_000 } = {}) {\n  const headers = { authorization: `Bearer ${token}`, 'content-type': 'application/json' };\n  for (let i = 0; i < attempts; i++) {\n    try {\n      const res = await fetch(`${base}/api/sessions`, {\n        method: 'POST',\n        headers,\n        body: JSON.stringify({ projectId: 'user' }),\n      });\n      if (res.ok) {\n        const { sessionId } = await res.json();\n        await new Promise((r) => setTimeout(r, settleMs));\n        const list = await fetch(`${base}/api/sessions`, { headers }).then((r) => r.json());\n        const alive = (list.sessions ?? []).some((s) => s.sessionId === sessionId);\n        if (alive) {\n          // Clean up the probe so it doesn't pollute the scenario's session list.\n          await fetch(`${base}/api/sessions/${sessionId}`, { method: 'DELETE', headers }).catch(() => {});\n          return true;\n        }\n      }\n    } catch {\n      /* pod mid-roll — retry */\n    }\n    await new Promise((r) => setTimeout(r, 5_000));\n  }\n  throw new Error('pod never settled: a freshly created session keeps disappearing');\n}\n\n/**\n * Poll until the gateway reports the pod ready (or throw).\n *\n * Readiness lives at `status.pod.ready` / `status.pod.stage === 'ready'` — NOT at the top level.\n * Note \"ready\" here means readyReplicas>0, which precedes Envoy actually wiring the woken\n * endpoint (see the pod-readiness-edge race); callers that immediately hit the pod should\n * tolerate one early 503, which `Pod.req` surfaces as a normal HttpError.\n */\nexport async function waitPodReady(token, { timeoutMs = 180_000, intervalMs = 3_000 } = {}) {\n  const deadline = Date.now() + timeoutMs;\n  let last;\n  while (Date.now() < deadline) {\n    try {\n      last = await podStatus(token);\n      if (last?.pod?.ready || last?.pod?.stage === 'ready') return last;\n    } catch (err) {\n      last = { error: String(err) };\n    }\n    await new Promise((r) => setTimeout(r, intervalMs));\n  }\n  throw new Error(`pod not ready after ${timeoutMs}ms: ${JSON.stringify(last)}`);\n}\n\n/**\n * Full disposable-test-user provision: register → mint session → ensure pod → load agent keys →\n * wait ready. Returns everything a scenario needs, including a `pod` base URL.\n *\n * Pods are reached through the chat origin: Envoy validates the JWT and routes on the `sub` claim\n * to `lmthing.user-<id>.svc`, waking a scaled-to-zero pod on the way.\n */\nexport async function provisionUser({ label = 'scn', password = 'Test-Passw0rd!' } = {}) {\n  // Local target: no register, no JWT, no pod env PUT. Bring up (or attach to) the one shared\n  // `lmthing serve`, which reads sdk/org/.env for the Azure keys itself. The pod does no auth, so\n  // token is null; lanes are isolated by projectId, not by user, on this single server.\n  if (LOCAL) {\n    await ensureLocalServer();\n    return { email: `${label}@local`, password, userId: `local-${label}`, session: null, token: null, pod: LOCAL_BASE };\n  }\n  const email = `${label}-${Date.now().toString(36)}@lmthing.test`;\n  const { user_id: userId } = await register(email, password);\n  const session = mintSession(userId, email);\n  await ensurePod(session.accessToken);\n  // Pod env must be loaded BEFORE the first agent turn: the PUT rolls the pod, and a restart\n  // mid-scenario destroys in-memory sessions (it would look like a spurious failure).\n  const { changed } = await mergePodEnv(session.accessToken, agentEnvFromSdk());\n  await waitPodReady(session.accessToken);\n  if (changed) await waitPodSettled(session.accessToken);\n  return { email, password, userId, session, token: session.accessToken, pod: podBase() };\n}\n\n/** The origin that fronts a user's pod (Envoy routes by JWT `sub`; local → the shared serve). */\nexport const podBase = () => process.env.LM_POD_BASE ?? (LOCAL ? LOCAL_BASE : 'https://lmthing.chat');\n",