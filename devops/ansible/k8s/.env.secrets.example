# Domain
DOMAIN=lmthing.cloud
COMPUTER_DOMAIN=lmthing.computer
AUTH_DOMAIN=auth.lmthing.cloud
BASE_URL=https://lmthing.cloud
ACME_EMAIL=admin@lmthing.cloud

# Azure Foundry
AZURE_API_KEY=your-azure-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com

# PostgreSQL (K8s StatefulSet — generate passwords with: openssl rand -hex 24)
POSTGRES_USER=lmthing
POSTGRES_PASSWORD=your-postgres-password
ZITADEL_DB_PASSWORD=your-zitadel-db-password
DATABASE_URL=postgresql://lmthing:your-postgres-password@postgres:5432/lmthing

# Zitadel (self-hosted at AUTH_DOMAIN)
# ZITADEL_MASTER_KEY: generate with: openssl rand -hex 16 (must be exactly 32 chars)
ZITADEL_MASTER_KEY=your-32-char-master-key
ZITADEL_ADMIN_PASSWORD=your-initial-admin-password
ZITADEL_ISSUER=https://auth.lmthing.cloud
# After initial Zitadel setup, create a machine user and fill these in:
ZITADEL_SERVICE_ACCOUNT_ID=your-machine-user-client-id
ZITADEL_SERVICE_ACCOUNT_KEY=your-machine-user-client-secret
ZITADEL_CLIENT_ID=your-web-app-client-id
ZITADEL_CLIENT_SECRET=your-web-app-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_BASIC=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_MAX=price_xxx

# LiteLLM (generate with: echo "sk-lmt-$(openssl rand -hex 32)")
LITELLM_MASTER_KEY=sk-lmt-xxx
