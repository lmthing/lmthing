{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_u4s2hx3zecES9hIhuNjRAJ8M","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { resolve } from 'node:path';\n3\timport { loadSpace } from './load.js';\n4\timport { runTasklist } from '../tasklist/orchestrator.js';\n5\timport { ForkEngine } from '../fork/fork.js';\n6\timport { createMockStreamFn } from '../testing/mock-provider.js';\n7\timport type { RenderHost } from '../session/types.js';\n8\timport type { StreamOpts } from '../eval/stream-types.js';\n9\t\n10\t/**\n11\t * Mock end-to-end coverage for P6's design guarantee: `user-thing`'s\n12\t * `build_specialist` tasklist ALWAYS runs the build step, even when the\n13\t * upstream research task degrades/salvages\n14\t * (.issues/thing-abandons-build-on-salvaged-research.md /\n15\t * .issues/investigate-forks-degrade-under-delegate-nesting.md — the exact\n16\t * failure mode this tasklist shape was built to route around structurally).\n17\t *\n18\t * Runs the REAL shipped `libs/core/system-spaces/user-thing/tasklists/\n19\t * build_specialist` files through the real orchestrator + ForkEngine, with a\n20\t * scripted `streamFn` standing in for the model and a scripted\n21\t * `delegateRunner` standing in for the real `system-research` / `system-architect`\n22\t * spaces (those are exercised by other e2e tests — this test isolates the\n23\t * \"degraded upstream doesn't abort downstream\" DAG behavior).\n24\t *\n25\t * Degrading the `research` task: its prelude ALREADY performs the\n26\t * `delegate('system-research', 'researcher', 'deep_research', …)` call (see\n27\t * `01-research.md`) — the model's only job is a single\n28\t * `currentTask.resolve({ report: … })` statement. Returning `''` for every one\n29\t * of the research fork's turns (initial + the 2 forced resolve-nudge turns)\n30\t * means the model NEVER calls resolve, so `fork.ts`'s guarantee kicks in: it\n31\t * salvages a NEUTRAL schema-valid placeholder (`{ report: {} }`, reason\n32\t * `no_resolve`) rather than throwing — this is the established\n33\t * \"mock model never resolves\" salvage pattern used by\n34\t * `tasklist/delegate-in-task.test.ts`.\n35\t */\n36\t\n37\tconst SYS = resolve(__dirname, '..', '..', 'system-spaces');\n38\tconst USER_THING_DIR = resolve(SYS, 'user-thing');\n39\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n40\t\n41\t// Markers unique to each task's instruction body (see the real .md files) —\n42\t// robust against wording tweaks elsewhere in the file, since these are the\n43\t// exact contract sentences the task files are built around.\n44\tconst RESEARCH_MARKER = 'Package the domain research for the build step.';\n45\tconst BUILD_MARKER = \"Hand the user's `request`\";\n46\t\n47\tdescribe('build_specialist mock e2e: degraded research → build still runs', () => {\n48\t  it('salvages the optional research task but still delegates the build task to the architect, producing a schema-shaped (non-prose) TaskEnvelope', async () => {\n49\t    const space = await loadSpace(USER_THING_DIR, { requireAgents: false });\n50\t\n51\t    const delegateCalls: Array<{ pkg: string; agent: string; action?: string }> = [];\n52\t    let buildTurn = 0;\n53\t\n54\t    const streamFn = createMockStreamFn((o: StreamOpts) => {\n55\t      const text = o.system + '\\n' + o.messages.map((m) => m.content).join('\\n');\n56\t\n57\t      if (text.includes(RESEARCH_MARKER)) {\n58\t        // The research fork's model never resolves on ANY of its turns (initial\n59\t        // call + 2 forced resolve-nudges) — forces fork.ts's salvage path.\n60\t        return '';\n61\t      }\n62\t\n63\t      if (text.includes(BUILD_MARKER)) {\n64\t        buildTurn++;\n65\t        if (buildTurn === 1) {\n66\t          // Mirrors 02-build.md's first statement verbatim.\n67\t          return `const t = await delegate('system-architect', 'architect', 'synthesize_and_run', { query: String(request), context: { topic: String(request), goal: String(request), research: (research && research.report) ? research.report : {} } });`;\n68\t        }\n69\t        // Mirrors 02-build.md's packaging + resolve statements verbatim.\n70\t        return [\n71\t          'const built = (t && t.data) ? t.data : { spaceKey: \"\", agentSlug: \"\", actionId: \"\", query: \"\", ok: false, errors: \"the architect returned no result\" };',\n72\t          'currentTask.resolve({ spaceKey: String(built.spaceKey || \"\"), agentSlug: String(built.agentSlug || \"\"), actionId: String(built.actionId || \"\"), query: String(built.query || request), ok: !!(t && t.ok === true && built.ok === true), errors: String(built.errors || \"\") });',\n73\t        ].join('\\n');\n74\t      }\n75\t\n76\t      throw new Error(`unexpected fork prompt (no marker matched):\\n${text.slice(0, 300)}`);\n77\t    });\n78\t\n79\t    const engine = new ForkEngine({\n80\t      maxConcurrentForks: 2,\n81\t      parentHistory: [],\n82\t      parentSpaceDir: USER_THING_DIR,\n83\t      parentAgentSlug: 'thing',\n84\t      renderHost: silentHost,\n85\t      streamFn,\n86\t      delegateRunner: async (pkg, agent, action) => {\n87\t        delegateCalls.push({ pkg, agent, action });\n88\t        if (pkg === 'system-research' && agent === 'researcher' && action === 'deep_research') {\n89\t          // Stand-in for a degraded researcher run (the real failure mode in\n90\t          // the linked .issues/ — the report comes back empty/salvaged).\n91\t          // Neutral/schema-shaped per exec/envelope.ts, never prose.\n92\t          return { ok: false, degraded: true, data: {}, reason: 'no_resolve', degradedTasks: ['scope', 'investigate[0]'] };\n93\t        }\n94\t        if (pkg === 'system-architect' && agent === 'architect' && action === 'synthesize_and_run') {\n95\t          return {\n96\t            ok: true,\n97\t            degraded: false,\n98\t            data: { spaceKey: 'user/dog-expert', agentSlug: 'dog-expert', actionId: 'answer', query: 'a dog breed helper', ok: true, errors: '' },\n99\t          };\n100\t        }\n101\t        throw new Error(`unexpected delegate target in mock: ${pkg}/${agent}#${action}`);\n102\t      },\n103\t    });\n104\t\n105\t    const env = await runTasklist({\n106\t      name: 'build_specialist',\n107\t      space,\n108\t      forkEngine: engine,\n109\t      seed: { request: 'a dog breed helper' },\n110\t    });\n111\t\n112\t    // (a) The build task's delegate to the architect was actually reached —\n113\t    // proof the DAG did not short-circuit after the research task salvaged.\n114\t    expect(delegateCalls).toContainEqual({ pkg: 'system-architect', agent: 'architect', action: 'synthesize_and_run' });\n115\t    // The research task's prelude-driven delegate ran too (host-executed,\n116\t    // before the model's first turn — independent of the model ever resolving).\n117\t    expect(delegateCalls).toContainEqual({ pkg: 'system-research', agent: 'researcher', action: 'deep_research' });\n118\t\n119\t    // (b) TaskEnvelope signals the degradation in the CONTROL plane: the\n120\t    // research task (never resolved by the mock model) is listed as salvaged.\n121\t    expect(env.degraded).toBe(true);\n122\t    expect(env.degradedTasks).toContain('research');\n123\t\n124\t    // The build task itself resolved cleanly (mock architect delegate\n125\t    // succeeded) — the overall run is `ok`, even though a task salvaged.\n126\t    expect(env.ok).toBe(true);\n127\t\n128\t    // (c) `data` is schema-shaped, never prose: exactly the build task's\n129\t    // declared output fields, with real (non-empty, non-placeholder) values,\n130\t    // and — the whole point of Phase 3's envelope redesign — no alarming\n131\t    // \"(unavailable …)\" placeholder text anywhere in the data plane.\n132\t    const data = env.data as Record<string, unknown>;\n133\t    expect(Object.keys(data).sort()).toEqual(['actionId', 'agentSlug', 'errors', 'ok', 'query', 'spaceKey']);\n134\t    expect(data).toEqual({\n135\t      spaceKey: 'user/dog-expert',\n136\t      agentSlug: 'dog-expert',\n137\t      actionId: 'answer',\n138\t      query: 'a dog breed helper',\n139\t      ok: true,\n140\t      errors: '',\n141\t    });\n142\t    for (const v of Object.values(data)) {\n143\t      if (typeof v === 'string') expect(v.toLowerCase()).not.toContain('unavailable');\n144\t    }\n145\t  });\n146\t});\n147\t"}]},"parent_tool_use_id":null,"session_id":"b8a0991b-bce4-420b-844a-664f990ff54b","uuid":"12ab63ea-0cf3-4f87-a3c3-6c2f905cf826","timestamp":"2026-07-15T22:51:11.636Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/spaces/build-specialist-mock-e2e.test.ts","content":"import { describe, it, expect } from 'vitest';\nimport { resolve } from 'node:path';\nimport { loadSpace } from './load.js';\nimport { runTasklist } from '../tasklist/orchestrator.js';\nimport { ForkEngine } from '../fork/fork.js';\nimport { createMockStreamFn } from '../testing/mock-provider.js';\nimport type { RenderHost } from '../session/types.js';\nimport type { StreamOpts } from '../eval/stream-types.js';\n\n/**\n * Mock end-to-end coverage for P6's design guarantee: `user-thing`'s\n * `build_specialist` tasklist ALWAYS runs the build step, even when the\n * upstream research task degrades/salvages\n * (.issues/thing-abandons-build-on-salvaged-research.md /\n * .issues/investigate-forks-degrade-under-delegate-nesting.md — the exact\n * failure mode this tasklist shape was built to route around structurally).\n *\n * Runs the REAL shipped `libs/core/system-spaces/user-thing/tasklists/\n * build_specialist` files through the real orchestrator + ForkEngine, with a\n * scripted `streamFn` standing in for the model and a scripted\n * `delegateRunner` standing in for the real `system-research` / `system-architect`\n * spaces (those are exercised by other e2e tests — this test isolates the\n * \"degraded upstream doesn't abort downstream\" DAG behavior).\n *\n * Degrading the `research` task: its prelude ALREADY performs the\n * `delegate('system-research', 'researcher', 'deep_research', …)` call (see\n * `01-research.md`) — the model's only job is a single\n * `currentTask.resolve({ report: … })` statement. Returning `''` for every one\n * of the research fork's turns (initial + the 2 forced resolve-nudge turns)\n * means the model NEVER calls resolve, so `fork.ts`'s guarantee kicks in: it\n * salvages a NEUTRAL schema-valid placeholder (`{ report: {} }`, reason\n * `no_resolve`) rather than throwing — this is the established\n * \"mock model never resolves\" salvage pattern used by\n * `tasklist/delegate-in-task.test.ts`.\n */\n\nconst SYS = resolve(__dirname, '..', '..', 'system-spaces');\nconst USER_THING_DIR = resolve(SYS, 'user-thing');\nconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n\n// Markers unique to each task's instruction body (see the real .md files) —\n// robust against wording tweaks elsewhere in the file, since these are the\n// exact contract sentences the task files are built around.\nconst RESEARCH_MARKER = 'Package the domain research for the build step.';\nconst BUILD_MARKER = \"Hand the user's `request`\";\n\ndescribe('build_specialist mock e2e: degraded research → build still runs', () => {\n  it('salvages the optional research task but still delegates the build task to the architect, producing a schema-shaped (non-prose) TaskEnvelope', async () => {\n    const space = await loadSpace(USER_THING_DIR, { requireAgents: false });\n\n    const delegateCalls: Array<{ pkg: string; agent: string; action?: string }> = [];\n    let buildTurn = 0;\n\n    const streamFn = createMockStreamFn((o: StreamOpts) => {\n      const text = o.system + '\\n' + o.messages.map((m) => m.content).join('\\n');\n\n      if (text.includes(RESEARCH_MARKER)) {\n        // The research fork's model never resolves on ANY of its turns (initial\n        // call + 2 forced resolve-nudges) — forces fork.ts's salvage path.\n        return '';\n      }\n\n      if (text.includes(BUILD_MARKER)) {\n        buildTurn++;\n        if (buildTurn === 1) {\n          // Mirrors 02-build.md's first statement verbatim.\n          return `const t = await delegate('system-architect', 'architect', 'synthesize_and_run', { query: String(request), context: { topic: String(request), goal: String(request), research: (research && research.report) ? research.report : {} } });`;\n        }\n        // Mirrors 02-build.md's packaging + resolve statements verbatim.\n        return [\n          'const built = (t && t.data) ? t.data : { spaceKey: \"\", agentSlug: \"\", actionId: \"\", query: \"\", ok: false, errors: \"the architect returned no result\" };',\n          'currentTask.resolve({ spaceKey: String(built.spaceKey || \"\"), agentSlug: String(built.agentSlug || \"\"), actionId: String(built.actionId || \"\"), query: String(built.query || request), ok: !!(t && t.ok === true && built.ok === true), errors: String(built.errors || \"\") });',\n        ].join('\\n');\n      }\n\n      throw new Error(`unexpected fork prompt (no marker matched):\\n${text.slice(0, 300)}`);\n    });\n\n    const engine = new ForkEngine({\n      maxConcurrentForks: 2,\n      parentHistory: [],\n      parentSpaceDir: USER_THING_DIR,\n      parentAgentSlug: 'thing',\n      renderHost: silentHost,\n      streamFn,\n      delegateRunner: async (pkg, agent, action) => {\n        delegateCalls.push({ pkg, agent, action });\n        if (pkg === 'system-research' && agent === 'researcher' && action === 'deep_research') {\n          // Stand-in for a degraded researcher run (the real failure mode in\n          // the linked .issues/ — the report comes back empty/salvaged).\n          // Neutral/schema-shaped per exec/envelope.ts, never prose.\n          return { ok: false, degraded: true, data: {}, reason: 'no_resolve', degradedTasks: ['scope', 'investigate[0]'] };\n        }\n        if (pkg === 'system-architect' && agent === 'architect' && action === 'synthesize_and_run') {\n          return {\n            ok: true,\n            degraded: false,\n            data: { spaceKey: 'user/dog-expert', agentSlug: 'dog-expert', actionId: 'answer', query: 'a dog breed helper', ok: true, errors: '' },\n          };\n        }\n        throw new Error(`unexpected delegate target in mock: ${pkg}/${agent}#${action}`);\n      },\n    });\n\n    const env = await runTasklist({\n      name: 'build_specialist',\n      space,\n      forkEngine: engine,\n      seed: { request: 'a dog breed helper' },\n    });\n\n    // (a) The build task's delegate to the architect was actually reached —\n    // proof the DAG did not short-circuit after the research task salvaged.\n    expect(delegateCalls).toContainEqual({ pkg: 'system-architect', agent: 'architect', action: 'synthesize_and_run' });\n    // The research task's prelude-driven delegate ran too (host-executed,\n    // before the model's first turn — independent of the model ever resolving).\n    expect(delegateCalls).toContainEqual({ pkg: 'system-research', agent: 'researcher', action: 'deep_research' });\n\n    // (b) TaskEnvelope signals the degradation in the CONTROL plane: the\n    // research task (never resolved by the mock model) is listed as salvaged.\n    expect(env.degraded).toBe(true);\n    expect(env.degradedTasks).toContain('research');\n\n    // The build task itself resolved cleanly (mock architect delegate\n    // succeeded) — the overall run is `ok`, even though a task salvaged.\n    expect(env.ok).toBe(true);\n\n    // (c) `data` is schema-shaped, never prose: exactly the build task's\n    // declared output fields, with real (non-empty, non-placeholder) values,\n    // and — the whole point of Phase 3's envelope redesign — no alarming\n    // \"(unavailable …)\" placeholder text anywhere in the data plane.\n    const data = env.data as Record<string, unknown>;\n    expect(Object.keys(data).sort()).toEqual(['actionId', 'agentSlug', 'errors', 'ok', 'query', 'spaceKey']);\n    expect(data).toEqual({\n      spaceKey: 'user/dog-expert',\n      agentSlug: 'dog-expert',\n      actionId: 'answer',\n      query: 'a dog breed helper',\n      ok: true,\n      errors: '',\n    });\n    for (const v of Object.values(data)) {\n      if (typeof v === 'string') expect(v.toLowerCase()).not.toContain('unavailable');\n    }\n  });\n});\n","numLines":147,"startLine":1,"totalLines":147}}}
