nst c = {\\n  name: \\\"ContactBadge\\\",\\n  purpose: \\\"Small badge/chip showing contact name, type icon (person vs hotel), and role.\\\",\\n  props: [\\\"contact_name: string\\\", \\\"contact_type: string\\\", \\\"role: string | null\\\", \\\"notes: string | null\\\"],\\n}\"}],\"model\":\"azure:DeepSeek-V4-Pro\"}},{\"seq\":1286,\"event\":{\"ts\":1784229531699,\"type\":\"statement\",\"context\":\"fork:implement_components\",\"nodeId\":\"fork_139_723b6419\",\"code\":\"// Write the MemoryCard component — presentational card for \n---\ntype CategoryTotal = { category: string; total_usd: number };\\\",\\n  \\\"\\\",\\n  \\\"type SummaryData = {\\\",\\n  \\\"  items: CategoryTotal[];\\\",\\n  \\\"  grand_total_usd: number;\\\",\\n  \\\"};\\\",\\n  \\\"\\\",\\n  \\\"const CATEGORIES = ['all', 'flight', 'accommodation', 'park_fee', 'safari_package', 'souvenir', 'tip'] as const;\\\",\\n  \\\"const CURRENCIES = ['all', 'USD', 'EUR', 'TZS'] as const;\\\",\\n  \\\"\\\",\\n  \\\"export default function CostsPage() {\\\",\\n  \\\"  const [filterCategory, setFilterCategory] = useState<string>('all');\\\",\\n  \\\"  const [filterCurrency, setFilterCurrency] = useState<string>('all');\\\",\\n  \\\"\\\",\\n  \\\"  const { data: listData, isLoading: listLoading, error: listError } = useApi<{ items: CostItem[] }>('trip-costs-list');\\\",\\n  \\\"  const { data: summaryData, isLoading: summaryLoading, error: summaryError } = useApi<{ items: CategoryTotal[]; grand_total_usd: number }>('trip-costs-summary');\\\",\\n  \\\"\\\",\\n  \\\"  const isLoading = listLoading || summaryLoading;\\\",\\n  \\\"  const error = listError || summaryError;\\\",\\n  \\\"\\\",\\n  \\\"  if (isLoading) return (\\\",\\n  \\\"    <div className=\\\\\\\"p-4 space-y-4\\\\\\\">\\\",\\n  \\\"      <div className=\\\\\\\"h-24 bg-primary/10 rounded-lg animate-pulse\\\\\\\" />\\\",\\n  \\\"      \n---\ntype CategoryTotal = { category: string; total_usd: number };\\\",\\n  \\\"\\\",\\n  \\\"type SummaryData = {\\\",\\n  \\\"  items: CategoryTotal[];\\\",\\n  \\\"  grand_total_usd: number;\\\",\\n  \\\"};\\\",\\n  \\\"\\\",\\n  \\\"const CATEGORIES = ['all', 'flight', 'accommodation', 'park_fee', 'safari_package', 'souvenir', 'tip'] as const;\\\",\\n  \\\"const CURRENCIES = ['all', 'USD', 'EUR', 'TZS'] as const;\\\",\\n  \\\"\\\",\\n  \\\"export default function CostsPage() {\\\",\\n  \\\"  const [filterCategory, setFilterCategory] = useState<string>('all');\\\",\\n  \\\"  const [filterCurrency, setFilterCurrency] = useState<string>('all');\\\",\\n  \\\"\\\",\\n  \\\"  const { data: listData, isLoading: listLoading, error: listError } = useApi<{ items: CostItem[] }>('trip-costs-list');\\\",\\n  \\\"  const { data: summaryData, isLoading: summaryLoading, error: summaryError } = useApi<{ items: CategoryTotal[]; grand_total_usd: number }>('trip-costs-summary');\\\",\\n  \\\"\\\",\\n  \\\"  const isLoading = listLoading || summaryLoading;\\\",\\n  \\\"  const error = listError || summaryError;\\\",\\n  \\\"\\\",\\n  \\\"  if (isLoading) return (\\\",\\n  \\\"    <div className=\\\\\\\"p-4 space-y-4\\\\\\\">\\\",\\n  \\\"      <div className=\\\\\\\"h-24 bg-primary/10 rounded-lg animate-pulse\\\\\\\" />\\\",\\n  \\\"      \n---","is_error":false}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"ee9b0b5c-4f8e-470e-b6bd-5e31d116823a","timestamp":"2026-07-16T19:22:38.815Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_NpbEXy7wO4pwgBEewzGd7At7","type":"tool_result","content":"220\t// holds).\n221\texport const PROJECT_AUTHORING_DTS = `declare function writeProjectHook(slug: string, src: string): { ok: boolean; error?: string };\n222\tdeclare function writeProjectEvent(name: string, src: string): { ok: boolean; error?: string };\n223\tdeclare function writeProjectFunction(name: string, src: string): { ok: boolean; error?: string };`;\n224\t\n225\t// `db:schema` also earns `writeTableSchema` — the AUTHORING form that writes a\n226\t// `database/<name>.json` schema file into the catalog app (distinct from the runtime\n227\t// `db.createTable` migration on `db`). Emitted alongside `composeDbDts` when db:schema\n228\t// is granted (see buildAppCapabilityDts) — kept OUT of composeDbDts because it is a\n229\t// standalone global, not a member of the `db` object.\n230\texport const WRITE_TABLE_SCHEMA_DTS = `declare function writeTableSchema(name: string, schema: unknown): { ok: boolean; error?: string };`;\n231\t\n232\t// `db:schema` ALSO earns the LIVE-PROJECT table writer, the twin of the S11 live hook/\n233\t// event/function writers: `writeTableSchema` targets a store/projects/<id>/ TEMPLATE,\n234\t// while `writeProjectTable` writes `database/<name>.json` into the project the session is\n235\t// actually running in and re-derives its db (a project with no table has no db at all).\n236\t// Emitted only when the host supplies the impl (i.e. a project-rooted session), so a\n237\t// catalog-only appbuilder session leaves it absent and a stray call fails typecheck.\n238\t// The optional third arg SEEDS rows at table-creation time (host-side insert after the db\n239\t// re-derives), so KNOWN data the user gave you to \"move into the app\" lands in one pass — the\n240\t// agent can't insert into a table it just created (`db` isn't injected until a table exists).\n241\texport const PROJECT_TABLE_DTS = `declare function writeProjectTable(name: string, schema: unknown, rows?: Array<Record<string, unknown>>): { ok: boolean; error?: string };`;\n242\t\n243\t// The read-side twins of the writeProject* writers — PROJECT-ROOTED introspection. `listProjectDir`\n244\t// lists the files under `<projectRoot>/<dir>` (a missing dir returns `entries: []`); `readProjectFile`\n245\t// reads a project file's text. These resolve against the PROJECT, unlike the space-rooted\n246\t// `execShell`/`readFileRaw` (+ the `listDir`/`readFile` system-global wrappers), which root at the\n247\t// agent's OWN `LMTHING_SPACE_DIR` — a footgun for a delegated system-space agent whose space dir is\n248\t// its source tree. A project-authoring agent uses THESE to see what already exists in the project.\n249\t// Emitted on any db grant + a project-rooted session (see buildAppCapabilityDts / injectAppGlobals).\n250\texport const PROJECT_READ_DTS = `declare function listProjectDir(dir: string): { ok: boolean; entries: string[]; error?: string };\n251\tdeclare function readProjectFile(path: string): { ok: boolean; content: string; error?: string };`;\n252\t\n253\t// `project:manage` — the appbuilder's authority to scaffold or bind a catalog app.\n254\t// createProject creates a NEW store/apps/<id>/ template + selects it as the authoring\n255\t// target; selectProject binds an existing one. Subsequent writePage/writeApi/... land\n256\t// in the currently-selected app. Synchronous host calls.\n257\texport const PROJECT_MANAGE_DTS = `declare function createProject(id: string, opts?: { title?: string }): { ok: boolean; appId?: string; root?: string; error?: string };\n258\tdeclare function selectProject(id: string): { ok: boolean; appId?: string; root?: string; error?: string };`;\n259\t\n260\t// `store:read` earns the two catalog-discovery globals (plan S10). Both are\n261\t// value-yielding (Promise); entries are the store catalog records VERBATIM\n262\t// (S12-enriched fields flow through), `any` by convention so `entry.field`\n263\t// reads without casts.\n264\texport const STORE_READ_DTS = `/** Search the lmthing store's space catalog (id/title/description/tag match; omit query for the full catalog). */\n265\tdeclare function storeSearch(query?: string): Promise<any[]>;\n266\t/** The full catalog entry for one store space, or undefined when the id is not in the catalog. */\n267\tdeclare function storeInspect(spaceId: string): Promise<any>;`;\n268\t\n269\t// `store:install` earns the CONSENT-MARKED `installSpace` (plan S10): the host\n270\t// asks the user for approval before installing; denial rejects the call. On\n271\t// success the space is installed into the CURRENT project AND live-registered —\n272\t// spaceKey/agentSlug are ready for delegate(). ok:false + diverged:true means\n273\t// local edits were held back (relay the message to the user).\n274\texport const STORE_INSTALL_DTS = `/** Install a store space into the current project and live-register it for delegate(). Asks the user for consent first; denial rejects. */\n275\tdeclare function installSpace(spaceId: string): Promise<{ ok: boolean; spaceId: string; projectId?: string; spaceKey?: string; agentSlug?: string; diverged?: boolean; message?: string; error?: string }>;`;\n276\t\n277\t// `events:emit` earns `emitEvent` (plan S10) — publish an event DECLARED by the\n278\t// agent's OWN scope's `events/*.ts` defs into the hook pipeline. Undeclared\n279\t// names / schema-mismatched payloads reject; `event` in the result is the"}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"9598d66b-15da-442d-9f3c-ef57eded5720","timestamp":"2026-07-16T19:22:38.819Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_KHMZaKv8jfwoKP3PeimnpUBI","type":"tool_result","content":"1\timport type { Space } from '../spaces/load.js';\n2\timport type { ForkEngine } from '../fork/fork.js';\n3\timport { loadTasklist } from '../spaces/tasklist-load.js';\n4\timport { validateDag, findReadyTasks, resolveGoalTask } from './dag.js';\n5\timport type { TaskNode } from '../spaces/tasklist-load.js';\n6\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n7\timport { validateInput } from './schema.js';\n8\timport type { TaskEnvelope, DegradeReason } from '../exec/envelope.js';\n9\t\n10\t/** Resolve a `forEach` reference (\"taskId\" or \"taskId.field.subfield\") against accumulated\n11\t *  task outputs. Returns the referenced array, or [] when missing / not an array. */\n12\tfunction resolveForEachItems(ref: string, allOutputs: Record<string, unknown>): unknown[] {\n13\t  const parts = ref.split('.');\n14\t  let val: unknown = allOutputs[parts[0]!];\n15\t  for (const part of parts.slice(1)) {\n16\t    if (val && typeof val === 'object') val = (val as Record<string, unknown>)[part];\n17\t    else { val = undefined; break; }\n18\t  }\n19\t  return Array.isArray(val) ? val : [];\n20\t}\n21\t\n22\t/**\n23\t * Execution context for ONE `kind:'code'` tasklist node, built by the host\n24\t * (CLI/pod) — never by core. `runCodeNode` loads + runs the node module's\n25\t * `run(ctx, inputs)` in a Node worker with a `ctx` gated by the space/tasklist\n26\t * `connections:` (db, callConnection, delegate). `inputs` is the SAME data an\n27\t * agent fork of this node would receive: the seed-filtered tasklist input merged\n28\t * with upstream task outputs (keyed by dependency id), plus `item`/`index` for a\n29\t * forEach element. The returned object feeds `allOutputs`/`TaskEnvelope` exactly\n30\t * like an agent node's output.\n31\t */\n32\texport interface CodeNodeContext {\n33\t  runCodeNode(inputs: Record<string, unknown>): Promise<Record<string, unknown>>;\n34\t}\n35\t\n36\t/**\n37\t * Maps a code node to its {@link CodeNodeContext}. Injected via\n38\t * {@link RunTasklistOptions} by the CLI/pod (the headless tasklist runner, plan\n39\t * step S9); the in-session yield-router threads one built from the session's\n40\t * project scope when available. When ABSENT, encountering a code node fails that\n41\t * task with a clear error (required-task-failure semantics) — core cannot\n42\t * execute node modules itself. Called once per code node (before any forEach\n43\t * fan-out), so the host can build per-node state up front.\n44\t */\n45\texport type CodeNodeCtxFactory = (node: TaskNode) => CodeNodeContext;\n46\t\n47\texport interface RunTasklistOptions {\n48\t  name: string;\n49\t  space: Space;\n50\t  forkEngine: ForkEngine;\n51\t  seed?: Record<string, unknown>;\n52\t  tracer?: Tracer;\n53\t  parentScope?: TraceScope;\n54\t  /** Host-provided runner for `kind:'code'` nodes (see {@link CodeNodeCtxFactory}).\n55\t   *  Omit outside a CLI/pod context — code nodes then fail as required-task errors. */\n56\t  codeNodeCtxFactory?: CodeNodeCtxFactory;\n57\t}\n58\t\n59\t/**\n60\t * Run a tasklist DAG and return a `TaskEnvelope` wrapping the goal task's output.\n61\t *\n62\t * Task→task UPSTREAM outputs stay RAW schema data (task files keep referencing\n63\t * `plan.questions` etc.) — degradation metadata never leaks into upstream\n64\t * variable values. Only the tasklist BOUNDARY result is enveloped:\n65\t * `{ ok, degraded, data, reason?, degradedTasks? }`.\n66\t */\n67\texport async function runTasklist(opts: RunTasklistOptions): Promise<TaskEnvelope> {\n68\t  const { name, space, forkEngine, seed, tracer, parentScope, codeNodeCtxFactory } = opts;\n69\t\n70\t  const tasklistDir = space.tasklists[name];\n71\t  if (!tasklistDir) {\n72\t    throw new Error(`Tasklist \"${name}\" not found in space`);\n73\t  }\n74\t\n75\t  // Validate the runtime seed against the tasklist's declared input schema\n76\t  // (tasklists/<name>/index.md frontmatter). No declared schema → accept any seed.\n77\t  const declaredInputKeys =\n78\t    tasklistDir.input && Object.keys(tasklistDir.input).length > 0\n79\t      ? Object.keys(tasklistDir.input)\n80\t      : undefined;\n81\t  if (declaredInputKeys) {\n82\t    const errors = validateInput(tasklistDir.input!, seed ?? {});\n83\t    if (errors.length > 0) {\n84\t      throw new Error(\n85\t        `Tasklist \"${name}\" received an invalid seed:\\n  - ${errors.join('\\n  - ')}`,\n86\t      );\n87\t    }\n88\t  }\n89\t\n90\t  // INPUT HARD FILTER: when the tasklist declares an `input` schema, forks receive\n91\t  // ONLY the declared keys — whatever extra baggage a delegator packed into the seed\n92\t  // (e.g. `parentHistory`, stray context) never rides into leaf prompts/ambient DTS.\n93\t  // This makes a leaf fork's prompt a pure function of (task file, declared inputs,\n94\t  // upstream outputs, forEach item) — identical shallow vs nested. No declared\n95\t  // schema → full passthrough (back-compat). Host-injected forEach `item`/`index`\n96\t  // are added AFTER the filter and are unaffected.\n97\t  const taskSeed = declaredInputKeys\n98\t    ? Object.fromEntries(Object.entries(seed ?? {}).filter(([k]) => declaredInputKeys.includes(k)))\n99\t    : seed;\n100\t\n101\t  const tasks = await loadTasklist(tasklistDir.slug, tasklistDir.files);\n102\t  validateDag(tasks);\n103\t  const goalTask = resolveGoalTask(tasks);\n104\t\n105\t  // Mint a tasklist node so the tree shows this orchestration scope\n106\t  const tasklistScope = tracer && parentScope\n107\t    ? tracer.child(parentScope, 'tasklist', `tasklist:${name}`, { tasklist: name })\n108\t    : undefined;\n109\t\n110\t  const done = new Set<string>();\n111\t  const skipped = new Set<string>();\n112\t  const allOutputs: Record<string, unknown> = {};\n113\t  let goalOutput: unknown;\n114\t  // Degradation aggregation (Phase 3): labels of every salvaged task / forEach\n115\t  // element (e.g. \"investigate[3]\"), plus the goal task's own degradation state.\n116\t  const degradedTasks: string[] = [];\n117\t  let goalDegraded = false;\n118\t  let goalReason: DegradeReason | undefined;\n119\t\n120\t  // Build up upstream outputs per task\n121\t  function getUpstreamOutputs(task: TaskNode): Record<string, unknown> {\n122\t    const upstream: Record<string, unknown> = {};\n123\t    for (const dep of task.dependsOn ?? []) {\n124\t      if (allOutputs[dep] !== undefined) {\n125\t        upstream[dep] = allOutputs[dep];\n126\t      }\n127\t    }\n128\t    return upstream;\n129\t  }\n130\t\n131\t  // Declared output schema per upstream dependency, so each `declare const <dep>` in the\n132\t  // fork's typecheck overlay gets a real type. A `forEach` dependency is flagged isArray —\n133\t  // its collected value is an array of its output shape (see fork.ts taskOutputDts).\n134\t  function getUpstreamOutputSchemas(task: TaskNode): Record<string, { fields: Record<string, string>; isArray: boolean }> {\n135\t    const schemas: Record<string, { fields: Record<string, string>; isArray: boolean }> = {};\n136\t    for (const dep of task.dependsOn ?? []) {\n137\t      const depTask = tasks[dep];\n138\t      if (depTask) schemas[dep] = { fields: depTask.output, isArray: Boolean(depTask.forEach) };\n139\t    }\n140\t    return schemas;\n141\t  }\n142\t\n143\t  // Emit a `task` node and immediately end it as skipped (condition not met /\n144\t  // optional fork failed). Tracks via `skippedEmitted` so we never double-emit.\n145\t  const skippedEmitted = new Set<string>();\n146\t  const emitSkip = (task: TaskNode): void => {\n147\t    if (!tracer || !tasklistScope || skippedEmitted.has(task.id)) return;\n148\t    skippedEmitted.add(task.id);\n149\t    const s = tracer.child(tasklistScope, 'task', `fork:${task.id}`, {\n150\t      tasklist: name, dependsOn: task.dependsOn, optional: task.optional, condition: task.condition, goal: task.goal,\n151\t    });\n152\t    tracer.end(s, 'skipped');\n153\t  };\n154\t\n155\t  try {\n156\t    // Run until all tasks are done/skipped\n157\t    while (done.size + skipped.size < Object.keys(tasks).length) {\n158\t      const ready = findReadyTasks(tasks, done, skipped, allOutputs);\n159\t\n160\t      if (ready.length === 0) {\n161\t        // Check if there are tasks remaining but none are ready (stuck)\n162\t        const remaining = Object.keys(tasks).filter((id) => !done.has(id) && !skipped.has(id));\n163\t        if (remaining.length > 0) {\n164\t          // Skip tasks whose conditions aren't met\n165\t          for (const id of remaining) {\n166\t            const task = tasks[id]!;\n167\t            const deps = task.dependsOn ?? [];\n168\t            const depsOk = deps.every((dep) => done.has(dep) || skipped.has(dep));\n169\t            if (depsOk && (task.optional || task.condition)) {\n170\t              // Condition not met (or optional with unmet deps) — skip + trace it.\n171\t              skipped.add(id);\n172\t              emitSkip(task);\n173\t            }\n174\t          }\n175\t\n176\t          // Check if we're truly stuck\n177\t          const stillRemaining = Object.keys(tasks).filter(\n178\t            (id) => !done.has(id) && !skipped.has(id),\n179\t          );\n180\t          if (stillRemaining.length === remaining.length) {\n181\t            throw new Error(`Tasklist \"${name}\" is stuck: tasks ${stillRemaining.join(', ')} cannot be resolved`);\n182\t          }\n183\t        }\n184\t        continue;\n185\t      }\n186\t\n187\t      // Mint each ready task's scope up front so we can end it on success OR failure.\n188\t      const taskScopes = new Map<string, TraceScope | undefined>();\n189\t\n190\t      // Run all ready tasks in parallel (within fork concurrency cap)\n191\t      const results = await Promise.allSettled(\n192\t        ready.map(async (task) => {\n193\t          const upstreamOutputs = getUpstreamOutputs(task);\n194\t          const upstreamOutputSchemas = getUpstreamOutputSchemas(task);\n195\t          const taskScope = tracer && tasklistScope\n196\t            ? tracer.child(tasklistScope, 'task', `fork:${task.id}`, {\n197\t                tasklist: name, dependsOn: task.dependsOn, optional: task.optional, condition: task.condition, goal: task.goal, forEach: task.forEach,\n198\t              })\n199\t            : undefined;\n200\t          taskScopes.set(task.id, taskScope);\n201\t\n202\t          const upstream = Object.keys(upstreamOutputs).length > 0 ? upstreamOutputs : undefined;\n203\t\n204\t          // CODE NODE: the host runs the node module's `run(ctx, inputs)` via the\n205\t          // injected factory (core stays free of any transpile/worker runtime).\n206\t          // Inputs mirror exactly what an agent fork of this node would see —\n207\t          // the seed-filtered tasklist input merged with upstream outputs (keyed\n208\t          // by dependency id), plus `item`/`index` for a forEach element. Output\n209\t          // feeds allOutputs/TaskEnvelope identically to an agent node. A code\n210\t          // node has no salvage path: `run` either returns (success) or throws\n211\t          // (→ required-task failure below, or skip when optional). forEach can\n212\t          // fan out over a code node, and a code node can be a forEach body.\n213\t          if (task.kind === 'code') {\n214\t            if (!codeNodeCtxFactory) {\n215\t              throw new Error(\n216\t                `Code node \"${task.id}\" cannot run here: no codeNodeCtxFactory was provided to ` +\n217\t                  `runTasklist. The CLI/pod injects one (headless tasklist runner); an in-session ` +\n218\t                  `run needs that runner wired. Core does not execute code-node modules itself.`,\n219\t              );\n220\t            }\n221\t            const codeCtx = codeNodeCtxFactory(task);\n222\t            const baseInputs: Record<string, unknown> = { ...(taskSeed ?? {}), ...upstreamOutputs };\n223\t            if (task.forEach) {\n224\t              const items = resolveForEachItems(task.forEach, allOutputs);\n225\t              const output = await Promise.all(\n226\t                items.map((item, index) => {\n227\t                  const elemScope = tracer && taskScope\n228\t                    ? tracer.child(taskScope, 'task', `code:${task.id}[${index}]`, { tasklist: name, forEachIndex: index })\n229\t                    : undefined;\n230\t                  return codeCtx.runCodeNode({ ...baseInputs, item, index }).then((val) => {\n231\t                    if (tracer && elemScope) tracer.end(elemScope, 'done', { result: val });\n232\t                    return val;\n233\t                  });\n234\t                }),\n235\t              );\n236\t              return { task, output };\n237\t            }\n238\t            const output = await codeCtx.runCodeNode(baseInputs);\n239\t            return { task, output };\n240\t          }\n241\t\n242\t          // forkWithMeta: same execution path as fork(), plus typed degradation\n243\t          // metadata so salvage becomes a control-plane signal (→ TaskEnvelope),\n244\t          // not prose inside the data.\n245\t          const runFork = (\n246\t            extraSeed?: Record<string, unknown>,\n247\t            elemScope?: TraceScope,\n248\t          ): Promise<import('../fork/fork.js').ForkResultMeta> =>\n249\t            forkEngine.forkWithMeta({\n250\t              instruction: task.instruction,\n251\t              output: task.output,\n252\t              seed: extraSeed ? { ...(taskSeed ?? {}), ...extraSeed } : taskSeed,\n253\t              upstreamOutputs: upstream,\n254\t              upstreamOutputSchemas,\n255\t              taskId: task.id,\n256\t              role: task.role,\n257\t              functions: task.functions,\n258\t              canDelegateTo: task.canDelegateTo,\n259\t              capabilities: task.capabilities as import('../spaces/capabilities.js').CapabilityId[] | undefined,\n260\t              prelude: task.prelude,\n261\t              tasklistDescription: tasklistDir.description,\n262\t              parentScope: elemScope ?? taskScope,\n263\t            });\n264\t\n265\t          // Record a salvage for the given label; when this is the goal task, its\n266\t          // (first) degradation also determines the envelope's ok/reason.\n267\t          const noteDegraded = (label: string, reason: DegradeReason | undefined): void => {\n268\t            degradedTasks.push(label);\n269\t            if (goalTask && task.id === goalTask.id) {\n270\t              goalDegraded = true;\n271\t              if (!goalReason) goalReason = reason ?? 'no_resolve';\n272\t            }\n273\t          };\n274\t\n275\t          // forEach: host-driven fan-out. Resolve the referenced upstream array and run the\n276\t          // task once per element (parallel, within the engine's concurrency cap), injecting\n277\t          // the element as `item` (+ `index`). Collect the resolved values into an array.\n278\t          if (task.forEach) {\n279\t            const items = resolveForEachItems(task.forEach, allOutputs);\n280\t            const output = await Promise.all(\n281\t              items.map((item, index) => {\n282\t                const elemScope = tracer && taskScope\n283\t                  ? tracer.child(taskScope, 'task', `fork:${task.id}[${index}]`, { tasklist: name, forEachIndex: index })\n284\t                  : undefined;\n285\t                return runFork({ item, index }, elemScope).then((meta) => {\n286\t                  if (meta.degraded) noteDegraded(`${task.id}[${index}]`, meta.reason);\n287\t                  if (tracer && elemScope) tracer.end(elemScope, 'done', { result: meta.value, ...(meta.degraded ? { degraded: true, reason: meta.reason } : {}) });\n288\t                  return meta.value;\n289\t                });\n290\t              }),\n291\t            );\n292\t            return { task, output };\n293\t          }\n294\t\n295\t          const meta = await runFork();\n296\t          if (meta.degraded) noteDegraded(task.id, meta.reason);\n297\t          return { task, output: meta.value };\n298\t        }),\n299\t      );\n300\t\n301\t      for (const result of results) {\n302\t        if (result.status === 'fulfilled') {\n303\t          const { task, output } = result.value;\n304\t          done.add(task.id);\n305\t          allOutputs[task.id] = output;\n306\t          if (tracer) { const ts = taskScopes.get(task.id); if (ts) tracer.end(ts, 'done', { result: output }); }\n307\t          if (goalTask && task.id === goalTask.id) goalOutput = output;\n308\t        } else {\n309\t          // Fork failed\n310\t          const failedTask = ready[results.indexOf(result)]!;\n311\t          const ts = taskScopes.get(failedTask.id);\n312\t          if (failedTask.optional) {\n313\t            skipped.add(failedTask.id);\n314\t            skippedEmitted.add(failedTask.id);\n315\t            if (tracer && ts) tracer.end(ts, 'skipped');\n316\t          } else {\n317\t            const errMsg = result.reason instanceof Error ? result.reason.message : String(result.reason);\n318\t            if (tracer && ts) tracer.end(ts, 'error', { error: errMsg });\n319\t            throw new Error(`Required task \"${failedTask.id}\" failed: ${errMsg}`);\n320\t          }\n321\t        }\n322\t      }\n323\t    }\n324\t\n325\t    // A skipped goal task means the pipeline short-circuited — an upstream\n326\t    // condition was not met — and produced NO result. Returning `undefined`\n327\t    // here would surface to the caller as a silent `null` delegate result with\n328\t    // no explanation (the exact failure that left the architect returning null).\n329\t    // Fail loudly instead, folding in any upstream `errors`/`error` fields so the\n330\t    // model sees WHY (e.g. a validation failure) and can react.\n331\t    if (goalTask && skipped.has(goalTask.id)) {\n332\t      const diagnostics = Object.entries(allOutputs)\n333\t        .map(([id, out]) => {\n334\t          if (out && typeof out === 'object') {\n335\t            const err = (out as Record<string, unknown>).errors ?? (out as Record<string, unknown>).error;\n336\t            if (typeof err === 'string' && err.trim()) return `${id}: ${err.trim()}`;\n337\t          }\n338\t          return null;\n339\t        })\n340\t        .filter((d): d is string => d !== null);\n341\t      const detail = diagnostics.length > 0 ? ` Upstream errors — ${diagnostics.join('; ')}` : '';\n342\t      throw new Error(\n343\t        `Tasklist \"${name}\" produced no result: its goal task \"${goalTask.id}\" was skipped ` +\n344\t          `because an upstream condition was not met.${detail}`,\n345\t      );\n346\t    }\n347\t\n348\t    // Wrap the goal output in a TaskEnvelope at the tasklist BOUNDARY:\n349\t    //   ok        — the goal task itself resolved un-salvaged\n350\t    //   degraded  — any salvage occurred anywhere in the DAG (incl. forEach elements)\n351\t    //   data      — the goal task's RAW schema output (salvaged fields are neutral empties)\n352\t    // Hard failures (stuck DAG, invalid seed, skipped goal, budget/timeout rejects)\n353\t    // still THROW above — they surface as retryable yield errors, unchanged.\n354\t    const envelope: TaskEnvelope = {\n355\t      ok: !goalDegraded,\n356\t      degraded: degradedTasks.length > 0,\n357\t      data: goalOutput,\n358\t      ...(goalDegraded ? { reason: goalReason ?? 'no_resolve' } : {}),\n359\t      ...(degradedTasks.length > 0 ? { degradedTasks } : {}),\n360\t    };"}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"b70be43e-94a1-4426-b2e8-785e129513a8","timestamp":"2026-07-16T19:22:38.820Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_ykAaenDOri6JRYvw5lYQCS22","type":"tool_result","content":"280\t    ctx.setProp(ctx.global, name, stub);\n281\t    stub.dispose();\n282\t  }\n283\t\n284\t  return vm;\n285\t}\n286\t\n287\t/** Ambient declaration for the `currentTask` result-capture global. */\n288\texport const CURRENT_TASK_DTS = `declare const currentTask: { resolve: (value: unknown) => void };`;\n289\t\n290\t/**\n291\t * One DTS assembler for all three contexts, replacing the three string-surgery\n292\t * sites (session `LIBRARY_DTS + overlay`, delegate `LIBRARY_DTS_NO_ASK + …`,\n293\t * fork's regex-strip of tasklist/fork/delegate from LIBRARY_DTS_NO_ASK). Built\n294\t * ADDITIVELY from the per-global fragments in typecheck/library-dts.ts; the\n295\t * declaration set for each context is identical to the pre-unification output\n296\t * (whitespace aside) — pinned by exec/bootstrap.test.ts.\n297\t */\n298\texport interface AmbientDtsOpts {\n299\t  /** Which orchestration + write + app-capability globals are declared. `registerSpace`\n300\t   *  and everything left in COMMON_DTS are declared unconditionally; the generic fs/shell\n301\t   *  primitives are NO LONGER emitted by `allowWrite` — `readFileRaw`/`writeFileRaw` are\n302\t   *  internal-only, and `execShell` + `createScratch` are emitted ONLY under `scratchFs`\n303\t   *  (the engineer's sandbox). The project-app globals are gated on the `app` grants. Pass\n304\t   *  the full CapabilityProfile (it satisfies this Pick). */\n305\t  capabilities: Pick<CapabilityProfile, 'ask' | 'orchestrate' | 'delegate' | 'setSessionMeta' | 'allowWrite' | 'scratchFs' | 'app'>;\n306\t  /** Function/component overlay (buildOverlay output). Empty/omitted → none. */\n307\t  overlay?: string;\n308\t  /** Declare the `currentTask` capture global (fork + delegate contexts). */\n309\t  currentTask?: boolean;\n310\t  /** Extra ambient declarations (fork seed/upstream vars, delegate query/context). */\n311\t  extraDecls?: string[];\n312\t  /** Project-generated typed `apiCall` overloads (Phase 4). When present AND the agent\n313\t   *  holds `api:call`, these REPLACE the generic apiCall fragment so calls are strictly typed. */\n314\t  appDts?: string;\n315\t  /** Whether this VM is project-rooted (has a projectRoot). Gates the project-read DTS\n316\t   *  (`listProjectDir`/`readProjectFile`) so it is declared exactly where the impls are\n317\t   *  injected (injectAppGlobals gates the same globals on projectRoot alone). */\n318\t  projectRoot?: boolean;\n319\t}\n320\t\n321\t/**\n322\t * The DTS side of the capability→{inject, dts} registry: emit exactly the app-global\n323\t * declarations the agent's `capabilities:` grants earned — the `db` object with only\n324\t * the granted verbs (`composeDbDts`), plus each standalone authoring/outbound global\n325\t * (`apiCall`/`writePage`/`writeApi`/`writeHook`). A grant that is absent is absent from\n326\t * the DTS, so a stray call fails typecheck — the same \"not listed ⇒ not injected AND\n327\t * absent from the DTS\" invariant the boolean flags enforce for ask/fork/delegate.\n328\t */\n329\tfunction buildAppCapabilityDts(app: AppCapabilities, appDts?: string, projectRoot?: boolean): string {\n330\t  const parts: string[] = [\n331\t    composeDbDts({ read: !!app['db:read'], write: !!app['db:write'], schema: !!app['db:schema'] }),\n332\t  ];\n333\t  // db:schema earns the standalone authoring global `writeTableSchema` (writes a\n334\t  // catalog `database/<name>.json`) in ADDITION to the `db.createTable`/`addColumn`\n335\t  // members composeDbDts put on the `db` object.\n336\t  // …and, for a project-rooted session, the LIVE-project twin `writeProjectTable`\n337\t  // (writes `database/<name>.json` into the running project and re-derives its db).\n338\t  if (app['db:schema']) parts.push(WRITE_TABLE_SCHEMA_DTS, PROJECT_TABLE_DTS);\n339\t  // The project-rooted introspection reads (listProjectDir/readProjectFile) are emitted for ANY\n340\t  // project-rooted session (projectRoot) — no db grant required. They are the only way to read\n341\t  // project files now that the space-rooted readFile/listDir wrappers are gone (THING reads its\n342\t  // instructions.md/documents/ through them), and they root at projectRoot, never the space dir.\n343\t  if (projectRoot) parts.push(PROJECT_READ_DTS);\n344\t  // api:call — when the caller supplies project-generated typed overloads (Phase 4:\n345\t  // `apiCall('markRead', { id: string }): { ok: boolean }` + a generic fallback), use\n346\t  // those so a malformed call fails the agent's typecheck; otherwise the generic fragment.\n347\t  if (app['api:call']) parts.push(appDts && appDts.trim() ? appDts : CAPABILITY_DTS_FRAGMENTS['api:call']);\n348\t  // connections:use — emit the typed `callConnection` with `provider` narrowed to the\n349\t  // granted providers (union), so a stray provider fails the agent's typecheck.\n350\t  if (app['connections:use']) parts.push(composeConnectionsDts(app['connections:use'].providers));\n351\t  // Standalone authoring/management/store/event globals: writePage/writeApi/\n352\t  // writeHook + createProject/selectProject (Phase 9), storeSearch/storeInspect +\n353\t  // installSpace + emitEvent (plan S10). Each emitted only when its grant is present.\n354\t  for (const id of ['pages:write', 'api:write', 'hooks:write', 'knowledge:write', 'project:manage', 'store:read', 'store:install', 'events:emit'] as const) {\n355\t    if (app[id]) parts.push(CAPABILITY_DTS_FRAGMENTS[id]);\n356\t  }\n357\t  return parts.filter(Boolean).join('\\n');\n358\t}\n359\t\n360\texport function buildAmbientDts(opts: AmbientDtsOpts): string {\n361\t  const caps = opts.capabilities;\n362\t  return [\n363\t    caps.ask ? ASK_DTS : '',\n364\t    caps.setSessionMeta ? SET_SESSION_META_DTS : '',\n365\t    caps.orchestrate ? TASKLIST_DTS : '',\n366\t    caps.orchestrate ? FORK_DTS : '',\n367\t    caps.delegate ? DELEGATE_DTS : '',\n368\t    COMMON_DTS,\n369\t    // Generic fs/shell is NOT part of any agent's model surface. readFileRaw/writeFileRaw"}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"60211771-2bfb-43ee-b8ca-54ee28efd48e","timestamp":"2026-07-16T19:22:38.821Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
