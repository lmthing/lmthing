{
  "name": "integration-synology-chat",
  "version": "1.0.0",
  "private": true,
  "lmthing": {
    "kind": "integration",
    "title": "Synology Chat",
    "tags": ["integration", "messaging"],
    "icon": "🗄️",
    "description": "Send messages to Synology Chat and reply to Synology Chat messages via THING.",
    "settings": {
      "type": "object",
      "properties": {
        "INTEGRATION_SYNOLOGY_CHAT_BASE_URL": { "type": "string", "title": "NAS base URL" },
        "INTEGRATION_SYNOLOGY_CHAT_TOKEN": { "type": "string", "title": "Incoming webhook token", "format": "password" },
        "INTEGRATION_SYNOLOGY_CHAT_OUTGOING_TOKEN": { "type": "string", "title": "Outgoing webhook token", "format": "password" }
      },
      "required": ["INTEGRATION_SYNOLOGY_CHAT_BASE_URL", "INTEGRATION_SYNOLOGY_CHAT_TOKEN", "INTEGRATION_SYNOLOGY_CHAT_OUTGOING_TOKEN"]
    },
    "connection": {
      "provider": "synology",
      "apiBase": { "env": "INTEGRATION_SYNOLOGY_CHAT_BASE_URL" },
      "tokenEnv": "INTEGRATION_SYNOLOGY_CHAT_TOKEN",
      "auth": { "kind": "query-token", "param": "token" }
    }
  }
}
