{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_HsB3l3eIfkx8XnC4lO8LHieW","type":"tool_result","content":"1\timport ts from 'typescript';\n2\timport type { VM } from '../sandbox/quickjs.js';\n3\timport type { YieldRequest } from '../eval/yield.js';\n4\timport type { RenderHost } from '../session/types.js';\n5\timport { runTsc } from '../typecheck/tsc.js';\n6\timport { transpileStatement } from '../typecheck/transpile.js';\n7\timport { emitVariables, extractBindingNames, extractBindingPattern } from '../context/variables.js';\n8\timport { bindYieldResults } from '../eval/turn-loop.js';\n9\timport { serialize } from '../globals/serialize.js';\n10\timport { BudgetExceededError, type Budget } from '../eval/budget.js';\n11\timport { NULL_TRACER } from '../sandbox/trace.js';\n12\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n13\t\n14\t/**\n15\t * Host-executed task prelude (Phase 4 of the reliability plan — fixes root\n16\t * cause A3 of `.issues/investigate-forks-degrade-under-delegate-nesting.md`).\n17\t *\n18\t * Leaf task files used to DICTATE a fixed sequence of TS statements the model\n19\t * had to re-emit verbatim (`const question = String(item); const results =\n20\t * await webSearch(question); …`). Every yield is a turn boundary where a small\n21\t * model can skip/rename/reorder a binding — the observed `Cannot find name\n22\t * 'question'` failures under delegate nesting. Those statements need ZERO model\n23\t * judgment, so the task author now puts them in frontmatter `prelude:` and the\n24\t * HOST executes them in the fork VM before the model's first turn, through the\n25\t * exact same statement pipeline the turn loop uses (typecheck → transpile →\n26\t * globalThis propagation → eval → yield routing → `bindYieldResults`).\n27\t *\n28\t * Error semantics: a failing prelude statement must NOT kill the fork. On a\n29\t * typecheck/eval/yield error its bound names are bound `undefined` in the VM\n30\t * and declared ambient `any` (same pattern as the turn loop's\n31\t * `yieldErrorNames`), the failure is noted in the VARIABLES block the model\n32\t * sees, and execution CONTINUES with the remaining statements — task\n33\t * instructions already specify degraded-output behavior, so the model gets a\n34\t * chance to resolve something honest.\n35\t *\n36\t * Budget: prelude yields tick the fork's Budget toolCall counter (they are\n37\t * real webSearch/webFetch calls); prelude statements do NOT count as episodes.\n38\t * A BudgetExceededError (tool-call cap, nested fork-depth cap) PROPAGATES —\n39\t * hard cost ceilings are honored exactly as in the turn loop.\n40\t */\n41\t\n42\t/** Statement failure surfaced in the prelude's VARIABLES block. */\n43\texport interface PreludeFailure {\n44\t  /** Zero-based statement index within the prelude source. */\n45\t  index: number;\n46\t  statement: string;\n47\t  /** Names the failed statement would have bound (now bound `undefined`). */\n48\t  names: string[];\n49\t  error: string;\n50\t}\n51\t\n52\texport interface RunPreludeOpts {\n53\t  vm: VM;\n54\t  /** The task's frontmatter `prelude:` source (trusted, statically authored). */\n55\t  source: string;\n56\t  /** Ambient DTS the prelude statements typecheck against. Callers pass a\n57\t   *  variant WITHOUT `currentTask` so a prelude cannot resolve the task —\n58\t   *  `currentTask.resolve(...)` in a prelude fails typecheck (a per-statement\n59\t   *  prelude error) instead of silently pre-resolving on the model's behalf. */\n60\t  ambientDts: string;\n61\t  /** The fork's OWN yield resolver (routeCommonYield with the fork context) —\n62\t   *  the prelude can call webSearch/webFetch/fetch/sleep/loadKnowledge like\n63\t   *  any fork statement. */\n64\t  processYield: (req: YieldRequest) => Promise<unknown>;\n65\t  renderHost: RenderHost;\n66\t  /** Fork budget: each resolved prelude yield ticks tickToolCalls. */\n67\t  budget?: Budget;\n68\t  tracer?: Tracer;\n69\t  /** The fork's scope — prelude events carry its nodeId with a `:prelude`\n70\t   *  context-label suffix so trace tooling attributes the activity. */\n71\t  scope?: TraceScope;\n72\t}\n73\t\n74\texport interface PreludeResult {\n75\t  /** Successfully executed statements, newline-joined — seeds the turn loop's\n76\t   *  `initialContext` so the model's statements typecheck against the\n77\t   *  prelude's bound names. */\n78\t  context: string;\n79\t  /** Every name the prelude bound (failed statements' names → undefined). */\n80\t  vars: Record<string, unknown>;\n81\t  /** Names of FAILED statements — the caller must declare these as ambient\n82\t   *  `declare const <n>: any;` (they are NOT in `context`, which only carries\n83\t   *  committed statements). */\n84\t  failedNames: string[];\n85\t  failures: PreludeFailure[];\n86\t  /** Ready-to-append first VARIABLES message for the fork's history (empty\n87\t   *  string when the prelude was empty). The model must SEE the values (e.g.\n88\t   *  search results), not just the names. */\n89\t  variablesBlock: string;\n90\t}\n91\t\n92\t/**\n93\t * Split trusted prelude source into top-level statements with a single TS\n94\t * parse. The streaming BoundaryDetector heuristics are unnecessary here — the\n95\t * source is a static string, so `ts.createSourceFile` + top-level statements\n96\t * is exact. Exported for direct testing.\n97\t */\n98\texport function splitPreludeStatements(source: string): string[] {\n99\t  const sf = ts.createSourceFile('_prelude.tsx', source, ts.ScriptTarget.ES2022, true, ts.ScriptKind.TSX);\n100\t  return sf.statements\n101\t    .map((s) => source.slice(s.getStart(sf), s.end).trim())\n102\t    .filter(Boolean);\n103\t}\n104\t\n105\t/** Bound so a pathological space function that yields forever cannot wedge the host. */\n106\tconst MAX_NESTED_YIELD_ROUNDS = 32;\n107\t\n108\texport async function runPrelude(opts: RunPreludeOpts): Promise<PreludeResult> {\n109\t  const { vm, renderHost, processYield } = opts;\n110\t  const tracer = opts.tracer ?? NULL_TRACER;\n111\t  const scope = opts.scope;\n112\t  const ctx = `${scope?.label ?? 'fork'}:prelude`;\n113\t  const nodeId = scope?.nodeId;\n114\t  let yieldCounter = 0;\n115\t\n116\t  const statements = splitPreludeStatements(opts.source);\n117\t\n118\t  let context = '';\n119\t  const vars: Record<string, unknown> = {};\n120\t  const failedNames: string[] = [];\n121\t  const failures: PreludeFailure[] = [];\n122\t\n123\t  // Ambient decls for failed statements' names, so LATER prelude statements\n124\t  // (and eventually the model, via the caller) referencing them still typecheck\n125\t  // — same mechanism as the turn loop's yieldErrorNames.\n126\t  const fullAmbient = (): string =>\n127\t    failedNames.length > 0\n128\t      ? opts.ambientDts + '\\n' + failedNames.map((n) => `declare const ${n}: any;`).join('\\n')\n129\t      : opts.ambientDts;\n130\t\n131\t  const fail = (index: number, statement: string, names: string[], error: string): void => {\n132\t    failures.push({ index, statement, names, error });\n133\t    for (const name of names) {\n134\t      if (!failedNames.includes(name)) failedNames.push(name);\n135\t      // Seed undefined in the VM so a later statement that references the name\n136\t      // cannot ReferenceError (it evaluates against a defined-but-undefined global).\n137\t      vm.setVar(name, undefined);\n138\t      vars[name] = undefined;\n139\t    }\n140\t    renderHost.log(`[prelude] statement ${index + 1} failed: ${error}`);\n141\t  };\n142\t\n143\t  for (let i = 0; i < statements.length; i++) {\n144\t    const stmt = statements[i]!;\n145\t    tracer.write({ ts: Date.now(), type: 'statement', context: ctx, ...(nodeId ? { nodeId } : {}), code: stmt });\n146\t    renderHost.log(`[prelude stmt] ${stmt}`);\n147\t\n148\t    // 1. Typecheck against the fork's ambient DTS + accumulated prelude context.\n149\t    const tscResult = runTsc({ ambientDts: fullAmbient(), sessionContext: context, statement: stmt });\n150\t    if (!tscResult.ok) {\n151\t      const errMsg = tscResult.diagnostics.map((d) => d.message).join('; ');\n152\t      tracer.write({ ts: Date.now(), type: 'typecheck_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: errMsg, attempt: 1 });\n153\t      fail(i, stmt, extractBindingNames(stmt), errMsg);\n154\t      continue;\n155\t    }\n156\t\n157\t    // 2. Transpile + globalThis propagation per bound name (each evalStatement\n158\t    //    is an isolated module — identical to the turn loop's pipeline).\n159\t    const boundNames = extractBindingNames(stmt);\n160\t    let jsCode = transpileStatement(stmt);\n161\t    if (boundNames.length > 0) {\n162\t      const assigns = boundNames.map((n) => `try { globalThis['${n}'] = ${n}; } catch {}`).join('\\n');\n163\t      jsCode += '\\n' + assigns;\n164\t    }\n165\t\n166\t    // 3. Eval.\n167\t    const evalResult = vm.evalStatement(jsCode);\n168\t    if (!evalResult.ok) {\n169\t      tracer.write({ ts: Date.now(), type: 'eval_error', context: ctx, ...(nodeId ? { nodeId } : {}), statement: stmt, message: evalResult.error });\n170\t      fail(i, stmt, boundNames, evalResult.error);\n171\t      continue;\n172\t    }\n173\t\n174\t    // 4. Resolve yields through the fork's OWN router. A resolved yield can\n175\t    //    surface FURTHER pending yields once jobs are driven (a space function\n176\t    //    awaiting fetch() more than once), so drain in rounds. The FIRST round's\n177\t    //    count/values carry the combinator semantics for bindYieldResults; the\n178\t    //    getVar preference inside it recovers the real outer value for nested\n179\t    //    yields (webSearch internally awaiting fetch — the load-bearing fix).\n180\t    if (vm.pendingYields.length > 0) {\n181\t      const pattern = extractBindingPattern(stmt);\n182\t      let firstRoundCount = 0;\n183\t      let firstRoundValues: unknown[] = [];\n184\t      let yieldError: string | null = null;\n185\t\n186\t      for (let round = 0; round < MAX_NESTED_YIELD_ROUNDS && vm.pendingYields.length > 0; round++) {\n187\t        const yields = vm.pendingYields.splice(0);\n188\t        // Budget: prelude yields are real tool calls — tick the fork's counter.\n189\t        // Throws BudgetExceededError (propagates: hard caps are honored).\n190\t        opts.budget?.tickToolCalls(yields.length);\n191\t\n192\t        const resolvedValues: unknown[] = new Array(yields.length);\n193\t        const roundErrors: string[] = [];\n194\t        await Promise.all(yields.map(async (yieldReq, j) => {\n195\t          const yieldId = `${nodeId ?? ctx}_p${++yieldCounter}`;\n196\t          tracer.write({ ts: Date.now(), type: 'yield', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, args: yieldReq.args, yieldId });\n197\t          try {\n198\t            const resolved = await processYield(yieldReq);\n199\t            tracer.write({ ts: Date.now(), type: 'yield_resolved', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, value: resolved, yieldId });\n200\t            yieldReq.deferred.resolve(resolved);\n201\t            resolvedValues[j] = resolved;\n202\t          } catch (err) {\n203\t            // Hard budget breaches (fork-depth, tool-call cap inside a nested\n204\t            // yield) propagate — everything else degrades this statement only.\n205\t            if (err instanceof BudgetExceededError) throw err;\n206\t            yieldReq.deferred.reject(err);\n207\t            resolvedValues[j] = undefined;\n208\t            roundErrors.push(`${yieldReq.kind}() failed: ${err instanceof Error ? err.message : String(err)}`);\n209\t          }\n210\t        }));\n211\t        vm.drivePendingJobs();\n212\t\n213\t        if (round === 0) {\n214\t          firstRoundCount = yields.length;\n215\t          firstRoundValues = resolvedValues;\n216\t        }\n217\t        if (roundErrors.length > 0) {\n218\t          yieldError = roundErrors.join('; ');\n219\t          break