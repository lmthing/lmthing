{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_Yg2yfxgXG5IimuunoXFZIte0","type":"tool_result","content":"1\timport { describe, it, expect, afterAll } from 'vitest';\n2\timport { mkdtemp, mkdir, writeFile, rm } from 'node:fs/promises';\n3\timport { join } from 'node:path';\n4\timport { tmpdir } from 'node:os';\n5\timport { createServer, type Server } from 'node:http';\n6\timport { ForkEngine } from '../fork/fork.js';\n7\timport { runTasklist } from '../tasklist/orchestrator.js';\n8\timport { loadTasklist } from '../spaces/tasklist-load.js';\n9\timport { loadSpace } from '../spaces/load.js';\n10\timport { createMockStreamFn } from '../testing/mock-provider.js';\n11\timport { Tracer, type TraceEvent } from '../sandbox/trace.js';\n12\timport { splitPreludeStatements } from './prelude.js';\n13\timport type { RenderHost } from '../session/types.js';\n14\timport type { StreamOpts } from '../eval/stream-types.js';\n15\t\n16\t/**\n17\t * Phase 4 — `prelude:` host-executed leaf statements (fixes root cause A3 of\n18\t * `.issues/investigate-forks-degrade-under-delegate-nesting.md`): the task's\n19\t * deterministic setup statements run in the fork VM with HOST reliability\n20\t * before the model's first turn, instead of being re-emitted (and skipped/\n21\t * renamed/reordered) by a small model across yield turn boundaries.\n22\t */\n23\t\n24\tconst silentHost: RenderHost = { display: () => {}, ask: async () => undefined, log: () => {} };\n25\t\n26\tconst tmpDirs: string[] = [];\n27\tafterAll(async () => {\n28\t  await Promise.all(tmpDirs.map((d) => rm(d, { recursive: true, force: true })));\n29\t});\n30\t\n31\tdescribe('splitPreludeStatements', () => {\n32\t  it('splits trusted source into top-level statements via a single TS parse', () => {\n33\t    const stmts = splitPreludeStatements(\n34\t      '// setup\\nconst a = 1;\\nconst r = await fetch(\"http://x/\", {\\n  method: \"GET\",\\n});\\nconst [x, y] = [a, a];',\n35\t    );\n36\t    expect(stmts)