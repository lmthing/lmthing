const pid = Number(readFileSync(PID_FILE, 'utf8').trim());\n73\t    return Number.isInteger(pid) && pid > 0 ? pid : null;\n74\t  } catch {\n75\t    return null;\n76\t  }\n77\t}\n78\t\n79\tconst sleep = (ms) => new Promise((r) => setTimeout(r, ms));\n80\t\n81\tasync function waitUp(base, { attempts = 120, everyMs = 1000 } = {}) {\n82\t  for (let i = 0; i < attempts; i++) {\n83\t    if (await serverUp(base)) return true;\n84\t    await sleep(everyMs);\n85\t  }\n86\t  return false;\n87\t}\n88\t\n89\t/**\n90\t * Guarantee a local server is listening; return its base URL. Idempotent and race-safe across\n91\t * concurrent lanes: whoever wins the exclusive lock spawns it, everyone else waits for it to come\n92\t * up. A stale lock (holder died before writing a live pid) is broken after a grace period.\n93\t */\n94\texport async function ensureLocalServer() {\n95\t  if (await serverUp()) return LOCAL_BASE;\n96\t  mkdirSync(DIR, { recursive: true });\n97\t  mkdirSync(POD_ROOT, { recursive: true });\n98\t\n99\t  // Exclusive-create the lock. If someone else holds it, they're booting — wait for the port.\n100\t  let lockFd;\n101\t  try {\n102\t    lockFd = openSync(LOCK_FILE, 'wx');\n103\t  } catch (e) {\n104\t    if (e?.code !== 'EEXIST') throw e;\n105\t    // Break a stale lock (>90s old and no live server, no live pid) so a crashed boot can't wedge us.\n106\t    const stale = Date.now() - safeMtime(LOCK_FILE) > 90_000;\n107\t    if (stale && !(await serverUp()) && !pidAlive(readPid())) {\n108\t      rmSync(LOCK_FILE, { force: true });\n109\t      return ensureLocalServer();\n110\t    }\n111\t    if (await waitUp(LOCAL_BASE)) return LOCAL_BASE;\n112\t    throw new Error('local server never came up (another lane held the start lock)');\n113\t  }\n114\t\n115\t  try {\n116\t    // A pid may already be live even though the probe missed (mid-boot) — attach to it.\n117\t    if (pidAlive(readPid()) && (await waitUp(LOCAL_BASE, { attempts: 30 }))) return LOCAL_BASE;\n118\t\n119\t    const logFd = openSync(LOG_FILE, 'a');\n120\t    // `--adopt-system-spaces`: this pod-root is a throwaway we own, so always take the freshly\n121\t    // built system-space tree (dist/system-spaces) on restart — that's how an agent's system-space\n122\t    // prompt improvements land after `pnpm build && local-server.mjs restart`.\n123\t    // `--max-sessions`: the default (8) is sized for ONE user's chat tabs. This server is shared by\n124\t    // every scenario lane at once, and a single authoring turn adds a delegate sub-session per\n125\t    // specialist it fans out to — so a handful of concurrent lanes blow past 8 easily, and the\n126\t    // capacity gate then sheds sessions the lanes are still using.\n127\t    const child = spawn(process.execPath, [BIN, 'serve', '--port', String(LOCAL_PORT), '--adopt-system-spaces', '--max-sessions', '40'], {\n128\t      cwd: SDK_ORG, // read sdk/org/.env → Azure keys credential the agents (budget-free direct Azure)\n129\t      env: { ...process.env, LMTHING_ROOT: join(POD_ROOT, '.lmthing') },\n130\t      detached: true, // own process group → survives the agent, killable as a tree\n131\t      stdio: ['ignore', logFd, logFd],\n132\t    });\n133\t    closeSync(logFd);\n134\t    child.unref();\n135\t    writeFileSync(PID_FILE, String(child.pid));\n136\t    if (!(await waitUp(LOCAL_BASE))) throw new Error(`local server did not listen on :${LOCAL_PORT} — see ${LOG_FILE}`);\n137\t    return LOCAL_BASE;\n138\t  } finally {\n139\t    closeSync(lockFd);\n140\t    rmSync(LOCK_FILE, { force: true });\n141\t  }\n142\t}\n143\t\n144\tfunction safeMtime(p) {\n145\t  try {\n146\t    return statSync(p).mtimeMs;\n147\t  } catch {\n148\t    return 0;\n149\t  }\n150\t}\n151\t\n152\t/** Kill the local server (whole process group) and clear its pidfile. */\n153\texport function stopLocalServer() {\n154\t  const pid = readPid();\n155\t  if (pidAlive(pid)) {\n156\t    try {\n157\t      process.kill(-pid, 'SIGTERM'); // negative → the detached gr