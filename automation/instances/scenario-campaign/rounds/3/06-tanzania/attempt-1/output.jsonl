{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_WZVeUZtrmi8L6YuRWRhNKdYZ","type":"tool_result","content":"1\timport { readFile } from 'node:fs/promises';\n2\timport { basename, resolve } from 'node:path';\n3\timport ts from 'typescript';\n4\timport { parseFrontmatter } from './frontmatter.js';\n5\timport { CAPABILITY_IDS, type CapabilityId } from './capabilities.js';\n6\timport type { Space } from './load.js';\n7\t\n8\texport interface TaskNode {\n9\t  id: string;\n10\t  /** Node kind: `'agent'` runs a model fork over `instruction` (an `NN-<id>.md`\n11\t   *  file); `'code'` runs a host-injected `run(ctx, inputs)` loaded from\n12\t   *  `codeModulePath` (an `NN-<id>.ts` file). Defaults to `'agent'`. Core NEVER\n13\t   *  imports/executes a code node's module — the CLI/pod does, via the\n14\t   *  orchestrator's injected `codeNodeCtxFactory` (keeps core free of any\n15\t   *  transpile/Node-worker runtime). */\n16\t  kind: 'agent' | 'code';\n17\t  /** Absolute path to the code node's `.ts` module (`kind:'code'` only). Handed\n18\t   *  verbatim to the injected `codeNodeCtxFactory`; core does not read it. */\n19\t  codeModulePath?: string;\n20\t  instruction: string; // body of the .md file (empty for code nodes)\n21\t  output: Record<string, string>; // JSON-schema-ish: field -> type\n22\t  input?: Record<string, string>; // JSON-schema-ish: field -> type\n23\t  dependsOn?: string[];\n24\t  condition?: string; // DSL expression\n25\t  optional?: boolean;\n26\t  goal?: boolean;\n27\t  /** Fork capability profile for this task's subagent (default 'general' when omitted).\n28\t   *  Read-only roles ('explore'/'plan') cannot write files or run mutating shell. */\n29\t  role?: 'explore' | 'plan' | 'general';\n30\t  /** Allowlist of space-function names available to this task's fork. When set, only these\n31\t   *  functions are injected + listed in the prompt (least privilege); omit for all. */\n32\t  functions?: string[];\n33\t  /** Host-driven fan-out: \"<upstreamTaskId>.<field>\" (or bare \"<upstreamTaskId>\") naming an\n34\t   *  upstream array. The host runs this task once per element, in parallel, and collects the\n35\t   *  resolved values into an array. The element is injected into each fork as `item` (+ `index`). */\n36\t  forEach?: string;\n37\t  /** Per-task delegation allowlist: `\"space/agent\"` (any action) or `\"space/agent#action\"`.\n38\t   *  When set, the task's fork may `delegate()` to exactly these targets (and nothing else). */\n39\t  canDelegateTo?: string[];\n40\t  /** Per-node capability NARROWING (least privilege per step). When set, the fork runs with\n41\t   *  only the intersection of these ids and the OWNING AGENT's declared capabilities — a node\n42\t   *  can never gain a cap the agent lacks (see `narrowAppCaps`). Bare ids only; each cap keeps\n43\t   *  the agent grant's scope config. Omit to inherit the agent's full set. */\n44\t  capabilities?: string[];\n45\t  /** Host-executed TS statements (YAML block scalar) run in the fork VM BEFORE the model's\n46\t   *  first turn — the task's deterministic setup (bindings, webSearch/webFetch gathering)\n47\t   *  executes with host reliability instead of being re-emitted by the model. Yields are\n48\t   *  allowed; failures degrade per-statement (never kill the fork). Deep validation happens\n49\t   *  at run time through the same typecheck pipeline as model statements. */\n50\t  prelude?: string;\n51\t}\n52\t\n53\texport async function loadTasklist(dir: string, files: string[]): Promise<Record<string, TaskNode>> {\n54\t  const tasks: Record<string, TaskNode> = {};\n55\t\n56\t  for (const filePath of files) {\n57\t    let task: TaskNode;\n58\t    if (filePath.endsWith('.ts')) {\n59\t      // Code node: statically extract its `node` metadata literal WITHOUT\n60\t      // importing/executing the module (core stays free of any transpile/worker\n61\t      // runtime — that lives in the CLI/pod, which runs `run(ctx, inputs)` later\n62\t      // via the orchestrator's injected factory). The metadata goes through the\n63\t      // EXACT same field validators as md-node frontmatter below.\n64\t      const raw = await readFile(filePath, 'utf8');\n65\t      const { node, hasRun } = extractCodeNodeMeta(raw, filePath);\n66\t      if (!hasRun) {\n67\t        throw new Error(\n68\t          `Code node \"${filePath}\" must export an async \\`run(ctx, inputs)\\` function`,\n69\t        );\n70\t      }\n71\t      const filename = basename(filePath, '.ts');\n72\t      task = buildTaskNode(node, {\n73\t        filename,\n74\t        filePath,\n75\t        kind: 'code',\n76\t        instruction: '',\n77\t        codeModulePath: resolve(filePath),\n78\t      });\n79\t    } else {\n80\t      const raw = await readFile(filePath, 'utf8');\n81\t      const { data, body } = parseFrontmatter(raw, filePath);\n82\t      // Derive ID from filename (strip numeric prefix and .md)\n83\t      const filename = basename(filePath, '.md');\n84\t      task = buildTaskNode(data, { filename, filePath, kind: 'agent', instruction: body.trim() });\n85\t    }\n86\t    tasks[task.id] = task;\n87\t  }\n88\t\n89\t  return tasks;\n90\t}\n91\t\n92\t/**\n93\t * Build a TaskNode from a metadata record — either parsed `.md` frontmatter\n94\t * (agent node) or the statically-extracted `node` object of a `.ts` file (code\n95\t * node). The two paths share this single validator so a code node's\n96\t * `id/dependsOn/condition/forEach/output/…` behave IDENTICALLY to an md node's.\n97\t */\n98\tfunction buildTaskNode(\n99\t  data: Record<string, unknown>,\n100\t  opts: { filename: string; filePath: string; kind: 'agent' | 'code'; instruction: string; codeModulePath?: string },\n101\t): TaskNode {\n102\t  const { filename, filePath, kind, instruction, codeModulePath } = opts;\n103\t\n104\t  // Remove leading numeric prefix like \"01-\" or \"001_\" (same rule for md + ts).\n105\t  const id = data['id']\n106\t    ? String(data['id'])\n107\t    : filename.replace(/^\\d+[-_]?/, '') || filename;\n108\t\n109\t  const output: Record<string, string> = {};\n110\t  if (data['output'] && typeof data['output'] === 'object' && !Array.isArray(data['output'])) {\n111\t    for (const [k, v] of Object.entries(data['output'] as Record<string, unknown>)) {\n112\t      output[k] = String(v);\n113\t    }\n114\t  }\n115\t\n116\t  const task: TaskNode = { id, kind, instruction, output };\n117\t  if (codeModulePath) task.codeModulePath = codeModulePath;\n118\t\n119\t  if (data['input'] && typeof data['input'] === 'object' && !Array.isArray(data['input'])) {\n120\t    const input: Record<string, string> = {};\n121\t    for (const [k, v] of Object.entries(data['input'] as Record<string, unknown>)) {\n122\t      input[k] = String(v);\n123\t    }\n124\t    task.input = input;\n125\t  }\n126\t\n127\t  if (Array.isArray(data['dependsOn'])) {\n128\t    task.dependsOn = data['dependsOn'].map(String);\n129\t  }\n130\t  if (typeof data['condition'] === 'string') {\n131\t    task.condition = data['condition'];\n132\t  }\n133\t  if (data['optional'] === true) {\n134\t    task.optional = true;\n135\t  }\n136\t  if (data['goal'] === true) {\n137\t    task.goal = true;\n138\t  }\n139\t  if (data['role'] === 'explore' || data['role'] === 'plan' || data['role'] === 'general') {\n140\t    task.role = data['role'];\n141\t  }\n142\t  if (Array.isArray(data['functions'])) {\n143\t    task.functions = data['functions'].map(String);\n144\t  }\n145\t  if (typeof data['forEach'] === 'string' && data['forEach'].trim()) {\n146\t    task.forEach = data['forEach'].trim();\n147\t  }\n148\t  if (Array.isArray(data['canDelegateTo'])) {\n149\t    task.canDelegateTo = data['canDelegateTo'].map(String);\n150\t  }\n151\t  if (data['capabilities'] !== undefined) {\n152\t    if (!Array.isArray(data['capabilities'])) {\n153\t      throw new Error(\n154\t        `Task \"${id}\" (${filePath}): \"capabilities\" must be a list of bare capability ids (a per-node subset of the agent's grants)`,\n155\t      );\n156\t    }\n157\t    const ids = data['capabilities'].map(String);\n158\t    const unknown = ids.filter((c) => !CAPABILITY_IDS.has(c as CapabilityId));\n159\t    if (unknown.length > 0) {\n160\t      throw new Error(\n161\t        `Task \"${id}\" (${filePath}): unknown capability id(s) in \"capabilities\": ${unknown.join(', ')}. Known: ${[...CAPABILITY_IDS].join(', ')}`,\n162\t      );\n163\t    }\n164\t    task.capabilities = ids;\n165\t  }\n166\t  if (data['prelude'] !== undefined) {\n167\t    // Light load-time validation only (non-empty string). Deep validation is\n168\t    // deferred to run time, where each statement goes through the same\n169\t    // typecheck pipeline as model statements (see exec/prelude.ts). Only\n170\t    // meaningful for agent nodes; a code node never carries one in practice.\n171\t    if (typeof data['prelude'] !== 'string' || !data['prelude'].trim()) {\n172\t      throw new Error(\n173\t        `Task \"${id}\" (${filePath}): \"prelude\" must be a non-empty string of TypeScript statements`,\n174\t      );\n175\t    }\n176\t    task.prelude = data['prelude'];\n177\t  }\n178\t\n179\t  return task;\n180\t}\n181\t\n182\t/**\n183\t * Statically extract a code node's exported `node` metadata object and confirm\n184\t * it exports a `run` function — parsed from the `.ts` SOURCE with the TypeScript\n185\t * compiler, never imported or executed. This keeps `@lmthing/core` free of any\n186\t * transpile/Node-worker runtime (the constraint that lets the same core run in\n187\t * the QuickJS sandbox). The `run(ctx, inputs)` body is deliberately ignored here;\n188\t * it is loaded + executed later by the CLI/pod's injected `codeNodeCtxFactory`.\n189\t *\n190\t * Only static literal values are supported for the metadata (it is always plain\n191\t * data: `id`/`dependsOn`/`condition`/`forEach`/`output`/…). A non-literal\n192\t * expression is an authoring error and throws.\n193\t */\n194\texport function extractCodeNodeMeta(source: string, filePath: string): { node: Record<string, unknown>; hasRun: boolean } {\n195\t  const sf = ts.createSourceFile(filePath, source, ts.ScriptTarget.Latest, /*setParentNodes*/ true);\n196\t  let nodeObj: Record<string, unknown> | undefined;\n197\t  let hasRun = false;\n198\t\n199\t  for (const stmt of sf.statements) {\n200\t    if (ts.isFunctionDeclaration(stmt) && stmt.name?.text === 'run') {\n201\t      hasRun = true;\n202\t      continue;\n203\t    }\n204\t    if (ts.isVariableStatement(stmt)) {\n205\t      for (const decl of stmt.declarationList.declarations) {\n206\t        if (!ts.isIdentifier(decl.name) || !decl.initializer) continue;\n207\t        if (decl.name.text === 'node') {\n208\t          if (!ts.isObjectLiteralExpression(decl.initializer)) {\n209\t            throw new Error(`Code node \"${filePath}\": exported \\`node\\` must be an object literal`);\n210\t          }\n211\t          nodeObj = literalToValue(decl.initializer, filePath) as Record<string, unknown>;\n212\t        } else if (\n213\t          decl.name.text === 'run' &&\n214\t          (ts.isArrowFunction(decl.initializer) || ts.isFunctionExpression(decl.initializer))\n215\t        ) {\n216\t          hasRun = true;\n217\t        }\n218\t      }\n219\t    }\n220\t  }\n221\t\n222\t  return { node: nodeObj ?? {}, hasRun };\n223\t}\n224\t\n225\t/** Convert a static TS literal expression (object/array/string/number/boolean/\n226\t *  null) to its JS value. Non-literal expressions in code-node metadata throw. */\n227\tfunction literalToValue(node: ts.Expression, filePath: string): unknown {\n228\t  if (ts.isStringLiteralLike(node)) return node.text;\n229\t  if (ts.isNumericLiteral(node)) return Number(node.text);\n230\t  if (node.kind === ts.SyntaxKind.TrueKeyword) return true;\n231\t  if (node.kind === ts.SyntaxKind.FalseKeyword) return false;\n232\t  if (node.kind === ts.SyntaxKind.NullKeyword) return null;\n233\t  if (ts.isArrayLiteralExpression(node)) {\n234\t    return node.elements.map((el) => literalToValue(el, filePath));\n235\t  }\n236\t  if (ts.isObjectLiteralExpression(node)) {\n237\t    const obj: Record<string, unknown> = {};\n238\t    for (const prop of node.properties) {\n239\t      if (!ts.isPropertyAssignment(prop)) {\n240\t        throw new Error(\n241\t          `Code node \"${filePath}\": \\`node\\` metadata must use plain \\`key: value\\` properties`,\n242\t        );\n243\t      }\n244\t      let key: string;\n245\t      if (ts.isIdentifier(prop.name) || ts.isStringLiteralLike(prop.name)) key = prop.name.text;\n246\t      else throw new Error(`Code node \"${filePath}\": unsupported \\`node\\` metadata key`);\n247\t      obj[key] = literalToValue(prop.initializer, filePath);\n248\t    }\n249\t    return obj;\n250\t  }\n251\t  throw new Error(\n252\t    `Code node \"${filePath}\": \\`node\\` metadata values must be static literals (found ${ts.SyntaxKind[node.kind]})`,\n253\t  );\n254\t}\n255\t\n256\t/**\n257\t * Load a tasklist by name from the space.\n258\t */\n259\texport async function loadTasklistFromSpace(space: Space, name: string): Promise<Record<string, TaskNode>> {\n260\t  const tasklistDir = space.tasklists[name];"}]},"parent_tool_use_id":null,"session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"9d6db793-12f3-4d21-a025-f5fe02df83b4","timestamp":"2026-07-16T19:27:09.659Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/spaces/tasklist-load.ts","content":"import { readFile } from 'node:fs/promises';\nimport { basename, resolve } from 'node:path';\nimport ts from 'typescript';\nimport { parseFrontmatter } from './frontmatter.js';\nimport { CAPABILITY_IDS, type CapabilityId } from './capabilities.js';\nimport type { Space } from './load.js';\n\nexport interface TaskNode {\n  id: string;\n  /** Node kind: `'agent'` runs a model fork over `instruction` (an `NN-<id>.md`\n   *  file); `'code'` runs a host-injected `run(ctx, inputs)` loaded from\n   *  `codeModulePath` (an `NN-<id>.ts` file). Defaults to `'agent'`. Core NEVER\n   *  imports/executes a code node's module — the CLI/pod does, via the\n   *  orchestrator's injected `codeNodeCtxFactory` (keeps core free of any\n   *  transpile/Node-worker runtime). */\n  kind: 'agent' | 'code';\n  /** Absolute path to the code node's `.ts` module (`kind:'code'` only). Handed\n   *  verbatim to the injected `codeNodeCtxFactory`; core does not read it. */\n  codeModulePath?: string;\n  instruction: string; // body of the .md file (empty for code nodes)\n  output: Record<string, string>; // JSON-schema-ish: field -> type\n  input?: Record<string, string>; // JSON-schema-ish: field -> type\n  dependsOn?: string[];\n  condition?: string; // DSL expression\n  optional?: boolean;\n  goal?: boolean;\n  /** Fork capability profile for this task's subagent (default 'general' when omitted).\n   *  Read-only roles ('explore'/'plan') cannot write files or run mutating shell. */\n  role?: 'explore' | 'plan' | 'general';\n  /** Allowlist of space-function names available to this task's fork. When set, only these\n   *  functions are injected + listed in the prompt (least privilege); omit for all. */\n  functions?: string[];\n  /** Host-driven fan-out: \"<upstreamTaskId>.<field>\" (or bare \"<upstreamTaskId>\") naming an\n   *  upstream array. The host runs this task once per element, in parallel, and collects the\n   *  resolved values into an array. The element is injected into each fork as `item` (+ `index`). */\n  forEach?: string;\n  /** Per-task delegation allowlist: `\"space/agent\"` (any action) or `\"space/agent#action\"`.\n   *  When set, the task's fork may `delegate()` to exactly these targets (and nothing else). */\n  canDelegateTo?: string[];\n  /** Per-node capability NARROWING (least privilege per step). When set, the fork runs with\n   *  only the intersection of these ids and the OWNING AGENT's declared capabilities — a node\n   *  can never gain a cap the agent lacks (see `narrowAppCaps`). Bare ids only; each cap keeps\n   *  the agent grant's scope config. Omit to inherit the agent's full set. */\n  capabilities?: string[];\n  /** Host-executed TS statements (YAML block scalar) run in the fork VM BEFORE the model's\n   *  first turn — the task's deterministic setup (bindings, webSearch/webFetch gathering)\n   *  executes with host reliability instead of being re-emitted by the model. Yields are\n   *  allowed; failures degrade per-statement (never kill the fork). Deep validation happens\n   *  at run time through the same typecheck pipeline as model statements. */\n  prelude?: string;\n}\n\nexport async function loadTasklist(dir: string, files: string[]): Promise<Record<string, TaskNode>> {\n  const tasks: Record<string, TaskNode> = {};\n\n  for (const filePath of files) {\n    let task: TaskNode;\n    if (filePath.endsWith('.ts')) {\n      // Code node: statically extract its `node` metadata literal WITHOUT\n      // importing/executing the module (core stays free of any transpile/worker\n      // runtime — that lives in the CLI/pod, which runs `run(ctx, inputs)` later\n      // via the orchestrator's injected factory). The metadata goes through the\n      // EXACT same field validators as md-node frontmatter below.\n      const raw = await readFile(filePath, 'utf8');\n      const { node, hasRun } = extractCodeNodeMeta(raw, filePath);\n      if (!hasRun) {\n        throw new Error(\n          `Code node \"${filePath}\" must export an async \\`run(ctx, inputs)\\` function`,\n        );\n      }\n      const filename = basename(filePath, '.ts');\n      task = buildTaskNode(node, {\n        filename,\n        filePath,\n        kind: 'code',\n        instruction: '',\n        codeModulePath: resolve(filePath),\n      });\n    } else {\n      const raw = await readFile(filePath, 'utf8');\n      const { data, body } = parseFrontmatter(raw, filePath);\n      // Derive ID from filename (strip numeric prefix and .md)\n      const filename = basename(filePath, '.md');\n      task = buildTaskNode(data, { filename, filePath, kind: 'agent', instruction: body.trim() });\n    }\n    tasks[task.id] = task;\n  }\n\n  return tasks;\n}\n\n/**\n * Build a TaskNode from a metadata record — either parsed `.md` frontmatter\n * (agent node) or the statically-extracted `node` object of a `.ts` file (code\n * node). The two paths share this single validator so a code node's\n * `id/dependsOn/condition/forEach/output/…` behave IDENTICALLY to an md node's.\n */\nfunction buildTaskNode(\n  data: Record<string, unknown>,\n  opts: { filename: string; filePath: string; kind: 'agent' | 'code'; instruction: string; codeModulePath?: string },\n): TaskNode {\n  const { filename, filePath, kind, instruction, codeModulePath } = opts;\n\n  // Remove leading numeric prefix like \"01-\" or \"001_\" (same rule for md + ts).\n  const id = data['id']\n    ? String(data['id'])\n    : filename.replace(/^\\d+[-_]?/, '') || filename;\n\n  const output: Record<string, string> = {};\n  if (data['output'] && typeof data['output'] === 'object' && !Array.isArray(data['output'])) {\n    for (const [k, v] of Object.entries(data['output'] as Record<string, unknown>)) {\n      output[k] = String(v);\n    }\n  }\n\n  const task: TaskNode = { id, kind, instruction, output };\n  if (codeModulePath) task.codeModulePath = codeModulePath;\n\n  if (data['input'] && typeof data['input'] === 'object' && !Array.isArray(data['input'])) {\n    const input: Record<string, string> = {};\n    for (const [k, v] of Object.entries(data['input'] as Record<string, unknown>)) {\n      input[k] = String(v);\n    }\n    task.input = input;\n  }\n\n  if (Array.isArray(data['dependsOn'])) {\n    task.dependsOn = data['dependsOn'].map(String);\n  }\n  if (typeof data['condition'] === 'string') {\n    task.condition = data['condition'];\n  }\n  if (data['optional'] === true) {\n    task.optional = true;\n  }\n  if (data['goal'] === true) {\n    task.goal = true;\n  }\n  if (data['role'] === 'explore' || data['role'] === 'plan' || data['role'] === 'general') {\n    task.role = data['role'];\n  }\n  if (Array.isArray(data['functions'])) {\n    task.functions = data['functions'].map(String);\n  }\n  if (typeof data['forEach'] === 'string' && data['forEach'].trim()) {\n    task.forEach = data['forEach'].trim();\n  }\n  if (Array.isArray(data['canDelegateTo'])) {\n    task.canDelegateTo = data['canDelegateTo'].map(String);\n  }\n  if (data['capabilities'] !== undefined) {\n    if (!Array.isArray(data['capabilities'])) {\n      throw new Error(\n        `Task \"${id}\" (${filePath}): \"capabilities\" must be a list of bare capability ids (a per-node subset of the agent's grants)`,\n      );\n    }\n    const ids = data['capabilities'].map(String);\n    const unknown = ids.filter((c) => !CAPABILITY_IDS.has(c as CapabilityId));\n    if (unknown.length > 0) {\n      throw new Error(\n        `Task \"${id}\" (${filePath}): unknown capability id(s) in \"capabilities\": ${unknown.join(', ')}. Known: ${[...CAPABILITY_IDS].join(', ')}`,\n      );\n    }\n    task.capabilities = ids;\n  }\n  if (data['prelude'] !== undefined) {\n    // Light load-time validation only (non-empty string). Deep validation is\n    // deferred to run time, where each statement goes through the same\n    // typecheck pipeline as model statements (see exec/prelude.ts). Only\n    // meaningful for agent nodes; a code node never carries one in practice.\n    if (typeof data['prelude'] !== 'string' || !data['prelude'].trim()) {\n      throw new Error(\n        `Task \"${id}\" (${filePath}): \"prelude\" must be a non-empty string of TypeScript statements`,\n      );\n    }\n    task.prelude = data['prelude'];\n  }\n\n  return task;\n}\n\n/**\n * Statically extract a code node's exported `node` metadata object and confirm\n * it exports a `run` function — parsed from the `.ts` SOURCE with the TypeScript\n * compiler, never imported or executed. This keeps `@lmthing/core` free of any\n * transpile/Node-worker runtime (the constraint that lets the same core run in\n * the QuickJS sandbox). The `run(ctx, inputs)` body is deliberately ignored here;\n * it is loaded + executed later by the CLI/pod's injected `codeNodeCtxFactory`.\n *\n * Only static literal values are supported for the metadata (it is always plain\n * data: `id`/`dependsOn`/`condition`/`forEach`/`output`/…). A non-literal\n * expression is an authoring error and throws.\n */\nexport function extractCodeNodeMeta(source: string, filePath: string): { node: Record<string, unknown>; hasRun: boolean } {\n  const sf = ts.createSourceFile(filePath, source, ts.ScriptTarget.Latest, /*setParentNodes*/ true);\n  let nodeObj: Record<string, unknown> | undefined;\n  let hasRun = false;\n\n  for (const stmt of sf.statements) {\n    if (ts.isFunctionDeclaration(stmt) && stmt.name?.text === 'run') {\n      hasRun = true;\n      continue;\n    }\n    if (ts.isVariableStatement(stmt)) {\n      for (const decl of stmt.declarationList.declarations) {\n        if (!ts.isIdentifier(decl.name) || !decl.initializer) continue;\n        if (decl.name.text === 'node') {\n          if (!ts.isObjectLiteralExpression(decl.initializer)) {\n            throw new Error(`Code node \"${filePath}\": exported \\`node\\` must be an object literal`);\n          }\n          nodeObj = literalToValue(decl.initializer, filePath) as Record<string, unknown>;\n        } else if (\n          decl.name.text === 'run' &&\n          (ts.isArrowFunction(decl.initializer) || ts.isFunctionExpression(decl.initializer))\n        ) {\n          hasRun = true;\n        }\n      }\n    }\n  }\n\n  return { node: nodeObj ?? {}, hasRun };\n}\n\n/** Convert a static TS literal expression (object/array/string/number/boolean/\n *  null) to its JS value. Non-literal expressions in code-node metadata throw. */\nfunction literalToValue(node: ts.Expression, filePath: string): unknown {\n  if (ts.isStringLiteralLike(node)) return node.text;\n  if (ts.isNumericLiteral(node)) return Number(node.text);\n  if (node.kind === ts.SyntaxKind.TrueKeyword) return true;\n  if (node.kind === ts.SyntaxKind.FalseKeyword) return false;\n  if (node.kind === ts.SyntaxKind.NullKeyword) return null;\n  if (ts.isArrayLiteralExpression(node)) {\n    return node.elements.map((el) => literalToValue(el, filePath));\n  }\n  if (ts.isObjectLiteralExpression(node)) {\n    const obj: Record<string, unknown> = {};\n    for (const prop of node.properties) {\n      if (!ts.isPropertyAssignment(prop)) {\n        throw new Error(\n          `Code node \"${filePath}\": \\`node\\` metadata must use plain \\`key: value\\` properties`,\n        );\n      }\n      let key: string;\n      if (ts.isIdentifier(prop.name) || ts.isStringLiteralLike(prop.name)) key = prop.name.text;\n      else throw new Error(`Code node \"${filePath}\": unsupported \\`node\\` metadata key`);\n      obj[key] = literalToValue(prop.initializer, filePath);\n    }\n    return obj;\n  }\n  throw new Error(\n    `Code node \"${filePath}\": \\`node\\` metadata values must be static literals (found ${ts.SyntaxKind[node.kind]})`,\n  );\n}\n\n/**\n * Load a tasklist by name from the space.\n */\nexport async function loadTasklistFromSpace(space: Space, name: string): Promise<Record<string, TaskNode>> {\n  const tasklistDir = space.tasklists[name];","numLines":260,"startLine":1,"totalLines":266}}}
