{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_PsA9yW5NgOMxxXMHy3iFsZli","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { runDelegate } from './delegate.js';\n3\timport { DelegateRegistry } from './registry.js';\n4\timport type { RenderHost } from '../session/types.js';\n5\timport type { StreamSession } from '../eval/stream-types.js';\n6\timport type { Space, AgentDef } from '../spaces/load.js';\n7\timport { loadSystemSpaces, defaultSystemSpaceDirs } from '../spaces/system.js';\n8\timport { createMockStreamFn } from '../testing/mock-provider.js';\n9\timport { Tracer, type TraceEvent } from '../sandbox/trace.js';\n10\t\n11\t/**\n12\t * Delegate depth guard. runDelegate refuses to recurse past maxDepth — the check\n13\t * fires before any space is loaded, so a runaway delegate chain is bounded. The\n14\t * happy-path + nested (A→B) chain is covered end-to-end in\n15\t * testing/harness-features.test.ts; here we pin the cap itself.\n16\t */\n17\t\n18\tconst silentHost: RenderHost = { display: () => {}, ask: async () => '', log: () => {} };\n19\tconst emptyStream = async (): Promise<StreamSession> => ({\n20\t  textStream: (async function* () {})(),\n21\t  abort() {},\n22\t});\n23\t\n24\tdescribe('runDelegate depth cap', () => {\n25\t  it('throws when depth has reached maxDepth (before loading the target)', async () => {\n26\t    const registry = new DelegateRegistry(new Map()); // empty: proves we never reach resolution\n27\t    await expect(\n28\t      runDelegate({\n29\t        packageName: 'pkg',\n30\t        agentName: 'agent',\n31\t        action: 'act',\n32\t        registry,\n33\t        renderHost: silentHost,\n34\t        streamFn: emptyStream,\n35\t        depth: 5,\n36\t        maxDepth: 5,\n37\t        maxConcurrentForks: 4,\n38\t      }),\n39\t    ).rejects.toThrow(/Maximum delegation depth \\(5\\) exceeded/);\n40\t  });\n41\t\n42\t  it('the error names the unresolved target', async () => {\n43\t    const registry = new DelegateRegistry(new Map());\n44\t    await expect(\n45\t      runDelegate({\n46\t        packageName: 'somePkg',\n47\t        agentName: 'someAgent',\n48\t        action: 'go',\n49\t        registry,\n50\t        renderHost: silentHost,\n51\t        streamFn: emptyStream,\n52\t        depth: 3,\n53\t        maxDepth: 3,\n54\t        maxConcurrentForks: 4,\n55\t      }),\n56\t    ).rejects.toThrow(/somePkg\\/someAgent/);\n57\t  });\n58\t});\n59\t\n60\t/**\n61\t * Regression: a delegate VM must have the universal `global` toolkit in BOTH the\n62\t * typecheck overlay and the injected runtime — not just the runtime. The `memory`\n63\t * system agent declares no functions of its own and calls `recallAll()` directly;\n64\t * before the fix the overlay was built from the agent's declared functions only, so\n65\t * the statement failed typecheck with \"Cannot find name 'recallAll'\", never resolved,\n66\t * and the delegate returned undefined. (Found via the THING → memory delegation.)\n67\t */\n68\tdescribe('runDelegate exposes the global toolkit to declared-functionless agents', () => {\n69\t  it('the memory agent can call recallAll() (typechecks + injects)', async () => {\n70\t    const systemSpaces = await loadSystemSpaces(defaultSystemSpaceDirs());\n71\t    const memory = systemSpaces.find((s) => s.dir.endsWith('/user-memory'));\n72\t    expect(memory, 'memory system space should load').toBeTruthy();\n73\t\n74\t    const registry = new DelegateRegistry(new Map([[memory!.dir, memory!]]));\n75\t    // The \"model\" calls a universal global tool and resolves with its result. If\n76\t    // recallAll were missing from the overlay this statement would fail typecheck and\n77\t    // the result would never be captured (→ undefined).\n78\t    const streamFn = createMockStreamFn(\n79\t      () => `const r = recallAll();\\ncurrentTask.resolve({ ok: r.ok, isObject: typeof r.facts === 'object' });`,\n80\t    );\n81\t\n82\t    const result = (await runDelegate({\n83\t      packageName: memory!.dir,\n84\t      agentName: 'memory',\n85\t      registry,\n86\t      renderHost: silentHost,\n87\t      streamFn,\n88\t      depth: 0,\n89\t      maxDepth: 5,\n90\t      maxConcurrentForks: 4,\n91\t      systemSpaces,\n92\t    })) as { ok: boolean; isObject: boolean } | undefined;\n93\t\n94\t    expect(result).toEqual({ ok: true, isObject: true });\n95\t  });\n96\t});\n97\t\n98\t/**\n99\t * A delegation's inputs are recorded on its trace node so a downstream ledger can\n100\t * report \"with what inputs\" it was made. runDelegate writes a truncated preview of\n101\t * `delegateOpts.query` into the delegate `node_start` detail.\n102\t */\n103\tdescribe('runDelegate records the query input on its trace node', () => {\n104\t  it('the delegate node_start detail carries the query preview', async () => {\n105\t    const systemSpaces = await loadSystemSpaces(defaultSystemSpaceDirs());\n106\t    const memory = systemSpaces.find((s) => s.dir.endsWith('/user-memory'));\n107\t    expect(memory).toBeTruthy();\n108\t    const registry = new DelegateRegistry(new Map([[memory!.dir, memory!]]));\n109\t    const streamFn = createMockStreamFn(() => `currentTask.resolve({ ok: true });`);\n110\t\n111\t    const tracer = new Tracer(null);\n112\t    const starts: Extract<TraceEvent, { type: 'node_start' }>[] = [];\n113\t    tracer.subscribe((e) => { if (e.type === 'node_start' && e.kind === 'delegate') starts.push(e); });\n114\t\n115\t    await runDelegate({\n116\t      packageName: memory!.dir,\n117\t      agentName: 'memory',\n118\t      registry,\n119\t      renderHost: silentHost,\n120\t      streamFn,\n121\t      depth: 0,\n122\t      maxDepth: 5,\n123\t      maxConcurrentForks: 4,\n124\t      systemSpaces,\n125\t      tracer,\n126\t      delegateOpts: { query: 'remember my birthday' },\n127\t    });\n128\t\n129\t    expect(starts).toHaveLength(1);\n130\t    expect(starts[0]!.detail?.query).toBe('remember my birthday');\n131\t    expect(starts[0]!.detail?.agent).toBe('memory');\n132\t  });\n133\t});\n134\t\n135\tdescribe('runDelegate forced-resolve nudge (E4 live finding)', () => {\n136\t  it('a model-driven delegate that finishes without resolving gets resolve-only turns instead of returning undefined', async () => {\n137\t    const systemSpaces = await loadSystemSpaces(defaultSystemSpaceDirs());\n138\t    const memory = systemSpaces.find((s) => s.dir.endsWith('/user-memory'));\n139\t    expect(memory).toBeTruthy();\n140\t    const registry = new DelegateRegistry(new Map([[memory!.dir, memory!]]));\n141\t\n142\t    let nudged = false;\n143\t    const streamFn = createMockStreamFn((o) => {\n144\t      const last = [...o.messages].reverse().find((m) => m.role === 'user')?.content ?? '';\n145\t      if (last.includes('currentTask.resolve()')) {\n146\t        // The STOP nudge — NOW resolve.\n147\t        nudged = true;\n148\t        return `currentTask.resolve({ done: true, via: 'nudge' });`;\n149\t      }\n150\t      // Main run: do work, display, and end WITHOUT resolving (the live E4 engineer shape).\n151\t      return `display(\"did the work but forgot to resolve\");`;\n152\t    });\n153\t\n154\t    const result = (await runDelegate({\n155\t      packageName: memory!.dir,\n156\t      agentName: 'memory',\n157\t      registry,\n158\t      renderHost: silentHost,\n159\t      streamFn,\n160\t      depth: 0,\n161\t      maxDepth: 5,\n162\t      maxConcurrentForks: 4,\n163\t      systemSpaces,\n164\t    })) as { done: boolean; via: string } | undefined;\n165\t\n166\t    expect(nudged).toBe(true);\n167\t    expect(result).toEqual({ done: true, via: 'nudge' });\n168\t  });\n169\t});\n170\t\n171\t/**\n172\t * Action-restriction enforcement (WP-3 / org/format/space/agents/delegation.md). A `canDelegateTo` entry with\n173\t * a `#action` suffix (e.g. \"helper#greet\") resolves to a `ResolvedDep` whose\n174\t * `allowedActions` gates which action ids may be delegated. `runDelegate` is the\n175\t * enforcement point: it rejects a disallowed action up front (before loading the\n176\t * target's VM) and lets an allowed one proceed normally.\n177\t */\n178\tdescribe('runDelegate action-restriction (allowedActions)', () => {\n179\t  function fakeAgent(slug: string, actions: { id: string }[]): AgentDef {\n180\t    return {\n181\t      slug,\n182\t      title: slug,\n183\t      instructBody: '',\n184\t      charterBody: '',\n185\t      actions: actions.map((a) => ({ id: a.id, label: a.id, description: '', tasklist: '' })),\n186\t      canDelegateTo: [],\n187\t      config: { knowledge: [], functions: [], components: [] },\n188\t    };\n189\t  }\n190\t\n191\t  function fakeSpace(dir: string, agents: Record<string, AgentDef>): Space {\n192\t    return {\n193\t      dir,\n194\t      packageName: undefined,\n195\t      agents,\n196\t      tasklists: {},\n197\t      functions: {},\n198\t      functionsBundled: {},\n199\t      dependentSpaces: {},\n200\t      components: { view: {}, form: {} },\n201\t      knowledge: { domains: {} },\n202\t    } as Space;\n203\t  }\n204\t\n205\t  it('throws naming the allowed actions when the requested action is disallowed', async () => {\n206\t    const helper = fakeAgent('helper', [{ id: 'greet' }, { id: 'farewell' }]);\n207\t    const space = fakeSpace('/fake/space', { helper });\n208\t    const registry = new DelegateRegistry(new Map([['/fake/space', space]]));\n209\t\n210\t    await expect(\n211\t      runDelegate({\n212\t        packageName: '/fake/space',\n213\t        agentName: 'helper',\n214\t        action: 'farewell',\n215\t        allowedActions: ['greet'],\n216\t        registry,\n217\t        renderHost: silentHost,\n218\t        streamFn: emptyStream,\n219\t        depth: 0,\n220\t        maxDepth: 5,\n221\t        maxConcurrentForks: 4,\n222\t      }),\n223\t    ).rejects.toThrow(/does not allow action \"farewell\".*allowed actions: greet/);\n224\t  });\n225\t\n226\t  it('allows a permitted action through to the model-driven run', async () => {\n227\t    const helper = fakeAgent('helper', [{ id: 'greet' }, { id: 'farewell' }]);\n228\t    const space = fakeSpace('/fake/space2', { helper });\n229\t    const registry = new DelegateRegistry(new Map([['/fake/space2', space]]));\n230\t    const streamFn = createMockStreamFn(() => `currentTask.resolve(\"hi\");`);\n231\t\n232\t    const result = await runDelegate({\n233\t      packageName: '/fake/space2',\n234\t      agentName: 'helper',\n235\t      action: 'greet',\n236\t      allowedActions: ['greet'],\n237\t      registry,\n238\t      renderHost: silentHost,\n239\t      streamFn,\n240\t      depth: 0,\n241\t      maxDepth: 5,\n242\t      maxConcurrentForks: 4,\n243\t    });\n244\t\n245\t    expect(result).toBe('hi');\n246\t  });\n247\t\n248\t  it('undefined allowedActions means unrestricted (no-action model-driven call passes)', async () => {\n249\t    const helper = fakeAgent('helper', [{ id: 'greet' }]);\n250\t    const space = fakeSpace('/fake/space3', { helper });\n251\t    const registry = new DelegateRegistry(new Map([['/fake/space3', space]]));\n252\t    const streamFn = createMockStreamFn(() => `currentTask.resolve(\"ok\");`);\n253\t\n254\t    const result = await runDelegate({\n255\t      packageName: '/fake/space3',\n256\t      agentName: 'helper',\n257\t      // no action — model-driven; no allowedActions — unrestricted.\n258\t      registry,\n259\t      renderHost: silentHost,\n260\t      streamFn,\n261\t      depth: 0,\n262\t      maxDepth: 5,\n263\t      maxConcurrentForks: 4,\n264\t    });\n265\t\n266\t    expect(result).toBe('ok');\n267\t  });\n268\t});\n269\t"}]},"parent_tool_use_id":"call_fzpUJSbHB3H8gLDKEI4xloQi","session_id":"838823e9-9562-4e94-a4a8-ddea09a60dee","uuid":"8527c506-83bb-4046-bc37-36daa4ee059b","timestamp":"2026-07-16T06:19:22.403Z","subagent_type":"Explore","task_description":"Trace automator structural failure"}
