{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4AGBuS64REKdQdbptlFfyP5W","type":"tool_result","content":"1\t/**\n2\t * Load / invoke **store-downloaded module code** in a worker-isolated runtime.\n3\t *\n4\t * Space emitter defs and space hook handlers are code the pod DID NOT author —\n5\t * they must never be `require()`d in the main process (a top-level side effect\n6\t * would run with the pod's privileges). This helper is the single seam both the\n7\t * emitter scanner (`server/emitter-manifests.ts`, S4) and the space-hook loader\n8\t * (`app/hooks/loader.ts`, S7) use to touch that code safely:\n9\t *\n10\t *   - {@link loadDefaultInWorker} — evaluate a `.ts` module in a worker and\n11\t *     return the default export's serializable DATA (functions stripped) + the\n12\t *     names of its function-valued keys. Used to read a def's shape without ever\n13\t *     holding a store-code closure in-proc.\n14\t *   - {@link invokeDefaultFnInWorker} — evaluate the module in a worker and call\n15\t *     `default.<fnKey>(ctx)`; the ctx's `db`/`delegate`/`callConnection`/\n16\t *     `tasklist.run` are proxies serviced by the caller's main-process\n17\t *     {@link WorkerInvokeHandlers}. Used to run a space hook handler.\n18\t *\n19\t * The `.ts` is transpiled to CJS in the main process (esbuild) and the CODE\n20\t * string is passed to the worker — no `.ts` toolchain in the worker, same as the\n21\t * api runtime. Every call is timeout-bounded (a hostile top-level loop or a hung\n22\t * handler is terminated).\n23\t */\n24\t\n25\timport { existsSync } from 'node:fs';\n26\timport { readFile } from 'node:fs/promises';\n27\timport { dirname, join } from 'node:path';\n28\timport { fileURLToPath } from 'node:url';\n29\timport { Worker as NodeWorker } from 'node:worker_threads';\n30\t\n31\timport { build, transform } from 'esbuild';\n32\t\n33\timport type { WorkerLoadJob, WorkerLoadToMain, ProxyReplyToWorker } from './worker-load-protocol.js';\n34\t\n35\t/** Default wall-clock budget for one worker load/invoke. */\n36\tconst DEFAULT_TIMEOUT_MS = 10_000;\n37\t\n38\t/** The db method names proxied to the main process (mirrors `@lmthing/core`'s `AsyncDbApi`). */\n39\tconst DB_METHODS = ['query', 'tables', 'insert', 'update', 'remove', 'createTable', 'addColumn'];\n40\t\n41\t/** Local structural view of a `node:worker_threads` Worker (the shared tsconfig's\n42\t *  DOM lib defines a colliding global `Worker`; cast to this instead). */\n43\tinterface WorkerHandle {\n44\t  on(event: 'message', listener: (msg: WorkerLoadToMain) => void): void;\n45\t  on(event: 'error', listener: (err: Error) => void): void;\n46\t  on(event: 'exit', listener: (code: number) => void): void;\n47\t  postMessage(value: ProxyReplyToWorker): void;\n48\t  terminate(): Promise<number>;\n49\t}\n50\t\n51\t// ── Worker source bundling (once per process) ─────────────────────────────────\n52\t\n53\tlet workerSourcePromise: Promise<string> | undefined;\n54\t\n55\t/** Bundle `worker-load-entry.ts` → a self-contained CJS string (cached). */\n56\tfunction workerSource(): Promise<string> {\n57\t  if (!workerSourcePromise) {\n58\t    const here = dirname(fileURLToPath(import.meta.url));\n59\t    const tsEntry = join(here, 'worker-load-entry.ts');\n60\t    const jsEntry = join(here, 'worker-load-entry.js');\n61\t    const entry = existsSync(tsEntry) ? tsEntry : jsEntry;\n62\t    workerSourcePromise = build({\n63\t      entryPoints: [entry],\n64\t      bundle: true,\n65\t      write: false,\n66\t      format: 'cjs',\n67\t      platform: 'node',\n68\t      target: 'node18',\n69\t    }).then((res) => res.outputFiles[0].text);\n70\t  }\n71\t  return workerSourcePromise;\n72\t}\n73\t\n74\t// ── Transpile (once per file content) ─────────────────────────────────────────\n75\t\n76\t/** Transpile a `.ts` file → CJS. Never evaluates it (that happens in the worker). */\n77\tasync function transpileFile(file: string): Promise<string> {\n78\t  const source = await readFile(file, 'utf8');\n79\t  const { code } = await transform(source, {\n80\t    loader: 'ts',\n81\t    format: 'cjs',\n82\t    target: 'node18',\n83\t    sourcefile: file,\n84\t  });\n85\t  return code;\n86\t}\n87\t\n88\t// ── Public API ────────────────────────────────────────────────────────────────\n89\t\n90\t/** The default export's serializable shape + the keys that held functions. */\n91\texport interface WorkerLoadResult {\n92\t  /** Own enumerable data properties of the default export (functions omitted). */\n93\t  data: Record<string, unknown>;\n94\t  /** Keys of the default export whose value was a function (e.g. `handler`, `emit`). */\n95\t  functionKeys: string[];\n96\t}\n97\t\n98\t/** Proxy handlers the main process supplies when a worker fn is invoked. Each is\n99\t *  optional — a call to a missing capability rejects in the worker. */\n100\texport interface WorkerInvokeHandlers {\n101\t  db?: Record<string, (...args: unknown[]) => Promise<unknown>>;\n102\t  delegate?: (spaceRef: string, action?: string, opts?: unknown) => Promise<unknown>;\n103\t  callConnection?: (provider: string, req?: unknown) => Promise<unknown>;\n104\t  tasklistRun?: (ref: string, seed?: unknown) => Promise<unknown>;\n105\t  /** Cron-emitter per-def JSON KV scratchpad (`ctx.state.get`/`set`), serviced\n106\t   *  main-side by `server/emitter-state.ts`. Omitted for hooks/code nodes (a\n107\t   *  `ctx.state` call then rejects). */\n108\t  state?: { get: (key: string) => Promise<unknown>; set: (key: string, value: unknown) => Promise<void> };\n109\t}\n110\t\n111\t/**\n112\t * Evaluate `file`'s module in a worker and return its default export's\n113\t * serializable data + function-key list. The module is NEVER evaluated in-proc.\n114\t */\n115\texport async function loadDefaultInWorker(\n116\t  file: string,\n117\t  opts: { timeoutMs?: number } = {},\n118\t): Promise<WorkerLoadResult> {\n119\t  const code = await transpileFile(file);\n120\t  const result = await runWorker({ mode: 'load', code }, {}, opts.timeoutMs ?? DEFAULT_TIMEOUT_MS);\n121\t  if (result.type !== 'loaded') {\n122\t    throw new Error(`worker-load: unexpected result loading \"${file}\"`);\n123\t  }\n124\t  return { data: result.data, functionKeys: result.functionKeys };\n125\t}\n126\t\n127\t/**\n128\t * Evaluate `file`'s module in a worker and invoke `default.<fnKey>(ctx)`. The\n129\t * ctx merges `ctxSeed` (serializable fields) with proxy methods serviced by\n130\t * `handlers` in the main process. Returns the fn's serializable result.\n131\t */\n132\texport async function invokeDefaultFnInWorker(\n133\t  file: string,\n134\t  fnKey: string,\n135\t  ctxSeed: Record<string, unknown>,\n136\t  handlers: WorkerInvokeHandlers,\n137\t  opts: { timeoutMs?: number } = {},\n138\t): Promise<unknown> {\n139\t  const code = await transpileFile(file);\n140\t  const job: WorkerLoadJob = { mode: 'invoke', code, fnKey, ctxSeed, dbMethods: DB_METHODS };\n141\t  const result = await runWorker(job, handlers, opts.timeoutMs ?? DEFAULT_TIMEOUT_MS);\n142\t  if (result.type === 'result') return result.value;\n143\t  throw new Error(`worker-load: unexpected result invoking \"${fnKey}\" in \"${file}\"`);\n144\t}\n145\t\n146\t/**\n147\t * Evaluate `file`'s module in a worker and invoke a top-level NAMED export\n148\t * `fnName(ctx, ...args)`. Unlike {@link invokeDefaultFnInWorker} (which targets a\n149\t * method on the module's `default` export object), this calls a function exported\n150\t * at module top level and passes extra positional `args` AFTER the proxied ctx —\n151\t * the shape a tasklist code node uses (`export async function run(ctx, inputs)`;\n152\t * no default export). The ctx's `db`/`delegate`/`callConnection` proxies are\n153\t * serviced by `handlers` in the main process, exactly as for the default path.\n154\t * Returns the fn's serializable result.\n155\t */\n156\texport async function invokeNamedFnInWorker(\n157\t  file: string,\n158\t  fnName: string,\n159\t  args: unknown[],\n160\t  handlers: WorkerInvokeHandlers,\n161\t  opts: { timeoutMs?: number } = {},\n162\t): Promise<unknown> {\n163\t  const code = await transpileFile(file);\n164\t  const job: WorkerLoadJob = {\n165\t    mode: 'invoke',\n166\t    code,\n167\t    fnKey: fnName,\n168\t    namedFn: fnName,\n169\t    extraArgs: args,\n170\t    ctxSeed: {},\n171\t    dbMethods: DB_METHODS,\n172\t  };\n173\t  const result = await runWorker(job, handlers, opts.timeoutMs ?? DEFAULT_TIMEOUT_MS);\n174\t  if (result.type === 'result') return result.value;\n175\t  throw new Error(`worker-load: unexpected result invoking \"${fnName}\" in \"${file}\"`);\n176\t}\n177\t\n178\t// ── Worker lifecycle + proxy servicing ────────────────────────────────────────\n179\t\n180\t/** Launch one worker for `job`, service its proxies against `handlers`, and\n181\t *  resolve with the terminal message (`loaded`/`result`) or reject (`error`,\n182\t *  crash, or timeout). The worker is always torn down. */\n183\tfunction runWorker(\n184\t  job: WorkerLoadJob,\n185\t  handlers: WorkerInvokeHandlers,\n186\t  timeoutMs: number,\n187\t): Promise<Extract<WorkerLoadToMain, { type: 'loaded' } | { type: 'result' }>> {\n188\t  return new Promise((resolve, reject) => {\n189\t    let settled = false;\n190\t    let worker: WorkerHandle | undefined;\n191\t    let timer: ReturnType<typeof setTimeout> | undefined;\n192\t\n193\t    const settle = (fn: () => void): void => {\n194\t      if (settled) return;\n195\t      settled = true;\n196\t      if (timer) clearTimeout(timer);\n197\t      void worker?.terminate();\n198\t      fn();\n199\t    };\n200\t\n201\t    timer = setTimeout(() => {\n202\t      settle(() => reject(new Error(`worker-load: timed out after ${timeoutMs}ms`)));\n203\t    }, timeoutMs);\n204\t    timer.unref?.();\n205\t\n206\t    workerSource()\n207\t      .then((source) => {\n208\t        worker = new NodeWorker(source, { eval: true, workerData: job }) as unknown as WorkerHandle;\n209\t\n210\t        worker.on('message', (msg: WorkerLoadToMain) => {\n211\t          if (msg.type === 'proxy') {\n212\t            void serviceProxy(worker!, msg, handlers);\n213\t          } else if (msg.type === 'loaded' || msg.type === 'result') {\n214\t            settle(() => resolve(msg));\n215\t          } else if (msg.type === 'error') {\n216\t            settle(() => reject(new Error(msg.message)));\n217\t          }\n218\t        });\n219\t        worker.on('error', (err) => settle(() => reject(err)));\n220\t        worker.on('exit', (exitCode) => {\n221\t          if (settled) return;\n222\t          settle(() => reject(new Error(`worker-load: worker exited early (code ${exitCode})`)));\n223\t        });\n224\t      })\n225\t      .catch((err) => settle(() => reject(err instanceof Error ? err : new Error(String(err)))));\n226\t  });\n227\t}\n228\t\n229\t/** Service one worker proxy request against the caller's main-process handlers. */\n230\tasync function serviceProxy("}]},"parent_tool_use_id":"call_uxqb06RglxS9Y92kx5H5jMqM","session_id":"08b44427-7432-4e2d-a9c3-d9296f1761a5","uuid":"564e8eb3-2600-4de9-82a6-9fb6a6143173","timestamp":"2026-07-16T04:44:38.498Z","subagent_type":"Explore","task_description":"Design lowest rung partition fix"}
