{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_82VQ01TYt0yU8CHRsYSAzczj","type":"tool_result","content":"1\timport { describe, it, expect } from 'vitest';\n2\timport { createReadDocumentGlobal, type ReadDocumentResult } from './read-document.js';\n3\timport type { YieldRequest } from '../eval/yield.js';\n4\t\n5\t/**\n6\t * Unit coverage for readDocument()'s yield wiring. The global is a thin\n7\t * pass-through: it pushes a single 'readDocument' yield carrying the\n8\t * attachmentId + opts verbatim (host-side documentResolver does the extraction).\n9\t */\n10\tfunction makeReadDocument(): {\n11\t  readDocument: (id: string, opts?: { maxChars?: number }) => Promise<ReadDocumentResult>;\n12\t  yields: YieldRequest[];\n13\t} {\n14\t  const yields: YieldRequest[] = [];\n15\t  const readDocument = createReadDocumentGlobal((req) => yields.push(req));\n16\t  return { readDocument, yields };\n17\t}\n18\t\n19\tdescribe('readDocument() global', () => {\n20\t  it('pushes a single readDocument yield with (attachmentId, opts) as args', () => {\n21\t    const { readDocument, yields } = makeReadDocument();\n22\t    void readDocument('doc-1', { maxChars: 500 });\n23\t    expect(yields).toHaveLength(1);\n24\t    expect(yields[0]!.kind).toBe('readDocument');\n25\t    expect(yields[0]!.args).toEqual(['doc-1', { maxChars: 500 }]);\n26\t    expect(yields[0]!.vmPromiseHandle).toBeUndefined();\n27\t  });\n28\t\n29\t  it('passes undefined opts through when omitted', () => {\n30\t    const { readDocument, yields } = makeReadDocument();\n31\t    void readDocument('doc-2');\n32\t    expect(yields[0]!.args).toEqual(['doc-2', undefined]);\n33\t  });\n34\t\n35\t  it('resolves with the ReadDocumentResult the host injects back', async () => {\n36\t    const { readDocument, yields } = makeReadDocument();\n37\t    const p = readDocument('doc-3');\n38\t    const result: ReadDocumentResult = {\n39\t      ok: true,\n40\t      attachmentId: 'doc-3',\n41\t      mediaType: 'text/plain',\n42\t      kind: 'text',\n43\t      text: 'the code is BANANA42',\n44\t    };\n45\t    yields[0]!.deferred.resolve(result);\n46\t    await expect(p).resolves.toEqual(result);\n47\t  });\n48\t});\n49\t"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"90d10d6f-a79f-48bf-b0f7-fc3bac318876","timestamp":"2026-07-16T02:07:06.072Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
