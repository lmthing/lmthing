: \"a8295e5c-1d7c-4f3d-836e-adb62be10443\",\n          \"date\": \"2025-08-05\",\n          \"title\": \"Arrival Tanzania — Serengeti Villa\",\n          \"description\": \"Arrive in Tanzania. Stay at Serengeti Villa (Aug 5–7).\",\n          \"location\": \"Serengeti Villa, Arusha\",\n          \"category\": \"hotel\",\n          \"people\": \"Vasilis, Athina Mari\",\n          \"sort_order\": 10\n        },\n        {\n          \"id\": \"e9b3f1af-2faa-446c-8faa-6128b782a611\",\n          \"date\": \"2025-08-07\",\n          \"title\": \"Safari Day 1 — Tarangire NP\",\n          \"description\": \"3-day Suricata Safaris camping safari begins. Tarangire National Park. Overnight at Twiga Camp Site (Full Board).\",\n          \"location\": \"Tarangire NP → Twiga Camp Site\",\n          \"category\": \"safari_day\",\n          \"people\": \"Richard (Suricata Safaris), Vasilis, Athina Mari\",\n          \"sort_order\": 20\n        },\n        {\n          \"id\": \"8e65b94d-c3fc-4ba2-844c-69cc7bb18abc\",\n          \"date\": \"2025-08-08\",\n          \"title\": \"Safari Day 2 — Lake Manyara NP\",\n          \"description\": \"Lake Manyara National Park. Overnight at Twiga Camp Site (Full Board).\",\n          \"location\": \"Lake Manyara NP → Twiga Camp Site\",\n          \"category\": \"safari_day\",\n          \"people\": \"Vasilis, Athina Mari\",\n          \"sort_order\": 30\n        },\n        {\n          \"id\": \"ec739021-680f-4452-8dfc-63ac85603034\",\n          \"date\": \"2025-08-09\",\n          \"title\": \"Ngorongoro Crater Day\",\n          \"description\": \"Crater day — one of the best days of my life. Wildlife everywhere, up close. Driver/guide: Emmanuel (not Richard from the office), very knowledgeable, kept pointing things out. At the rim on the way out, bought 2 beaded bracelets for Athina Mari from a Maasai lady (~35,000 TZS / $20–25 USD). Emmanuel mentioned extra ranger tip ~5,000 TZS cash at gate, separate from park fees — nobody told us before. Post-safari: Jevas Hotel (Half Board).\",\n          \"location\": \"Ngorongoro Crater → Jevas Hotel\",\n          \"category\": \"crater\",\n          \"people\": \"Emmanuel (driver/guide), Vasilis, Athina Mari\",\n          \"sort_order\": 40\n        },\n        {\n          \"id\": \"85ba0cfc-5e41-4b87-823e-c17e2c88b903\",\n          \"date\": \"2025-08-09\",\n          \"title\": \"Post-Safari — Kutoka Lodge\",\n          \"description\": \"Stay at Kutoka Lodge (Aug 9–11).\",\n          \"location\": \"Kutoka Lodge\",\n          \"category\": \"hotel\",\n          \"people\": \"Vasilis, Athina Mari\",\n          \"sort_order\": 50\n        },\n        {\n          \"id\": \"a77b5f0d-7e3a-4dbe-a20e-b0fffbc43cc9\",\n          \"date\": \"2025-08-11\",\n          \"title\": \"Departure / Dar es Salaam / Stone Town\",\n          \"description\": \"Travel to Dar es Salaam and onward to Stone Town, Zanzibar. Stone Town photo: bright upward-looking courtyard/atrium, white walls, arched windows, dark carved wooden balconies stacked several stories high, sunny airy mood, classic Stone Town architecture.\",\n          \"location\": \"Stone Town, Zanzibar\",\n          \"category\": \"stone_town\",\n          \"people\": \"Vasilis, Athina Mari\",\n          \"sort_order\": 60\n        }\n      ],\n      \"purchases\": [\n        {\n          \"id\": \"acba4caa-4f02-4049-9d20-e8bcdc4832fd\",\n          \"item\": \"Maasai beaded bracelets\",\n          \"quantity\": 2,\n          \"amount\": 35000,\n          \"currency\": \"TZS\",\n          \"amount_usd_approx\": 22.5,\n          \"seller\": \"Maasai lady at crater rim\",\n          \"location\": \"Ngorongoro Crater rim\",\n          \"for_person\": \"Athina Mari\",\n          \"notes\": \"Exact amount uncertain — Vasilis thinks roughly 35,000 TZS, ~$20–25 USD for both. Paid in shillings.\"\n        }\n      ],\n      \"reminders\": [\n        {\n          \"id\": \"79b8a7d6-e8cf-4894-a17a-d0f10b839f2c\",\n          \"question\": \"Is the ranger tip (~5,000 TZS) at Ngorongoro gate legit/expected?\",\n          \"context\": \"Emmanuel mentioned it on crater day — cash, separate from park fees. Nobody told us before.\",\n          \"who_to_ask\": \"Richard (Suricata Safaris)\",\n          \"status\": \"urgent\",\n          \"priority\": 1\n        },\n        {\n          \"id\": \"8eda936b-1684-471f-8b63-7f2b63800bca\",\n          \"question\": \"Are park fees ($814.20 total) included in the $1,200 safari package?\",\n          \"context\": \"Tarangire + Lake Manyara + Ngorongoro park fees. Spreadsheet shows them separately. Safari package may or may not cover them.\",\n          \"who_to_ask\": \"Richard (Suricata Safaris)\",\n          \"status\": \"urgent\",\n          \"priority\": 1\n        },\n        {\n          \"id\": \"5b42d2ef-3cec-49b2-9cc9-31c7d89f14bb\",\n          \"question\": \"Is the $295 Ngorongoro vehicle fee included in the safari package?\",\n          \"context\": \"Official NCA tariff for 4×4 safari vehicle crater descent. Need to confirm before bringing cash.\",\n          \"who_to_ask\": \"Richard (Suricata Safaris)\",\n          \"status\": \"urgent\",\n          \"priority\": 1\n        },\n        {\n          \"id\": \"b122fea7-d175-4989-a036-edff209ac6ad\",\n          \"question\": \"Bring $960 cash in post-2009 USD bills for safari balance\",\n          \"context\": \"Paid on arrival. Check that Richard accepts post-2009 USD (some operators require pre-2009 for Tanzania).\",\n          \"who_to_ask\": \"Richard (Suricata Safaris)\",\n          \"status\": \"open\",\n          \"priority\": 2\n        },\n        {\n          \"id\": \"ec62fac8-3de0-4f82-87fb-943a698ebd17\",\n          \"question\": \"Exact bracelet cost? ~35,000 TZS or different?\",\n          \"context\": \"Vasilis unsure if it was $20 or $25 for both bracelets. Paid in shillings.\",\n          \"who_to_ask\": \"Vasilis (self)\",\n          \"status\": \"open\",\n          \"priority\": 3\n        }\n      ]\n    },\n    \"appManifest\": {\n      \"tables\": [\n        {\n          \"name\": \"contacts\",\n          \"schema\": {\n            \"title\": \"Contacts\",\n            \"description\": \"People and organisations for the Tanzania trip.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"description\": \"Primary key\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\"\n              },\n              \"name\": {\n                \"type\": \"string\",\n                \"description\": \"Name of person or organisation\"\n              },\n              \"role\": {\n                \"type\": \"string\",\n                \"description\": \"Role or relationship to the trip\"\n              },\n              \"organisation\": {\n                \"type\": \"string\",\n                \"description\": \"Company or group they belong to\"\n              },\n              \"phone\": {\n                \"type\": \"string\",\n                \"description\": \"Phone number\"\n              },\n              \"email\": {\n                \"type\": \"string\",\n                \"description\": \"Email address\"\n              },\n              \"notes\": {\n                \"type\": \"string\",\n                \"description\": \"Additional notes or context\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"expenses\",\n          \"schema\": {\n            \"title\": \"Expenses & Costs\",\n            \"description\": \"All trip costs: safari, park fees, hotels, flights, purchases.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"description\": \"Primary key\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\"\n              },\n              \"category\": {\n                \"type\": \"string\",\n                \"description\": \"safari, park_fee, hotel, flight, purchase, tip, other\"\n              },\n              \"description\": {\n                \"type\": \"string\",\n                \"description\": \"What this expense is for\"\n              },\n              \"amount\": {\n                \"type\": \"number\",\n                \"description\": \"Amount in the original currency\"\n              },\n              \"currency\": {\n                \"type\": \"string\",\n                \"description\": \"USD, TZS, EUR, etc.\"\n              },\n              \"amount_usd_approx\": {\n                \"type\": \"number\",\n                \"description\": \"Approximate USD equivalent\"\n              },\n              \"date\": {\n                \"type\": \"string\",\n                \"description\": \"Date incurred or due\"\n              },\n              \"status\": {\n                \"type\": \"string\",\n                \"description\": \"paid, due, unknown, estimated\"\n              },\n              \"notes\": {\n                \"type\": \"string\",\n                \"description\": \"Additional context\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"itinerary\",\n          \"schema\": {\n            \"title\": \"Itinerary & Events\",\n            \"description\": \"Trip events, legs, and activities for the Tanzania trip.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"description\": \"Primary key\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\"\n              },\n              \"date\": {\n                \"type\": \"string\",\n                \"description\": \"Date of the event (YYYY-MM-DD or range)\"\n              },\n              \"title\": {\n                \"type\": \"string\",\n                \"description\": \"Short event title\"\n              },\n              \"description\": {\n                \"type\": \"string\",\n                \"description\": \"Detailed notes about this event\"\n              },\n              \"location\": {\n                \"type\": \"string\",\n                \"description\": \"Place or venue\"\n              },\n              \"category\": {\n                \"type\": \"string\",\n                \"description\": \"Type: safari_day, flight, hotel, transit, crater, stone_town, other\"\n              },\n              \"people\": {\n                \"type\": \"string\",\n                \"description\": \"People involved or guide names\"\n              },\n              \"sort_order\": {\n                \"type\": \"number\",\n                \"description\": \"Chronological sort order\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"purchases\",\n          \"schema\": {\n            \"title\": \"Purchases\",\n            \"description\": \"Souvenirs, gifts, and items bought during the trip.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"description\": \"Primary key\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\"\n              },\n              \"item\": {\n                \"type\": \"string\",\n                \"description\": \"What was bought\"\n              },\n              \"quantity\": {\n                \"type\": \"number\",\n                \"description\": \"How many\"\n              },\n              \"amount\": {\n                \"type\": \"number\",\n                \"description\": \"Amount paid in original currency\"\n              },\n              \"currency\": {\n                \"type\": \"string\",\n                \"description\": \"TZS, USD, etc.\"\n              },\n              \"amount_usd_approx\": {\n                \"type\": \"number\",\n                \"description\": \"Approximate USD equivalent\"\n              },\n              \"seller\": {\n                \"type\": \"string\",\n                \"description\": \"Who it was bought from\"\n              },\n              \"location\": {\n                \"type\": \"string\",\n                \"description\": \"Where it was bought\"\n              },\n              \"for_person\": {\n                \"type\": \"string\",\n                \"description\": \"Who it was bought for\"\n              },\n              \"notes\": {\n                \"type\": \"string\",\n                \"description\": \"Additional context\"\n              }\n            }\n          }\n        },\n        {\n          \"name\": \"reminders\",\n          \"schema\": {\n            \"title\": \"Open Questions & Reminders\",\n            \"description\": \"Things to check, confirm, or remember before/during the trip.\",\n            \"columns\": {\n              \"id\": {\n                \"type\": \"string\",\n                \"description\": \"Primary key\",\n                \"primaryKey\": true,\n                \"generated\": \"uuid\"\n              },\n              \"question\": {\n                \"type\": \"string\",\n                \"description\": \"The open question or reminder\"\n              },\n              \"context\": {\n                \"type\": \"string\",\n                \"description\": \"Where this came from or why it matters\"\n              },\n              \"who_to_ask\": {\n                \"type\": \"string\",\n                \"description\": \"Who can answer this\"\n              },\n              \"status\": {\n                \"type\": \"string\",\n                \"description\": \"open, resolved, urgent\"\n              },\n              \"priority\": {\n                \"type\": \"number\",\n                \"description\": \"1=urgent, 2=before trip, 3=whenever\"\n              }\n            }\n          }\n        }\n      ],\n      \"pages\": [\n        {\n          \"routePath\": \"/\",\n          \"file\": \"pages/index.tsx\"\n        }\n      ],\n      \"built\": false\n    },\n    \"error\": null\n  }\n}","numLines":916,"startLine":1,"totalLines":916}}}
