      "reminders": [
        {
          "id": "7e65f530-8c63-4cc5-81e6-40e2145588c2",
          "title": "Ask Richard about the ranger tip (~TZS 5,000) before safari balance payment",
          "detail": "Emmanuel mentioned an extra ranger tip at the Ngorongoro gate: ~TZS 5,000 cash, separate from park fees. This was not disclosed beforehand. Confirm with Richard at Suricata Safaris (+255 763 222 293) whether this is expected and if it should be budgeted. Ask BEFORE paying the $960 safari balance on arrival.",
          "priority": "high",
          "category": "payment",
          "done": false,
          "due_date": "Before Aug 7 (safari start)"
        },
        {
          "id": "c5e45ca5-450e-4060-a3d4-6d907b112196",
          "title": "Pay safari balance — $960 USD cash on arrival",
          "detail": "Suricata Safaris balance: $960 total ($1,200 less $240 deposit). Must be paid in cash with post-2009 USD notes. Alternative: online via Pesapal (+5% surcharge = $1,008): payments.pesapal.com/suricatasafaris.",
          "priority": "high",
          "category": "payment",
          "done": false,
          "due_date": "Aug 7 (safari arrival)"
        },
        {
          "id": "19d2d55e-57be-46fb-b2cd-7df3bf9c8cb2",
          "title": "Apply for Tanzania e-visa (2 travelers × $50)",
          "detail": "Mandatory online at visa.immigration.go.tz. Visa-on-arrival NO LONGER available as of January 2025. Apply well in advance. $100 total for both travelers.",
          "priority": "high",
          "category": "visa",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "fd45fc33-3436-404f-a360-3ff85e933388",
          "title": "Apply for Egypt e-visa, multiple-entry (2 travelers × $65)",
          "detail": "Apply separately per traveler at the Egypt e-visa portal. Multiple-entry required. Printed copy MANDATORY — print and carry. $130 total.",
          "priority": "high",
          "category": "visa",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "2b57e94c-9145-4e85-8297-4106aed5a595",
          "title": "Get Zanzibar mandatory travel insurance from ZIC (2 travelers × $44)",
          "detail": "Zanzibar Insurance Corporation travel insurance is MANDATORY for Zanzibar entry. $88 total for both travelers. Arrange before departure.",
          "priority": "high",
          "category": "visa",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "55f4c833-3966-4e6b-a846-02e4edefaef6",
          "title": "Arrange Zanzibar local driving permit (~$15)",
          "detail": "Vasilis holds an IDP. A local Zanzibar Driving Permit is also required (~$15, valid up to 3 months). Most rental companies arrange with license photo provided 24+ hours before arrival. Police checkpoints are frequent — carry both IDP and local permit (screenshot acceptable).",
          "priority": "medium",
          "category": "transport",
          "done": false,
          "due_date": "24h before Zanzibar arrival (Aug 10-11)"
        },
        {
          "id": "4404aa77-6b13-40cb-8c6d-a0709be2027f",
          "title": "Pack warm layers for Ngorongoro",
          "detail": "Ngorongoro nights are COLD. Bring warm layers — fleece, jacket, beanie. Evenings at Twiga Camp Site (Tarangire/Lake Manyara) also cool. Decathlon Forclaz trekking line recommended.",
          "priority": "medium",
          "category": "packing",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "a3c9333c-2b16-4c8d-8758-7a0d9b84999d",
          "title": "Pack DEET-based insect repellent",
          "detail": "Essential for Tanzania safari and Zanzibar. DEET-based repellent strongly recommended.",
          "priority": "medium",
          "category": "packing",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "43601ab7-0339-442b-9c74-fd0c82309fbf",
          "title": "Use soft bags for Precision Air flights",
          "detail": "Precision Air TC144 (DAR→ARK) and TC145 (ARK→ZNZ) have luggage restrictions favoring soft bags. Avoid hard-shell suitcases for these legs.",
          "priority": "low",
          "category": "packing",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "7eef70fb-9d01-4f39-a3ba-1558b71f12af",
          "title": "Print Egypt e-visa copies",
          "detail": "Egypt e-visa requires a MANDATORY printed copy. Do not rely on digital only.",
          "priority": "high",
          "category": "visa",
          "done": false,
          "due_date": "Before departure"
        },
        {
          "id": "3d7bc74d-e278-4d58-b3b8-cf0da1d6bd5f",
          "title": "The Rock Restaurant dinner — Aug 15, 18:00-20:00",
          "detail": "Confirmed and fully paid ($46). 2 adults, 2x Tropical Passion Fruit Cheesecake. Outdoor seating for sunset/star views. Contact: +255 776 591 360 / +255 763 070 658.",
          "priority": "low",
          "category": "other",
          "done": false,
          "due_date": "Aug 15"
        },
        {
          "id": "78f35091-9278-4303-9abf-265e5e164dd0",
          "title": "Carry post-2009 USD notes for safari balance",
