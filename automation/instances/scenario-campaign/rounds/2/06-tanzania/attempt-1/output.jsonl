{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_yFkWGEFPMFAWPBQoD0G9Psz9","type":"tool_result","content":"1\timport { appendFileSync, readFileSync } from 'node:fs';\n2\timport type { NodeKind, TraceEvent } from '@lmthing/core';\n3\timport { computeTurnCost, type ModelPricing } from './pricing.js';\n4\t\n5\t/** One delegation made inside a session — the target agent, the inputs it was\n6\t *  given, and the tokens/cost attributed to that delegate's own turns (nearest\n7\t *  enclosing delegate; a nested delegate keeps its own tokens). */\n8\texport interface DelegateEntry {\n9\t  /** `pkg/agent#action`, or `pkg/agent` when model-driven (no explicit action). */\n10\t  target: string;\n11\t  /** Truncated preview of the delegate's `query` input, when one was passed. */\n12\t  query?: string;\n13\t  inputTokens: number;\n14\t  outputTokens: number;\n15\t  costUsd: number;\n16\t  model?: string;\n17\t  durationMs: number;\n18\t  status: 'running' | 'done' | 'error' | 'skipped';\n19\t  /** Delegation depth — 0 for a delegate made directly by the session's agent,\n20\t   *  >0 for a delegate spawned inside another delegate. */\n21\t  depth: number;\n22\t  ts: number;\n23\t}\n24\t\n25\t/** One recorded session — a chat session, or a headless run spawned by a project\n26\t *  hook / code node. Carries the session's own token totals plus the delegates it\n27\t *  made (each with its own inputs + token breakdown). */\n28\texport interface SessionLedgerRecord {\n29\t  sessionId: string;\n30\t  /** Origin of the session: `chat`, `hook:<slug>`, or `code-node`. */\n31\t  source: string;\n32\t  projectId?: string;\n33\t  title?: string;\n34\t  startedAt: number;\n35\t  endedAt?: number;\n36\t  status: 'running' | 'done' | 'error';\n37\t  totalInputTokens: number;\n38\t  totalOutputTokens: number;\n39\t  totalCostUsd: number;\n40\t  delegates: DelegateEntry[];\n41\t}\n42\t\n43\t/** Identity of a session being tracked — supplied by the caller (SessionManager). */\n44\texport interface TrackBase {\n45\t  source: string;\n46\t  sessionId: string;\n47\t  projectId?: string;\n48\t}\n49\t\n50\tinterface Tracking {\n51\t  record: SessionLedgerRecord;\n52\t  /** node lineage, for walking an llm_response up to its enclosing delegate. */\n53\t  nodes: Map<string, { kind: NodeKind; parentId: string | null }>;\n54\t  /** delegate nodeId → its entry within record.delegates. */\n55\t  delegateByNode: Map<string, DelegateEntry>;\n56\t  lastFlush: number;\n57\t}\n58\t\n59\tconst MAX_RECORDS = 500;\n60\t/** Minimum ms between throttled (turn_end) flushes for a long-running session. */\n61\tconst FLUSH_THROTTLE_MS = 2000;\n62\t\n63\t/**\n64\t * Pod-global ledger of every session (chat + hook/code-node headless) and the\n65\t * delegates each made, with token/cost accounting at both levels. Fed from each\n66\t * session's {@link Tracer} via {@link trackTracer}; persisted append-only to a\n67\t * JSONL file (latest snapshot per sessionId wins on reload).\n68\t */\n69\texport class SessionLedger {\n70\t  /** sessionId → most recent record (source of truth for reads). */\n71\t  private records = new Map<string, SessionLedgerRecord>();\n72\t  private tracking = new Map<string, Tracking>();\n73\t\n74\t  constructor(\n75\t    private readonly filePath: string | null,\n76\t    private readonly prices: Record<string, ModelPricing>,\n77\t  ) {\n78\t    this.load();\n79\t  }\n80\t\n81\t  /** Rebuild the in-memory map from the JSONL file, collapsing to the latest\n82\t   *  snapshot per sessionId and keeping the most recent MAX_RECORDS. */\n83\t  private load(): void {\n84\t    if (!this.filePath) return;\n85\t    let raw: string;\n86\t    try {\n87\t      raw = readFileSync(this.filePath, 'utf8');\n88\t    } catch {\n89\t      return; // no file yet — empty ledger\n90\t    }\n91\t    for (const line of raw.split('\\n')) {\n92\t      if (!line.trim()) continue;\n93\t      try {\n94\t        const rec = JSON.parse(line) as SessionLedgerRecord;\n95\t        if (rec && typeof rec.sessionId === 'string') this.records.set(rec.sessionId, rec);\n96\t      } catch {\n97\t        // skip a corrupt line — best-effort\n98\t      }\n99\t    }\n100\t    this.trim();\n101\t  }\n102\t\n103\t  /** Drop the oldest records (by startedAt) beyond MAX_RECORDS. */\n104\t  private trim(): void {\n105\t    if (this.records.size <= MAX_RECORDS) return;\n106\t    const sorted = [...this.records.values()].sort((a, b) => a.startedAt - b.startedAt);\n107\t    for (const rec of sorted.slice(0, this.records.size - MAX_RECORDS)) {\n108\t      this.records.delete(rec.sessionId);\n109\t    }\n110\t  }\n111\t\n112\t  /** Append one record snapshot to the JSONL file (best-effort). */\n113\t  private flush(sessionId: string): void {\n114\t    const rec = this.records.get(sessionId);\n115\t    if (!rec) return;\n116\t    const t = this.tracking.get(sessionId);\n117\t    if (t) t.lastFlush = Date.now();\n118\t    if (!this.filePath) return;\n119\t    try {\n120\t      appendFileSync(this.filePath, JSON.stringify(rec) + '\\n', 'utf8');\n121\t    } catch {\n122\t      // best-effort persistence — never disturb the run\n123\t    }\n124\t  }\n125\t\n126\t  /**\n127\t   * Subscribe to a session's tracer and maintain its ledger record. Safe to call\n128\t   * once per session (chat: at creation; headless: before start). Subscriber\n129\t   * errors are swallowed by the Tracer, so this never disturbs the turn loop.\n130\t   */\n131\t  trackTracer(tracer: { subscribe(fn: (e: TraceEvent) => void): () => void }, base: TrackBase): void {\n132\t    const record: SessionLedgerRecord = this.records.get(base.sessionId) ?? {\n133\t      sessionId: base.sessionId,\n134\t      source: base.source,\n135\t      ...(base.projectId !== undefined ? { projectId: base.projectId } : {}),\n136\t      startedAt: Date.now(),\n137\t      status: 'running',\n138\t      totalInputTokens: 0,\n139\t      totalOutputTokens: 0,\n140\t      totalCostUsd: 0,\n141\t      delegates: [],\n142\t    };\n143\t    // Adopt the live source/project (a reloaded stub may predate them).\n144\t    record.source = base.source;\n145\t    if (base.projectId !== undefined) record.projectId = base.projectId;\n146\t    this.records.set(base.sessionId, record);\n147\t    const t: Tracking = { record, nodes: new Map(), delegateByNode: new Map(), lastFlush: 0 };\n148\t    this.tracking.set(base.sessionId, t);\n149\t    this.trim();\n150\t\n151\t    tracer.subscribe((e) => this.ingest(t, e));\n152\t  }\n153\t\n154\t  private ingest(t: Tracking, e: TraceEvent): void {\n155\t    switch (e.type) {\n156\t      case 'node_start': {\n157\t        t.nodes.set(e.nodeId, { kind: e.kind, parentId: e.parentId });\n158\t        if (e.kind === 'delegate') {\n159\t          const d = e.detail ?? {};\n160\t          const target =\n161\t            `${d.pkg ?? '?'}/${d.agent ?? '?'}` + (d.action ? `#${d.action}` : '');\n162\t          const entry: DelegateEntry = {\n163\t            target,\n164\t            ...(typeof d.query === 'string' ? { query: d.query } : {}),\n165\t            inputTokens: 0,\n166\t            outputTokens: 0,\n167\t            costUsd: 0,\n168\t            durationMs: 0,\n169\t            status: 'running',\n170\t            depth: typeof d.depth === 'number' ? d.depth : 0,\n171\t            ts: e.ts,\n172\t          };\n173\t          t.record.delegates.push(entry);\n174\t          t.delegateByNode.set(e.nodeId, entry);\n175\t        }\n176\t        break;\n177\t      }\n178\t      case 'llm_response': {\n179\t        if (typeof e.inputTokens !== 'number' || typeof e.outputTokens !== 'number') break;\n180\t        const cost = computeTurnCost(this.prices, e.model, e.inputTokens, e.outputTokens);\n181\t        t.record.totalInputTokens += e.inputTokens;\n182\t        t.record.totalOutputTokens += e.outputTokens;\n183\t        t.record.totalCostUsd += cost;\n184\t        // Attribute to the nearest enclosing delegate (self first, then ancestors).\n185\t        const entry = e.nodeId ? this.nearestDelegate(t, e.nodeId) : undefined;\n186\t        if (entry) {\n187\t          entry.inputTokens += e.inputTokens;\n188\t          entry.outputTokens += e.outputTokens;\n189\t          entry.costUsd += cost;\n190\t          if (e.model) entry.model = e.model;\n191\t        }\n192\t        break;\n193\t      }\n194\t      case 'node_end': {\n195\t        const entry = t.delegateByNode.get(e.nodeId);\n196\t        if (entry) {\n197\t          entry.durationMs = e.durationMs;\n198\t          entry.status = e.status;\n199\t          this.flush(t.record.sessionId); // persist as each delegate completes\n200\t        }\n201\t        break;\n202\t      }\n203\t      case 'session_meta': {\n204\t        if (e.title) t.record.title = e.title;\n205\t        break;\n206\t      }\n207\t      case 'turn_end': {\n208\t        // Throttled flush so a long chat session's totals stay fresh on disk\n209\t        // without an append per turn.\n210\t        if (Date.now() - t.lastFlush >= FLUSH_THROTTLE_MS) this.flush(t.record.sessionId);\n211\t        break;\n212\t      }\n213\t    }\n214\t  }\n215\t\n216\t  /** Walk `nodeId` and its ancestors to the closest delegate node, if any. */\n217\t  private nearestDelegate(t: Tracking, nodeId: string): DelegateEntry | undefined {\n218\t    let cur: string | null = nodeId;\n219\t    const seen = new Set<string>();\n220\t    while (cur && !seen.has(cur)) {\n221\t      seen.add(cur);\n222\t      const entry = t.delegateByNode.get(cur);\n223\t      if (entry) return entry;\n224\t      cur = t.nodes.get(cur)?.parentId ?? null;\n225\t    }\n226\t    return undefined;\n227\t  }\n228\t\n229\t  /** Mark a session finished and persist a final snapshot. Called by the manager\n230\t   *  when a session is torn down (evicted/deleted) or a headless run completes. */\n231\t  finalize(sessionId: string, status: 'done' | 'error' = 'done'): void {\n232\t    const rec = this.records.get(sessionId);\n233\t    if (!rec) return;\n234\t    rec.status = status;\n235\t    rec.endedAt = Date.now();\n236\t    // Any still-open delegate is orphaned by teardown — settle it.\n237\t    for (const d of rec.delegates) if (d.status === 'running') d.status = status;\n238\t    this.flush(sessionId);\n239\t    this.tracking.delete(sessionId);\n240\t  }\n241\t\n242\t  /** Newest-first snapshot of the ledger (bounded by `limit`). */\n243\t  list(limit = 200): SessionLedgerRecord[] {\n244\t    return [...this.records.values()]\n245\t      .sort((a, b) => b.startedAt - a.startedAt)\n246\t      .slice(0, limit);\n247\t  }\n248\t}\n249\t"}]},"parent_tool_use_id":"call_sc8TxR4N98D3JKwXfOKvuRrQ","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"8aba29c4-562d-43e9-af40-21409bf034b1","timestamp":"2026-07-16T22:24:51.574Z","subagent_type":"Explore","task_description":"Trace appbuilder timeout"}
