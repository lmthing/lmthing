# Supabase (auto-set by `supabase start` for local dev)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Token Billing handles LLM API keys internally.
# You do NOT need OPENAI_API_KEY or ANTHROPIC_API_KEY —
# Stripe's proxy at llm.stripe.com routes to providers for you.

# --- Local Development (offline mode) ---
# Set to "true" to run without Stripe or any external services
LOCAL_DEV=false

# LLM Provider: "stripe" (default), "ollama" (offline), "openai" (direct)
LLM_PROVIDER=stripe

# Ollama settings (only when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=

# Direct OpenAI (only when LLM_PROVIDER=openai)
OPENAI_API_KEY=
