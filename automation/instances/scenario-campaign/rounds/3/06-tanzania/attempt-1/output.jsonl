for (let round = 0; round < MAX_NESTED_YIELD_ROUNDS && vm.pendingYields.length > 0; round++) {\n187\t        const yields = vm.pendingYields.splice(0);\n188\t        // Budget: prelude yields are real tool calls — tick the fork's counter.\n189\t        // Throws BudgetExceededError (propagates: hard caps are honored).\n190\t        opts.budget?.tickToolCalls(yields.length);\n191\t\n192\t        const resolvedValues: unknown[] = new Array(yields.length);\n193\t        const roundErrors: string[] = [];\n194\t        await Promise.all(yields.map(async (yieldReq, j) => {\n195\t          const yieldId = `${nodeId ?? ctx}_p${++yieldCounter}`;\n196\t          tracer.write({ ts: Date.now(), type: 'yield', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, args: yieldReq.args, yieldId });\n197\t          try {\n198\t            const resolved = await processYield(yieldReq);\n199\t            tracer.write({ ts: Date.now(), type: 'yield_resolved', context: ctx, ...(nodeId ? { nodeId } : {}), kind: yieldReq.kind, value: resolved, yieldId });\n200\t            yieldReq.deferred.resolve(resolved);\n201\t            resolvedValues[j] = resolved;\n202\t          } catch (err) {\n203\t            // Hard budget breaches (fork-depth, tool-call cap inside a nested\n204\t            // yield) propagate — everything else degrades this statement only.\n205\t            if (err instanceof BudgetExceededError) throw err;\n206\t            yieldReq.deferred.reject(err);\n207\t            resolvedValues[j] = undefined;\n208\t            roundErrors.push(`${yieldReq.kind}() failed: ${err instanceof Error ? err.message : String(err)}`);\n209\t          }\n210\t        }));"}]},"parent_tool_use_id":"call_xceELgSEMbLiZDXxIvlOMHdS","session_id":"77ab428b-0827-4b0f-9cdb-3f06c26238c4","uuid":"92f0ce1f-34ce-4115-bab8-2e75a706d322","timestamp":"2026-07-16T19:24:53.040Z","subagent_type":"Explore","task_description":"Trace appbuilder structural failure"}
