{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_ILmFciRPSbrlXNja1dwUEGbp","type":"tool_result","content":"1\timport { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2\timport { mkdtempSync, rmSync, writeFileSync, mkdirSync } from 'node:fs';\n3\timport { tmpdir } from 'node:os';\n4\timport { join, dirname } from 'node:path';\n5\timport type { Space } from '../spaces/load.js';\n6\timport { ForkEngine } from './fork.js';\n7\timport { salvageData } from '../exec/envelope.js';\n8\timport { BudgetExceededError } from '../eval/budget.js';\n9\timport type { RenderHost } from '../session/types.js';\n10\timport type { StreamSession } from '../eval/stream-types.js';\n11\t\n12\tfunction makeStream(text: string): StreamSession {\n13\t  let aborted = false;\n14\t  async function* gen() {\n15\t    if (!aborted) yield text;\n16\t  }\n17\t  return {\n18\t    textStream: gen(),\n19\t    abort() { aborted = true; },\n20\t  };\n21\t}\n22\t\n23\tconst silentHost: RenderHost = {\n24\t  display: () => {},\n25\t  ask: () => Promise.resolve(''),\n26\t  log: () => {},\n27\t};\n28\t\n29\tfunction makeEngine(streamText: string): ForkEngine {\n30\t  return new ForkEngine({\n31\t    maxConcurrentForks: 4,\n32\t    parentHistory: [],\n33\t    parentSpaceDir: '/tmp',\n34\t    parentAgentSlug: 'test',\n35\t    renderHost: silentHost,\n36\t    streamFn: async () => makeStream(streamText),\n37\t  });\n38\t}\n39\t\n40\tdescribe('salvageData', () => {\n41\t  it('produces type-appropriate NEUTRAL placeholders for every schema field', () => {\n42\t    const out = salvageData({ summary: 'string', findings: 'array', count: 'number', ok: 'boolean', meta: 'object' });\n43\t    // Strings are EMPTY — no prose note that a model could read and go off-script on.\n44\t    expect(out.summary).toBe('');\n45\t    expect(out.findings).toEqual([]);\n46\t    expect(out.count).toBe(0);\n47\t    expect(out.ok).toBe(false);\n48\t    expect(out.meta).toEqual({});\n49\t    expect(JSON.stringify(out)).not.toContain('unavailable');\n50\t  });\n51\t\n52\t  it('handles array shorthand and empty schema', () => {\n53\t    expect(salvageData({ items: 'string[]' }).items).toEqual([]);\n54\t    expect(salvageData({})).toEqual({});\n55\t  });\n56\t});\n57\t\n58\tdescribe('ForkEngine', () => {\n59\t  it('resolves when currentTask.resolve() is called with a valid value', async () => {\n60\t    const engine = makeEngine('currentTask.resolve({ answer: \"pasta\" });\\n');\n61\t    const result = await engine.fork<{ answer: string }>({\n62\t      instruction: 'test task',\n63\t      output: { answer: 'string' },\n64\t    });\n65\t    expect(result).toEqual({ answer: 'pasta' });\n66\t  });\n67\t\n68\t  it('does not crash (QuickJS lifetime) when currentTask.resolve() is called with a multi-field object', async () => {\n69\t    const engine = makeEngine(\n70\t      'currentTask.resolve({ title: \"spaghetti\", steps: 3, ready: true });\\n',\n71\t    );\n72\t    const result = await engine.fork<{ title: string; steps: number; ready: boolean }>({\n73\t      instruction: 'test task',\n74\t      output: { title: 'string', steps: 'number', ready: 'boolean' },\n75\t    });\n76\t    expect(result).toMatchObject({ title: 'spaghetti', steps: 3, ready: true });\n77\t  });\n78\t\n79\t  it('salvages a NEUTRAL schema-valid placeholder when currentTask.resolve() is never called', async () => {\n80\t    // Robustness contract: rather than hard-failing the parent when the model wanders\n81\t    // without resolving (model stupidity), the fork forces resolve-only turns and, as a\n82\t    // last resort, returns a type-appropriate NEUTRAL placeholder (\"\" for strings — no\n83\t    // alarming prose in the data plane) so orchestration can proceed.\n84\t    const engine = makeEngine('const x = 1;\\n');\n85\t    const result = await engine.fork<{ x: string }>({ instruction: 'test', output: { x: 'string' } });\n86\t    expect(result.x).toBe('');\n87\t  });\n88\t\n89\t  it('forkWithMeta reports { degraded: true, reason: \"no_resolve\" } for a salvaged fork and degraded: false for a clean one', async () => {\n90\t    // The typed degradation signal that replaces the old prose placeholder (Phase 3).\n91\t    const salvagedMeta = await makeEngine('const x = 1;\\n').forkWithMeta<{ x: string }>({\n92\t      instruction: 'test', output: { x: 'string' },\n93\t    });\n94\t    expect(salvagedMeta.degraded).toBe(true);\n95\t    expect(salvagedMeta.reason).toBe('no_resolve');\n96\t    expect(salvagedMeta.value).toEqual({ x: '' });\n97\t\n98\t    const cleanMeta = await makeEngine('currentTask.resolve({ x: \"real\" });\\n').forkWithMeta<{ x: string }>({\n99\t      instruction: 'test', output: { x: 'string' },\n100\t    });\n101\t    expect(cleanMeta.degraded).toBe(false);\n102\t    expect(cleanMeta.reason).toBeUndefined();\n103\t    expect(cleanMeta.value).toEqual({ x: 'real' });\n104\t  });\n105\t\n106\t  it('injects the JSX runtime so a fork can display(<JSX>) without \"React is not defined\"', async () => {\n107\t    // Regression: research forks crashed ×3 because React/catalog stubs were not\n108\t    // injected into the fork VM, so transpiled `display(<Stack>…)` threw.\n109\t    const engine = makeEngine('display(<Stack><Heading>Hi</Heading></Stack>);\\ncurrentTask.resolve({ ok: true });\\n');\n110\t    const result = await engine.fork<{ ok: boolean }>({ instruction: 'render', output: { ok: 'boolean' } });\n111\t    expect(result).toEqual({ ok: true });\n112\t  });\n113\t\n114\t  it('rejects when the resolved value does not match the output schema', async () => {\n115\t    // Schema wants a number; the fork resolves a string → validateOutput fails and\n116\t    // the fork rejects rather than handing back an off-schema value.\n117\t    const engine = makeEngine('currentTask.resolve({ count: \"not a number\" });\\n');\n118\t    await expect(\n119\t      engine.fork({ instruction: 'count things', output: { count: 'number' } }),\n120\t    ).rejects.toThro