n Tools list above: when the running space IS a\n249\t  // system space (e.g. the architect), its functions are also in systemFunctions,\n250\t  // and would otherwise be listed twice.\n251\t  const systemFnNames = new Set(Object.keys(opts.systemFunctions ?? {}));\n252\t  const agentFunctions = getAgentFunctions(space, agent);\n253\t  const scopedFunctions = Object.entries(agentFunctions).filter(([name]) => !systemFnNames.has(name));\n254\t  if (scopedFunctions.length > 0) {\n255\t    const fnParts = scopedFunctions.map(([name, src]) => extractToolSummary(name, src));\n256\t    sections.push(`# Available Functions\\n\\nCall directly (already in scope):\\n\\n${fnParts.join('\\n')}`);\n257\t  }\n258\t\n259\t  // 4b. Knowledge — refs are \"domain/field\" (on-demand: list the field + its\n260\t  // options, agent loads via loadKnowledge()) or \"domain/field/option\" (PRELOAD:\n261\t  // inject the option's body directly, and do NOT list its sibling options —\n262\t  // the agent only has access to the one it was bound to).\n263\t  if (agent.config.knowledge.length > 0) {\n264\t    const preloadByKey = new Map((opts.knowledgePreloads ?? []).map((p) => [`${p.domainSlug}/${p.fieldSlug}`, p]));\n265\t    const onDemandLines: string[] = [];\n266\t    const preloadParts: string[] = [];\n267\t    const describedDomains = new Set<string>();\n268\t    const domainDescLines: string[] = [];\n269\t"}]},"parent_tool_use_id":null,"session_id":"7193a049-8ab5-4b33-ba1c-323f4246ccc2","uuid":"869a1ab9-f1c5-4577-8511-015e66849368","timestamp":"2026-07-16T00:54:40.940Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/context/system-block.ts","content":"\n  // 1. Globals summary\n  sections.push(globalsSummary(opts.omitAsk === true, opts.omitDelegate === true));\n\n  // 1a. UI component catalog — tell the model what display/form components exist\n  sections.push(catalogSummary());\n\n  // 1b. Built-in tools from system spaces (concise