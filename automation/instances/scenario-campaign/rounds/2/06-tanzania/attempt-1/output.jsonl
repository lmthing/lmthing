he session to a specific project space + agent; else the\n1225\t    // agent runs at the project root. Either way it keeps full project context\n1226\t    // (appGlobals, contracts, preloaded spaces) so its `db` writes fire hooks.\n1227\t    let spaceDir = join(root, projectId);\n1228\t    let agentSlug = opts.agentSlug ?? 'thing';\n1229\t    if (opts.spaceRef) {\n1230\t      const { space, agent } = parseSpaceRef(opts.spaceRef);\n1231\t      spaceDir = projectSpaceDir(root, projectId, space);\n1232\t      agentSlug = agent ?? (await resolveDefaultAgent(spaceDir)) ?? agentSlug;\n1233\t    }\n1234\t    const projectSpacesDir = join(root, projectId, 'spaces');\n1235\t\n1236\t    const [systemSpaceDirs, preloadSpaceDirs] = await Promise.all([\n1237\t      listSystemSpaceDirs(root),\n1238\t      listProjectSpaceDirs(root, projectId),\n1239\t    ]);\n1240\t\n1241\t    const appGlobals = await this.getProjectAppGlobals(root, projectId);\n1242\t    const contracts = await this.getProjectContracts(root, projectId);\n1243\t    const projectFunctions = await this.getProjectFunctions(join(root, projectId));\n1244\t    const session = this.buildSessionFn({\n1245\t      spaceDir,\n1246\t      agentSlug,\n1247\t      model: opts.model,\n1248\t      budget: opts.budget,\n1249\t      renderHost: entry.renderHost,\n1250\t      systemSpaceDirs,\n1251\t      preloadSpaceDirs,\n1252\t      projectSpacesDir,\n1253\t      projectFunctions: projectFunctions.functions,\n1254\t      projectFunctionsBundled: projectFunctions.functionsBundled,\n1255\t      projectId,\n1256\t      projectRoot: join(root, projectId),\n1257\t      appGlobals,\n1258\t      appDts: contracts?.apiCallDts,\n1259\t      interactive: true,\n1260\t    });\n1261\t\n1262\t    // Wire up the tracer to this session's hub + cost tracking.\n1263\t    this.wireTracer(session, entry);\n1264\t\n1265\t    // Fill in the placeholder — update mutable fields in-place so the Map entry\n1266\t    // already visible to getSession() ca