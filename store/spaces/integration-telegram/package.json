{
  "name": "integration-telegram",
  "version": "1.0.0",
  "private": true,
  "lmthing": {
    "kind": "integration",
    "title": "Telegram",
    "tags": ["integration", "messaging"],
    "icon": "✈️",
    "description": "Send Telegram messages and receive Telegram chats via THING.",
    "settings": {
      "type": "object",
      "properties": {
        "INTEGRATION_TELEGRAM_BOT_TOKEN": { "type": "string", "title": "Bot token", "format": "password" },
        "INTEGRATION_TELEGRAM_WEBHOOK_SECRET": { "type": "string", "title": "Webhook secret token", "format": "password" }
      },
      "required": ["INTEGRATION_TELEGRAM_BOT_TOKEN", "INTEGRATION_TELEGRAM_WEBHOOK_SECRET"]
    },
    "connection": {
      "provider": "telegram",
      "apiBase": "https://api.telegram.org/bot{token}",
      "tokenEnv": "INTEGRATION_TELEGRAM_BOT_TOKEN",
      "auth": { "kind": "none" }
    }
  }
}
