{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_p6o5menGpMa5RNZAF1RtMgg3","type":"tool_result","content":"1\timport type { YieldRequest } from './yield.js';\n2\timport type { ApiCallFn, ConnectionResolver } from '../db/types.js';\n3\timport type { DocumentResolver } from '../globals/read-document.js';\n4\timport type { IntegrationStatusResolver } from '../globals/integration-status.js';\n5\timport type { StoreResolver, InstallSpaceResult } from '../globals/store.js';\n6\timport type { EmitEventResolver } from '../globals/emit-event.js';\n7\timport {\n8\t  CONSENT_MARKED_YIELD_KINDS,\n9\t  enforceConsent,\n10\t  summarizeConsentArgs,\n11\t  type ConsentCard,\n12\t  type ConsentPrompter,\n13\t} from '../globals/consent.js';\n14\timport type { Clock } from '../session/types.js';\n15\timport type { Space } from '../spaces/load.js';\n16\timport type { ForkEngine, ForkTask } from '../fork/fork.js';\n17\timport type { DelegateOpts } from '../globals/delegate.js';\n18\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n19\t\n20\t/**\n21\t * Dependencies the shared yield router needs to resolve the yield kinds common\n22\t * to the full (session) VM, the delegate VM and fork leaf VMs: sleep, fork,\n23\t * tasklist, delegate, fetch — plus, for fork leaves (which have no session-side\n24\t * handler to fall back to), loadKnowledge and registerSpace.\n25\t *\n26\t * The genuine per-caller differences are parameterized:\n27\t *  - `runDelegate` — the session builds a fresh registry from its spaces; a\n28\t *    delegate recurses with depth+1; a fork leaf gates on the task's\n29\t *    `canDelegateTo` and routes to the engine's delegateRunner. The caller\n30\t *    supplies the right behaviour.\n31\t *  - `onTasklistResult` — delegate uses it to auto-capture the action's tasklist\n32\t *    result; the session leaves it undefined.\n33\t *  - `getForkEngine` — absent for fork leaves (no fork/tasklist there): those\n34\t *    kinds fall through as unhandled, preserving the old leaf behaviour.\n35\t */\n36\texport interface YieldRouterContext {\n37\t  /** Space for tasklist resolution. Absent in fork-leaf contexts (no tasklist there). */\n38\t  space?: Space;\n39\t  clock?: Clock;\n40\t  /** Lazily-resolved, shared ForkEngine (one per session/delegate scope) so the\n41\t   *  maxConcurrentForks semaphore is enforced across all fork/tasklist yields.\n42\t   *  Absent for fork leaves — fork/tasklist yields are then unhandled. */\n43\t  getForkEngine?: () => ForkEngine | Promise<ForkEngine>;\n44\t  /** Resolve a delegate() yield. May throw (e.g. a fork task's canDelegateTo\n45\t   *  gate) — the error surfaces to the model as a retryable yield error. */\n46\t  runDelegate: (\n47\t    packageName: string,\n48\t    agentName: string,\n49\t    action: string | undefined,\n50\t    delegateOpts: DelegateOpts | undefined,\n51\t  ) => Promise<unknown>;\n52\t  /** Fired after a tasklist resolves (delegate uses it for auto-capture). */\n53\t  onTasklistResult?: (name: string, result: unknown) => void;\n54\t  /** Run a shell command host-side (cwd = space dir). */\n55\t  execCommand?: (cmd: string) => { ok: boolean; output: string };\n56\t  /** Tracer for minting child scopes in tasklist. */\n57\t  tracer?: Tracer;\n58\t  /** Current execution scope — becomes parentScope on spawned forks/delegates. */\n59\t  scope?: TraceScope;\n60\t  /** When set, loadKnowledge yields are resolved HERE by reading the file under\n61\t   *  `<knowledgeSpaceDir>/knowledge/…` and returning its content (fork leaves,\n62\t   *  which must win the race against the global's own concurrent resolve —\n63\t   *  otherwise undefined is bound before the file read completes). The session\n64\t   *  handles loadKnowledge itself; leave unset there. */\n65\t  knowledgeSpaceDir?: string;\n66\t  /** When true, registerSpace yields are resolved HERE (fork leaves): the space\n67\t   *  is loaded and inserted into `dynamicSpaces` when provided. The map is the\n68\t   *  SAME reference the parent Session hands to delegate(), so a space\n69\t   *  registered inside a fork is reachable by the parent's later delegate(). */\n70\t  resolveRegisterSpace?: boolean;\n71\t  dynamicSpaces?: Map<string, Space>;\n72\t  /** Resolve an `apiCall()` yield — enter the project's api runtime by endpoint\n73\t   *  `name` (host-supplied via the project's app globals). Absent outside a\n74\t   *  project-app context; an `apiCall` yield then rejects with a clear error. */\n75\t  apiCallResolver?: ApiCallFn;\n76\t  /** The running agent's `api:call: { allow: [...] }` grant — the endpoints it may\n77\t   *  enter. Enforced in the `apiCall` yield (a name outside the list is refused with a\n78\t   *  retryable error naming what IS allowed). `['*']` = any endpoint this project\n79\t   *  declares. Absent ⇒ unenforced (a non-agent context, e.g. a bare unit test). */\n80\t  apiCallAllow?: string[];\n81\t  /** Resolve a `callConnection()` yield — forward the request to the gateway's\n82\t   *  egress proxy for the named connected service (host-supplied via the pod's\n83\t   *  scoped connections JWT). Absent outside a pod with a configured connections\n84\t   *  gateway; a `callConnection` yield then rejects with a clear error. */\n85\t  connectionResolver?: ConnectionResolver;\n86\t  /** Build a per-node execution context for a `kind:'code'` tasklist node\n87\t   *  (db + callConnection locked to the space/tasklist `connections:` + delegate).\n88\t   *  Threaded into `runTasklist`. Absent until the CLI/pod wires a runner (plan\n89\t   *  step S9); a code node then fails with a clear required-task error. Core\n90\t   *  never imports/executes the node module. */\n91\t  codeNodeCtxFactory?: import('../tasklist/orchestrator.js').CodeNodeCtxFactory;\n92\t  /** Resolve a `readDocument()` yield — extract a stored upload's text host-side\n93\t   *  (host-supplied by libs/cli, where the uploads dir is known). Absent outside a\n94\t   *  pod/CLI with an uploads dir; a `readDocument` yield then rejects with a clear\n95\t   *  error. Not an app-global (project-independent) — threaded from SessionOpts. */\n96\t  documentResolver?: DocumentResolver;\n97\t  /** Resolve an `integrationStatus()` yield — report presence-only config status\n98\t   *  (names of missing required env vars, never their values) for an installed\n99\t   *  integration space in the current project. Host-supplied by libs/cli (knows the\n100\t   *  project root + `process.env`). Absent outside a project-rooted session; an\n101\t   *  `integrationStatus` yield then rejects with a clear error. */\n102\t  integrationStatusResolver?: IntegrationStatusResolver;\n103\t  /** Consent prompter for consent-marked invocations (plan S10) — supplied ONLY\n104\t   *  by interactive session contexts (the cli builds it on `renderHost.ask`).\n105\t   *  Absent (headless runs, forks, delegates, hooks) ⇒ a consent-marked yield\n106\t   *  FAILS CLOSED with a clear \"requires user consent\" error. */\n107\t  requestConsent?: ConsentPrompter;\n108\t  /** Resolve the store-global yields (`storeSearch`/`storeInspect`/`installSpace`)\n109\t   *  — host-supplied by libs/cli on `AppGlobalImpls.store` (mirrors\n110\t   *  `connectionResolver`). Absent ⇒ a store yield rejects with a clear error. */\n111\t  storeResolver?: StoreResolver;\n112\t  /** Resolve an `emitEvent()` yield — validate against the caller scope's\n113\t   *  declared events and dispatch to subscribing hooks (host-supplied by\n114\t   *  libs/cli on `AppGlobalImpls.emitEvent`). Absent ⇒ a clear error. */\n115\t  emitEventResolver?: EmitEventResolver;\n116\t}\n117\t\n118\texport type RouteResult =\n119\t  | { handled: true; value: unknown }\n120\t  | { handled: false };\n121\t\n122\t/**\n123\t * Single resolver for the yield kinds shared by the session, delegate and fork\n124\t * leaf VMs. Returns `{ handled: false }` for kinds the caller must handle itself\n125\t * (ask/inspect are session-only; the session also resolves its own\n126\t * loadKnowledge/registerSpace before consulting the router).\n127\t *\n128\t * `fetch` is real, non-blocking Node I/O — see `eval/fetch-yield.ts`. A future\n129\t * `execShell`/`tool` yield kind would follow the same shape.\n130\t */\n131\texport async function routeCommonYield(\n132\t  req: YieldRequest,\n133\t  ctx: YieldRouterContext,\n134\t): Promise<RouteResult> {\n135\t  // Generic HOST-ENFORCED consent (plan S10): a consent-marked yield kind (the\n136\t  // registry in globals/consent.ts — `installSpace` today) must be approved by\n137\t  // the USER before its resolver runs. No prompter (headless/fork/delegate/hook\n138\t  // contexts) ⇒ FAIL CLOSED; denial ⇒ a structured refusal the agent sees. This\n139\t  // runs BEFORE the switch so no resolver below can execute unapproved.\n140\t  if (CONSENT_MARKED_YIELD_KINDS.has(req.kind)) {\n141\t    await enforceConsent(ctx.requestConsent, {\n142\t      function: req.kind,\n143\t      argsSummary: summarizeConsentArgs(req.args),\n144\t    });\n145\t  }\n146\t  switch (req.kind) {\n147\t    case 'sleep': {\n148\t      const ms = req.args[1] as number;\n149\t      await new Promise<void>((resolve) => {\n150\t        if (ctx.clock) ctx.clock.setTimeout(resolve, ms);\n151\t        else setTimeout(resolve, ms);\n152\t      });\n153\t      return { handled: true, value: undefined };\n154\t    }\n155\t    case 'fork': {\n156\t      if (!ctx.getForkEngine) return { handled: false }; // fork leaves have no fork()\n157\t      const engine = await ctx.getForkEngine();\n158\t      const task = req.args[0] as ForkTask;\n159\t      // Attach the current scope as parent so the fork's node is correctly nested\n160\t      if (ctx.scope && !task.parentScope) task.parentScope = ctx.scope;\n161\t      const value = await engine.fork(task);\n162\t      return { handled: true, value };\n163\t    }\n164\t    case 'tasklist': {\n165\t      if (!ctx.getForkEngine || !ctx.space) return { handled: false }; // fork leaves have no tasklist()\n166\t      const name = req.args[0] as string;\n167\t      const seed = req.args[1] as Record<string, unknown> | undefined;\n168\t      const engine = await ctx.getForkEngine();\n169\t      const { runTasklist } = await import('../tasklist/orchestrator.js');\n170\t      const result = await runTasklist({ name, space: ctx.space, forkEngine: engine, seed, tracer: ctx.tracer, parentScope: ctx.scope, codeNodeCtxFactory: ctx.codeNodeCtxFactory });\n171\t      ctx.onTasklistResult?.(name, result);\n172\t      return { handled: true, value: result };\n173\t    }\n174\t    case 'delegate': {\n175\t      const [packageName, agentName, action, delegateOpts] = req.args as [\n176\t        string,\n177\t        string,\n178\t        string | undefined,\n179\t        DelegateOpts | undefined,\n180\t      ];\n181\t      const value = await ctx.runDelegate(packageName, agentName, action, delegateOpts);\n182\t      return { handled: true, value };\n183\t    }\n184\t    case 'fetch': {\n185\t      const [url, fetchOpts] = req.args as [string, import('../globals/fetch.js').FetchOpts | undefined];\n186\t      const { resolveFetchYield } = await import('./fetch-yield.js');\n187\t      const value = await resolveFetchYield(url, fetchOpts);\n188\t      return { handled: true, value };\n189\t    }\n190\t    case 'apiCall': {\n191\t      // Enter the project's own api endpoint by name (agent-facing `apiCall`).\n192\t      // A missing resolver means this context has no project api runtime — throw\n193\t      // an actionable, retryable error rather than binding undefined.\n194\t      if (!ctx.apiCallResolver) {\n195\t        throw new Error('apiCall is not available here: this session has no project api runtime');\n196\t      }\n197\t      const [name, input] = req.args as [string, unknown];\n198\t      // ENFORCE the `api:call: { allow: [...] }` grant. Holding the capability is what\n199\t      // injects the global; the allowlist is what says WHICH endpoints it may enter, and\n200\t      // until now it was parsed, validated — and never checked, so any holder could call\n201\t      // anything. `'*'` is the one wildcard (any endpoint THIS project declares).\n202\t      const allow = ctx.apiCallAllow;\n203\t      if (allow && !allow.includes('*') && !allow.includes(name)) {\n204\t        throw new Error(\n205\t          `apiCall(\"${name}\") is not permitted: this agent's api:call allowlist is [${allow.join(', ')}]`,\n206\t        );\n207\t      }\n208\t      const value = await ctx.apiCallResolver(name, input);\n209\t      return { handled: true, value };\n210\t    }\n211\t    case 'callConnection': {\n212\t      // Forward an authenticated request to an external service; the pod resolver\n213\t      // attaches the user's own token (bring-your-own-token, Settings →\n214\t      // Integrations) and calls the provider directly. A missing resolver means\n215\t      // this context has no connection support wired (e.g. a bare unit test) —\n216\t      // throw an actionable, retryable error rather than binding undefined.\n217\t      if (!ctx.connectionResolver) {\n218\t        throw new Error('callConnection is not available here: no connection resolver configured');\n219\t      }\n220\t      const [provider, request] = req.args as [string, import('../db/types.js').ConnectionRequest];\n221\t      const value = await ctx.connectionResolver(provider, request);\n222\t      return { handled: true, value };\n223\t    }\n224\t    case 'readDocument': {\n225\t      // Extract a stored upload's content host-side (unpdf for PDF, utf8 for text,\n226\t      // transcript for audio). A missing resolver means this context has no uploads\n227\t      // dir (e.g. a bare in-memory session) — throw an actionable, retryable error\n228\t      // rather than binding undefined.\n229\t      if (!ctx.documentResolver) {\n230\t        throw new Error('readDocument is not available here: no document resolver configured');\n231\t      }\n232\t      const [attachmentId, opts] = req.args as [string, { maxChars?: number } | undefined];\n233\t      const value = await ctx.documentResolver(attachmentId, opts);\n234\t      return { handled: true, value };\n235\t    }\n236\t    case 'integrationStatus': {\n237\t      // Presence-only config status of an installed integration in the current\n238\t      // project (missing REQUIRED env-var names — never their values). A missing\n239\t      // resolver means this context has no project scope (e.g. a fork leaf / bare\n240\t      // unit test) — throw an actionable, retryable error rather than binding"}]},"parent_tool_use_id":null,"session_id":"625ee3e5-57b1-42a3-9cc2-762259deb6f8","uuid":"eefece73-6b27-4485-867d-9aed1d2d99ab","timestamp":"2026-07-16T04:11:43.535Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vasilis/LMTHING/lmthing/sdk/org/libs/core/src/eval/yield-router.ts","content":"import type { YieldRequest } from './yield.js';\nimport type { ApiCallFn, ConnectionResolver } from '../db/types.js';\nimport type { DocumentResolver } from '../globals/read-document.js';\nimport type { IntegrationStatusResolver } from '../globals/integration-status.js';\nimport type { StoreResolver, InstallSpaceResult } from '../globals/store.js';\nimport type { EmitEventResolver } from '../globals/emit-event.js';\nimport {\n  CONSENT_MARKED_YIELD_KINDS,\n  enforceConsent,\n  summarizeConsentArgs,\n  type ConsentCard,\n  type ConsentPrompter,\n} from '../globals/consent.js';\nimport type { Clock } from '../session/types.js';\nimport type { Space } from '../spaces/load.js';\nimport type { ForkEngine, ForkTask } from '../fork/fork.js';\nimport type { DelegateOpts } from '../globals/delegate.js';\nimport type { Tracer, TraceScope } from '../sandbox/trace.js';\n\n/**\n * Dependencies the shared yield router needs to resolve the yield kinds common\n * to the full (session) VM, the delegate VM and fork leaf VMs: sleep, fork,\n * tasklist, delegate, fetch — plus, for fork leaves (which have no session-side\n * handler to fall back to), loadKnowledge and registerSpace.\n *\n * The genuine per-caller differences are parameterized:\n *  - `runDelegate` — the session builds a fresh registry from its spaces; a\n *    delegate recurses with depth+1; a fork leaf gates on the task's\n *    `canDelegateTo` and routes to the engine's delegateRunner. The caller\n *    supplies the right behaviour.\n *  - `onTasklistResult` — delegate uses it to auto-capture the action's tasklist\n *    result; the session leaves it undefined.\n *  - `getForkEngine` — absent for fork leaves (no fork/tasklist there): those\n *    kinds fall through as unhandled, preserving the old leaf behaviour.\n */\nexport interface YieldRouterContext {\n  /** Space for tasklist resolution. Absent in fork-leaf contexts (no tasklist there). */\n  space?: Space;\n  clock?: Clock;\n  /** Lazily-resolved, shared ForkEngine (one per session/delegate scope) so the\n   *  maxConcurrentForks semaphore is enforced across all fork/tasklist yields.\n   *  Absent for fork leaves — fork/tasklist yields are then unhandled. */\n  getForkEngine?: () => ForkEngine | Promise<ForkEngine>;\n  /** Resolve a delegate() yield. May throw (e.g. a fork task's canDelegateTo\n   *  gate) — the error surfaces to the model as a retryable yield error. */\n  runDelegate: (\n    packageName: string,\n    agentName: string,\n    action: string | undefined,\n    delegateOpts: DelegateOpts | undefined,\n  ) => Promise<unknown>;\n  /** Fired after a tasklist resolves (delegate uses it for auto-capture). */\n  onTasklistResult?: (name: string, result: unknown) => void;\n  /** Run a shell command host-side (cwd = space dir). */\n  execCommand?: (cmd: string) => { ok: boolean; output: string };\n  /** Tracer for minting child scopes in tasklist. */\n  tracer?: Tracer;\n  /** Current execution scope — becomes parentScope on spawned forks/delegates. */\n  scope?: TraceScope;\n  /** When set, loadKnowledge yields are resolved HERE by reading the file under\n   *  `<knowledgeSpaceDir>/knowledge/…` and returning its content (fork leaves,\n   *  which must win the race against the global's own concurrent resolve —\n   *  otherwise undefined is bound before the file read completes). The session\n   *  handles loadKnowledge itself; leave unset there. */\n  knowledgeSpaceDir?: string;\n  /** When true, registerSpace yields are resolved HERE (fork leaves): the space\n   *  is loaded and inserted into `dynamicSpaces` when provided. The map is the\n   *  SAME reference the parent Session hands to delegate(), so a space\n   *  registered inside a fork is reachable by the parent's later delegate(). */\n  resolveRegisterSpace?: boolean;\n  dynamicSpaces?: Map<string, Space>;\n  /** Resolve an `apiCall()` yield — enter the project's api runtime by endpoint\n   *  `name` (host-supplied via the project's app globals). Absent outside a\n   *  project-app context; an `apiCall` yield then rejects with a clear error. */\n  apiCallResolver?: ApiCallFn;\n  /** The running agent's `api:call: { allow: [...] }` grant — the endpoints it may\n   *  enter. Enforced in the `apiCall` yield (a name outside the list is refused with a\n   *  retryable error naming what IS allowed). `['*']` = any endpoint this project\n   *  declares. Absent ⇒ unenforced (a non-agent context, e.g. a bare unit test). */\n  apiCallAllow?: string[];\n  /** Resolve a `callConnection()` yield — forward the request to the gateway's\n   *  egress proxy for the named connected service (host-supplied via the pod's\n   *  scoped connections JWT). Absent outside a pod with a configured connections\n   *  gateway; a `callConnection` yield then rejects with a clear error. */\n  connectionResolver?: ConnectionResolver;\n  /** Build a per-node execution context for a `kind:'code'` tasklist node\n   *  (db + callConnection locked to the space/tasklist `connections:` + delegate).\n   *  Threaded into `runTasklist`. Absent until the CLI/pod wires a runner (plan\n   *  step S9); a code node then fails with a clear required-task error. Core\n   *  never imports/executes the node module. */\n  codeNodeCtxFactory?: import('../tasklist/orchestrator.js').CodeNodeCtxFactory;\n  /** Resolve a `readDocument()` yield — extract a stored upload's text host-side\n   *  (host-supplied by libs/cli, where the uploads dir is known). Absent outside a\n   *  pod/CLI with an uploads dir; a `readDocument` yield then rejects with a clear\n   *  error. Not an app-global (project-independent) — threaded from SessionOpts. */\n  documentResolver?: DocumentResolver;\n  /** Resolve an `integrationStatus()` yield — report presence-only config status\n   *  (names of missing required env vars, never their values) for an installed\n   *  integration space in the current project. Host-supplied by libs/cli (knows the\n   *  project root + `process.env`). Absent outside a project-rooted session; an\n   *  `integrationStatus` yield then rejects with a clear error. */\n  integrationStatusResolver?: IntegrationStatusResolver;\n  /** Consent prompter for consent-marked invocations (plan S10) — supplied ONLY\n   *  by interactive session contexts (the cli builds it on `renderHost.ask`).\n   *  Absent (headless runs, forks, delegates, hooks) ⇒ a consent-marked yield\n   *  FAILS CLOSED with a clear \"requires user consent\" error. */\n  requestConsent?: ConsentPrompter;\n  /** Resolve the store-global yields (`storeSearch`/`storeInspect`/`installSpace`)\n   *  — host-supplied by libs/cli on `AppGlobalImpls.store` (mirrors\n   *  `connectionResolver`). Absent ⇒ a store yield rejects with a clear error. */\n  storeResolver?: StoreResolver;\n  /** Resolve an `emitEvent()` yield — validate against the caller scope's\n   *  declared events and dispatch to subscribing hooks (host-supplied by\n   *  libs/cli on `AppGlobalImpls.emitEvent`). Absent ⇒ a clear error. */\n  emitEventResolver?: EmitEventResolver;\n}\n\nexport type RouteResult =\n  | { handled: true; value: unknown }\n  | { handled: false };\n\n/**\n * Single resolver for the yield kinds shared by the session, delegate and fork\n * leaf VMs. Returns `{ handled: false }` for kinds the caller must handle itself\n * (ask/inspect are session-only; the session also resolves its own\n * loadKnowledge/registerSpace before consulting the router).\n *\n * `fetch` is real, non-blocking Node I/O — see `eval/fetch-yield.ts`. A future\n * `execShell`/`tool` yield kind would follow the same shape.\n */\nexport async function routeCommonYield(\n  req: YieldRequest,\n  ctx: YieldRouterContext,\n): Promise<RouteResult> {\n  // Generic HOST-ENFORCED consent (plan S10): a consent-marked yield kind (the\n  // registry in globals/consent.ts — `installSpace` today) must be approved by\n  // the USER before its resolver runs. No prompter (headless/fork/delegate/hook\n  // contexts) ⇒ FAIL CLOSED; denial ⇒ a structured refusal the agent sees. This\n  // runs BEFORE the switch so no resolver below can execute unapproved.\n  if (CONSENT_MARKED_YIELD_KINDS.has(req.kind)) {\n    await enforceConsent(ctx.requestConsent, {\n      function: req.kind,\n      argsSummary: summarizeConsentArgs(req.args),\n    });\n  }\n  switch (req.kind) {\n    case 'sleep': {\n      const ms = req.args[1] as number;\n      await new Promise<void>((resolve) => {\n        if (ctx.clock) ctx.clock.setTimeout(resolve, ms);\n        else setTimeout(resolve, ms);\n      });\n      return { handled: true, value: undefined };\n    }\n    case 'fork': {\n      if (!ctx.getForkEngine) return { handled: false }; // fork leaves have no fork()\n      const engine = await ctx.getForkEngine();\n      const task = req.args[0] as ForkTask;\n      // Attach the current scope as parent so the fork's node is correctly nested\n      if (ctx.scope && !task.parentScope) task.parentScope = ctx.scope;\n      const value = await engine.fork(task);\n      return { handled: true, value };\n    }\n    case 'tasklist': {\n      if (!ctx.getForkEngine || !ctx.space) return { handled: false }; // fork leaves have no tasklist()\n      const name = req.args[0] as string;\n      const seed = req.args[1] as Record<string, unknown> | undefined;\n      const engine = await ctx.getForkEngine();\n      const { runTasklist } = await import('../tasklist/orchestrator.js');\n      const result = await runTasklist({ name, space: ctx.space, forkEngine: engine, seed, tracer: ctx.tracer, parentScope: ctx.scope, codeNodeCtxFactory: ctx.codeNodeCtxFactory });\n      ctx.onTasklistResult?.(name, result);\n      return { handled: true, value: result };\n    }\n    case 'delegate': {\n      const [packageName, agentName, action, delegateOpts] = req.args as [\n        string,\n        string,\n        string | undefined,\n        DelegateOpts | undefined,\n      ];\n      const value = await ctx.runDelegate(packageName, agentName, action, delegateOpts);\n      return { handled: true, value };\n    }\n    case 'fetch': {\n      const [url, fetchOpts] = req.args as [string, import('../globals/fetch.js').FetchOpts | undefined];\n      const { resolveFetchYield } = await import('./fetch-yield.js');\n      const value = await resolveFetchYield(url, fetchOpts);\n      return { handled: true, value };\n    }\n    case 'apiCall': {\n      // Enter the project's own api endpoint by name (agent-facing `apiCall`).\n      // A missing resolver means this context has no project api runtime — throw\n      // an actionable, retryable error rather than binding undefined.\n      if (!ctx.apiCallResolver) {\n        throw new Error('apiCall is not available here: this session has no project api runtime');\n      }\n      const [name, input] = req.args as [string, unknown];\n      // ENFORCE the `api:call: { allow: [...] }` grant. Holding the capability is what\n      // injects the global; the allowlist is what says WHICH endpoints it may enter, and\n      // until now it was parsed, validated — and never checked, so any holder could call\n      // anything. `'*'` is the one wildcard (any endpoint THIS project declares).\n      const allow = ctx.apiCallAllow;\n      if (allow && !allow.includes('*') && !allow.includes(name)) {\n        throw new Error(\n          `apiCall(\"${name}\") is not permitted: this agent's api:call allowlist is [${allow.join(', ')}]`,\n        );\n      }\n      const value = await ctx.apiCallResolver(name, input);\n      return { handled: true, value };\n    }\n    case 'callConnection': {\n      // Forward an authenticated request to an external service; the pod resolver\n      // attaches the user's own token (bring-your-own-token, Settings →\n      // Integrations) and calls the provider directly. A missing resolver means\n      // this context has no connection support wired (e.g. a bare unit test) —\n      // throw an actionable, retryable error rather than binding undefined.\n      if (!ctx.connectionResolver) {\n        throw new Error('callConnection is not available here: no connection resolver configured');\n      }\n      const [provider, request] = req.args as [string, import('../db/types.js').ConnectionRequest];\n      const value = await ctx.connectionResolver(provider, request);\n      return { handled: true, value };\n    }\n    case 'readDocument': {\n      // Extract a stored upload's content host-side (unpdf for PDF, utf8 for text,\n      // transcript for audio). A missing resolver means this context has no uploads\n      // dir (e.g. a bare in-memory session) — throw an actionable, retryable error\n      // rather than binding undefined.\n      if (!ctx.documentResolver) {\n        throw new Error('readDocument is not available here: no document resolver configured');\n      }\n      const [attachmentId, opts] = req.args as [string, { maxChars?: number } | undefined];\n      const value = await ctx.documentResolver(attachmentId, opts);\n      return { handled: true, value };\n    }\n    case 'integrationStatus': {\n      // Presence-only config status of an installed integration in the current\n      // project (missing REQUIRED env-var names — never their values). A missing\n      // resolver means this context has no project scope (e.g. a fork leaf / bare\n      // unit test) — throw an actionable, retryable error rather than binding","numLines":240,"startLine":1,"totalLines":374}}}
