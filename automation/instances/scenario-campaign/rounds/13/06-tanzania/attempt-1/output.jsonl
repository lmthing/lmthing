{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_HKDeQaga4VLzCQ0v54hVV3xU","type":"tool_result","content":"1\timport type { YieldRequest } from '../eval/yield.js';\n2\t\n3\t/**\n4\t * The result of a `readDocument()` call — the host-extracted content of a stored\n5\t * upload. `kind:'text'` carries the decoded/extracted `text`; `kind:'unsupported'`\n6\t * carries a human-readable `error` explaining why (image, scanned PDF, unhandled\n7\t * binary type, missing/invalid id). Mirrors the shape of a ConnectionResponse: a\n8\t * plain, serializable object the sandbox can branch on.\n9\t */\n10\texport interface ReadDocumentResult {\n11\t  ok: boolean;\n12\t  attachmentId: string;\n13\t  mediaType: string;\n14\t  filename?: string;\n15\t  kind: 'text' | 'unsupported';\n16\t  /** Extracted/decoded document text (present when kind==='text'). */\n17\t  text?: string;\n18\t  /** Set when the text was capped at `opts.maxChars`. */\n19\t  truncated?: boolean;\n20\t  /** Present when !ok or kind==='unsupported'. */\n21\t  error?: string;\n22\t}\n23\t\n24\t/**\n25\t * Resolve a `readDocument()` yield — extract a stored upload's content in Node\n26\t * (unpdf for PDF, utf8 passthrough for text/csv, transcript for audio). Host-\n27\t * supplied (libs/cli, where the uploads dir is known); absent outside a pod/CLI\n28\t * with an uploads dir, in which case a `readDocument` yield rejects with a clear,\n29\t * retryable error. Exactly the ConnectionResolver pattern, but for local uploads.\n30\t * @param attachmentId The upload id from the user message's attachment list.\n31\t * @param opts         `maxChars` caps the returned text (default 100_000).\n32\t */\n33\texport type DocumentResolver = (\n34\t  attachmentId: string,\n35\t  opts?: { maxChars?: number },\n36\t) => Promise<ReadDocumentResult>;\n37\t\n38\t/**\n39\t * Create the `readDocument` global — the agent/space-function entry to a stored\n40\t * upload's text. Value-yielding, exactly like `callConnection`/`fetch`: it ends\n41\t * the current turn and resumes once the host resolver reads + extracts the file.\n42\t * Injected UNIVERSALLY (like `fetch`, never gated) so any agent/fork/delegate can\n43\t * read an attachment by id. The host resolver is threaded through the yield router\n44\t * (`YieldRouterContext.documentResolver`); if absent (no uploads dir configured)\n45\t * the yield rejects with a clear, retryable error rather than binding undefined.\n46\t *\n47\t * The bytes never enter the sandbox: the sandbox supplies only the `attachmentId`\n48\t * (+ optional `maxChars`); the host reads the file from the uploads dir and hands\n49\t * back the extracted text.\n50\t */\n51\texport function createReadDocumentGlobal(\n52\t  pushYield: (req: YieldRequest) => void,\n53\t): (attachmentId: string, opts?: { maxChars?: number }) => Promise<ReadDocumentResult> {\n54\t  return function readDocument(\n55\t    attachmentId: string,\n56\t    opts?: { maxChars?: number },\n57\t  ): Promise<ReadDocumentResult> {\n58\t    return new Promise<ReadDocumentResult>((resolve, reject) => {\n59\t      pushYield({\n60\t        kind: 'readDocument',\n61\t        args: [attachmentId, opts],\n62\t        deferred: { resolve: resolve as (v: unknown) => void, reject },\n63\t        vmPromiseHandle: undefined,\n64\t      });\n65\t    });\n66\t  };\n67\t}\n68\t"}]},"parent_tool_use_id":"call_bfvU7nDI1AKjo98p7nkMUqln","session_id":"7bda0fe1-a1bd-4c4c-afd5-fcbbac333cca","uuid":"9c171de0-c61b-4508-82bd-774fb045a118","timestamp":"2026-07-16T02:06:56.946Z","subagent_type":"Explore","task_description":"Trace task action semantics"}
