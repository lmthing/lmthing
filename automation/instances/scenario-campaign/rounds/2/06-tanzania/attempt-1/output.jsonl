{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_51JL0Sh6HklT6jm75CV1XChc","type":"tool_result","content":"1\t/**\n2\t * Plan S9 — headless SPACE-tasklist runner + the code-node execution context.\n3\t *\n4\t * Two seams live here, both consumed by {@link ../session-manager.js SessionManager}:\n5\t *\n6\t *   1. {@link createCodeNodeCtxFactory} — builds the `codeNodeCtxFactory` the core\n7\t *      tasklist orchestrator (`libs/core` S2) calls for every `kind:'code'` node.\n8\t *      For each node it loads the node module's `run(ctx, inputs)` in a Node worker\n9\t *      ({@link invokeNamedFnInWorker}) with a ctx whose `db`/`delegate`/`callConnection`\n10\t *      are serviced main-side — store-downloaded node code never runs in-proc. The\n11\t *      SAME factory is threaded into (a) the interactive session (so an agent's\n12\t *      `tasklist()` yield can run code nodes) and (b) the headless runner below.\n13\t *\n14\t *   2. {@link runTasklistHeadless} — the standalone entry point (the `TasklistRunner`\n15\t *      a hook handler's `ctx.tasklist.run('<spaceId>/<slug>', seed)` calls). It parses\n16\t *      the `<spaceId>/<slug>` ref and delegates to `manager.runTasklistHeadless`,\n17\t *      which owns the fork-engine + session-record plumbing (it needs the manager's\n18\t *      private streamFn/resolvers). Keeping the heavy path on the manager maximizes\n19\t *      reuse of the existing headless wiring; this module stays the thin, importable\n20\t *      seam that `routes/hooks.ts` injects.\n21\t *\n22\t * Security (plan \"Security invariants\"): a space tasklist's code nodes are store\n23\t * code — they execute ONLY worker-isolated + timeout-bounded, and their\n24\t * `callConnection` is locked to the tasklist's declared `connections:` INTERSECT\n25\t * the owning space's own provider(s), so a space can never reach beyond what it\n26\t * itself declared (mirrors the space-hook gate in `routes/hooks.ts`).\n27\t */\n28\timport { readFileSync } from 'node:fs';\n29\timport { basename, dirname, join } from 'node:path';\n30\timport { parseFrontmatter } from '@lmthing/core';\n31\timport type { ConnectionRequest, ConnectionResolver, CodeNodeCtxFactory, TaskNode } from '@lmthing/core';\n32\timport { invokeNamedFnInWorker, type WorkerInvokeHandlers } from '../app/worker-load.js';\n33\timport type { ProjectAuthoringGlobals } from '../app/authoring/globals.js';\n34\t\n35\t/** Dependencies {@link createCodeNodeCtxFactory} needs from the host (SessionManager).\n36\t *  All are project-scoped closures the manager already has the pieces to build. */\n37\texport interface CodeNodeFactoryDeps {\n38\t  /** Lazily resolve the project's async db (or `null` for a spaces-only project).\n39\t   *  Called per code-node run so an interactive session that built the factory\n40\t   *  before its db booted still gets a live handle. */\n41\t  getDb: () => Promise<{ async: unknown } | null>;\n42\t  /** Run a headless agent for a code node's `ctx.delegate(spaceRef, action?, opts?)`\n43\t   *  — mirrors the hook ctx's delegate (returns the run's `DelegateResult`). */\n44\t  delegate: (spaceRef: string, action?: string, opts?: unknown) => Promise<unknown>;\n45\t  /** Pod connection resolver (bring-your-own-token). Gated per call by the\n46\t   *  tasklist's `connections:` ∩ the owning space's own provider(s). */\n47\t  connectionResolver: ConnectionResolver;\n48\t  /** Per-node worker wall-clock budget (ms). Omit for the worker-load default. */\n49\t  timeoutMs?: number;\n50\t  /** Typed live-project writers (`writeProjectTable`/`writeProjectApi`/`writeProjectPage`/\n51\t   *  `writeProjectComponent`/…) for CODE nodes that author files — the SAME host impls the\n52\t   *  agent nodes use, exposed on `ctx.<name>`. Omit for a project with no authoring. */\n53\t  projectAuthoring?: ProjectAuthoringGlobals;\n54\t}\n55\t\n56\t/** Read a space's OWN connection provider(s) from `<spaceDir>/package.json`\n57\t *  (`lmthing.connection.provider`). Best-effort — a missing/malformed manifest ⇒\n58\t *  no own providers (every `callConnection` in the tasklist then throws). */\n59\tfunction spaceOwnProviders(spaceDir: string): Set<string> {\n60\t  try {\n61\t    const pkg = JSON.parse(readFileSync(join(spaceDir, 'package.json'), 'utf8')) as {\n62\t      lmthing?: { connection?: { provider?: unknown } };\n63\t    };\n64\t    const provider = pkg.lmthing?.connection?.provider;\n65\t    return typeof provider === 'string' && provider ? new Set([provider]) : new Set();\n66\t  } catch {\n67\t    return new Set();\n68\t  }\n69\t}\n70\t\n71\t/** Read a tasklist's declared `connections:` from `<tasklistDir>/index.md`\n72\t *  frontmatter (the tasklist-level gate). Best-effort — no index / no key ⇒ []. */\n73\tfunction tasklistDeclaredConnections(tasklistDir: string): string[] {\n74\t  try {\n75\t    const raw = readFileSync(join(tasklistDir, 'index.md'), 'utf8');\n76\t    const { data } = parseFrontmatter(raw, join(tasklistDir, 'index.md'));\n77\t    return Array.isArray(data['connections']) ? data['connections'].map(String) : [];\n78\t  } catch {\n79\t    return [];\n80\t  }\n81\t}\n82\t\n83\t/**\n84\t * Build the {@link CodeNodeCtxFactory} the orchestrator calls per `kind:'code'`\n85\t * node. The allowed-provider set for a node is derived ENTIRELY from its\n86\t * `codeModulePath` (`.../<space>/tasklists/<slug>/NN-<id>.ts`): the owning space\n87\t * dir and the tasklist dir are path-relative, so ONE session-wide factory works\n88\t * for any tasklist the agent runs (the in-session path) and for the resolved\n89\t * headless run alike. Result is cached per tasklist dir.\n90\t */\n91\texport function createCodeNodeCtxFactory(deps: CodeNodeFactoryDeps): CodeNodeCtxFactory {\n92\t  const allowedCache = new Map<string, Set<string>>();\n93\t\n94\t  const allowedFor = (codeModulePath: string): Set<string> => {\n95\t    const tasklistDir = dirname(codeModulePath);\n96\t    const cached = allowedCache.get(tasklistDir);\n97\t    if (cached) return cached;\n98\t    // .../<space>/tasklists/<slug>/NN-<id>.ts → space dir is two levels above the\n99\t    // tasklist dir (tasklists/<slug> → tasklists → <space>).\n100\t    const spaceDir = dirname(dirname(tasklistDir));\n101\t    const own = spaceOwnProviders(spaceDir);\n102\t    const declared = tasklistDeclaredConnections(tasklistDir);\n103\t    // Space tasklist: locked to declared ∩ own (a space can never reach beyond\n104\t    // what it itself declared AND owns).\n105\t    const allowed = new Set(declared.filter((p) => own.has(p)));\n106\t    allowedCache.set(tasklistDir, allowed);\n107\t    return allowed;\n108\t  };\n109\t\n110\t  return (node: TaskNode) => ({\n111\t    runCodeNode: async (inputs) => {\n112\t      const modulePath = node.codeModulePath;\n113\t      if (!modulePath) {\n114\t        throw new Error(`code node \"${node.id}\" has no codeModulePath — cannot run`);\n115\t      }\n116\t      const allowed = allowedFor(modulePath);\n117\t      const db = await deps.getDb();\n118\t      const handlers: WorkerInvokeHandlers = {\n119\t        ...(db ? { db: db.async as WorkerInvokeHandlers['db'] } : {}),\n120\t        delegate: deps.delegate,\n121\t        callConnection: (provider, req) => {\n122\t          if (!allowed.has(provider)) {\n123\t            throw new Error(\n124\t              `callConnection(\"${provider}\"): not allowed for tasklist \"${basename(dirname(modulePath))}\"` +\n125\t                (allowed.size\n126\t                  ? ` (allowed: ${[...allowed].sort().join(', ')})`\n127\t                  : ' — the tasklist declared no connections owned by its space'),\n128\t            );\n129\t          }\n130\t          return deps.connectionResolver(provider, req as ConnectionRequest);\n131\t        },\n132\t        ...(deps.projectAuthoring\n133\t          ? { authoring: deps.projectAuthoring as unknown as Record<string, (...args: unknown[]) => unknown> }\n134\t          : {}),\n135\t      };\n136\t      const out = await invokeNamedFnInWorker(\n137\t        modulePath,\n138\t        'run',\n139\t        [inputs],\n140\t        handlers,\n141\t        deps.timeoutMs ? { timeoutMs: deps.timeoutMs } : {},\n142\t      );\n143\t      return out && typeof out === 'object' ? (out as Record<string, unknown>) : {};\n144\t    },\n145\t  });\n146\t}\n147\t\n148\t/** The manager surface {@link runTasklistHeadless} needs — the heavy fork-engine +\n149\t *  session-record path lives on `SessionManager.runTasklistHeadless` (it needs the\n150\t *  manager's private streamFn/resolvers). Structural so this module never imports\n151\t *  the concrete `SessionManager` (and tests can fake it). */\n152\texport interface TasklistRunnerManager {\n153\t  runTasklistHeadless(args: {\n154\t    projectId: string;\n155\t    spaceId: string;\n156\t    slug: string;\n157\t    seed?: Record<string, unknown>;\n158\t  }): Promise<unknown>;\n159\t}\n160\t\n161\t/** Parse a `<spaceId>/<slug>` tasklist ref. Extra path segments are folded back\n162\t *  into the slug is NOT supported — a tasklist ref is exactly two segments. */\n163\tfunction parseTasklistRef(ref: string): { spaceId: string; slug: string } {\n164\t  const slash = ref.indexOf('/');\n165\t  if (slash < 0) {\n166\t    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n167\t  }\n168\t  const spaceId = ref.slice(0, slash);\n169\t  const slug = ref.slice(slash + 1);\n170\t  if (!spaceId || !slug) {\n171\t    throw new Error(`invalid tasklist ref \"${ref}\": expected \"<spaceId>/<slug>\"`);\n172\t  }\n173\t  return { spaceId, slug };\n174\t}\n175\t\n176\t/**\n177\t * Run a SPACE tasklist headless (plan S9). Resolves `<spaceId>/<slug>` from the\n178\t * ref and delegates to `manager.runTasklistHeadless`. This is the callable a hook\n179\t * handler's `ctx.tasklist.run(ref, seed)` routes to; `routes/hooks.ts` injects a\n180\t * per-project binding of it via {@link makeHookTasklistRunner}.\n181\t */\n182\texport function runTasklistHeadless(opts: {\n183\t  root: string;\n184\t  projectId: string;\n185\t  ref: string;\n186\t  seed?: Record<string, unknown>;\n187\t  manager: TasklistRunnerManager;\n188\t}): Promise<unknown> {\n189\t  const { spaceId, slug } = parseTasklistRef(opts.ref);\n190\t  return opts.manager.runTasklistHeadless({ projectId: opts.projectId, spaceId, slug, seed: opts.seed });\n191\t}\n192\t\n193\t/** Build the per-project `TasklistRunner` (`(ref, seed) => Promise`) that\n194\t *  `routes/hooks.ts` injects into `runHook` so a hook handler's\n195\t *  `ctx.tasklist.run('<spaceId>/<slug>', seed)` runs the resolved space tasklist\n196\t *  headless. */\n197\texport function makeHookTasklistRunner(\n198\t  manager: TasklistRunnerManager,\n199\t  root: string,\n200\t  projectId: string,\n201\t): (ref: string, seed?: unknown) => Promise<unknown> {\n202\t  return (ref, seed) =>\n203\t    runTasklistHeadless({ root, projectId, ref, seed: seed as Record<string, unknown> | undefined, manager });\n204\t}\n205\t"}]},"parent_tool_use_id":"call_0lb5WCKZ0OPAnEXw8oFAxUMW","session_id":"10d74089-d65b-435d-a979-1d29f6775b52","uuid":"3d1d5e2a-1cfb-428d-822a-0ded1fc9d00a","timestamp":"2026-07-16T22:46:57.569Z","subagent_type":"Explore","task_description":"Trace source-data loss"}
