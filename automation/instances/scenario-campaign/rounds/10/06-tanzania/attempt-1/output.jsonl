{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_OEz12MhPqElQWXLcOLGrhZj1","type":"tool_result","content":"1\timport type { Space } from '../spaces/load.js';\n2\timport type { ForkEngine } from '../fork/fork.js';\n3\timport { loadTasklist } from '../spaces/tasklist-load.js';\n4\timport { validateDag, findReadyTasks, resolveGoalTask } from './dag.js';\n5\timport type { TaskNode } from '../spaces/tasklist-load.js';\n6\timport type { Tracer, TraceScope } from '../sandbox/trace.js';\n7\timport { validateInput } from './schema.js';\n8\timport type { TaskEnvelope, DegradeReason } from '../exec/envelope.js';\n9\t\n10\t/** Resolve a `forEach` reference (\"taskId\" or \"taskId.field.subfield\") against accumulated\n11\t *  task outputs. Returns the referenced array, or [] when missing / not an array. */\n12\tfunction resolveForEachItems(ref: string, allOutputs: Record<string, unknown>): unknown[] {\n13\t  const parts = ref.split('.');\n14\t  let val: unknown = allOutputs[parts[0]!];\n15\t  for (const part of parts.slice(1)) {\n16\t    if (val && typeof val === 'object') val = (val as Record<string, unknown>)[part];\n17\t    else { val = undefined; break; }\n18\t  }\n19\t  return Array.isArray(val) ? val : [];\n20\t}\n21\t\n22\t/**\n23\t * Execution context for ONE `kind:'code'` tasklist node, built by the host\n24\t * (CLI/pod) — never by core. `runCodeNode` loads + runs the node module's\n25\t * `run(ctx, inputs)` in a Node worker with a `ctx` gated by the space/tasklist\n26\t * `connections:` (db, callConnection, delegate). `inputs` is the SAME data an\n27\t * agent fork of this node would receive: the seed-filtered tasklist input merged\n28\t * with upstream task outputs (keyed by dependency id), plus `item`/`index` for a\n29\t * forEach element. The returned object feeds `allOutputs`/`TaskEnvelope` exactly\n30\t * like an agent node's output.\n31\t */\n32\texport interface CodeNodeContext {\n33\t  runCodeNode(inputs: Record<string, unknown>): Promise<Record<string, unknown>>;\n34\t}\n35\t\n36\t/**\n37\t * Maps a code node to its {@link CodeNodeContext}. Injected via\n38\t * {@link RunTasklistOptions} by the CLI/pod (the headless tasklist runner, plan\n39\t * step S9); the in-session yield-router threads one built from the session's\n40\t * project scope when available. When ABSENT, encountering a code node fails that\n41\t * task with a clear error (required-task-failure semantics) — core cannot\n42\t * execute node modules itself. Called once per code node (before any forEach\n43\t * fan-out), so the host can build per-node state up front.\n44\t */\n45\texport type CodeNodeCtxFactory = (node: TaskNode) => CodeNodeContext;\n46\t\n47\texport interface RunTasklistOptions {\n48\t  name: string;\n49\t  space: Space;\n50\t  forkEngine: ForkEngine;\n51\t  seed?: Record<string, unknown>;\n52\t  tracer?: Tracer;\n53\t  parentScope?: TraceScope;\n54\t  /** Host-provided runner for `kind:'code'` nodes (see {@link CodeNodeCtxFactory}).\n55\t   *  Omit outside a CLI/pod context — code nodes then fail as required-task errors. */\n56\t  codeNodeCtxFactory?: CodeNodeCtxFactory;\n57\t}\n58\t\n59\t/**\n60\t * Run a tasklist DAG and return a `TaskEnvelope` wrapping the goal task's output.\n61\t *\n62\t * Task→task UPSTREAM outputs stay RAW schema data (task files keep referencing\n63\t * `plan.questions` etc.) — degradation metadata never leaks into upstream\n64\t * variable values. Only the tasklist BOUNDARY result is enveloped:\n65\t * `{ ok, degraded, data, reason?, degradedTasks? }`.\n66\t */\n67\texport async function runTasklist(opts: RunTasklistOptions): Promise<TaskEnvelope> {\n68\t  const { name, space, forkEngine, seed, tracer, parentScope, codeNodeCtxFactory } = opts;\n69\t\n70\t  const tasklistDir = space.tasklists[name];\n71\t  if (!tasklistDir) {\n72\t    throw new Error(`Tasklist \"${name}\" not found in space`);\n73\t  }\n74\t\n75\t  // Validate the runtime seed against the tasklist's declared input schema\n76\t  // (tasklists/<name>/index.md frontmatter). No declared schema → accept any seed.\n77\t  const declaredInputKeys =\n78\t    tasklistDir.input && Object.keys(tasklistDir.input).length > 0\n79\t      ? Object.keys(tasklistDir.input)\n80\t      : undefined;\n81\t  if (declaredInputKeys) {\n82\t    const errors = validateInput(tasklistDir.input!, seed ?? {});\n83\t    if (errors.length > 0) {\n84\t      throw new Error(\n85\t        `Tasklist \"${name}\" received an invalid seed:\\n  - ${errors.join('\\n  - ')}`,\n86\t      );\n87\t    }\n88\t  }\n89\t\n90\t  // INPUT HARD FILTER: when the tasklist declares an `input` schema, forks receive\n91\t  // ONLY the declared keys — whatever extra baggage a delegator packed into the seed\n92\t  // (e.g. `parentHistory`, stray context) never rides into leaf prompts/ambient DTS.\n93\t  // This makes a leaf fork's prompt a pure function of (task file, declared inputs,\n94\t  // upstream outputs, forEach item) — identical shallow vs nested. No declared\n95\t  // schema → full passthrough (back-compat). Host-injected forEach `item`/`index`\n96\t  // are added AFTER the filter and are unaffected.\n97\t  const taskSeed = declaredInputKeys\n98\t    ? Object.fromEntries(Object.entries(seed ?? {}).filter(([k]) => declaredInputKeys.includes(k)))\n99\t    : seed;\n100\t\n101\t  const tasks = await loadTasklist(tasklistDir.slug, tasklistDir.files);\n102\t  validateDag(tasks);\n103\t  const goalTask = resolveGoalTask(tasks);\n104\t\n105\t  // Mint a tasklist node so the tree shows this orchestration scope\n106\t  const tasklistScope = tracer && parentScope\n107\t    ? tracer.child(parentScope, 'tasklist', `tasklist:${name}`, { tasklist: name })\n108\t    : undefined;\n109\t\n110\t  const done = new Set<string>();\n111\t  const skipped = new Set<string>();\n112\t  const allOutputs: Record<string, unknown> = {};\n113\t  let goalOutput: unknown;\n114\t  // Degradation aggregation (Phase 3): labels of every salvaged task / forEach\n115\t  // element (e.g. \"investigate[3]\"), plus the goal task's own degradation state.\n116\t  const degradedTasks: string[] = [];\n117\t  let goalDegraded = false;\n118\t  let goalReason: DegradeReason | undefined;\n119\t\n120\t  // Build up upstream outputs per task\n121\t  function getUpstreamOutputs(task: TaskNode): Record<string, unknown> {\n122\t    const upstream: Record<string, unknown> = {};\n123\t    for (const dep of task.dependsOn ?? []) {\n124\t      if (allOutputs[dep] !== undefined) {\n125\t        upstream[dep] = allOutputs[dep];\n126\t      }\n127\t    }\n128\t    return upstream;\n129\t  }\n130\t\n131\t  // Emit a `task` node and immediately end it as skipped (condition not met /\n132\t  // optional fork failed). Tracks via `skippedEmitted` so we never double-emit.\n133\t  const skippedEmitted = new Set<string>();\n134\t  const emitSkip = (task: TaskNode): void => {\n135\t    if (!tracer || !tasklistScope || skippedEmitted.has(task.id)) return;\n136\t    skippedEmitted.add(task.id);\n137\t    const s = tracer.child(tasklistScope, 'task', `fork:${task.id}`, {\n138\t      tasklist: name, dependsOn: task.dependsOn, optional: task.optional, condition: task.condition, goal: task.goal,\n139\t    });\n140\t    tracer.end(s, 'skipped');\n141\t  };\n142\t\n143\t  try {\n144\t    // Run until all tasks are done/skipped\n145\t    while (done.size + skipped.size < Object.keys(tasks).length) {\n146\t      const ready = findReadyTasks(tasks, done, skipped, allOutputs);\n147\t\n148\t      if (ready.length === 0) {\n149\t        // Check if there are tasks remaining but none are ready (stuck)\n150\t        const remaining = Object.keys(tasks).filter((id) => !done.has(id) && !skipped.has(id));\n151\t        if (remaining.length > 0) {\n152\t          // Skip tasks whose conditions aren't met\n153\t          for (const id of remaining) {\n154\t            const task = tasks[id]!;\n155\t            const deps = task.dependsOn ?? [];\n156\t            const depsOk = deps.every((dep) => done.has(dep) || skipped.has(dep));\n157\t            if (depsOk && (task.optional || task.condition)) {\n158\t              // Condition not met (or optional with unmet deps) — skip + trace it.\n159\t              skipped.add(id);\n160\t              emitSkip(task);\n161\t            }\n162\t          }\n163\t\n164\t          // Check if we're truly stuck\n165\t          const stillRemaining = Object.keys(tasks).filter(\n166\t            (id) => !done.has(id) && !skipped.has(id),\n167\t          );\n168\t          if (stillRemaining.length === remaining.length) {\n169\t            throw new Error(`Tasklist \"${name}\" is stuck: tasks ${stillRemaining.join(', ')} cannot be resolved`);\n170\t          }\n171\t        }\n172\t        continue;\n173\t      }\n174\t\n175\t      // Mint each ready task's scope up front so we can end it on success OR failure.\n176\t      const taskScopes = new Map<string, TraceScope | undefined>();\n177\t\n178\t      // Run all ready tasks in parallel (within fork concurrency cap)\n179\t      const results = await Promise.allSettled(\n180\t        ready.map(async (task) => {\n181\t          const upstreamOutputs = getUpstreamOutputs(task);\n182\t          const taskScope = tracer && tasklistScope\n183\t            ? tracer.child(tasklistScope, 'task', `fork:${task.id}`, {\n184\t                tasklist: name, dependsOn: task.dependsOn, optional: task.optional, condition: task.condition, goal: task.goal, forEach: task.forEach,\n185\t              })\n186\t            : undefined;\n187\t          taskScopes.set(task.id, taskScope);\n188\t\n189\t          const upstream = Object.keys(upstreamOutputs).length > 0 ? upstreamOutputs : undefined;\n190\t\n191\t          // CODE NODE: the host runs the node module's `run(ctx, inputs)` via the\n192\t          // injected factory (core stays free of any transpile/worker runtime).\n193\t          // Inputs mirror exactly what an agent fork of this node would see —\n194\t          // the seed-filtered tasklist input merged with upstream outputs (keyed\n195\t          // by dependency id), plus `item`/`index` for a forEach element. Output\n196\t          // feeds allOutputs/TaskEnvelope identically to an agent node. A code\n197\t          // node has no salvage path: `run` either returns (success) or throws\n198\t          // (→ required-task failure below, or skip when optional). forEach can\n199\t          // fan out over a code node, and a code node can be a forEach body.\n200\t          if (task.kind === 'code') {\n201\t            if (!codeNodeCtxFactory) {\n202\t              throw new Error(\n203\t                `Code node \"${task.id}\" cannot run here: no codeNodeCtxFactory was provided to ` +\n204\t                  `runTasklist. The CLI/pod injects one (headless tasklist runner); an in-session ` +\n205\t                  `run needs that runner wired. Core does not execute code-node modules itself.`,\n206\t              );\n207\t            }\n208\t            const codeCtx = codeNodeCtxFactory(task);\n209\t            const baseInputs: Record<string, unknown> = { ...(taskSeed ?? {}), ...upstreamOutputs };\n210\t            if (task.forEach) {\n211\t              const items = resolveForEachItems(task.forEach, allOutputs);\n212\t              const output = await Promise.all(\n213\t                items.map((item, index) => {\n214\t                  const elemScope = tracer && taskScope\n215\t                    ? tracer.child(taskScope, 'task', `code:${task.id}[${index}]`, { tasklist: name, forEachIndex: index })\n216\t                    : undefined;\n217\t                  return codeCtx.runCodeNode({ ...baseInputs, item, index }).then((val) => {\n218\t                    if (tracer && elemScope) tracer.end(elemScope, 'done', { result: val });\n219\t                    return val;\n220\t                  });\n221\t                }),\n222\t              );\n223\t              return { task, output };\n224\t            }\n225\t            const output = await codeCtx.runCodeNode(baseInputs);\n226\t            return { task, output };\n227\t          }\n228\t\n229\t          // forkWithMeta: same execution path as fork(), plus typed degradation\n230\t          // metadata so salvage becomes a control-plane signal (→ TaskEnvelope),\n231\t          // not prose inside the data.\n232\t          const runFork = (\n233\t            extraSeed?: Record<string, unknown>,\n234\t            elemScope?: TraceScope,\n235\t          ): Promise<import('../fork/fork.js').ForkResultMeta> =>\n236\t            forkEngine.forkWithMeta({\n237\t              instruction: task.instruction,\n238\t              output: task.output,\n239\t              seed: extraSeed ? { ...(taskSeed ?? {}), ...extraSeed } : taskSeed,\n240\t              upstreamOutputs: upstream,\n241\t              taskId: task.id,\n242\t              role: task.role,\n243\t              functions: task.functions,\n244\t              canDelegateTo: task.canDelegateTo,\n245\t              capabilities: task.capabilities as import('../spaces/capabilities.js').CapabilityId[] | undefined,\n246\t              prelude: task.prelude,\n247\t              tasklistDescription: tasklistDir.description,\n248\t              parentScope: elemScope ?? taskScope,\n249\t            });\n250\t\n251\t          // Record a salvage for the given label; when this is the goal task, its\n252\t          // (first) degradation also determines the envelope's ok/reason.\n253\t          const noteDegraded = (label: string, reason: DegradeReason | undefined): void => {\n254\t            degradedTasks.push(label);\n255\t            if (goalTask && task.id === goalTask.id) {\n256\t              goalDegraded = true;\n257\t              if (!goalReason) goalReason = reason ?? 'no_resolve';\n258\t            }\n259\t          };\n260\t"}]},"parent_tool_use_id":"call_VsdMSqwzult8golfb0xW5BYw","session_id":"a7fe4138-ba72-469d-8c93-8d7c68dc56e8","uuid":"3e8d4b84-05f6-4efa-a3c5-17c1fa7d20b3","tim